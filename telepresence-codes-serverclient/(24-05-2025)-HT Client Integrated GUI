    drawRoundedRect(CARD_X, CARD_Y, CARD_W, CARD_H, CARD_R, PANEL_COLOR);

    // Top Title
    drawTextModern(CARD_X + 30, glutHeight - 50, "Network & Haptic Stats Dashboard", GLUT_BITMAP_HELVETICA_18, TEXT_TITLE);

    // Stats: sent/received pkts, latency, mode
    float y = glutHeight - 100;
    float left = CARD_X + 40;
    drawTextModern(left, y, "Mode: " + std::string(useVirtualEnvironment ? "Virtual Environment" : "Network"), GLUT_BITMAP_HELVETICA_12, TEXT_BODY); y -= 28;
    drawTextModern(left, y, "Packets Sent: " + std::to_string(successfulSends) + " (Failed: " + std::to_string(failedSends) + ")", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); y -= 22;
    drawTextModern(left, y, "Packets Received: " + std::to_string(successfulReceives) + " (Failed: " + std::to_string(failedReceives) + ")", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); y -= 22;
    drawTextModern(left, y, "Avg Latency: " + to_string_with_precision(avgLatency, 1) + " ms", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); y -= 32;

    // ===== Graph: Sent/Received Packet Magnitudes =====
    float graphX = CARD_X + 40, graphY = y - 340, graphW = glutWidth * 0.47f, graphH = 150;
    // Panel for graph
    drawRoundedRect(graphX - 15, graphY - 20, graphW + 30, graphH + 40, 14, PANEL_SUBTLE);

    // Grid lines
    glColor3fv(GRID_COLOR);
    glBegin(GL_LINES);
    for (int i = 0; i <= 5; ++i) {
        float gy = graphY + (i / 5.0f) * graphH;
        glVertex2f(graphX, gy); glVertex2f(graphX + graphW, gy);
    }
    glEnd();

    // Axis labels
    drawTextModern(graphX, graphY + graphH + 22, "Packet Magnitudes (Last 100)", GLUT_BITMAP_HELVETICA_12, TEXT_TITLE);

    // Local history copy (thread-safe)
    std::vector<PacketData> localSentPackets, localReceivedPackets;
    {
        std::lock_guard<std::mutex> lock(packetHistoryMutex);
        localSentPackets = sentPackets;
        localReceivedPackets = receivedPackets;
    }

    // Draw sent bars (blue)
    float barW = 15.0f, maxPosition = 0.1f;
    for (size_t i = 0; i < localSentPackets.size(); ++i) {
        float height = std::min((float)(localSentPackets[i].magnitude / maxPosition) * graphH, graphH);
        float x = graphX + i * (barW + 0.5f);
        drawBar(x, graphY, barW, height, BAR_SENT, 0.85f);
    }
    // Draw received bars (red)
    float maxForce = 5.0f;
    for (size_t i = 0; i < localReceivedPackets.size(); ++i) {
        float height = std::min((float)(localReceivedPackets[i].magnitude / maxForce) * graphH, graphH);
        float x = graphX + i * (barW + 0.5f) + 1.6f;
        drawBar(x, graphY, barW, height, BAR_RECV, 0.85f);
    }

    // ===== Graph: Delay =====
    float delayGraphY = graphY - 200;
    drawRoundedRect(graphX - 15, delayGraphY - 20, graphW + 30, graphH + 80, 14, PANEL_SUBTLE);
    drawTextModern(graphX, delayGraphY + graphH + 22, "Packet Delays (ms)", GLUT_BITMAP_HELVETICA_12, TEXT_TITLE);

    // Delay: draw lines for sent/received (use .delay)
    float maxDelay = 100.0f;
    // Sent delays (blue line)
    glColor3fv(BAR_SENT);
    glBegin(GL_LINE_STRIP);
    for (size_t i = 0; i < localSentPackets.size(); ++i) {
        float x = graphX + i * (barW + 0.5f);
        float y = delayGraphY + std::min((float)(localSentPackets[i].delay / maxDelay) * graphH, graphH);
        glVertex2f(x, y);
    }
    glEnd();
    // Received delays (red line)
    glColor3fv(BAR_RECV);
    glBegin(GL_LINE_STRIP);
    for (size_t i = 0; i < localReceivedPackets.size(); ++i) {
        float x = graphX + i * (barW + 0.5f) + 1.6f;
        float y = delayGraphY + std::min((float)(localReceivedPackets[i].delay / maxDelay) * graphH, graphH);
        glVertex2f(x, y);
    }
    glEnd();

    // ===== Controls Section =====
    float ctrlY = CARD_Y + 400;
    float ctrlX = CARD_X + 1550;
    drawTextModern(ctrlX, ctrlY, "Controls", GLUT_BITMAP_HELVETICA_18, TEXT_TITLE);
    ctrlY -= 32;

    // Each toggle/control with indicator dot:
    struct CtrlEntry { const char* label; bool state; int key; };
    CtrlEntry entries[] = {
        {"[1] Send Packets", sendPacketsEnabled, 1},
        {"[2] Receive Feedback", receiveFeedbackEnabled, 2},
        {"[3] Apply Haptic", applyHapticFeedback, 3},
        {"[4] Raw Mode", rawModeEnabled, 4}
    };
    for (int i = 0; i < 4; ++i) {
        drawTextModern(ctrlX + 32, ctrlY, entries[i].label, GLUT_BITMAP_HELVETICA_12, TEXT_BODY);
        drawCircle(ctrlX, ctrlY + 6, 9, entries[i].state ? STATUS_ON : STATUS_OFF);
        ctrlY -= 28;
    }

    // Other controls (without toggles)
    ctrlY -= 12;
    drawTextModern(ctrlX, ctrlY, "[5] Net Priority: " + std::string(networkThreadPriority == THREAD_PRIORITY_ABOVE_NORMAL ? "ABOVE" : "NORMAL"), GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 20;
    drawTextModern(ctrlX, ctrlY, "[6] Hap Priority: " + std::string(hapticThreadPriority == THREAD_PRIORITY_ABOVE_NORMAL ? "ABOVE" : "NORMAL"), GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 20;
    drawTextModern(ctrlX, ctrlY, "[7] Delay Min: " + to_string_with_precision(packetDelayMin, 1) + " ms", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 20;
    drawTextModern(ctrlX, ctrlY, "[8] Delay Max: " + to_string_with_precision(packetDelayMax, 1) + " ms", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 20;
    drawTextModern(ctrlX, ctrlY, "[9] Max Packets: " + std::to_string(maxPacketsToSend), GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 20;
    drawTextModern(ctrlX, ctrlY, "[0] Packet Interval: " + to_string_with_precision(packetIntervalMs, 1) + " ms", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 20;
    drawTextModern(ctrlX, ctrlY, "[w] Feedback Window: " + std::to_string(FORCE_PACKET_WINDOW), GLUT_BITMAP_HELVETICA_12, TEXT_BODY); ctrlY -= 24;
    drawTextModern(ctrlX, ctrlY, "[q] or [Esc] Exit", GLUT_BITMAP_HELVETICA_12, TEXT_BODY);

    // ===== Real-Time Packet Coordinates Section =====
    float rtX = CARD_X + CARD_W - 350;
    float rtY = glutHeight - 110;
    drawTextModern(rtX, rtY, "Latest Packet Data", GLUT_BITMAP_HELVETICA_18, TEXT_TITLE);
    rtY -= 40;

    static cVector3d lastSentPosition(0.0, 0.0, 0.0);
    if (successfulSends > 0) {
        cVector3d pos;
        if (hapticDevice && hapticDevice->getPosition(pos)) lastSentPosition = pos;
    }
    drawTextModern(rtX, rtY, "Last Sent: (" + to_string_with_precision(lastSentPosition.x(), 4) + ", " +
        to_string_with_precision(lastSentPosition.y(), 4) + ", " +
        to_string_with_precision(lastSentPosition.z(), 4) + ") m", GLUT_BITMAP_HELVETICA_12, TEXT_BODY);
    rtY -= 26;

