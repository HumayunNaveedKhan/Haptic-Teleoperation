    drawTextModern(rtX, rtY, "Last Force: (" + to_string_with_precision(lastReceivedForce.x(), 2) + ", " +
        to_string_with_precision(lastReceivedForce.y(), 2) + ", " +
        to_string_with_precision(lastReceivedForce.z(), 2) + ") N", GLUT_BITMAP_HELVETICA_12, TEXT_BODY);
    rtY -= 26;
    drawTextModern(rtX, rtY, "Stiffness: " + to_string_with_precision(lastStiffness, 2) + " N/m", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); rtY -= 22;
    drawTextModern(rtX, rtY, "Damping: " + to_string_with_precision(lastDamping, 2) + " N·s/m", GLUT_BITMAP_HELVETICA_12, TEXT_BODY); rtY -= 22;
    drawTextModern(rtX, rtY, "Error: (" + to_string_with_precision(lastError.x(), 4) + ", " +
