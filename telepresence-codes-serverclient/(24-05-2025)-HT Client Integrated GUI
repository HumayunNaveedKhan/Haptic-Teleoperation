// Draw a rounded rectangle panel (fancy card look)
void drawRoundedRect(float x, float y, float w, float h, float r, const float col[4]) {
    glColor4fv(col);
    glBegin(GL_POLYGON);
    // Four corners: each is a quarter circle
    for (int i = 0; i <= 16; i++)
        glVertex2f(x + r + cosf(i * 3.14159f / 32.0f) * r, y + h - r + sinf(i * 3.14159f / 32.0f) * r);
    for (int i = 16; i <= 32; i++)
        glVertex2f(x + w - r + cosf(i * 3.14159f / 32.0f) * r, y + h - r + sinf(i * 3.14159f / 32.0f) * r);
    for (int i = 32; i <= 48; i++)
        glVertex2f(x + w - r + cosf(i * 3.14159f / 32.0f) * r, y + r + sinf(i * 3.14159f / 32.0f) * r);
    for (int i = 48; i <= 64; i++)
        glVertex2f(x + r + cosf(i * 3.14159f / 32.0f) * r, y + r + sinf(i * 3.14159f / 32.0f) * r);
    glEnd();
}
void drawBar(float x, float y, float w, float h, const float color[3], float alpha = 1.0f) {
    glColor4f(color[0], color[1], color[2], alpha);
    glBegin(GL_QUADS);
    glVertex2f(x, y); glVertex2f(x + w, y); glVertex2f(x + w, y + h); glVertex2f(x, y + h);
    glEnd();
}
// Helper functions
void drawText(float x, float y, const string& text, void* font = GLUT_BITMAP_HELVETICA_12, Color color = COLOR_TEXT) {
    glColor3f(color.r, color.g, color.b);
    glRasterPos2f(x, y);
    for (char c : text) {
        glutBitmapCharacter(font, c);
    }
}

void drawCircle(float x, float y, float radius, Color color, bool filled = true) {
    glColor3f(color.r, color.g, color.b);
    glBegin(filled ? GL_TRIANGLE_FAN : GL_LINE_LOOP);
    for (int i = 0; i < 360; i++) {
        float rad = i * 3.14159265f / 180.0f;
        glVertex2f(x + cos(rad) * radius, y + sin(rad) * radius);
    }
    glEnd();
}

void drawRect(float x, float y, float width, float height, Color color, bool filled = true) {
    glColor3f(color.r, color.g, color.b);
    if (filled)
        glBegin(GL_QUADS);
    else
        glBegin(GL_LINE_LOOP);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();
}
void drawGrid(float x, float y, float width, float height, int numHLines, Color color) {
    glColor3f(color.r, color.g, color.b);
    glBegin(GL_LINES);
    for (int i = 1; i < numHLines; i++) {
        float ly = y + (i * height / numHLines);
        glVertex2f(x, ly);
        glVertex2f(x + width, ly);
    }
    glEnd();
}

void drawPacketBarGraph(const vector<PacketData>& packets, float x, float y, float width, float height, Color barColor, bool showTimestamps) {
    // Assume TIME_WINDOW_S seconds (e.g. 10)
    const double TIME_WINDOW_S = 10.0;
    if (packets.empty()) return;
    auto now = chrono::steady_clock::now();
    auto timeWindowStart = now - chrono::duration_cast<chrono::microseconds>(chrono::duration<double>(TIME_WINDOW_S));

    float barW = 14.0f;
    int idx = 0;
    for (const auto& pkt : packets) {
        if (pkt.timestamp < timeWindowStart) continue;
        double t = chrono::duration_cast<chrono::microseconds>(pkt.timestamp - timeWindowStart).count() / 1e6;
        float xBar = x + (t / TIME_WINDOW_S) * (width - barW);
        float barH = std::min((float)(pkt.magnitude / 0.1 * height), height); // adjust scale as needed
        drawRect(xBar, y, barW, barH, barColor, true);
        if (showTimestamps && idx % 4 == 0) {
            drawText(xBar, y + barH + 6, to_string_with_precision(t, 2), GLUT_BITMAP_HELVETICA_10, { 0.7f, 0.7f, 0.7f });
        }
        idx++;
    }
}
void drawCircle(float x, float y, float radius, const float col[3]) {
    glColor3fv(col);
    glBegin(GL_TRIANGLE_FAN);
    for (int i = 0; i < 360; i += 15) {
        float rad = i * 3.1415926f / 180.0f;
        glVertex2f(x + cos(rad) * radius, y + sin(rad) * radius);
    }
    glEnd();
}

void glutDisplay() {
    // Set modern background
