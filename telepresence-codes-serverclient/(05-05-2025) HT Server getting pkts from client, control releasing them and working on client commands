// Handle keyboard input
void keyboardFunc(unsigned char key, int x, int y) {
    switch (key) {
    case 'q':
    case 'Q':
    case 27: // ESC key
        // Clean shutdown
        exit(0);
        break;

    case 'f':
    case 'F':
        // Toggle fullscreen
        fullscreen = !fullscreen;
        if (fullscreen) {
            glutFullScreen();
        }
        else {
            glutReshapeWindow(windowWidth, windowHeight);
            glutPositionWindow(100, 100);
        }
        break;

    case 'h':
    case 'H':
        // Toggle haptic feedback
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.hapticEnabled = !hapticConfig.hapticEnabled;
    }
    break;

    case 'r':
    case 'R':
        // Reset packet stats
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        globalPacketStats.totalPacketsReceived = 0;
        globalPacketStats.avgReceiveRate = 0.0;
        globalPacketStats.packetTimings.clear();
        globalPacketStats.firstPacketTime = std::chrono::steady_clock::now();
    }
    break;

    case 'b':
    case 'B':
        // Toggle client feedback
        FEEDBACK_ENABLED = !FEEDBACK_ENABLED;
        std::cout << "Client feedback " << (FEEDBACK_ENABLED ? "enabled" : "disabled") << std::endl;
        break;

    case '+':
    case '=':
        // Increase release rate
        GLOBAL_RELEASE_RATE_FACTOR = std::min(2.0f, GLOBAL_RELEASE_RATE_FACTOR + 0.1f);
        std::cout << "Release rate factor: " << GLOBAL_RELEASE_RATE_FACTOR << "x" << std::endl;
        break;

    case '-':
    case '_':
        // Decrease release rate
        GLOBAL_RELEASE_RATE_FACTOR = std::max(0.1f, GLOBAL_RELEASE_RATE_FACTOR - 0.1f);
        std::cout << "Release rate factor: " << GLOBAL_RELEASE_RATE_FACTOR << "x" << std::endl;
        break;
    }
}

// Handle special keys (F1-F12, arrows, etc.)
void specialKeyFunc(int key, int x, int y) {
    switch (key) {
    case GLUT_KEY_F1:
        // Increase Kp
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.Kp = std::min(500.0, hapticConfig.Kp + 10.0);
        std::cout << "Kp increased to " << hapticConfig.Kp << std::endl;
    }
    break;

    case GLUT_KEY_F2:
        // Decrease Kp
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.Kp = std::max(10.0, hapticConfig.Kp - 10.0);
        std::cout << "Kp decreased to " << hapticConfig.Kp << std::endl;
    }
    break;

    case GLUT_KEY_F3:
        // Increase force scale
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.forceScale = std::min(5.0, hapticConfig.forceScale + 0.1);
        std::cout << "Force scale increased to " << hapticConfig.forceScale << "x" << std::endl;
    }
    break;

    case GLUT_KEY_F4:
        // Decrease force scale
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.forceScale = std::max(0.1, hapticConfig.forceScale - 0.1);
        std::cout << "Force scale decreased to " << hapticConfig.forceScale << "x" << std::endl;
    }
    break;
    }
}

// Function to update haptic device state
void updateHapticState() {
    // Set thread priority for haptics
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_HAPTICS);

    while (true) {
        bool hapticEnabled;
        double Kp, Kd, maxForce, forceScale;

        // Get haptic parameters
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticEnabled = hapticConfig.hapticEnabled && hapticConfig.deviceConnected;
            Kp = hapticConfig.Kp;
            Kd = hapticConfig.Kd;
            maxForce = hapticConfig.maxForce;
            forceScale = hapticConfig.forceScale;
        }

        if (hapticEnabled) {
            // Get current and target position
            double currentPos[3], targetPos[3], velocity[3];

            // Get actual position from device
            dhdGetPosition(&currentPos[0], &currentPos[1], &currentPos[2]);
            dhdGetLinearVelocity(&velocity[0], &velocity[1], &velocity[2]);

            // Get target position
            {
                std::lock_guard<std::mutex> lock(deviceMutex);
                memcpy(targetPos, deviceState.targetPos, sizeof(double) * 3);

                // Update device position
                memcpy(deviceState.position, currentPos, sizeof(double) * 3);
                memcpy(deviceState.velocity, velocity, sizeof(double) * 3);
            }

            // Calculate force (PD control)
            double force[3];
            double posError[3];

            for (int i = 0; i < 3; i++) {
                posError[i] = targetPos[i] - currentPos[i];
                force[i] = (Kp * posError[i] - Kd * velocity[i]) * forceScale;
            }

            // Apply force limiting
            double forceMagnitude = sqrt(force[0] * force[0] + force[1] * force[1] + force[2] * force[2]);
            if (forceMagnitude > maxForce) {
                double scale = maxForce / forceMagnitude;
                force[0] *= scale;
                force[1] *= scale;
                force[2] *= scale;
            }

            // Apply force to device
            dhdSetForce(force[0], force[1], force[2]);

            // Store force for visualization
            {
                std::lock_guard<std::mutex> lock(deviceMutex);
                memcpy(deviceState.force, force, sizeof(double) * 3);
            }

            // Send feedback to client
            {
                std::lock_guard<std::mutex> lock(clientMutex);
                if (lastClient.valid) {
                    // Get latest processed packet
                    auto processedPackets = packetDistributor.getProcessedPackets();
                    if (!processedPackets.empty()) {
                        int latestPacketNum = processedPackets.back().packetNumber;
                        sendFeedback(lastClient.addr, latestPacketNum, force, currentPos, posError);
                    }
                }
            }
        }
        else {
            // No haptic feedback, set zero force
            dhdSetForce(0.0, 0.0, 0.0);

            // Clear stored force
            {
                std::lock_guard<std::mutex> lock(deviceMutex);
                deviceState.force[0] = 0.0;
                deviceState.force[1] = 0.0;
                deviceState.force[2] = 0.0;
            }
        }

        // Sleep to maintain haptic update rate (1kHz is ideal, but we'll use a bit faster)
        std::this_thread::sleep_for(std::chrono::microseconds(500));
    }
}

// Function to clean up resources on exit
void cleanup() {
    // Close haptic device
    if (dhdGetDeviceCount() > 0) {
        dhdStop();
    }

    // Close sockets
    {
        std::lock_guard<std::mutex> lock(socketMutex);
        if (recvSocket != INVALID_SOCKET) {
            closesocket(recvSocket);
            recvSocket = INVALID_SOCKET;
        }

        if (feedbackSocket != INVALID_SOCKET) {
            closesocket(feedbackSocket);
            feedbackSocket = INVALID_SOCKET;
        }
    }

    // Cleanup Winsock
    WSACleanup();

    std::cout << "Application cleaned up successfully" << std::endl;
}

// Initialize haptic device
bool initHapticDevice() {
    // Initialize Force Dimension device
    int deviceID = dhdOpen();

    if (deviceID < 0) {
        std::cerr << "Error: Failed to open haptic device. Error code: " << deviceID << std::endl;
        std::cerr << "Error message: " << dhdErrorGetLastStr() << std::endl;

        // Continue without haptic feedback
        std::cout << "Continuing without haptic feedback..." << std::endl;
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.deviceConnected = false;
            hapticConfig.deviceID = -1;
        }
        return false;
    }

    // Device connected successfully
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.deviceConnected = true;
        hapticConfig.deviceID = deviceID;
    }

    // Configure device
    dhdEnableForce(DHD_ON);

    std::cout << "Haptic device initialized: " << dhdGetSystemName() << std::endl;
    return true;
}

// Initialize network
bool initNetwork() {
    // Initialize Winsock
    WSADATA wsaData;
    int result = WSAStartup(MAKEWORD(2, 2), &wsaData);
    if (result != 0) {
        std::cerr << "WSAStartup failed: " << result << std::endl;
        return false;
    }

    // Create receive socket
    {
        std::lock_guard<std::mutex> lock(socketMutex);
        recvSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (recvSocket == INVALID_SOCKET) {
            std::cerr << "Failed to create receive socket. Error: " << WSAGetLastError() << std::endl;
            WSACleanup();
            return false;
        }

        // Set up receive socket address
        sockaddr_in recvAddr;
        recvAddr.sin_family = AF_INET;
        recvAddr.sin_port = htons(UDP_PORT);
        recvAddr.sin_addr.s_addr = INADDR_ANY;

        // Bind socket
        if (bind(recvSocket, (sockaddr*)&recvAddr, sizeof(recvAddr)) == SOCKET_ERROR) {
            std::cerr << "Failed to bind socket. Error: " << WSAGetLastError() << std::endl;
            closesocket(recvSocket);
            WSACleanup();
            return false;
        }

        // Create feedback socket
        feedbackSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (feedbackSocket == INVALID_SOCKET) {
            std::cerr << "Failed to create feedback socket. Error: " << WSAGetLastError() << std::endl;
            closesocket(recvSocket);
            WSACleanup();
            return false;
        }
    }

    std::cout << "Network initialized, listening on UDP port " << UDP_PORT << std::endl;
    return true;
}

// Thread function to receive packets
void receivePackets() {
    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_PACKET_RECEPTION);

    std::cout << "Packet receiver thread started" << std::endl;

    char buffer[MAX_PACKET_SIZE];

    while (true) {
        sockaddr_in clientAddr;
        int clientAddrLen = sizeof(clientAddr);

        // Wait for packet
        int bytesReceived = recvfrom(recvSocket, buffer, MAX_PACKET_SIZE, 0,
            (sockaddr*)&clientAddr, &clientAddrLen);

        if (bytesReceived > 0) {
            // Store the client information for feedback
            {
                std::lock_guard<std::mutex> lock(clientMutex);
                lastClient.addr = clientAddr;
                lastClient.valid = true;
            }

            // Create packet structure
            Packet packet;
            int copySize = bytesReceived;
            if (copySize > (int)sizeof(Packet)) {
                copySize = (int)sizeof(Packet);
            }
            memcpy(&packet, buffer, copySize);

            // Set receive time
            packet.receiveTime = std::chrono::steady_clock::now();

            // Add to distributor
            packetDistributor.addPacket(packet);

            // Update packet statistics
            {
                std::lock_guard<std::mutex> lock(statsMutex);

                // If this is the first packet, initialize time
                if (globalPacketStats.totalPacketsReceived == 0) {
                    globalPacketStats.firstPacketTime = packet.receiveTime;
                }

                // Store packet timing
                if (globalPacketStats.totalPacketsReceived > 0) {
                    auto timeSinceLastPacket = std::chrono::duration<double, std::milli>(
                        packet.receiveTime - globalPacketStats.lastPacketTime).count();

                    globalPacketStats.packetTimings.push_back(timeSinceLastPacket);

                    // Keep only the most recent PACKET_HISTORY_SIZE timings
                    while (globalPacketStats.packetTimings.size() > PACKET_HISTORY_SIZE) {
                        globalPacketStats.packetTimings.pop_front();
                    }

                    // Calculate average inter-packet time
                    double sum = 0.0;
                    for (const auto& timing : globalPacketStats.packetTimings) {
                        sum += timing;
                    }

                    globalPacketStats.avgInterPacketTime = sum / globalPacketStats.packetTimings.size();
                }

                // Update packet count and rate
                globalPacketStats.totalPacketsReceived++;
                globalPacketStats.lastPacketTime = packet.receiveTime;

                // Calculate packets per second
                auto elapsedSeconds = std::chrono::duration<double>(
                    globalPacketStats.lastPacketTime - globalPacketStats.firstPacketTime).count();

                if (elapsedSeconds > 0) {
                    globalPacketStats.avgReceiveRate = globalPacketStats.totalPacketsReceived / elapsedSeconds;
                }
            }
        }
    }
}

// Thread function to process packets
void processPacketsThread() {
    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_PROCESSING);

    std::cout << "Packet processor thread started" << std::endl;

    while (true) {
        // Process packets based on timing
        packetDistributor.processPackets();

        // Sleep briefly to prevent high CPU usage
        std::this_thread::sleep_for(std::chrono::milliseconds(1));
    }
}

// GLUT display function
void displayFunc() {
    glClear(GL_COLOR_BUFFER_BIT);
    glLoadIdentity();

    // Get statistics for visualization
    PacketStats stats;
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        stats = globalPacketStats;
    }

    // Get buffered and processed packets
    auto bufferedPackets = packetDistributor.getBufferedPackets();
    auto processedPackets = packetDistributor.getProcessedPackets();

    // Draw sliding window visualizations
    drawSlidingWindowGraph(bufferedPackets, 0.0f, "Incoming Packets", stats, true);
    drawSlidingWindowGraph(processedPackets, 0.5f, "Processed Packets", stats, false);

    // Draw haptic device state
    drawHapticState(0.0f);

    // Draw controls help
    drawControls();

    glutSwapBuffers();
}

// GLUT reshape function
void reshapeFunc(int width, int height) {
    windowWidth = width;
    windowHeight = height;

    glViewport(0, 0, width, height);
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    glOrtho(0, 1, 0, 1, -1, 1);
    glMatrixMode(GL_MODELVIEW);
}

// GLUT idle function
void idleFunc() {
    glutPostRedisplay();
}

// Main function
int main(int argc, char** argv) {
    // Register cleanup handler
    atexit(cleanup);

    // Initialize network
    if (!initNetwork()) {
        std::cerr << "Failed to initialize network, exiting." << std::endl;
        return 1;
    }

    // Initialize haptic device (continue even if failed)
    if (!initHapticDevice()) {
        std::cout << "Warning: Failed to initialize haptic device. Continuing without haptic feedback." << std::endl;
    }

    // Start packet receiver thread
    std::thread receiverThread(receivePackets);
    receiverThread.detach();

    // Start packet processor thread
    std::thread processorThread(processPacketsThread);
    processorThread.detach();

    // Start haptic update thread
    std::thread hapticThread(updateHapticState);
    hapticThread.detach();

    // Initialize GLUT
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(windowWidth, windowHeight);
    glutCreateWindow("Haptic Teleoperation System");

    // Register GLUT callbacks
    glutDisplayFunc(displayFunc);
    glutReshapeFunc(reshapeFunc);
    glutIdleFunc(idleFunc);
    glutKeyboardFunc(keyboardFunc);
    glutSpecialFunc(specialKeyFunc);

    // Set up OpenGL
    glClearColor(0.1f, 0.1f, 0.1f, 1.0f);
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);

    std::cout << "Haptic Teleoperation System initialized successfully" << std::endl;
    std::cout << "UDP server listening on port " << UDP_PORT << " for incoming packets" << std::endl;
    std::cout << "Client feedback will be sent back on port " << UDP_PORT << std::endl;

    // Start GLUT main loop
    glutMainLoop();

    return 0;
}
