// Convert timestamp string to more compact format for display
std::string formatTimestampForDisplay(const char* timestamp) {
    // Extract just the time portion (assuming format "YYYY-MM-DD HH:MM:SS")
    std::string ts(timestamp);
    size_t spacePos = ts.find(' ');
    if (spacePos != std::string::npos && spacePos + 1 < ts.length()) {
        return ts.substr(spacePos + 1); // Return just the time part
    }
    return ts;
}

// Draw sliding window visualization with packets moving from right to left
void drawSlidingWindowGraph(const std::deque<Packet>& packets, float xOffset, const char* title,
    const PacketStats& stats, bool showTimeGaps = true) {

    if (packets.empty()) {
        renderSmallText(xOffset + 0.05f, 0.9f, GLUT_BITMAP_HELVETICA_12, "No packets to display");
        return;
    }

    // Draw title and stats
    renderSmallText(xOffset + 0.05f, 0.95f, GLUT_BITMAP_HELVETICA_12, title);

    std::ostringstream statsText;
    statsText << "Packets: " << stats.totalPacketsReceived
        << " | Avg Rate: " << std::fixed << std::setprecision(1)
        << stats.avgReceiveRate << " pkt/s"
        << " | Avg Time: " << std::fixed << std::setprecision(2)
        << stats.avgInterPacketTime << " ms";

    renderSmallText(xOffset + 0.05f, 0.92f, GLUT_BITMAP_HELVETICA_10, statsText.str().c_str());

    // Calculate space allocation
    float packetSpacing = 0.8f / MAX_DISPLAY_PACKETS;
    float maxValue = 0.0f;

    for (const auto& packet : packets) {
        float magnitude = calculateMagnitude(packet);
        if (magnitude > maxValue) maxValue = magnitude;
    }

    // Ensure we have a reasonable scale
    if (maxValue < 0.1f) maxValue = 1.0f;

    // Draw packets as vertical bars with dynamic spacing
    int index = 0;
    for (const auto& packet : packets) {
        float x = xOffset + 0.1f + (packets.size() - 1 - index) * packetSpacing;
        float magnitude = calculateMagnitude(packet);
        float normalizedHeight = (magnitude / maxValue) * BAR_MAX_HEIGHT;

        // Use packet number to create a repeating color pattern
        int colorIndex = packet.packetNumber % 6;
        float r = 0.2f, g = 0.2f, b = 0.7f;  // Default blue

        switch (colorIndex) {
        case 0: r = 0.7f; g = 0.2f; b = 0.2f; break; // Red
        case 1: r = 0.2f; g = 0.7f; b = 0.2f; break; // Green
        case 2: r = 0.2f; g = 0.2f; b = 0.7f; break; // Blue
        case 3: r = 0.7f; g = 0.7f; b = 0.2f; break; // Yellow
        case 4: r = 0.7f; g = 0.2f; b = 0.7f; break; // Purple
        case 5: r = 0.2f; g = 0.7f; b = 0.7f; break; // Cyan
        }

        // Draw the packet bar
        glColor3f(r, g, b);
        glBegin(GL_QUADS);
        glVertex2f(x - BAR_WIDTH / 2, 0.4f);
        glVertex2f(x + BAR_WIDTH / 2, 0.4f);
        glVertex2f(x + BAR_WIDTH / 2, 0.4f + normalizedHeight);
        glVertex2f(x - BAR_WIDTH / 2, 0.4f + normalizedHeight);
        glEnd();

        // Display packet number above bar with staggered positioning to prevent overlap
        char packetNumStr[32];
        snprintf(packetNumStr, sizeof(packetNumStr), "%d", packet.packetNumber);
        float textY = 0.4f + normalizedHeight + TEXT_Y_OFFSET;

        // Stagger text positions to prevent overlap
        if (index % 2 == 0) {
            textY += TEXT_Y_OFFSET;
        }

        renderSmallText(x - 0.015f, textY, GLUT_BITMAP_HELVETICA_10, packetNumStr);

        // Show timestamp for some packets to avoid crowding
        if (index % TIMESTAMP_DISPLAY_INTERVAL == 0) {
            std::string formattedTime = formatTimestampForDisplay(packet.timestamp);
            renderSmallText(x - 0.04f, 0.35f, GLUT_BITMAP_HELVETICA_10, formattedTime.c_str());
        }

        // Show time gap between packets if enabled
        if (showTimeGaps && index > 0) {
            double timeGap = packetDistributor.getPacketTimeGap(packet.packetNumber);
            if (timeGap > 0) {
                char timeGapStr[32];
                snprintf(timeGapStr, sizeof(timeGapStr), "%.1f ms", timeGap);
                renderSmallText(x - 0.02f, 0.32f, GLUT_BITMAP_HELVETICA_10, timeGapStr);
            }
        }

        index++;
    }
}

// Draw a 3D vector representation in 2D space
void draw3DVector(float x, float y, float scale, const float vec[3], const char* label = nullptr) {
    // Draw base axes
    glColor3f(0.5f, 0.5f, 0.5f);
    glBegin(GL_LINES);
    // X axis
    glVertex2f(x - 0.05f, y);
    glVertex2f(x + 0.05f, y);
    // Y axis
    glVertex2f(x, y - 0.05f);
    glVertex2f(x, y + 0.05f);
    glEnd();

    // Draw vector
    glColor3f(0.9f, 0.3f, 0.3f); // Red vector
    glBegin(GL_LINES);
    glVertex2f(x, y);
    glVertex2f(x + vec[0] * scale, y + vec[1] * scale);
    glEnd();

    // Draw vector endpoint
    glPointSize(5.0f);
    glBegin(GL_POINTS);
    glVertex2f(x + vec[0] * scale, y + vec[1] * scale);
    glEnd();

    // Draw label if provided
    if (label) {
        renderSmallText(x - 0.04f, y + 0.08f, GLUT_BITMAP_HELVETICA_10, label);
    }

    // Draw magnitude and components
    char magnitudeStr[64];
    float magnitude = sqrt(vec[0] * vec[0] + vec[1] * vec[1] + vec[2] * vec[2]);
    snprintf(magnitudeStr, sizeof(magnitudeStr), "Mag: %.2f", magnitude);
    renderSmallText(x - 0.04f, y - 0.08f, GLUT_BITMAP_HELVETICA_10, magnitudeStr);

    char compStr[64];
    snprintf(compStr, sizeof(compStr), "[%.2f, %.2f, %.2f]", vec[0], vec[1], vec[2]);
    renderSmallText(x - 0.04f, y - 0.10f, GLUT_BITMAP_HELVETICA_10, compStr);
}

// Draw haptic device state visualization
void drawHapticState(float xOffset) {
    // Draw section title
    renderSmallText(xOffset + 0.05f, 0.95f, GLUT_BITMAP_HELVETICA_12, "Haptic Device State");

    // Get haptic config
    bool hapticEnabled;
    bool deviceConnected;
    int deviceID;
    double Kp, Kd, maxForce, forceScale;
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticEnabled = hapticConfig.hapticEnabled;
        deviceConnected = hapticConfig.deviceConnected;
        deviceID = hapticConfig.deviceID;
        Kp = hapticConfig.Kp;
        Kd = hapticConfig.Kd;
        maxForce = hapticConfig.maxForce;
        forceScale = hapticConfig.forceScale;
    }

    // Draw device status
    std::ostringstream deviceStatusStr;
    deviceStatusStr << "Device: " << (deviceConnected ? "Connected" : "Not Connected");
    if (deviceConnected) {
        deviceStatusStr << " (ID: " << deviceID << ")";
    }
    deviceStatusStr << " | Haptic Feedback: " << (hapticEnabled ? "Enabled" : "Disabled");
    renderSmallText(xOffset + 0.05f, 0.92f, GLUT_BITMAP_HELVETICA_10, deviceStatusStr.str().c_str(),
        deviceConnected ? 0.2f : 0.7f, deviceConnected ? 0.7f : 0.2f, 0.2f);

    // Draw haptic parameters
    std::ostringstream paramsStr;
    paramsStr << "Kp: " << Kp << " | Kd: " << Kd << " | Max Force: " << maxForce
        << " N | Force Scale: " << forceScale << "x";
    renderSmallText(xOffset + 0.05f, 0.89f, GLUT_BITMAP_HELVETICA_10, paramsStr.str().c_str());

    // Get device state
    float position[3], targetPos[3], force[3], error[3];
    {
        std::lock_guard<std::mutex> lock(deviceMutex);
        position[0] = static_cast<float>(deviceState.position[0]);
        position[1] = static_cast<float>(deviceState.position[1]);
        position[2] = static_cast<float>(deviceState.position[2]);

        targetPos[0] = static_cast<float>(deviceState.targetPos[0]);
        targetPos[1] = static_cast<float>(deviceState.targetPos[1]);
        targetPos[2] = static_cast<float>(deviceState.targetPos[2]);

        force[0] = static_cast<float>(deviceState.force[0]);
        force[1] = static_cast<float>(deviceState.force[1]);
        force[2] = static_cast<float>(deviceState.force[2]);

        // Calculate position error
        error[0] = targetPos[0] - position[0];
        error[1] = targetPos[1] - position[1];
        error[2] = targetPos[2] - position[2];
    }

    // Draw current position vector
    draw3DVector(xOffset + 0.2f, 0.7f, 0.05f, position, "Current Position");

    // Draw target position vector
    draw3DVector(xOffset + 0.5f, 0.7f, 0.05f, targetPos, "Target Position");

    // Draw force vector
    draw3DVector(xOffset + 0.2f, 0.5f, 0.01f, force, "Applied Force");

    // Draw error vector
    draw3DVector(xOffset + 0.5f, 0.5f, 0.05f, error, "Position Error");

    // Draw feedback status
    std::ostringstream feedbackStr;
    feedbackStr << "Feedback: " << (FEEDBACK_ENABLED ? "Enabled" : "Disabled")
        << " | Release Rate: " << GLOBAL_RELEASE_RATE_FACTOR << "x";
    renderSmallText(xOffset + 0.05f, 0.35f, GLUT_BITMAP_HELVETICA_10, feedbackStr.str().c_str(),
        FEEDBACK_ENABLED ? 0.2f : 0.7f, FEEDBACK_ENABLED ? 0.7f : 0.2f, 0.2f);
}

