// Initialize client extension
bool initClientExtension() {
    // Initialize random generators
    uniformDist = std::uniform_real_distribution<>(0.0, 1.0);
    normalDist = std::normal_distribution<>(0.0, 1.0);
    
    // Initialize delay parameters
    resetDelayParams();
    
    // Initialize send socket
    if (!initSendSocket()) {
        return false;
    }
    
    // Initialize feedback socket
    if (!initFeedbackSocket()) {
        return false;
    }
    
    // Initialize control window
    if (!initControlWindow()) {
        return false;
    }
    
    // Start the network thread
    networkThread = new std::thread(networkCommunication);
    
    // Start the feedback thread
    feedbackThread = new std::thread(receiveFeedback);
    
    return true;
}

// Update the control window
void updateControlWindow() {
    // Make sure window exists
    if (!controlWindow) return;
    
    // Make current
    glfwMakeContextCurrent(controlWindow);
    
    // Render the window
    renderControlWindow();
    
    // Poll for events
    glfwPollEvents();
    
    // Return to main window context
    glfwMakeContextCurrent(window);
}

// Clean up resources
void cleanupClientExtension() {
    // Signal threads to stop
    networkRunning = false;
    feedbackRunning = false;
    
    // Wait for threads to finish
    if (networkThread && networkThread->joinable()) {
        networkThread->join();
        delete networkThread;
        networkThread = nullptr;
    }
    
    if (feedbackThread && feedbackThread->joinable()) {
        feedbackThread->join();
        delete feedbackThread;
        feedbackThread = nullptr;
    }
    
    // Clean up sockets
    if (clientSocket != INVALID_SOCKET) {
        closesocket(clientSocket);
        clientSocket = INVALID_SOCKET;
    }
    
    if (feedbackSocket != INVALID_SOCKET) {
        closesocket(feedbackSocket);
        feedbackSocket = INVALID_SOCKET;
    }
    
    // Destroy control window
    if (controlWindow) {
        glfwDestroyWindow(controlWindow);
        controlWindow = nullptr;
    }
    
    WSACleanup();
}

