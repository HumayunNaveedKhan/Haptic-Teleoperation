// Draw a radio button group
bool drawRadioGroup(float x, float y, float spacing, const char* groupLabel, 
                   const std::vector<const char*>& options, int& selectedIndex, bool highlighted) {
    bool changed = false;
    
    // Draw group label
    drawText(x, y, groupLabel, highlighted ? 0.9f : 0.8f, highlighted ? 0.9f : 0.8f, highlighted ? 1.0f : 0.8f);
    
    float radioY = y + TEXT_SPACING;
    float radioSize = 12;
    
    // Draw each radio button
    for (int i = 0; i < options.size(); i++) {
        // Draw radio button circle
        glColor3f(0.6f, 0.6f, 0.6f);
        glBegin(GL_TRIANGLE_FAN);
        glVertex2f(x + radioSize/2, radioY + radioSize/2);
        for (int j = 0; j <= 12; j++) {
            float angle = 2.0f * 3.14159f * j / 12;
            glVertex2f(x + radioSize/2 + radioSize/2 * cos(angle), 
                      radioY + radioSize/2 + radioSize/2 * sin(angle));
        }
        glEnd();
        
        // Draw selection dot if selected
        if (i == selectedIndex) {
            glColor3f(0.2f, 0.6f, 0.8f);
            glBegin(GL_TRIANGLE_FAN);
            glVertex2f(x + radioSize/2, radioY + radioSize/2);
            for (int j = 0; j <= 12; j++) {
                float angle = 2.0f * 3.14159f * j / 12;
                glVertex2f(x + radioSize/2 + radioSize/3 * cos(angle), 
                          radioY + radioSize/2 + radioSize/3 * sin(angle));
            }
            glEnd();
        }
        
        // Draw label
        drawText(x + radioSize + 5, radioY + radioSize/2 + 5, options[i]);
        
        // Check if clicked
        if (controlMousePressed &&
            controlMouseX >= x && controlMouseX <= x + radioSize &&
            controlMouseY >= radioY && controlMouseY <= radioY + radioSize) {
            if (selectedIndex != i) {
                selectedIndex = i;
                changed = true;
            }
            controlMousePressed = false;
        }
        
        radioY += spacing;
    }
    
    return changed;
}

// Draw a numeric input field
bool drawNumericInput(float x, float y, float width, float height, const char* label, 
                     int& value, int minVal, int maxVal, bool highlighted) {
    bool changed = false;
    
    // Draw input background
    if (highlighted) {
        drawRect(x, y, width, height, 0.25f, 0.25f, 0.3f);
    } else {
        drawRect(x, y, width, height, 0.2f, 0.2f, 0.25f);
    }
    
    // Draw label
    drawText(x + 5, y + height - 5, label);
    
    // Draw value
    char valueStr[32];
    sprintf_s(valueStr, "%d", value);
    float valueWidth = glutBitmapLength(GLUT_BITMAP_HELVETICA_12, (const unsigned char*)valueStr);
    drawText(x + width/2 - valueWidth/2, y + height/2 + 5, valueStr);
    
    // Draw increment/decrement buttons
    float buttonWidth = 20;
    float buttonHeight = height / 2 - 2;
    
    // Decrement button (-)
    if (drawButton(x + width - buttonWidth - 5, y + 2, buttonWidth, buttonHeight, "-", 
                  highlighted && controlMouseX >= x + width - buttonWidth - 5 && 
                  controlMouseX <= x + width - 5 &&
                  controlMouseY >= y + 2 && 
                  controlMouseY <= y + 2 + buttonHeight)) {
        value = max(minVal, value - 1);
        changed = true;
    }
    
    // Increment button (+)
    if (drawButton(x + width - buttonWidth - 5, y + buttonHeight + 4, buttonWidth, buttonHeight, "+",
                  highlighted && controlMouseX >= x + width - buttonWidth - 5 && 
                  controlMouseX <= x + width - 5 &&
                  controlMouseY >= y + buttonHeight + 4 && 
                  controlMouseY <= y + 2*buttonHeight + 4)) {
        value = min(maxVal, value + 1);
        changed = true;
    }
    
    return changed;
}

// Draw tab buttons
bool drawTabs(float x, float y, float width, float height, const std::vector<const char*>& labels, int& selectedTab) {
    bool changed = false;
    int numTabs = static_cast<int>(labels.size());
    float tabWidth = width / numTabs;
    
    // Draw tabs
    for (int i = 0; i < numTabs; i++) {
        bool isSelected = (i == selectedTab);
        float r = isSelected ? 0.3f : 0.2f;
        float g = isSelected ? 0.5f : 0.2f;
        float b = isSelected ? 0.7f : 0.25f;
        
        // Draw tab background
        drawRect(x + i * tabWidth, y, tabWidth, height, r, g, b);
        
        // Draw tab label
        float labelWidth = glutBitmapLength(GLUT_BITMAP_HELVETICA_12, (const unsigned char*)labels[i]);
        drawText(x + i * tabWidth + (tabWidth - labelWidth) / 2, y + height/2 + 5, labels[i]);
        
        // Check if clicked
        if (controlMousePressed &&
            controlMouseX >= x + i * tabWidth && controlMouseX <= x + (i+1) * tabWidth &&
            controlMouseY >= y && controlMouseY <= y + height) {
            selectedTab = i;
            changed = true;
            controlMousePressed = false;
        }
    }
    
    return changed;
}

// Draw a graph for packet delays
void drawGraph(float x, float y, float width, float height, const char* title,
              const std::deque<std::pair<int, double>>& data, 
              float r = 0.2f, float g = 0.6f, float b = 0.8f) {
    // Draw graph background
    drawRect(x, y, width, height, 0.15f, 0.15f, 0.2f, 0.7f);
    
    // Draw title
    drawText(x + 5, y + height - 15, title);
    
    // Check if we have data
    if (data.empty()) {
        drawText(x + width/2 - 40, y + height/2, "No data available");
        return;
    }
    
    // Find min and max values
    int minPacketNum = data.front().first;
    int maxPacketNum = data.back().first;
    double maxDelay = 0.1; // Minimum scale to prevent division by zero
    
    for (const auto& point : data) {
        if (point.second > maxDelay) {
            maxDelay = point.second;
        }
    }
    
    // Add 10% margin to max delay
    maxDelay *= 1.1;
    
    // Draw axes
    glColor3f(0.6f, 0.6f, 0.6f);
    glBegin(GL_LINES);
    // X axis
    glVertex2f(x + 10, y + 10);
    glVertex2f(x + width - 10, y + 10);
    // Y axis
    glVertex2f(x + 10, y + 10);
    glVertex2f(x + 10, y + height - 20);
    glEnd();
    
    // Draw Y-axis scale
    char scaleStr[32];
    sprintf_s(scaleStr, "%.1f ms", maxDelay);
    drawText(x + 15, y + height - 35, scaleStr, 0.7f, 0.7f, 0.7f);
    
    // Draw data points
    float graphWidth = width - 20;
    float graphHeight = height - 30;
    
    // Connect the points with lines
    glColor3f(r, g, b);
    glBegin(GL_LINE_STRIP);
    
    for (const auto& point : data) {
        float xPos = x + 10 + graphWidth * (point.first - minPacketNum) / 
                    (float)(maxPacketNum - minPacketNum + 1);
        float yPos = y + 10 + graphHeight * point.second / maxDelay;
        glVertex2f(xPos, yPos);
    }
    
    glEnd();
    
    // Draw min and max packet numbers on x-axis
    sprintf_s(scaleStr, "%d", minPacketNum);
    drawText(x + 10, y + 5, scaleStr, 0.7f, 0.7f, 0.7f);
    
    sprintf_s(scaleStr, "%d", maxPacketNum);
    drawText(x + width - 30, y + 5, scaleStr, 0.7f, 0.7f, 0.7f);
}

// Draw recent packets visualization (like in server)
void drawPacketVisualization(float x, float y, float width, float height, const char* title,
                            const std::deque<Packet>& packets) {
    // Draw background
    drawRect(x, y, width, height, 0.15f, 0.15f, 0.2f, 0.7f);
    
    // Draw title
    drawText(x + 5, y + height - 15, title);
    
    // Check if we have data
    if (packets.empty()) {
        drawText(x + width/2 - 40, y + height/2, "No packets sent yet");
        return;
    }
    
    // Calculate parameters for visualization
    int displayCount = min((int)packets.size(), MAX_DISPLAY_PACKETS);
    float barSpacing = (width - 20) / displayCount;
    float barWidth = barSpacing * 0.6f;
    
    // Find max magnitude for scaling
    float maxMagnitude = 0.01f; // Prevent division by zero
    
    for (const auto& packet : packets) {
        float magnitude = sqrt(packet.x*packet.x + packet.y*packet.y + packet.z*packet.z);
        if (magnitude > maxMagnitude) {
            maxMagnitude = magnitude;
        }
    }
    
    // Draw bars for each packet
    int index = 0;
    auto it = packets.end() - displayCount;
    for (int i = 0; i < displayCount; i++, it++) {
        const Packet& packet = *it;
        
        // Calculate magnitude
        float magnitude = sqrt(packet.x*packet.x + packet.y*packet.y + packet.z*packet.z);
        float barHeight = (height - 40) * (magnitude / maxMagnitude);
        
        // Calculate position
        float barX = x + 10 + barSpacing * i;
        float barY = y + 20;
        
        // Choose color based on packet number
        int colorIndex = packet.packetNumber % 6;
        float r = 0.2f, g = 0.2f, b = 0.7f;  // Default blue
        
        switch (colorIndex) {
            case 0: r = 0.7f; g = 0.2f; b = 0.2f; break; // Red
            case 1: r = 0.2f; g = 0.7f; b = 0.2f; break; // Green
            case 2: r = 0.2f; g = 0.2f; b = 0.7f; break; // Blue
            case 3: r = 0.7f; g = 0.7f; b = 0.2f; break; // Yellow
            case 4: r = 0.7f; g = 0.2f; b = 0.7f; break; // Purple
            case 5: r = 0.2f; g = 0.7f; b = 0.7f; break; // Cyan
        }
        
        // Draw the bar
        drawRect(barX, barY, barWidth, barHeight, r, g, b);
        
        // Draw packet number
        if (i % 2 == 0) { // To prevent overlapping, only show every other number
            char numStr[16];
            sprintf_s(numStr, "%d", packet.packetNumber);
            drawText(barX, barY + barHeight + 10, numStr, 0.7f, 0.7f, 0.7f);
        }
        
        // Draw applied delay below
        char delayStr[16];
        sprintf_s(delayStr, "%.1f ms", packet.delay);
        drawText(barX, barY - 15, delayStr, 0.7f, 0.7f, 0.7f);
        
        index++;
    }
}

// Draw the delay control section
void drawDelayControls(float x, float y, float width, float height) {
