// Initialize the network for sending packets to server
bool initSendSocket() {
    WSADATA wsaData;
    
    // Initialize Winsock
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        strcpy_s(statusMessage, "WSAStartup failed for send socket");
        return false;
    }
    
    // Create the UDP socket for sending
    clientSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (clientSocket == INVALID_SOCKET) {
        strcpy_s(statusMessage, "Failed to create send socket");
        WSACleanup();
        return false;
    }
    
    return true;
}

// Initialize the network for receiving feedback from server
bool initFeedbackSocket() {
    // Create the UDP socket for receiving feedback
    feedbackSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (feedbackSocket == INVALID_SOCKET) {
        sprintf_s(statusMessage, sizeof(statusMessage), "Failed to create feedback socket, error: %d", WSAGetLastError());
        return false;
    }
    
    // Set socket to be reusable - this helps with the "Address already in use" error
    BOOL bReuseAddr = TRUE;
    if (setsockopt(feedbackSocket, SOL_SOCKET, SO_REUSEADDR, (char*)&bReuseAddr, sizeof(bReuseAddr)) == SOCKET_ERROR) {
        sprintf_s(statusMessage, sizeof(statusMessage), "Failed to set SO_REUSEADDR, error: %d", WSAGetLastError());
        // Continue despite this error - not critical
    }
    
    // Bind to the fixed feedback port (LISTEN_PORT = 5000)
    sockaddr_in recvAddr;
    memset(&recvAddr, 0, sizeof(recvAddr));
    recvAddr.sin_family = AF_INET;
    recvAddr.sin_port = htons(LISTEN_PORT);
    recvAddr.sin_addr.s_addr = INADDR_ANY;
    
    // Try to bind to the port
    if (bind(feedbackSocket, (sockaddr*)&recvAddr, sizeof(recvAddr)) == SOCKET_ERROR) {
        int error = WSAGetLastError();
        sprintf_s(statusMessage, sizeof(statusMessage), "Failed to bind to port %d, error: %d", LISTEN_PORT, error);
        std::cout << "Failed to bind to feedback port " << LISTEN_PORT << ", error: " << error << std::endl;
        
        // Close the socket and return failure
        closesocket(feedbackSocket);
        feedbackSocket = INVALID_SOCKET;
        return false;
    }
    
    std::cout << "Successfully bound feedback socket to port: " << LISTEN_PORT << std::endl;
    std::cout << "Make sure the server sends feedback to this port" << std::endl;
    
    // Set non-blocking mode for the socket
    u_long mode = 1;
    if (ioctlsocket(feedbackSocket, FIONBIO, &mode) == SOCKET_ERROR) {
        sprintf_s(statusMessage, sizeof(statusMessage), "Failed to set non-blocking mode, error: %d", WSAGetLastError());
        // Continue despite this error - we'll handle it in the receive loop
    }
    
    std::cout << "Feedback socket initialized successfully on port " << LISTEN_PORT << std::endl;
    return true;
}

// Network thread for sending packets to server
void networkCommunication(void) {
    Packet packet;
    sockaddr_in serverAddr;
    
    // Set up the server address
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(DST_PORT);
    if (inet_pton(AF_INET, DST_IP, &serverAddr.sin_addr) <= 0) {
        strcpy_s(statusMessage, "Invalid destination IP");
        networkRunning = false;
        return;
    }
    
    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    
    // Initialize statistics
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        stats.firstPacketTime = std::chrono::steady_clock::now();
        stats.lastPacketTime = stats.firstPacketTime;
    }
    
    // Sending loop based on haptic rate
    while (networkRunning) {
        // Get current haptic rate
        int currentHapticRate;
        {
            std::lock_guard<std::mutex> lock(delayMutex);
            currentHapticRate = delayParams.hapticRateHz;
        }
        
        // Get haptic device position directly
        cVector3d position;
        if (hapticDevice && hapticDevice->getPosition(position)) {
            auto sendTime = std::chrono::steady_clock::now();
            
            // Calculate delay for this packet
            int appliedDelayMs = calculateDelayMs();
            
            // If delay is -1, simulate packet loss by skipping this packet
            if (appliedDelayMs == -1) {
                // Sleep for the appropriate interval to match haptic rate
                std::this_thread::sleep_for(std::chrono::microseconds(1000000 / currentHapticRate));
                continue;
            }
            
            // Apply the delay if there is one
            if (appliedDelayMs > 0) {
                std::this_thread::sleep_for(std::chrono::milliseconds(appliedDelayMs));
            }
            
            // Fill packet data
            packet.packetNumber = ++packetNumber;
            packet.x = static_cast<float>(position.x());
            packet.y = static_cast<float>(position.y());
            packet.z = static_cast<float>(position.z());
            packet.delay = static_cast<float>(appliedDelayMs); // Store the applied delay

            getTimestamp(packet.timestamp);
            strcpy_s(packet.srcIP, SRC_IP);
            strcpy_s(packet.dstIP, DST_IP);
            packet.srcPort = SRC_PORT;
            packet.dstPort = DST_PORT;
            packet.receiveTime = sendTime;
            
            // Store packet in recent history
            {
                std::lock_guard<std::mutex> lock(packetMutex);
                recentPackets.push_back(packet);
                
                // Keep only the latest packets
                while (recentPackets.size() > PACKET_HISTORY_SIZE) {
                    recentPackets.pop_front();
                }
            }
            
            // Update statistics
            {
                std::lock_guard<std::mutex> lock(statsMutex);
                
                // Calculate time since last packet
                if (stats.totalPacketsSent > 0) {
                    double timeSinceLastPacket = calculateTimeDiffMs(
                        stats.lastPacketTime, sendTime);
                    
                    stats.packetTimings.push_back(timeSinceLastPacket);
                    
                    // Keep only most recent timing data
                    while (stats.packetTimings.size() > PACKET_HISTORY_SIZE) {
                        stats.packetTimings.pop_front();
                    }
                }
                
                // Update counters and time
                stats.totalPacketsSent++;
                stats.lastPacketTime = sendTime;
                
                // Calculate send rate (packets/second)
                auto elapsedSeconds = std::chrono::duration<double>(
                    stats.lastPacketTime - stats.firstPacketTime).count();
                
                if (elapsedSeconds > 0) {
                    stats.avgSendRate = stats.totalPacketsSent / elapsedSeconds;
                }
                
                // Store applied delay for graphing
                stats.appliedDelayData.push_back(
                    std::make_pair(packet.packetNumber, appliedDelayMs));
                
                // Keep only the latest data points
                while (stats.appliedDelayData.size() > MAX_GRAPH_POINTS) {
                    stats.appliedDelayData.pop_front();
                }
            }
            
            // Send packet over UDP
            sendto(clientSocket, reinterpret_cast<char*>(&packet), sizeof(Packet), 0,
                  (sockaddr*)&serverAddr, sizeof(serverAddr));
        }
        
        // Sleep for the appropriate interval to match haptic rate
        std::this_thread::sleep_for(std::chrono::microseconds(1000000 / currentHapticRate));
    }
}

// Thread to receive feedback from server
void receiveFeedback(void) {
    char buffer[BUFFER_SIZE];
    FeedbackPacket feedback;
    int bytesReceived;
    
    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_HIGHEST);
    
    while (feedbackRunning) {
        // Try to receive feedback packet
        bytesReceived = recv(feedbackSocket, buffer, BUFFER_SIZE, 0);
        
        if (bytesReceived > 0 && bytesReceived >= sizeof(FeedbackPacket)) {
            // Got a valid feedback packet
            memcpy(&feedback, buffer, sizeof(FeedbackPacket));
            
            // Set receive time
            feedback.receiveTime = std::chrono::steady_clock::now();
            
            // Store the feedback
            {
                std::lock_guard<std::mutex> lock(feedbackMutex);
                recentFeedback.push_back(feedback);
                
                // Keep only the most recent feedback
                while (recentFeedback.size() > PACKET_HISTORY_SIZE) {
                    recentFeedback.pop_front();
                }
            }
            
            // Find matching sent packet to calculate response time
            {
                std::lock_guard<std::mutex> lockPackets(packetMutex);
                std::lock_guard<std::mutex> lockStats(statsMutex);
                
                for (const auto& packet : recentPackets) {
                    if (packet.packetNumber == feedback.packetNumber) {
                        // Calculate response time
                        double responseTime = calculateTimeDiffMs(
                            packet.receiveTime, feedback.receiveTime);
                        
                        // Store for graphing
                        stats.responseTimeData.push_back(
                            std::make_pair(feedback.packetNumber, responseTime));
                        
                        // Keep only the latest data points
                        while (stats.responseTimeData.size() > MAX_GRAPH_POINTS) {
                            stats.responseTimeData.pop_front();
                        }
                        
                        // Update average response time
                        if (stats.totalFeedbackReceived == 0) {
                            stats.avgResponseTime = responseTime;
                        } else {
                            stats.avgResponseTime = 
                                (stats.avgResponseTime * stats.totalFeedbackReceived + responseTime) / 
                                (stats.totalFeedbackReceived + 1);
                        }
                        
                        stats.totalFeedbackReceived++;
                        break;
                    }
                }
            }
            
            // Apply haptic feedback if enabled
            if (enableHapticFeedback && hapticDevice) {
                // Only apply feedback for every Nth packet (based on user setting)
                if (hapticParams.packetsApplied % hapticParams.packetApplyInterval == 0) {
                    // Check if we've reached the limit of packets to apply
                    if (hapticParams.packetsToApply == 0 || 
                        hapticParams.packetsApplied < hapticParams.packetsToApply) {
                        
                        // Apply feedback based on selected mode
                        switch (feedbackMode) {
                            case 0: // Position-based feedback
                                {
                                    // Create a target position using the received position
                                    cVector3d targetPos(
                                        feedback.position[0],
                                        feedback.position[1],
                                        feedback.position[2]
                                    );
                                    
                                    // Get current device position
                                    cVector3d currPos;
                                    hapticDevice->getPosition(currPos);
                                    
                                    // Calculate error (distance to target)
                                    cVector3d posDiff = targetPos - currPos;
                                    
                                    // Apply force based on position error (spring model)
                                    double k = hapticParams.useServerStiffness ? 
                                              feedback.stiffness : hapticParams.stiffness;
                                    
                                    // Apply force with stiffness (spring) and damping
                                    cVector3d force = k * posDiff;
                                    
                                    // Get velocity for damping
                                    cVector3d velocity;
                                    hapticDevice->getLinearVelocity(velocity);
                                    
                                    // Apply damping
                                    double b = hapticParams.useServerStiffness ? 
                                              feedback.damping : hapticParams.damping;
                                    force -= b * velocity;
                                    
                                    // Limit maximum force
                                    if (force.length() > MAX_FORCE) {
                                        force = MAX_FORCE * cNormalize(force);
                                    }
                                    
                                    // Send force to device
                                    hapticDevice->setForce(force);
                                }
                                break;
                                
                            case 1: // Force-based feedback
                                {
                                    // Directly apply the force vector from the feedback
                                    cVector3d force(
                                        feedback.force[0] * hapticParams.forceScale,
                                        feedback.force[1] * hapticParams.forceScale,
                                        feedback.force[2] * hapticParams.forceScale
                                    );
                                    
                                    // Limit maximum force
                                    if (force.length() > MAX_FORCE) {
                                        force = MAX_FORCE * cNormalize(force);
                                    }
                                    
                                    // Apply force directly
                                    hapticDevice->setForce(force);
                                }
                                break;
                                
                            case 2: // Stiffness/Damping based feedback
                                {
                                    // Use stiffness and damping values from feedback
                                    double k = feedback.stiffness;
                                    double b = feedback.damping;
                                    
                                    // Calculate position error
                                    cVector3d error(
                                        feedback.error[0],
                                        feedback.error[1],
                                        feedback.error[2]
                                    );
                                    
                                    // Get current velocity
                                    cVector3d velocity;
                                    hapticDevice->getLinearVelocity(velocity);
                                    
                                    // Calculate force: F = -k*x - b*v
                                    cVector3d force = k * error - b * velocity;
                                    
                                    // Limit maximum force
                                    if (force.length() > MAX_FORCE) {
                                        force = MAX_FORCE * cNormalize(force);
                                    }
                                    
                                    // Apply force
                                    hapticDevice->setForce(force);
                                }
                                break;
                        }
                    }
                }
                
                // Increment applied packets counter
                hapticParams.packetsApplied++;
                
                // Increment validation counter
                hapticParams.validationCounter++;
                
                // Check if we need to validate/alter stiffness and damping
                if (hapticParams.validationCounter >= FEEDBACK_VALIDATION_INTERVAL) {
                    // Reset counter
                    hapticParams.validationCounter = 0;
                    
                    // Get the most recent feedback
                    FeedbackPacket latestFeedback;
                    {
                        std::lock_guard<std::mutex> lock(feedbackMutex);
                        if (!recentFeedback.empty()) {
                            latestFeedback = recentFeedback.back();
                            
                            // Update stiffness and damping if using server values
                            if (hapticParams.useServerStiffness) {
                                hapticParams.stiffness = latestFeedback.stiffness;
                                hapticParams.damping = latestFeedback.damping;
                            }
                        }
                    }
                }
            }
        }
        
        // Small sleep to prevent CPU hogging
        std::this_thread::sleep_for(std::chrono::milliseconds(1));
    }
}

