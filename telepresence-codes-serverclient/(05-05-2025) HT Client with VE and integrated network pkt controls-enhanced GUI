//------------------------------------------------------------------------------
// Draw a rectangle for UI
void drawRect(float x, float y, float width, float height, float r, float g, float b, float a = 1.0f) {
    glColor4f(r, g, b, a);
    glBegin(GL_QUADS);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();
    
    // Draw border
    glColor4f(r * 0.7f, g * 0.7f, b * 0.7f, 1.0f);
    glBegin(GL_LINE_LOOP);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();
}

// Draw text in the control window
void drawText(float x, float y, const char* text, float r = 1.0f, float g = 1.0f, float b = 1.0f) {
    glColor3f(r, g, b);
    glRasterPos2f(x, y);
    for (const char* c = text; *c != '\0'; c++) {
        glutBitmapCharacter(GLUT_BITMAP_HELVETICA_12, *c);
    }
}

// Draw a button and return if it was clicked
bool drawButton(float x, float y, float width, float height, const char* text, bool highlighted) {
    // Draw button background
    if (highlighted) {
        drawRect(x, y, width, height, 0.4f, 0.6f, 0.9f);
    } else {
        drawRect(x, y, width, height, 0.3f, 0.3f, 0.6f);
    }
    
    // Draw button text
    float textX = x + (width - glutBitmapLength(GLUT_BITMAP_HELVETICA_12, (const unsigned char*)text)) / 2;
    float textY = y + height / 2 + 5;
    drawText(textX, textY, text);
    
    // Check if button was clicked
    if (controlMousePressed && 
        controlMouseX >= x && controlMouseX <= x + width &&
        controlMouseY >= y && controlMouseY <= y + height) {
        controlMousePressed = false;
        return true;
    }
    
    return false;
}

// Draw a slider for numeric input
bool drawSlider(float x, float y, float width, float height, const char* label, 
               double& value, double minVal, double maxVal, double step, bool highlighted) {
    bool changed = false;
    
    // Draw slider background
    if (highlighted) {
        drawRect(x, y, width, height, 0.25f, 0.25f, 0.3f);
    } else {
        drawRect(x, y, width, height, 0.2f, 0.2f, 0.25f);
    }
    
    // Draw slider label
    drawText(x + 5, y + height - 5, label);
    
    // Calculate slider track and handle
    float trackY = y + height / 2;
    float trackHeight = 4;
    float handleRadius = 8;
    float trackStart = x + 10;
    float trackWidth = width - 20;
    float trackEnd = trackStart + trackWidth;
    
    // Draw track
    drawRect(trackStart, trackY - trackHeight/2, trackWidth, trackHeight, 0.5f, 0.5f, 0.5f);
    
    // Calculate handle position
    float normalizedVal = (value - minVal) / (maxVal - minVal);
    float handleX = trackStart + normalizedVal * trackWidth;
    
    // Draw handle
    glColor3f(0.7f, 0.7f, 0.8f);
    glBegin(GL_TRIANGLE_FAN);
    glVertex2f(handleX, trackY);
    for (int i = 0; i <= 12; i++) {
        float angle = 2.0f * 3.14159f * i / 12;
        glVertex2f(handleX + handleRadius * cos(angle), trackY + handleRadius * sin(angle));
    }
    glEnd();
    
    // Draw value
    char valueStr[32];
    sprintf_s(valueStr, "%.2f", value);
    drawText(trackEnd + 5, trackY + 5, valueStr);
    
    // Modify the value if the slider is being dragged
    if (controlMousePressed && 
        controlMouseY >= trackY - handleRadius && controlMouseY <= trackY + handleRadius) {
        if (controlMouseX >= trackStart - handleRadius && controlMouseX <= trackEnd + handleRadius) {
            // Compute new value based on mouse position
            float normalizedPos = (controlMouseX - trackStart) / trackWidth;
            normalizedPos = fmax(0.0f, fmin(1.0f, normalizedPos));
            
            double newValue = minVal + normalizedPos * (maxVal - minVal);
            
            // Round to nearest step
            newValue = round(newValue / step) * step;
            
            // Update if changed
            if (newValue != value) {
                value = newValue;
                changed = true;
            }
        }
    }
    
    return changed;
}

