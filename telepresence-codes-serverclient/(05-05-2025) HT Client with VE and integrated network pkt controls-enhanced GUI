//------------------------------------------------------------------------------
// UTILITY FUNCTIONS
//------------------------------------------------------------------------------
// Get magnitude of a 3D vector
double vectorMagnitude(const double vec[3]) {
    return sqrt(vec[0]*vec[0] + vec[1]*vec[1] + vec[2]*vec[2]);
}

// Get string representation of a 3D vector
std::string vectorToString(const double vec[3]) {
    std::ostringstream oss;
    oss << std::fixed << std::setprecision(3) 
        << "[" << vec[0] << ", " << vec[1] << ", " << vec[2] << "]";
    return oss.str();
}

// Calculate time difference in milliseconds
double calculateTimeDiffMs(const std::chrono::steady_clock::time_point& start,
                          const std::chrono::steady_clock::time_point& end) {
    return std::chrono::duration<double, std::milli>(end - start).count();
}

// Get delay for the current packet based on configured delay mode
int calculateDelayMs() {
    std::lock_guard<std::mutex> lock(delayMutex);
    
    // If delay is disabled, return 0
    if (!delayParams.enabled) {
        return 0;
    }
    
    int delayMs = 0;
    
    switch (delayParams.mode) {
        case NO_DELAY:
            delayMs = 0;
            break;
            
        case FIXED_DELAY:
            delayMs = delayParams.fixedDelayMs;
            break;
            
        case UNIFORM_RANDOM_DELAY:
            {
                // Update distribution range
                uniformDist = std::uniform_real_distribution<>(
                    delayParams.minRandomDelayMs, 
                    delayParams.maxRandomDelayMs);
                
                delayMs = static_cast<int>(uniformDist(gen));
            }
            break;
            
        case NORMAL_RANDOM_DELAY:
            {
                // Update normal distribution parameters
                normalDist = std::normal_distribution<>(
                    delayParams.meanDelayMs, 
                    delayParams.stdDevDelayMs);
                
                // Get value, ensure it's non-negative
                delayMs = static_cast<int>(max(0.0, normalDist(gen)));
            }
            break;
            
        case INCREASING_DELAY:
            {
                // Use current delay value
                delayMs = delayParams.currentDelayMs;
                
                // Check if we need to increase
                delayParams.packetsSinceLastIncrease++;
                
                if (delayParams.packetsSinceLastIncrease >= delayParams.increaseIntervalPackets) {
                    // Increase delay for next time
                    delayParams.currentDelayMs += delayParams.increaseStepMs;
                    delayParams.packetsSinceLastIncrease = 0;
                }
            }
            break;
            
        case NETWORK_SIMULATION_DELAY:
            {
                // Base delay based on congestion level (0-200ms)
                int baseDelay = 20 * delayParams.networkCongestionLevel;
                
                // Add jitter (0-50ms depending on jitter level)
                int maxJitter = 5 * delayParams.jitterLevel;
                int jitter = 0;
                
                if (maxJitter > 0) {
                    std::uniform_real_distribution<> jitterDist(0, maxJitter);
                    jitter = static_cast<int>(jitterDist(gen));
                }
                
                delayMs = baseDelay + jitter;
                
                // Simulate packet loss (return -1 to indicate packet should be dropped)
                if (delayParams.packetLossPercent > 0) {
                    std::uniform_real_distribution<> lossDist(0, 100);
                    if (lossDist(gen) < delayParams.packetLossPercent) {
                        delayMs = -1; // Signal to drop this packet
                    }
                }
            }
            break;
    }
    
    return delayMs;
}

// Reset all delay parameters to defaults
void resetDelayParams() {
    std::lock_guard<std::mutex> lock(delayMutex);
    
    delayParams.mode = NO_DELAY;
    delayParams.hapticRateHz = DEFAULT_HAPTIC_RATE_HZ;
    delayParams.fixedDelayMs = 0;
    delayParams.minRandomDelayMs = 0;
    delayParams.maxRandomDelayMs = 100;
    delayParams.meanDelayMs = 50.0;
    delayParams.stdDevDelayMs = 10.0;
    delayParams.increaseStepMs = 5;
    delayParams.increaseIntervalPackets = 100;
    delayParams.networkCongestionLevel = 0;
    delayParams.packetLossPercent = 0;
    delayParams.jitterLevel = 0;
    delayParams.enabled = false;
    delayParams.currentDelayMs = 0;
    delayParams.packetsSinceLastIncrease = 0;
}

