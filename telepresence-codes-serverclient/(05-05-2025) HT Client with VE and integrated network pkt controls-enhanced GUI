//------------------------------------------------------------------------------
// PACKET STRUCTURES
//------------------------------------------------------------------------------
// Outgoing packet structure (to server)
struct Packet {
    int packetNumber;                 // Sequential packet number
    float x, y, z;                    // 3D Vector components
    float delay;                      // Processing delay in milliseconds
    char timestamp[64];               // Timestamp of packet creation
    char srcIP[INET_ADDRSTRLEN];      // Source IP address
    char dstIP[INET_ADDRSTRLEN];      // Destination IP address
    int srcPort;                      // Source port
    int dstPort;                      // Destination port
    std::chrono::steady_clock::time_point receiveTime; // For client tracking
};

// Incoming feedback packet structure (from server)
struct FeedbackPacket {
    int packetNumber;                 // Sequential packet number
    double force[3];                  // Force vector (x,y,z)
    double position[3];               // Current device position
    double error[3];                  // Position error
    double stiffness;                 // Current stiffness value used (K)
    double damping;                   // Current damping value used (B)
    char message[64];                 // Message/status
    std::chrono::steady_clock::time_point receiveTime; // For client tracking
};

// Statistics tracking
struct PacketStats {
    int totalPacketsSent = 0;
    int totalFeedbackReceived = 0;
    double avgSendRate = 0.0;
    double avgResponseTime = 0.0;
    std::chrono::steady_clock::time_point firstPacketTime;
    std::chrono::steady_clock::time_point lastPacketTime;
    std::deque<double> packetTimings;  // Store timing between sent packets
    std::deque<std::pair<int, double>> responseTimeData; // For graphing
    std::deque<std::pair<int, double>> appliedDelayData; // For tracking applied delays
};

// Delay configuration parameters
enum DelayMode {
    NO_DELAY = 0,
    FIXED_DELAY,
    UNIFORM_RANDOM_DELAY,
    NORMAL_RANDOM_DELAY,
    INCREASING_DELAY,
    NETWORK_SIMULATION_DELAY
};

struct DelayParams {
    DelayMode mode = NO_DELAY;
    int hapticRateHz = DEFAULT_HAPTIC_RATE_HZ;     // Base rate for haptic updates
    int fixedDelayMs = 0;                          // Fixed delay in milliseconds
    int minRandomDelayMs = 0;                      // Minimum delay for uniform random
    int maxRandomDelayMs = 100;                    // Maximum delay for uniform random
    double meanDelayMs = 50.0;                     // Mean for normal distribution
    double stdDevDelayMs = 10.0;                   // Std deviation for normal distribution
    int increaseStepMs = 5;                        // Increment step for increasing delay
    int increaseIntervalPackets = 100;             // Number of packets before increasing
    int networkCongestionLevel = 0;                // 0-10 scale for network congestion
    int packetLossPercent = 0;                     // Percentage of packets to drop (0-100)
    int jitterLevel = 0;                           // Jitter level for network sim (0-10)
    bool enabled = false;                          // Master enable for delay
    
    // Track current delay for some modes
    int currentDelayMs = 0;
    int packetsSinceLastIncrease = 0;
};

