    std::vector<const char*> tabLabels = { "Basic Delay", "Advanced Delay" };
    drawTabs(x + 10, y + 30, width - 20, 25, tabLabels, selectedDelayTab);
    
    // Get current delay parameters (for UI display)
    DelayParams currentParams;
    {
        std::lock_guard<std::mutex> lock(delayMutex);
        currentParams = delayParams;
    }
    
    // Draw the master enable checkbox
    bool enableChanged = drawCheckbox(x + 10, y + 65, 20, "Enable Delay", 
                                     currentParams.enabled, 
                                     controlMouseX >= x + 10 && controlMouseX <= x + 30 &&
                                     controlMouseY >= y + 65 && controlMouseY <= y + 85);
    
    if (enableChanged) {
        std::lock_guard<std::mutex> lock(delayMutex);
        delayParams.enabled = currentParams.enabled;
    }
    
    // Draw Haptic Rate control
    bool rateChanged = drawNumericInput(x + width - 170, y + 65, 150, 25, 
                                       "Haptic Rate (Hz):", currentParams.hapticRateHz, 10, 2000,
                                       controlMouseX >= x + width - 170 && 
                                       controlMouseX <= x + width - 20 &&
                                       controlMouseY >= y + 65 && 
                                       controlMouseY <= y + 90);
    
    if (rateChanged) {
        std::lock_guard<std::mutex> lock(delayMutex);
        delayParams.hapticRateHz = currentParams.hapticRateHz;
    }
    
    // Based on selected tab, show different delay controls
    if (selectedDelayTab == 0) {
        // Basic delay controls
        std::vector<const char*> delayOptions = {
            "No Delay",
            "Fixed Delay",
            "Uniform Random Delay",
            "Normal Random Delay",
            "Increasing Delay",
            "Network Simulation"
        };
        
        bool modeChanged = drawRadioGroup(x + 10, y + 100, 22, "Delay Mode:", 
                                         delayOptions, (int&)currentParams.mode,
                                         controlMouseX >= x + 10 && 
                                         controlMouseX <= x + 200 &&
                                         controlMouseY >= y + 100 && 
                                         controlMouseY <= y + 240);
        
        if (modeChanged) {
            std::lock_guard<std::mutex> lock(delayMutex);
            delayParams.mode = (DelayMode)currentParams.mode;
            
            // Reset current delay for increasing mode
            if (delayParams.mode == INCREASING_DELAY) {
                delayParams.currentDelayMs = 0;
                delayParams.packetsSinceLastIncrease = 0;
            }
        }
        
        // Draw specific controls based on selected mode
        float controlY = y + 230;
        
        switch (currentParams.mode) {
            case FIXED_DELAY:
                {
                    bool changed = drawIntSlider(x + 10, controlY, width - 20, 25, 
                                               "Fixed Delay (ms):", currentParams.fixedDelayMs, 0, 1000,
                                               controlMouseX >= x + 10 && 
                                               controlMouseX <= x + width - 10 &&
                                               controlMouseY >= controlY && 
                                               controlMouseY <= controlY + 25);
                    
                    if (changed) {
                        std::lock_guard<std::mutex> lock(delayMutex);
                        delayParams.fixedDelayMs = currentParams.fixedDelayMs;
                    }
                }
                break;
                
            case UNIFORM_RANDOM_DELAY:
                {
                    // Min delay
                    bool minChanged = drawIntSlider(x + 10, controlY, width - 20, 25, 
                                                  "Min Delay (ms):", currentParams.minRandomDelayMs, 0, 500,
                                                  controlMouseX >= x + 10 && 
                                                  controlMouseX <= x + width - 10 &&
                                                  controlMouseY >= controlY && 
                                                  controlMouseY <= controlY + 25);
                    
                    if (minChanged) {
                        std::lock_guard<std::mutex> lock(delayMutex);
                        delayParams.minRandomDelayMs = currentParams.minRandomDelayMs;
                        
                        // Ensure min <= max
                        if (delayParams.minRandomDelayMs > delayParams.maxRandomDelayMs) {
                            delayParams.maxRandomDelayMs = delayParams.minRandomDelayMs;
                        }
