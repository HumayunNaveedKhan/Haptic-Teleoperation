                        delayParams.networkCongestionLevel = currentParams.networkCongestionLevel;
                    }
                    
                    // Jitter level
                    controlY += 35;
                    bool jitterChanged = drawIntSlider(x + 10, controlY, width - 20, 25, 
                                                     "Jitter (0-10):", currentParams.jitterLevel, 0, 10,
                                                     controlMouseX >= x + 10 && 
                                                     controlMouseX <= x + width - 10 &&
                                                     controlMouseY >= controlY && 
                                                     controlMouseY <= controlY + 25);
                    
                    if (jitterChanged) {
                        std::lock_guard<std::mutex> lock(delayMutex);
                        delayParams.jitterLevel = currentParams.jitterLevel;
                    }
                    
                    // Packet loss
                    controlY += 35;
                    bool lossChanged = drawIntSlider(x + 10, controlY, width - 20, 25, 
                                                   "Packet Loss (%):", currentParams.packetLossPercent, 0, 100,
                                                   controlMouseX >= x + 10 && 
                                                   controlMouseX <= x + width - 10 &&
                                                   controlMouseY >= controlY && 
                                                   controlMouseY <= controlY + 25);
                    
                    if (lossChanged) {
                        std::lock_guard<std::mutex> lock(delayMutex);
                        delayParams.packetLossPercent = currentParams.packetLossPercent;
                    }
                }
                break;
        }
        
        // Draw reset button at the bottom
        if (drawButton(x + 10, y + height - 40, width - 20, 30, "Reset All Delay Settings", 
                      controlMouseX >= x + 10 && controlMouseX <= x + width - 10 &&
                      controlMouseY >= y + height - 40 && controlMouseY <= y + height - 10)) {
            resetDelayParams();
        }
    }
    else {
        // Advanced delay controls will go here
        // This could include custom delay patterns, imported delay profiles, etc.
        drawText(x + 10, y + 150, "Advanced delay controls coming soon...");
    }
}

// Render control window
void renderControlWindow() {
    // Get window size
    int width, height;
    glfwGetWindowSize(controlWindow, &width, &height);
    
    // Set up orthographic projection
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    glOrtho(0, width, height, 0, -1, 1);
    glMatrixMode(GL_MODELVIEW);
    glLoadIdentity();
    
    // Clear background
    glClearColor(0.12f, 0.12f, 0.15f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT);
    
    // Enable blending
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    
    // Draw title
    drawText(20, 30, "Haptic Teleoperation Client Control Panel", 0.9f, 0.9f, 1.0f);
    
    // Connection status
    drawRect(20, 50, width - 40, 50, 0.15f, 0.15f, 0.20f);
    
    // Get statistics
    PacketStats currentStats;
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        currentStats = stats;
    }
    
    // Display connection and packet statistics
    char statsText[256];
    sprintf_s(statsText, "Connected to: %s:%d | Packets Sent: %d | Send Rate: %.1f packets/s",
             DST_IP, DST_PORT, currentStats.totalPacketsSent, currentStats.avgSendRate);
    drawText(30, 70, statsText);
    
    sprintf_s(statsText, "Feedback Received: %d | Avg Response Time: %.1f ms | Status: %s",
             currentStats.totalFeedbackReceived, currentStats.avgResponseTime, statusMessage);
    drawText(30, 90, statsText);
    
    //------------------------------------------------------------------------
    // Delay Controls Section
    //------------------------------------------------------------------------
    float sectionY = 120;
    drawDelayControls(20, sectionY, width - 40, 400);
    
    //------------------------------------------------------------------------
    // Haptic Feedback Control Section
    //------------------------------------------------------------------------
    sectionY = 540;
    drawRect(20, sectionY, width - 40, 140, 0.18f, 0.18f, 0.22f);
    drawText(30, sectionY + 20, "Haptic Feedback Control", 0.9f, 0.9f, 1.0f);
    
    // Enable/Disable Feedback checkbox
    bool highlightCheckbox = 
        controlMouseX >= 30 && controlMouseX <= 30 + 20 &&
        controlMouseY >= sectionY + 40 && controlMouseY <= sectionY + 40 + 20;
        
    bool tempEnableFeedback = enableHapticFeedback;
    if (drawCheckbox(30, sectionY + 40, 20, "Enable Haptic Feedback", tempEnableFeedback, highlightCheckbox)) {
        enableHapticFeedback = tempEnableFeedback;
    }
    
    // Use server stiffness/damping checkbox
    highlightCheckbox = 
        controlMouseX >= 30 && controlMouseX <= 30 + 20 &&
        controlMouseY >= sectionY + 70 && controlMouseY <= sectionY + 70 + 20;
        
    if (drawCheckbox(30, sectionY + 70, 20, "Use Server Stiffness/Damping", 
                    hapticParams.useServerStiffness, highlightCheckbox)) {
        // Value changed in the function
    }
    
    // Feedback mode radio buttons
    std::vector<const char*> feedbackOptions = {
        "Position-based Feedback", 
        "Force-based Feedback", 
        "Stiffness/Damping Feedback"
    };
    
    bool highlightRadio = 
        controlMouseX >= 30 && controlMouseX <= 200 &&
        controlMouseY >= sectionY + 100 && controlMouseY <= sectionY + 100 + 80;
        
    int tempFeedbackMode = feedbackMode;
    if (drawRadioGroup(30, sectionY + 100, 20, "Feedback Mode:", feedbackOptions, tempFeedbackMode, highlightRadio)) {
        feedbackMode = tempFeedbackMode;
    }
    
    //------------------------------------------------------------------------
    // Data Visualization Section
    //------------------------------------------------------------------------
    sectionY = 700;
    drawRect(20, sectionY, width - 40, 250, 0.18f, 0.18f, 0.22f);
    drawText(30, sectionY + 20, "Data Visualization", 0.9f, 0.9f, 1.0f);
    
    // Get recent packets and feedback for visualization
    std::deque<Packet> recentPacketsCopy;
    {
        std::lock_guard<std::mutex> lock(packetMutex);
        recentPacketsCopy = recentPackets;
    }
    
    // Draw response time graph
    std::deque<std::pair<int, double>> responseTimeDataCopy;
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        responseTimeDataCopy = currentStats.responseTimeData;
    }
    
    // Draw applied delay graph
    std::deque<std::pair<int, double>> appliedDelayDataCopy;
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        appliedDelayDataCopy = currentStats.appliedDelayData;
    }
    
    // Draw the graphs in a grid layout
    float graphWidth = (width - 60) / 2;
    float graphHeight = 100;
    
    // Draw response time graph (top left)
    drawGraph(30, sectionY + 40, graphWidth, graphHeight, 
             "Response Time (ms)", responseTimeDataCopy, 0.2f, 0.6f, 0.8f);
    
    // Draw applied delay graph (top right)
    drawGraph(40 + graphWidth, sectionY + 40, graphWidth, graphHeight, 
             "Applied Delay (ms)", appliedDelayDataCopy, 0.8f, 0.4f, 0.2f);
    
    // Draw packet visualization (bottom)
    drawPacketVisualization(30, sectionY + 50 + graphHeight, width - 60, graphHeight, 
                          "Recent Packets with Applied Delays", recentPacketsCopy);
    
    // Reset the mouse click state
    controlMousePressed = false;
    
    // Swap buffers
    glfwSwapBuffers(controlWindow);
}

// Mouse button callback for control window
void controlMouseButtonCallback(GLFWwindow* window, int button, int action, int mods) {
    if (button == GLFW_MOUSE_BUTTON_LEFT && action == GLFW_PRESS) {
        controlMousePressed = true;
    }
}

// Mouse position callback for control window
void controlCursorPosCallback(GLFWwindow* window, double xpos, double ypos) {
    controlMouseX = xpos;
    controlMouseY = ypos;
}

// Initialize the control window
bool initControlWindow() {
    // Create a window for GUI controls
    glfwWindowHint(GLFW_VISIBLE, GLFW_TRUE);
    controlWindow = glfwCreateWindow(CONTROL_WINDOW_WIDTH, CONTROL_WINDOW_HEIGHT, 
                                    "Haptic Teleoperation Control", NULL, window);
    
    if (!controlWindow) {
        strcpy_s(statusMessage, "Failed to create control window");
        return false;
    }
    
    // Set callbacks
    glfwSetMouseButtonCallback(controlWindow, controlMouseButtonCallback);
    glfwSetCursorPosCallback(controlWindow, controlCursorPosCallback);
    
    // Position the window
    const GLFWvidmode* mode = glfwGetVideoMode(glfwGetPrimaryMonitor());
    glfwSetWindowPos(controlWindow, mode->width - CONTROL_WINDOW_WIDTH - 50, 50);
    
    return true;
}

