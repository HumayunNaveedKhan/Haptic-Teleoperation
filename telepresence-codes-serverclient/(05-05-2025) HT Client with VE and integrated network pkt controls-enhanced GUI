                                                  "Max Delay (ms):", currentParams.maxRandomDelayMs, 
                                                  currentParams.minRandomDelayMs, 1000,
                                                  controlMouseX >= x + 10 && 
                                                  controlMouseX <= x + width - 10 &&
                                                  controlMouseY >= controlY && 
                                                  controlMouseY <= controlY + 25);
                    
                    if (maxChanged) {
                        std::lock_guard<std::mutex> lock(delayMutex);
                        delayParams.maxRandomDelayMs = currentParams.maxRandomDelayMs;
                    }
                }
                break;
                
            case NORMAL_RANDOM_DELAY:
                {
                    // Mean delay
