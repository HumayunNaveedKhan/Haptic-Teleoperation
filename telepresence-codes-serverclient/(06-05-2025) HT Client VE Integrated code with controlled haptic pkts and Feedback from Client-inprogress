//------------------------------------------------------------------------------
// CONSTANTS & ENUMS
//------------------------------------------------------------------------------
// Network settings
const int SRC_PORT = 1000;          // Source UDP port
const int DST_PORT = 4000;          // Destination UDP port
const int BUFFER_SIZE = 1024;       // Packet buffer size
const int HAPTIC_RATE_HZ = 1000;    // Haptic device update rate
const int MAX_HISTORY_SIZE = 1000;  // Maximum history size for graphs
const int MAX_DISPLAY_PACKETS = 100; // Maximum packets to display in GUI

// GUI modes
enum GuiMode {
    GUI_HIDDEN = 0,
    GUI_MINIMAL = 1,
    GUI_FULL = 2
};

// Feedback types
enum FeedbackType {
    FEEDBACK_POSITION = 0,
    FEEDBACK_FORCE = 1,
    FEEDBACK_STIFFNESS_DAMPING = 2
};

//------------------------------------------------------------------------------
// PACKET STRUCTURES
//------------------------------------------------------------------------------
// Client packet structure
struct ClientPacket {
    int packetNumber;
    float x, y, z;                // Position data
    float delay;                  // Delay information in ms
    char timestamp[64];           // Timestamp for synchronization
    char srcIP[16];               // Source IP address
    char dstIP[16];               // Destination IP address
    int srcPort;                  // Source port
    int dstPort;                  // Destination port
};

// Feedback packet structure
struct FeedbackPacket {
    int packetNumber;             // Matching packet number from client
    float fx, fy, fz;             // Force feedback
    float px, py, pz;             // Actual position on server
    float positionError;          // Error between commanded and actual position
    float latency;                // Estimated latency in ms
    char timestamp[64];           // Timestamp for synchronization
};

//------------------------------------------------------------------------------
// NETWORK MANAGER CLASS
//------------------------------------------------------------------------------
class NetworkManager {
public:
    // Constructor
    NetworkManager()
        : m_client(nullptr),
        m_localPort(SRC_PORT),
        m_serverPort(DST_PORT),
        m_socket(INVALID_SOCKET),
        m_threadRunning(false),
        m_connected(false),
        m_packetsSent(0),
        m_packetsReceived(0)
    {
        // Initialize local IP
        strcpy_s(m_localIP, "127.0.0.1");

        // Initialize server IP
        strcpy_s(m_serverIP, "127.0.0.1");
    }

    // Destructor
    ~NetworkManager() {
        disconnect();
    }

    // Initialize the network manager
    bool initialize() {
        // Initialize Windows socket API
        WSADATA wsaData;
        if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
            std::cerr << "Failed to initialize Winsock" << std::endl;
            return false;
        }

        // Get local IP address
        getLocalIPAddress(m_localIP);

        // Initialize socket
        return initializeSocket();
    }

    // Connect to server
    bool connect(const std::string& serverIP, int serverPort) {
        if (m_connected) {
            return true;  // Already connected
        }

        // Copy server IP and port
        strcpy_s(m_serverIP, serverIP.c_str());
        m_serverPort = serverPort;

        // Set up server address
        m_serverAddr.sin_family = AF_INET;
        m_serverAddr.sin_port = htons(m_serverPort);
        inet_pton(AF_INET, m_serverIP, &m_serverAddr.sin_addr);

        // Start network threads
        m_threadRunning = true;
        m_networkThread = std::thread(&NetworkManager::networkThreadFunc, this);

        m_connected = true;
        return true;
    }

    // Disconnect from server
    void disconnect() {
        if (!m_connected) {
            return;  // Not connected
        }

        // Stop threads
        m_threadRunning = false;

        if (m_networkThread.joinable()) {
            m_networkThread.join();
        }

        // Close socket
        closeSocket();

        m_connected = false;
    }

    // Send packet to server
    bool sendPacket(const ClientPacket& packet) {
        if (!m_connected || m_socket == INVALID_SOCKET) {
            return false;
        }

        std::lock_guard<std::mutex> lock(m_socketMutex);

        // Send packet
        int bytesSent = sendto(
            m_socket,
            reinterpret_cast<const char*>(&packet),
            sizeof(packet),
            0,
            reinterpret_cast<const sockaddr*>(&m_serverAddr),
            sizeof(m_serverAddr)
        );

        if (bytesSent == SOCKET_ERROR) {
            std::cerr << "Error sending packet: " << WSAGetLastError() << std::endl;
            return false;
        }

        m_packetsSent++;
        return true;
    }

    // Set client reference
    void setClient(HapticTeleoperationClient* client) {
        m_client = client;
    }

    // Get connection status
    bool isConnected() const {
        return m_connected;
    }

    // Get local IP address
    const char* getLocalIP() const {
        return m_localIP;
    }

    // Get server IP address
    const char* getServerIP() const {
        return m_serverIP;
    }

    // Get packet statistics
    void getPacketStats(int& sent, int& received) const {
        sent = m_packetsSent;
        received = m_packetsReceived;
    }

private:
    // Initialize socket
    bool initializeSocket() {
        // Create UDP socket
        m_socket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (m_socket == INVALID_SOCKET) {
            std::cerr << "Error creating socket: " << WSAGetLastError() << std::endl;
            return false;
        }

        // Bind to local port
        sockaddr_in localAddr;
        localAddr.sin_family = AF_INET;
        localAddr.sin_addr.s_addr = INADDR_ANY;
        localAddr.sin_port = htons(m_localPort);

        if (bind(m_socket, reinterpret_cast<sockaddr*>(&localAddr), sizeof(localAddr)) == SOCKET_ERROR) {
            std::cerr << "Error binding socket: " << WSAGetLastError() << std::endl;
            closeSocket();
            return false;
        }

        // Set socket to non-blocking mode
        u_long mode = 1;
        if (ioctlsocket(m_socket, FIONBIO, &mode) == SOCKET_ERROR) {
            std::cerr << "Error setting non-blocking mode: " << WSAGetLastError() << std::endl;
            closeSocket();
            return false;
        }

        return true;
    }

    // Close socket
    void closeSocket() {
        if (m_socket != INVALID_SOCKET) {
            closesocket(m_socket);
            m_socket = INVALID_SOCKET;
        }
    }

    // Get local IP address
    void getLocalIPAddress(char* ipBuffer) {
        char hostname[256];
        struct addrinfo hints {}, * info, * p;
        struct sockaddr_in* sockaddr_ipv4;

        if (gethostname(hostname, sizeof(hostname)) == 0) {
            hints.ai_family = AF_INET;
            hints.ai_socktype = SOCK_DGRAM;
            hints.ai_flags = AI_PASSIVE;

            if (getaddrinfo(hostname, NULL, &hints, &info) == 0) {
                for (p = info; p != NULL; p = p->ai_next) {
                    sockaddr_ipv4 = (struct sockaddr_in*)p->ai_addr;
                    inet_ntop(AF_INET, &sockaddr_ipv4->sin_addr, ipBuffer, 16);
                    // Skip localhost address
                    if (strcmp(ipBuffer, "127.0.0.1") != 0) {
                        break;
                    }
                }
                freeaddrinfo(info);
            }
        }
    }

    // Network thread function
    void networkThreadFunc() {
        char recvBuffer[BUFFER_SIZE];
        sockaddr_in senderAddr;
        int senderAddrLen = sizeof(senderAddr);

        while (m_threadRunning) {
            // Receive packet
            int bytesReceived = recvfrom(
                m_socket,
                recvBuffer,
                BUFFER_SIZE,
                0,
                reinterpret_cast<sockaddr*>(&senderAddr),
                &senderAddrLen
            );

            if (bytesReceived > 0) {
                m_packetsReceived++;

                // Process feedback packet
                if (bytesReceived == sizeof(FeedbackPacket) && m_client) {
                    processFeedbackPacket(reinterpret_cast<FeedbackPacket*>(recvBuffer));
                }
            }
            else if (bytesReceived == SOCKET_ERROR) {
                int error = WSAGetLastError();
                if (error != WSAEWOULDBLOCK) {
                    std::cerr << "Error receiving packet: " << error << std::endl;
                }
            }

            // Small sleep to prevent CPU hogging
            std::this_thread::sleep_for(std::chrono::milliseconds(1));
        }
    }

    // Process feedback packet
    void processFeedbackPacket(FeedbackPacket* packet);

    // Client reference
    HapticTeleoperationClient* m_client;

    // Network configuration
    char m_localIP[16];
    char m_serverIP[16];
    int m_localPort;
    int m_serverPort;

    // Socket information
    SOCKET m_socket;
    sockaddr_in m_serverAddr;

    // Thread management
    std::thread m_networkThread;
    std::atomic<bool> m_threadRunning;

    // Connection status
    std::atomic<bool> m_connected;

    // Packet statistics
    std::atomic<int> m_packetsSent;
    std::atomic<int> m_packetsReceived;

    // Mutex for thread safety
    std::mutex m_socketMutex;
};

//------------------------------------------------------------------------------
// FEEDBACK PROCESSOR CLASS
//------------------------------------------------------------------------------
class FeedbackProcessor {
public:
    // Constructor
    FeedbackProcessor()
        : m_client(nullptr),
        m_feedbackType(FEEDBACK_POSITION),
        m_feedbackEnabled(true),
        m_stiffness(100.0),
        m_damping(20.0),
        m_positionError(0.0f),
        m_averageLatency(0.0f),
        m_packetsProcessed(0)
    {
        // Initialize arrays
        for (int i = 0; i < 3; i++) {
            m_currentForce[i] = 0.0f;
            m_targetPosition[i] = 0.0f;
        }
    }

    // Destructor
    ~FeedbackProcessor() {
        // Clean up
    }

    // Initialize the processor
    bool initialize() {
        return true;
    }

    // Set client reference
    void setClient(HapticTeleoperationClient* client) {
        m_client = client;
    }

    // Process feedback packet
    void processFeedback(const FeedbackPacket& packet) {
        std::lock_guard<std::mutex> lock(m_dataMutex);

        // Store force values
        m_currentForce[0] = packet.fx;
        m_currentForce[1] = packet.fy;
        m_currentForce[2] = packet.fz;

        // Store target position
        m_targetPosition[0] = packet.px;
        m_targetPosition[1] = packet.py;
        m_targetPosition[2] = packet.pz;

        // Store error and latency
        m_positionError = packet.positionError;

        // Update statistics
        updateStatistics(packet);

        // Apply feedback based on type
        if (m_feedbackEnabled) {
            calculateForce();
        }

        m_packetsProcessed++;
    }

    // Set feedback type
    void setFeedbackType(FeedbackType type) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_feedbackType = type;
    }

    // Enable/disable feedback
    void setFeedbackEnabled(bool enabled) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_feedbackEnabled = enabled;
    }

    // Set stiffness parameter
    void setStiffness(double stiffness) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_stiffness = stiffness;
    }

    // Set damping parameter
    void setDamping(double damping) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_damping = damping;
    }

    // Get current force feedback
    void getCurrentForce(float& fx, float& fy, float& fz) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        fx = m_currentForce[0];
        fy = m_currentForce[1];
        fz = m_currentForce[2];
    }

    // Get current target position
    void getTargetPosition(float& x, float& y, float& z) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        x = m_targetPosition[0];
        y = m_targetPosition[1];
        z = m_targetPosition[2];
    }

    // Get feedback type
    FeedbackType getFeedbackType() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_feedbackType;
    }

    // Get feedback enabled state
    bool isFeedbackEnabled() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_feedbackEnabled;
    }

    // Get stiffness
    double getStiffness() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_stiffness;
    }

    // Get damping
    double getDamping() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_damping;
    }

    // Get position error
    float getPositionError() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_positionError;
    }

    // Get average latency
    float getAverageLatency() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_averageLatency;
    }

private:
    // Calculate force feedback based on position error
    void calculateForce() {
        // Force calculation is implemented in the haptic loop
        // This method just handles special processing if needed
    }

    // Update statistics
    void updateStatistics(const FeedbackPacket& packet) {
        // Add packet to history
        m_packetHistory.push_back(packet);
        if (m_packetHistory.size() > MAX_HISTORY_SIZE) {
            m_packetHistory.pop_front();
        }

        // Calculate average latency
        float totalLatency = 0.0f;
        for (const auto& p : m_packetHistory) {
            totalLatency += p.latency;
        }
        m_averageLatency = totalLatency / m_packetHistory.size();
    }

    // Client reference
    HapticTeleoperationClient* m_client;

    // Feedback parameters
    FeedbackType m_feedbackType;
    bool m_feedbackEnabled;
    double m_stiffness;
    double m_damping;

    // Current feedback values
    float m_currentForce[3];
    float m_targetPosition[3];
    float m_positionError;
    float m_averageLatency;

    // Packet history for statistics
    std::deque<FeedbackPacket> m_packetHistory;
    std::atomic<int> m_packetsProcessed;

    // Thread safety
    mutable std::mutex m_dataMutex;
};

