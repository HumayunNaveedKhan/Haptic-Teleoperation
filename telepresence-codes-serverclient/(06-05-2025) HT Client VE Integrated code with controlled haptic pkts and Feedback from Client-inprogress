        return true;
    }

    // Set client reference
    void setClient(HapticTeleoperationClient* client) {
        m_client = client;
    }

    // Update user interface
    void update() {
        // Update UI state
    }

    // Render user interface
    void render() {
        // Simple console-based UI for now
