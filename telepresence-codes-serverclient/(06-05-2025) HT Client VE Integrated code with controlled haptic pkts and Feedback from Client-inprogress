        labelMessage->setText(message);
    }
}

void networkCommunication(void) {
    WSADATA wsaData;
    sockaddr_in serverAddr;
    
    // Initialize Winsock
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        logMessage("WSAStartup failed: " + std::to_string(WSAGetLastError()));
        return;
    }

    // Create the UDP socket
    clientSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (clientSocket == INVALID_SOCKET) {
        logMessage("Socket creation failed: " + std::to_string(WSAGetLastError()));
        WSACleanup();
        return;
    }

    // Set up the server address
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(DST_PORT);
    if (inet_pton(AF_INET, DST_IP, &serverAddr.sin_addr) <= 0) {
        logMessage("Invalid destination IP");
        closesocket(clientSocket);
        WSACleanup();
        return;
    }

    // Set socket to non-blocking mode
    u_long iMode = 1;
    ioctlsocket(clientSocket, FIONBIO, &iMode);

    logMessage("Network thread initialized. Sending to " + std::string(DST_IP) + ":" + std::to_string(DST_PORT));
    networkConnected = true;

    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);

    // High-precision timer for timing
    LARGE_INTEGER frequency;
    LARGE_INTEGER startTime, endTime;
    double elapsedMs;
    QueryPerformanceFrequency(&frequency);

    // Start receiver thread
    receiverThread = new std::thread(networkReceiver);

    // Sending loop based on haptic rate
    while (networkRunning) {
        QueryPerformanceCounter(&startTime);

        if (isReplaying) {
            // In replay mode, use recorded data
            double currentTime = ((double)startTime.QuadPart / frequency.QuadPart) - replayStartTime;
            
            // Find the appropriate packet for the current time
            if (replayIndex < recordedData.size()) {
                if (currentTime >= recordedData[replayIndex].first) {
                    std::lock_guard<std::mutex> lock(dataMutex);
                    currentPacket = recordedData[replayIndex].second;
                    replayIndex++;
                    
                    // Send packet over UDP
                    sendto(clientSocket, reinterpret_cast<char*>(&currentPacket), sizeof(Packet), 0,
                        (sockaddr*)&serverAddr, sizeof(serverAddr));
                    
                    packetsSent++;
                    freqCounterNetwork.signal(1);
                    
                    // Add to history
                    sentPacketsHistory.push_back(currentPacket);
                    if (sentPacketsHistory.size() > MAX_HISTORY_SIZE) {
                        sentPacketsHistory.pop_front();
                    }
                }
            } else {
                // End of replay
                stopReplay();
            }
        } else {
            // Get haptic device position directly
            cVector3d position;
            if (hapticDevice && hapticDevice->getPosition(position)) {
                // Apply position scaling
                position *= positionScaling;
                
                // Fill packet data
                std::lock_guard<std::mutex> lock(dataMutex);
                currentPacket.packetNumber = ++packetNumber;
                currentPacket.x = static_cast<float>(position.x());
                currentPacket.y = static_cast<float>(position.y());
                currentPacket.z = static_cast<float>(position.z());
                currentPacket.delay = 1000.0f / HAPTIC_RATE_HZ;

                getTimestamp(currentPacket.timestamp);
                strcpy_s(currentPacket.srcIP, SRC_IP);
                strcpy_s(currentPacket.dstIP, DST_IP);
                currentPacket.srcPort = SRC_PORT;
                currentPacket.dstPort = DST_PORT;

                // Record if enabled
                if (isRecording) {
                    double timestamp = (double)startTime.QuadPart / frequency.QuadPart;
                    recordedData.push_back(std::make_pair(timestamp - replayStartTime, currentPacket));
                    recordFile.write(reinterpret_cast<char*>(&currentPacket), sizeof(Packet));
                }

                // Send packet over UDP
                if (networkConnected) {
                    sendto(clientSocket, reinterpret_cast<char*>(&currentPacket), sizeof(Packet), 0,
                        (sockaddr*)&serverAddr, sizeof(serverAddr));
                    
                    packetsSent++;
                    freqCounterNetwork.signal(1);
                    
                    // Add to history
                    sentPacketsHistory.push_back(currentPacket);
                    if (sentPacketsHistory.size() > MAX_HISTORY_SIZE) {
                        sentPacketsHistory.pop_front();
                    }
                }
            }
        }

        // Calculate time taken and sleep for the remaining interval
        QueryPerformanceCounter(&endTime);
        elapsedMs = ((endTime.QuadPart - startTime.QuadPart) * 1000.0) / frequency.QuadPart;
        
        int sleepTime = (1000 / HAPTIC_RATE_HZ) - static_cast<int>(elapsedMs);
        if (sleepTime > 0) {
            Sleep(sleepTime);
        }
    }

    // Cleanup socket
    networkConnected = false;
    closesocket(clientSocket);
    WSACleanup();
    
    // Wait for receiver thread to terminate
    if (receiverThread && receiverThread->joinable()) {
        receiverThread->join();
        delete receiverThread;
        receiverThread = nullptr;
    }
    
    logMessage("Network communication stopped");
}

void networkReceiver(void) {
    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    
    char recvBuffer[BUFFER_SIZE];
    sockaddr_in senderAddr;
    int senderAddrLen = sizeof(senderAddr);
    int bytesReceived;
    
    // High-precision timer for timing
    LARGE_INTEGER frequency;
    LARGE_INTEGER startTime, currentTime;
    QueryPerformanceFrequency(&frequency);
    QueryPerformanceCounter(&startTime);
    
    logMessage("Network receiver started");
    
    while (networkRunning && networkConnected) {
        // Receive data from server
        bytesReceived = recvfrom(clientSocket, recvBuffer, BUFFER_SIZE, 0, 
                               (sockaddr*)&senderAddr, &senderAddrLen);
                               
        if (bytesReceived > 0) {
            // Process received packet
            if (bytesReceived == sizeof(FeedbackPacket)) {
                std::lock_guard<std::mutex> lock(dataMutex);
                
                // Copy packet data
                FeedbackPacket* feedback = reinterpret_cast<FeedbackPacket*>(recvBuffer);
                memcpy(&currentFeedback, feedback, sizeof(FeedbackPacket));
                
                // Update statistics
                packetsReceived++;
                
                // Calculate latency
                QueryPerformanceCounter(&currentTime);
                double currentTimeSec = (double)(currentTime.QuadPart - startTime.QuadPart) / frequency.QuadPart;
                
                // Add to history
                receivedPacketsHistory.push_back(currentFeedback);
                latencyHistory.push_back(currentFeedback.latency);
                positionErrorHistory.push_back(currentFeedback.positionError);
                
                // Limit history size
                if (receivedPacketsHistory.size() > MAX_HISTORY_SIZE) {
                    receivedPacketsHistory.pop_front();
                }
                if (latencyHistory.size() > MAX_HISTORY_SIZE) {
                    latencyHistory.pop_front();
                }
                if (positionErrorHistory.size() > MAX_HISTORY_SIZE) {
                    positionErrorHistory.pop_front();
                }
                
                // Calculate average latency and position error
                double totalLatency = 0.0;
                double totalError = 0.0;
                
                for (const auto& latency : latencyHistory) {
                    totalLatency += latency;
                }
                
                for (const auto& error : positionErrorHistory) {
                    totalError += error;
                }
                
                if (!latencyHistory.empty()) {
                    averageLatency = totalLatency / latencyHistory.size();
                }
                
                if (!positionErrorHistory.empty()) {
                    averagePositionError = totalError / positionErrorHistory.size();
                }
            }
        }
        
        // Short sleep to prevent CPU hogging
        Sleep(1);
    }
    
    logMessage("Network receiver stopped");
}

