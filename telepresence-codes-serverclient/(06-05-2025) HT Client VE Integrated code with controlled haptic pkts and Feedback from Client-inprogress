//------------------------------------------------------------------------------
// PACKET STRUCTURES
//------------------------------------------------------------------------------
// Client packet structure
struct ClientPacket {
    int packetNumber;
    float x, y, z;                // Position data
    float delay;                  // Delay information in ms
    char timestamp[64];           // Timestamp for synchronization
    char srcIP[16];               // Source IP address
    char dstIP[16];               // Destination IP address
    int srcPort;                  // Source port
    int dstPort;                  // Destination port
};

// Feedback packet structure
struct FeedbackPacket {
    int packetNumber;             // Matching packet number from client
    float fx, fy, fz;             // Force feedback
    float px, py, pz;             // Actual position on server
    float positionError;          // Error between commanded and actual position
    float latency;                // Estimated latency in ms
    char timestamp[64];           // Timestamp for synchronization
};

//------------------------------------------------------------------------------
// NETWORK MANAGER CLASS
//------------------------------------------------------------------------------
class NetworkManager {
public:
    // Constructor
    NetworkManager()
        : m_client(nullptr),
        m_localPort(SRC_PORT),
        m_serverPort(DST_PORT),
        m_sendSocket(INVALID_SOCKET),
        m_receiveSocket(INVALID_SOCKET),
        m_threadRunning(false),
        m_connected(false),
        m_packetsSent(0),
        m_packetsReceived(0)
    {
        // Initialize local IP
        strcpy_s(m_localIP, "127.0.0.1");

        // Initialize server IP
        strcpy_s(m_serverIP, DEFAULT_SERVER_IP);
    }

    // Destructor
    ~NetworkManager() {
        disconnect();
    }

    // Initialize the network manager
    bool initialize() {
        // Initialize Windows socket API
        WSADATA wsaData;
        if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
            std::cerr << "Failed to initialize Winsock: " << WSAGetLastError() << std::endl;
            return false;
        }

        // Get local IP address
        if (!getLocalIPAddress(m_localIP)) {
            std::cerr << "Warning: Failed to get local IP, using default" << std::endl;
            strcpy_s(m_localIP, "127.0.0.1");
        }

        std::cout << "Local IP: " << m_localIP << std::endl;

        // Initialize sockets
        return initializeSockets();
    }

    // Connect to server
    bool connect(const std::string& serverIP, int serverPort) {
        if (m_connected) {
            return true;  // Already connected
        }

        // Copy server IP and port
        strcpy_s(m_serverIP, serverIP.c_str());
        m_serverPort = serverPort;

        std::cout << "Connecting to server: " << m_serverIP << ":" << m_serverPort << std::endl;

        // Set up server address
        m_serverAddr.sin_family = AF_INET;
        m_serverAddr.sin_port = htons(m_serverPort);
        if (inet_pton(AF_INET, m_serverIP, &m_serverAddr.sin_addr) != 1) {
            std::cerr << "Invalid address format: " << m_serverIP << std::endl;
            return false;
        }

        // Start network threads
        m_threadRunning = true;
        m_networkThread = std::thread(&NetworkManager::networkThreadFunc, this);

        m_connected = true;
        return true;
    }

    // Disconnect from server
    void disconnect() {
        if (!m_connected) {
            return;  // Not connected
        }

        // Stop threads
        m_threadRunning = false;

        if (m_networkThread.joinable()) {
            m_networkThread.join();
        }

        // Close sockets
        closeSockets();

        m_connected = false;
    }

    // Send packet to server
    bool sendPacket(const ClientPacket& packet) {
        if (!m_connected || m_sendSocket == INVALID_SOCKET) {
            return false;
        }

        std::lock_guard<std::mutex> lock(m_socketMutex);

        // Send packet
        int bytesSent = sendto(
            m_sendSocket,
            reinterpret_cast<const char*>(&packet),
            sizeof(packet),
            0,
            reinterpret_cast<const sockaddr*>(&m_serverAddr),
            sizeof(m_serverAddr)
        );

        if (bytesSent == SOCKET_ERROR) {
            std::cerr << "Error sending packet: " << WSAGetLastError() << std::endl;
            return false;
        }

        m_packetsSent++;
        return true;
    }

    // Set client reference
    void setClient(HapticClient* client) {
        m_client = client;
    }

    // Get connection status
    bool isConnected() const {
        return m_connected;
    }

    // Get local IP address
    const char* getLocalIP() const {
        return m_localIP;
    }

    // Get server IP address
    const char* getServerIP() const {
        return m_serverIP;
    }

    // Get packet statistics
    void getPacketStats(int& sent, int& received) const {
        sent = m_packetsSent;
        received = m_packetsReceived;
    }

    // Set server IP directly (for manual configuration)
    void setServerIP(const std::string& serverIP) {
        strcpy_s(m_serverIP, serverIP.c_str());

        // Update server address
        m_serverAddr.sin_family = AF_INET;
        m_serverAddr.sin_port = htons(m_serverPort);
        inet_pton(AF_INET, m_serverIP, &m_serverAddr.sin_addr);
    }

private:
    // Initialize sockets
    bool initializeSockets() {
        // Create UDP send socket
        m_sendSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (m_sendSocket == INVALID_SOCKET) {
            std::cerr << "Error creating send socket: " << WSAGetLastError() << std::endl;
            return false;
        }

        // Create UDP receive socket
        m_receiveSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (m_receiveSocket == INVALID_SOCKET) {
            std::cerr << "Error creating receive socket: " << WSAGetLastError() << std::endl;
            closesocket(m_sendSocket);
            m_sendSocket = INVALID_SOCKET;
            return false;
        }

        // Bind receive socket to local port
        sockaddr_in localAddr;
        localAddr.sin_family = AF_INET;
        localAddr.sin_addr.s_addr = INADDR_ANY;
        localAddr.sin_port = htons(m_localPort);

        if (bind(m_receiveSocket, reinterpret_cast<sockaddr*>(&localAddr), sizeof(localAddr)) == SOCKET_ERROR) {
            std::cerr << "Error binding receive socket: " << WSAGetLastError() << std::endl;
            closeSockets();
            return false;
        }

        // Set receive socket to non-blocking mode
        u_long mode = 1;
        if (ioctlsocket(m_receiveSocket, FIONBIO, &mode) == SOCKET_ERROR) {
            std::cerr << "Error setting non-blocking mode: " << WSAGetLastError() << std::endl;
            closeSockets();
            return false;
        }

        return true;
    }

    // Close sockets
    void closeSockets() {
        if (m_sendSocket != INVALID_SOCKET) {
            closesocket(m_sendSocket);
            m_sendSocket = INVALID_SOCKET;
        }

        if (m_receiveSocket != INVALID_SOCKET) {
            closesocket(m_receiveSocket);
            m_receiveSocket = INVALID_SOCKET;
        }
    }

    // Get local IP address using Windows API
    bool getLocalIPAddress(char* ipBuffer) {
        // This implementation uses GetAdaptersAddresses to get the active IP
        ULONG outBufLen = 0;
        PIP_ADAPTER_ADDRESSES pAddresses = nullptr;
        DWORD dwRetVal = 0;

        // First call to get the required buffer size
        dwRetVal = GetAdaptersAddresses(AF_INET, GAA_FLAG_INCLUDE_PREFIX, nullptr, nullptr, &outBufLen);

        if (dwRetVal == ERROR_BUFFER_OVERFLOW) {
            pAddresses = (IP_ADAPTER_ADDRESSES*)malloc(outBufLen);
            if (pAddresses == nullptr) {
                return false;
            }

            // Second call to get the actual data
            dwRetVal = GetAdaptersAddresses(AF_INET, GAA_FLAG_INCLUDE_PREFIX, nullptr, pAddresses, &outBufLen);

            if (dwRetVal == NO_ERROR) {
                // Iterate through interfaces
                for (PIP_ADAPTER_ADDRESSES pCurrAddresses = pAddresses; pCurrAddresses != nullptr; pCurrAddresses = pCurrAddresses->Next) {
                    // Skip loopback adapters
                    if (pCurrAddresses->IfType == IF_TYPE_SOFTWARE_LOOPBACK) {
                        continue;
                    }

                    // Skip adapters that are not operational
                    if (pCurrAddresses->OperStatus != IfOperStatusUp) {
                        continue;
                    }

                    // Get linked IP address
                    for (PIP_ADAPTER_UNICAST_ADDRESS pUnicast = pCurrAddresses->FirstUnicastAddress; pUnicast != nullptr; pUnicast = pUnicast->Next) {
                        if (pUnicast->Address.lpSockaddr->sa_family == AF_INET) {
                            sockaddr_in* sa_in = (sockaddr_in*)pUnicast->Address.lpSockaddr;
                            // Convert to string
                            inet_ntop(AF_INET, &(sa_in->sin_addr), ipBuffer, 16);
                            free(pAddresses);
                            return true;
                        }
                    }
                }
            }

            free(pAddresses);
        }

        // Fallback method using gethostname if the above method fails
        char hostname[256];
        struct addrinfo hints {}, * info = nullptr, * p = nullptr;
        struct sockaddr_in* sockaddr_ipv4;

        if (gethostname(hostname, sizeof(hostname)) == 0) {
            hints.ai_family = AF_INET;
            hints.ai_socktype = SOCK_DGRAM;
            hints.ai_flags = AI_PASSIVE;

            if (getaddrinfo(hostname, nullptr, &hints, &info) == 0) {
                for (p = info; p != nullptr; p = p->ai_next) {
                    sockaddr_ipv4 = (struct sockaddr_in*)p->ai_addr;
                    inet_ntop(AF_INET, &sockaddr_ipv4->sin_addr, ipBuffer, 16);
                    // Skip localhost address
                    if (strcmp(ipBuffer, "127.0.0.1") != 0) {
                        freeaddrinfo(info);
                        return true;
                    }
                }
                freeaddrinfo(info);
            }
        }

        return false;
    }

    // Network thread function
    void networkThreadFunc() {
        char recvBuffer[BUFFER_SIZE];
        sockaddr_in senderAddr;
        int senderAddrLen = sizeof(senderAddr);

        while (m_threadRunning) {
            // Receive packet
            int bytesReceived = recvfrom(
                m_receiveSocket,
                recvBuffer,
                BUFFER_SIZE,
                0,
                reinterpret_cast<sockaddr*>(&senderAddr),
                &senderAddrLen
            );

            if (bytesReceived > 0) {
                m_packetsReceived++;

                // Process feedback packet
                if (bytesReceived == sizeof(FeedbackPacket) && m_client) {
                    processFeedbackPacket(reinterpret_cast<FeedbackPacket*>(recvBuffer));
                }
            }
            else if (bytesReceived == SOCKET_ERROR) {
                int error = WSAGetLastError();
                if (error != WSAEWOULDBLOCK) {
                    std::cerr << "Error receiving packet: " << error << std::endl;
                }
            }

            // Small sleep to prevent CPU hogging
            std::this_thread::sleep_for(std::chrono::milliseconds(1));
        }
    }

    // Process feedback packet
    void processFeedbackPacket(FeedbackPacket* packet);

    // Client reference
    HapticClient* m_client;

    // Network configuration
    char m_localIP[16];
    char m_serverIP[16];
    int m_localPort;
    int m_serverPort;

    // Socket information
    SOCKET m_sendSocket;
    SOCKET m_receiveSocket;
    sockaddr_in m_serverAddr;

    // Thread management
    std::thread m_networkThread;
    std::atomic<bool> m_threadRunning;

    // Connection status
    std::atomic<bool> m_connected;

    // Packet statistics
    std::atomic<int> m_packetsSent;
    std::atomic<int> m_packetsReceived;

    // Mutex for thread safety
    std::mutex m_socketMutex;
};

//------------------------------------------------------------------------------
// FEEDBACK PROCESSOR CLASS
//------------------------------------------------------------------------------
class FeedbackProcessor {
public:
    // Constructor
    FeedbackProcessor()
        : m_client(nullptr),
        m_feedbackType(FEEDBACK_POSITION),
        m_feedbackEnabled(true),
        m_stiffness(100.0),
        m_damping(20.0),
        m_positionError(0.0f),
        m_averageLatency(0.0f),
        m_packetsProcessed(0)
    {
        // Initialize arrays
        for (int i = 0; i < 3; i++) {
            m_currentForce[i] = 0.0f;
            m_targetPosition[i] = 0.0f;
        }

        // Initialize min/max tracking
        resetMinMaxValues();
    }

    // Destructor
    ~FeedbackProcessor() {
        // Clean up
    }

    // Initialize the processor
    bool initialize() {
        return true;
    }

    // Set client reference
    void setClient(HapticClient* client) {
        m_client = client;
    }

    // Process feedback packet
    void processFeedback(const FeedbackPacket& packet) {
        std::lock_guard<std::mutex> lock(m_dataMutex);

        // Store force values
        m_currentForce[0] = packet.fx;
        m_currentForce[1] = packet.fy;
        m_currentForce[2] = packet.fz;

        // Store target position
        m_targetPosition[0] = packet.px;
        m_targetPosition[1] = packet.py;
        m_targetPosition[2] = packet.pz;

        // Store error and latency
        m_positionError = packet.positionError;

        // Update statistics
        updateStatistics(packet);

        // Update min/max values for position
        updateMinMaxValues(m_targetPosition[0], m_targetPosition[1], m_targetPosition[2],
            m_currentForce[0], m_currentForce[1], m_currentForce[2]);

        // Apply feedback based on type
        if (m_feedbackEnabled) {
            calculateForce();
        }

        m_packetsProcessed++;
    }

    // Set feedback type
    void setFeedbackType(FeedbackType type) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_feedbackType = type;
    }

    // Enable/disable feedback
    void setFeedbackEnabled(bool enabled) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_feedbackEnabled = enabled;
    }

    // Set stiffness parameter
    void setStiffness(double stiffness) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_stiffness = stiffness;
    }

    // Set damping parameter
    void setDamping(double damping) {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_damping = damping;
    }

    // Get current force feedback
    void getCurrentForce(float& fx, float& fy, float& fz) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        fx = m_currentForce[0];
        fy = m_currentForce[1];
        fz = m_currentForce[2];
    }

    // Get current target position
    void getTargetPosition(float& x, float& y, float& z) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        x = m_targetPosition[0];
        y = m_targetPosition[1];
        z = m_targetPosition[2];
    }

    // Get Min/Max position values
    void getMinMaxPosition(float& minX, float& maxX, float& minY, float& maxY, float& minZ, float& maxZ) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        minX = m_minPositionX;
        maxX = m_maxPositionX;
        minY = m_minPositionY;
        maxY = m_maxPositionY;
        minZ = m_minPositionZ;
        maxZ = m_maxPositionZ;
    }

    // Get Min/Max force values
    void getMinMaxForce(float& minFx, float& maxFx, float& minFy, float& maxFy, float& minFz, float& maxFz) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        minFx = m_minForceX;
        maxFx = m_maxForceX;
        minFy = m_minForceY;
        maxFy = m_maxForceY;
        minFz = m_minForceZ;
        maxFz = m_maxForceZ;
    }

    // Reset min/max tracking
    void resetMinMaxValues() {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        m_minPositionX = m_minPositionY = m_minPositionZ = std::numeric_limits<float>::max();
        m_maxPositionX = m_maxPositionY = m_maxPositionZ = std::numeric_limits<float>::lowest();
        m_minForceX = m_minForceY = m_minForceZ = std::numeric_limits<float>::max();
        m_maxForceX = m_maxForceY = m_maxForceZ = std::numeric_limits<float>::lowest();
    }

    // Get feedback type
    FeedbackType getFeedbackType() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_feedbackType;
    }

    // Get feedback enabled state
    bool isFeedbackEnabled() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_feedbackEnabled;
    }

    // Get stiffness
    double getStiffness() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_stiffness;
    }

    // Get damping
    double getDamping() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_damping;
    }

    // Get position error
    float getPositionError() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_positionError;
    }

    // Get average latency
    float getAverageLatency() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        return m_averageLatency;
    }

    // Get position history for graphs
    std::vector<float> getPositionHistory(int axis) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        std::vector<float> history;
        history.reserve(m_packetHistory.size());

        for (const auto& packet : m_packetHistory) {
            if (axis == 0) history.push_back(packet.px);
            else if (axis == 1) history.push_back(packet.py);
            else if (axis == 2) history.push_back(packet.pz);
        }
        return history;
    }

    // Get force history for graphs
    std::vector<float> getForceHistory(int axis) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        std::vector<float> history;
        history.reserve(m_packetHistory.size());

        for (const auto& packet : m_packetHistory) {
            if (axis == 0) history.push_back(packet.fx);
            else if (axis == 1) history.push_back(packet.fy);
            else if (axis == 2) history.push_back(packet.fz);
        }
        return history;
    }

    // Get latency history for graphs
    std::vector<float> getLatencyHistory() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        std::vector<float> history;
        history.reserve(m_packetHistory.size());

        for (const auto& packet : m_packetHistory) {
            history.push_back(packet.latency);
        }
        return history;
    }

    // Get error history for graphs
    std::vector<float> getErrorHistory() const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        std::vector<float> history;
        history.reserve(m_packetHistory.size());

        for (const auto& packet : m_packetHistory) {
            history.push_back(packet.positionError);
        }
        return history;
    }

    // Save data to CSV
    bool saveDataToCSV(const std::string& filename) const {
        std::lock_guard<std::mutex> lock(m_dataMutex);
        try {
            std::ofstream file(filename);
            if (!file.is_open()) return false;

            // Write header
            file << "PacketNumber,PosX,PosY,PosZ,ForceX,ForceY,ForceZ,PositionError,Latency,Timestamp\n";

            // Write data
            for (const auto& packet : m_packetHistory) {
                file << packet.packetNumber << ","
                    << packet.px << "," << packet.py << "," << packet.pz << ","
                    << packet.fx << "," << packet.fy << "," << packet.fz << ","
                    << packet.positionError << "," << packet.latency << ","
                    << packet.timestamp << "\n";
            }

            file.close();
            return true;
        }
        catch (std::exception& e) {
            std::cerr << "Error saving data: " << e.what() << std::endl;
            return false;
        }
    }

private:
    // Calculate force feedback based on position error
    void calculateForce() {
        // Force calculation is implemented in the haptic loop
        // This method just handles special processing if needed
    }

    // Update statistics
    void updateStatistics(const FeedbackPacket& packet) {
        // Add packet to history
        m_packetHistory.push_back(packet);
        if (m_packetHistory.size() > MAX_HISTORY_SIZE) {
            m_packetHistory.pop_front();
        }

        // Calculate average latency
        float totalLatency = 0.0f;
        for (const auto& p : m_packetHistory) {
            totalLatency += p.latency;
        }
        m_averageLatency = totalLatency / m_packetHistory.size();
    }

    // Update min/max values
    void updateMinMaxValues(float posX, float posY, float posZ, float forceX, float forceY, float forceZ) {
        m_minPositionX = std::min(m_minPositionX, posX);
        m_maxPositionX = std::max(m_maxPositionX, posX);
        m_minPositionY = std::min(m_minPositionY, posY);
        m_maxPositionY = std::max(m_maxPositionY, posY);
        m_minPositionZ = std::min(m_minPositionZ, posZ);
        m_maxPositionZ = std::max(m_maxPositionZ, posZ);

        m_minForceX = std::min(m_minForceX, forceX);
        m_maxForceX = std::max(m_maxForceX, forceX);
        m_minForceY = std::min(m_minForceY, forceY);
        m_maxForceY = std::max(m_maxForceY, forceY);
        m_minForceZ = std::min(m_minForceZ, forceZ);
        m_maxForceZ = std::max(m_maxForceZ, forceZ);
    }

    // Client reference
    HapticClient* m_client;

    // Feedback parameters
    FeedbackType m_feedbackType;
    bool m_feedbackEnabled;
    double m_stiffness;
    double m_damping;

    // Current feedback values
    float m_currentForce[3];
    float m_targetPosition[3];
    float m_positionError;
    float m_averageLatency;

    // Min/Max tracking for position
    float m_minPositionX, m_maxPositionX;
    float m_minPositionY, m_maxPositionY;
    float m_minPositionZ, m_maxPositionZ;

    // Min/Max tracking for force
    float m_minForceX, m_maxForceX;
    float m_minForceY, m_maxForceY;
    float m_minForceZ, m_maxForceZ;

    // Packet history for statistics
    std::deque<FeedbackPacket> m_packetHistory;
    std::atomic<int> m_packetsProcessed;

    // Thread safety
    mutable std::mutex m_dataMutex;
};

//------------------------------------------------------------------------------
// CONSOLE INTERFACE CLASS
//------------------------------------------------------------------------------
class ConsoleInterface {
public:
    // Constructor
    ConsoleInterface()
        : m_client(nullptr),
        m_visible(true),
        m_mode(GUI_MINIMAL)
    {
    }

    // Destructor
    ~ConsoleInterface() {
        // Clean up
    }

    // Initialize
    bool initialize() {
        return true;
    }

    // Set client reference
    void setClient(HapticClient* client) {
        m_client = client;
    }

    // Update
    void update() {
        // Update state
    }

    // Render console output
    void render() {
        if (!m_visible) return;

        system("cls");  // Clear console

        std::cout << "====== HAPTIC TELEOPERATION CLIENT ======\n";
