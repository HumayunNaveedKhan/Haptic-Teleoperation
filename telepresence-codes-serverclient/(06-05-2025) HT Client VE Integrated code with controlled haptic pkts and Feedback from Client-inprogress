void mouseButtonCallback(GLFWwindow* a_window, int a_button, int a_action, int a_mods) {
    // handle mouse button events
    if (a_button == GLFW_MOUSE_BUTTON_LEFT && a_action == GLFW_PRESS) {
        // get cursor position
        double x, y;
        glfwGetCursorPos(window, &x, &y);
        
        // check if click is on a GUI element
        cCollisionResult result;
        bool hit = camera->selectFrontLayer(x, y, result);
        
        if (hit) {
            // check if clicked on a button or slider
            cGenericObject* object = result.m_object;
            if (object) {
                cButton* button = dynamic_cast<cButton*>(object);
                if (button) {
                    button->setState(true);
                }
                
                cSlider* slider = dynamic_cast<cSlider*>(object);
                if (slider) {
                    // Handle slider interaction
                    double value = slider->getValueFromPosition(result.m_localPos);
                    slider->setValue(value);
                }
                
                cCheckBox* checkbox = dynamic_cast<cCheckBox*>(object);
                if (checkbox) {
                    checkbox->setCheck(!checkbox->getCheck());
                }
            }
        }
    }
}

