int main(int argc, char* argv[]) {
    std::cout << "Haptic Teleoperation Client - Windows Implementation" << std::endl;
    std::cout << "Copyright (c) 2023" << std::endl << std::endl;

    // Create client
    HapticTeleoperationClient client;

    // Initialize client
    if (!client.initialize()) {
        std::cerr << "Failed to initialize client" << std::endl;
        return 1;
    }

    // Run client (blocking call)
    client.run();

    return 0;
}
