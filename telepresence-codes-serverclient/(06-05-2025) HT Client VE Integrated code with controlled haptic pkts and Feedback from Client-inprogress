        system("cls");  // Clear console

        // Display title and mode
        std::cout << "===== HAPTIC TELEOPERATION CLIENT =====\n";
        std::cout << "Mode: " << (m_mode == GUI_HIDDEN ? "Hidden" : (m_mode == GUI_MINIMAL ? "Minimal" : "Full")) << "\n\n";

        // Display position and force
        std::cout << "Position: (" << std::fixed << std::setprecision(3)
            << m_positionX << ", " << m_positionY << ", " << m_positionZ << ")\n";

        std::cout << "Force: (" << std::fixed << std::setprecision(3)
            << m_forceX << ", " << m_forceY << ", " << m_forceZ << ")\n\n";

        // Display network statistics
        std::cout << "Network Statistics:\n";
        std::cout << "  Packets Sent: " << m_packetsSent << "\n";
        std::cout << "  Packets Received: " << m_packetsReceived << "\n";
        std::cout << "  Latency: " << std::fixed << std::setprecision(2) << m_latency << " ms\n\n";

        // Display haptic parameters
        std::cout << "Haptic Parameters:\n";
        std::cout << "  Stiffness: " << std::fixed << std::setprecision(1) << m_stiffness << "\n";
        std::cout << "  Damping: " << std::fixed << std::setprecision(1) << m_damping << "\n";
        std::cout << "  Feedback Type: " << (m_feedbackType == FEEDBACK_POSITION ? "Position" :
            (m_feedbackType == FEEDBACK_FORCE ? "Force" : "Stiffness/Damping")) << "\n";
        std::cout << "  Feedback Enabled: " << (m_feedbackEnabled ? "Yes" : "No") << "\n\n";

        // Display scaling
        std::cout << "Scaling:\n";
        std::cout << "  Position Scale: " << std::fixed << std::setprecision(2) << m_positionScale << "\n";
        std::cout << "  Force Scale: " << std::fixed << std::setprecision(2) << m_forceScale << "\n\n";

        // Display message
        if (!m_message.empty()) {
            std::cout << "Message: " << m_message << "\n\n";
        }

        // Display commands
        std::cout << "Commands:\n";
        std::cout << "  [G] Toggle GUI Mode        [F] Toggle Feedback\n";
        std::cout << "  [T] Change Feedback Type   [+/-] Adjust Stiffness\n";
        std::cout << "  [D/C] Adjust Damping       [R] Reset Position\n";
        std::cout << "  [Q] Quit\n";
    }

    // Process user input
    void processInput() {
        // Process keyboard input
        if (_kbhit()) {
            char key = _getch();

            switch (key) {
            case 'g':
            case 'G':
                // Toggle GUI mode
                toggleGuiMode();
                break;

            case 'f':
            case 'F':
                // Toggle feedback
                toggleFeedback();
                break;

            case 't':
            case 'T':
                // Change feedback type
                cycleFeedbackType();
                break;

            case '+':
                // Increase stiffness
                adjustStiffness(10.0);
                break;

            case '-':
                // Decrease stiffness
                adjustStiffness(-10.0);
                break;

            case 'd':
            case 'D':
                // Increase damping
                adjustDamping(5.0);
                break;

            case 'c':
            case 'C':
                // Decrease damping
                adjustDamping(-5.0);
                break;

            case 'r':
            case 'R':
                // Reset position
                resetPosition();
                break;

            case 'q':
            case 'Q':
                // Quit application
                onButtonPressed(0); // Quit button ID
                break;
            }
        }
    }

    // Show or hide UI
    void setVisible(bool visible) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_visible = visible;
    }

    // Set UI mode (minimal/full)
    void setMode(int mode) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_mode = mode;
    }

    // Set message to display
    void setMessage(const std::string& message) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_message = message;
    }

    // Handle slider events
    void onSliderChanged(int id, float value) {
        std::lock_guard<std::mutex> lock(m_uiMutex);

        switch (id) {
        case 0: // Position Scale
            m_positionScale = value;
            break;

        case 1: // Force Scale
            m_forceScale = value;
            break;
        }
    }

    // Handle button events
    void onButtonPressed(int id);

    // Handle checkbox events
    void onCheckboxChanged(int id, bool checked) {
        std::lock_guard<std::mutex> lock(m_uiMutex);

        switch (id) {
        case 0: // Feedback Enabled
            m_feedbackEnabled = checked;
            break;
        }
    }

    // Update position display
    void updatePositionDisplay(float x, float y, float z) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_positionX = x;
        m_positionY = y;
        m_positionZ = z;
    }

    // Update force display
    void updateForceDisplay(float fx, float fy, float fz) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_forceX = fx;
        m_forceY = fy;
        m_forceZ = fz;
    }

    // Update network statistics
    void updateNetworkStats(int sent, int received, float latency) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_packetsSent = sent;
        m_packetsReceived = received;
        m_latency = latency;
    }

    // Update haptic parameters
    void updateHapticParams(double stiffness, double damping, FeedbackType type) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_stiffness = stiffness;
        m_damping = damping;
        m_feedbackType = type;
    }

private:
    // Initialize UI components
    void initializeComponents() {
        // Simple console UI initialization
    }

    // Create visualization graphs
    void createGraphs() {
        // Console doesn't support graphs
    }

    // Update graphs with new data
    void updateGraphs() {
        // Console doesn't support graphs
    }

    // Toggle GUI mode
    void toggleGuiMode() {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_mode = (m_mode + 1) % 3; // Cycle through modes
    }

    // Toggle feedback
    void toggleFeedback() {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_feedbackEnabled = !m_feedbackEnabled;
    }

    // Cycle feedback type
    void cycleFeedbackType() {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_feedbackType = static_cast<FeedbackType>((m_feedbackType + 1) % 3);
    }

    // Adjust stiffness
    void adjustStiffness(double delta) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_stiffness += delta;
        m_stiffness = std::max(0.0, std::min(200.0, m_stiffness)); // Clamp value
    }

    // Adjust damping
    void adjustDamping(double delta) {
        std::lock_guard<std::mutex> lock(m_uiMutex);
        m_damping += delta;
        m_damping = std::max(0.0, std::min(50.0, m_damping)); // Clamp value
    }

    // Reset position
    void resetPosition() {
        // This needs to be implemented in the client
    }

    // Client reference
    HapticTeleoperationClient* m_client;

    // UI state
    bool m_visible;
    int m_mode; // 0 = hidden, 1 = minimal, 2 = full

    // UI components
    std::string m_message;

    // Position data for display
    float m_positionX, m_positionY, m_positionZ;

    // Force data for display
    float m_forceX, m_forceY, m_forceZ;

    // Network statistics
    int m_packetsSent;
    int m_packetsReceived;
    float m_latency;

    // Haptic parameters
    double m_stiffness;
    double m_damping;
    FeedbackType m_feedbackType;
    bool m_feedbackEnabled;

    // Position scale
    float m_positionScale;

    // Force scale
    float m_forceScale;

    // Thread safety
    mutable std::mutex m_uiMutex;
};

//------------------------------------------------------------------------------
// HAPTIC TELEOPERATION CLIENT CLASS
//------------------------------------------------------------------------------
class HapticTeleoperationClient {
public:
    //--------------------------------------------------------------------------
    // CONSTRUCTOR & DESTRUCTOR
    //--------------------------------------------------------------------------
    HapticTeleoperationClient()
        : m_simulationRunning(false),
        m_simulationFinished(true),
        m_position{ 0.0f, 0.0f, 0.0f },
        m_force{ 0.0f, 0.0f, 0.0f },
        m_velocityDamping(0.95f),
        m_deviceMass(1.0f)
    {
        // Set up network manager, feedback processor, and UI
        m_networkManager.setClient(this);
        m_feedbackProcessor.setClient(this);
        m_userInterface.setClient(this);

        // Initialize packet counter
        m_packetCounter = 0;

        // Get timestamp for file naming
        char timestamp[64];
        getTimestamp(timestamp);
        std::string timeStr(timestamp);
        std::replace(timeStr.begin(), timeStr.end(), ':', '-');

        // Initialize recording file name
        m_recordingFileName = "haptic_recording_" + timeStr + ".dat";

        // Initialize velocity
        m_velocity[0] = m_velocity[1] = m_velocity[2] = 0.0f;
    }

    // Destructor
    ~HapticTeleoperationClient() {
        close();
    }

    //--------------------------------------------------------------------------
    // INITIALIZATION & RUN
    //--------------------------------------------------------------------------
    // Initialize the client
    bool initialize() {
        // Initialize network manager
        if (!m_networkManager.initialize()) {
            std::cerr << "Failed to initialize network manager" << std::endl;
            return false;
        }

        // Initialize feedback processor
        if (!m_feedbackProcessor.initialize()) {
            std::cerr << "Failed to initialize feedback processor" << std::endl;
            return false;
        }

        // Initialize user interface
        if (!m_userInterface.initialize()) {
            std::cerr << "Failed to initialize user interface" << std::endl;
            return false;
        }

        // Connect to server
        if (!m_networkManager.connect("127.0.0.1", DST_PORT)) {
            std::cerr << "Failed to connect to server" << std::endl;
            // Don't return false here, we can connect later
        }

        return true;
    }

    // Run the client application
    void run() {
        std::cout << "Starting haptic teleoperation client..." << std::endl;

        // Start haptic simulation
        startHapticSimulation();

        // Main loop
        bool running = true;
        auto lastUpdate = std::chrono::high_resolution_clock::now();

        while (running) {
            // Calculate elapsed time
            auto currentTime = std::chrono::high_resolution_clock::now();
            auto elapsedTime = std::chrono::duration<float>(currentTime - lastUpdate).count();
            lastUpdate = currentTime;

            // Update interface
            m_userInterface.update();

            // Process user input
            m_userInterface.processInput();

            // Send haptic device position to server
            sendPositionData();

            // Render user interface
            m_userInterface.render();

            // Sleep to limit update rate
            std::this_thread::sleep_for(std::chrono::milliseconds(50));
        }

        // Cleanup when done
        close();
    }

    //--------------------------------------------------------------------------
    // NETWORK & FEEDBACK
    //--------------------------------------------------------------------------
    // Process feedback from network
    void processFeedback(const FeedbackPacket& feedback) {
        // Pass to feedback processor
        m_feedbackProcessor.processFeedback(feedback);

        // Update UI with latest values
        float fx, fy, fz;
        m_feedbackProcessor.getCurrentForce(fx, fy, fz);
        m_userInterface.updateForceDisplay(fx, fy, fz);

        // Update network statistics
        int sent, received;
        m_networkManager.getPacketStats(sent, received);
        m_userInterface.updateNetworkStats(sent, received, m_feedbackProcessor.getAverageLatency());

        // Update haptic parameters
        m_userInterface.updateHapticParams(
            m_feedbackProcessor.getStiffness(),
            m_feedbackProcessor.getDamping(),
            m_feedbackProcessor.getFeedbackType()
        );
    }

    //--------------------------------------------------------------------------
    // HAPTIC SIMULATION
    //--------------------------------------------------------------------------
    // Start haptic simulation
    void startHapticSimulation() {
        if (m_simulationRunning) {
            return;  // Already running
        }

        m_simulationRunning = true;
        m_simulationFinished = false;

        // Start haptic thread
        m_hapticThread = std::thread(&HapticTeleoperationClient::hapticLoop, this);
    }

    // Stop haptic simulation
    void stopHapticSimulation() {
        if (!m_simulationRunning) {
            return;  // Not running
        }

        m_simulationRunning = false;

        // Wait for haptic thread to finish
        if (m_hapticThread.joinable()) {
            m_hapticThread.join();
        }

        m_simulationFinished = true;
    }

    // Main haptic loop
    void hapticLoop() {
        std::cout << "Haptic loop started" << std::endl;

        // Haptic update rate in seconds
        const float updateRate = 1.0f / HAPTIC_RATE_HZ;

        // Timestamp tracking
        auto lastUpdate = std::chrono::high_resolution_clock::now();

        while (m_simulationRunning) {
            // Calculate elapsed time
            auto currentTime = std::chrono::high_resolution_clock::now();
            float dt = std::chrono::duration<float>(currentTime - lastUpdate).count();
            lastUpdate = currentTime;

            // Limit dt to prevent instability
            if (dt > 0.05f) dt = 0.05f;

            // Lock for thread safety
            std::lock_guard<std::mutex> lock(m_positionMutex);

            // Apply force to simulated device 
            // (in real implementation this would interact with a physical haptic device)
            float force[3];
            m_feedbackProcessor.getCurrentForce(force[0], force[1], force[2]);

            // Scale force based on feedback type
            switch (m_feedbackProcessor.getFeedbackType()) {
            case FEEDBACK_POSITION:
                // Force is already set directly
                break;

            case FEEDBACK_FORCE:
                // Use received force directly
                break;

            case FEEDBACK_STIFFNESS_DAMPING:
                // Calculate spring-damper force
                float stiffness = static_cast<float>(m_feedbackProcessor.getStiffness());
                float damping = static_cast<float>(m_feedbackProcessor.getDamping());

                // Spring force (attraction to origin)
                force[0] = -stiffness * m_position[0];
                force[1] = -stiffness * m_position[1];
                force[2] = -stiffness * m_position[2];

                // Damping force
                force[0] -= damping * m_velocity[0];
                force[1] -= damping * m_velocity[1];
                force[2] -= damping * m_velocity[2];
                break;
            }

            // Simple physics simulation
            // F = m * a; a = F / m
            float acceleration[3] = {
                force[0] / m_deviceMass,
                force[1] / m_deviceMass,
                force[2] / m_deviceMass
            };

            // Update velocity (v = v + a * dt)
            m_velocity[0] += acceleration[0] * dt;
            m_velocity[1] += acceleration[1] * dt;
            m_velocity[2] += acceleration[2] * dt;

            // Apply some damping to prevent unbounded movement
            m_velocity[0] *= m_velocityDamping;
            m_velocity[1] *= m_velocityDamping;
            m_velocity[2] *= m_velocityDamping;

            // Update position (p = p + v * dt)
            m_position[0] += m_velocity[0] * dt;
            m_position[1] += m_velocity[1] * dt;
            m_position[2] += m_velocity[2] * dt;

            // Update UI with new position
            m_userInterface.updatePositionDisplay(m_position[0], m_position[1], m_position[2]);

            // Sleep to maintain update rate
            std::this_thread::sleep_for(std::chrono::microseconds(static_cast<int>(updateRate * 1000000)));
        }

        std::cout << "Haptic loop stopped" << std::endl;
    }

    //--------------------------------------------------------------------------
    // PARAMETER CONTROL
    //--------------------------------------------------------------------------
    // Set haptic stiffness
    void setHapticStiffness(double stiffness) {
        m_feedbackProcessor.setStiffness(stiffness);
    }

    // Set haptic damping
    void setHapticDamping(double damping) {
        m_feedbackProcessor.setDamping(damping);
    }

    // Set feedback type
    void setFeedbackType(FeedbackType type) {
        m_feedbackProcessor.setFeedbackType(type);
    }

    // Enable/disable feedback
    void setFeedbackEnabled(bool enabled) {
        m_feedbackProcessor.setFeedbackEnabled(enabled);
    }

    //--------------------------------------------------------------------------
    // UTILITY FUNCTIONS
    //--------------------------------------------------------------------------
    // Send position data to server
    void sendPositionData() {
        if (!m_networkManager.isConnected()) {
            return;
        }

        // Lock position data
        std::lock_guard<std::mutex> lock(m_positionMutex);

        // Create packet
        ClientPacket packet;
        packet.packetNumber = ++m_packetCounter;
        packet.x = m_position[0];
        packet.y = m_position[1];
        packet.z = m_position[2];
        packet.delay = 1000.0f / HAPTIC_RATE_HZ; // Time between packets in ms

        // Set timestamps and network info
        getTimestamp(packet.timestamp);
        strcpy_s(packet.srcIP, m_networkManager.getLocalIP());
        strcpy_s(packet.dstIP, m_networkManager.getServerIP());
        packet.srcPort = SRC_PORT;
        packet.dstPort = DST_PORT;

        // Send packet
        m_networkManager.sendPacket(packet);

        // Record packet if recording is enabled
        if (m_isRecording && m_recordFile.is_open()) {
            m_recordFile.write(reinterpret_cast<const char*>(&packet), sizeof(packet));
        }
    }

    // Start recording
    void startRecording() {
        if (m_isRecording) {
            return; // Already recording
        }

        m_recordFile.open(m_recordingFileName, std::ios::binary);
        if (m_recordFile.is_open()) {
            m_isRecording = true;
            m_userInterface.setMessage("Recording started: " + m_recordingFileName);
            std::cout << "Recording started: " << m_recordingFileName << std::endl;
        }
        else {
            m_userInterface.setMessage("Failed to open recording file");
            std::cerr << "Failed to open recording file" << std::endl;
        }
    }

    // Stop recording
    void stopRecording() {
        if (!m_isRecording) {
            return; // Not recording
        }

        if (m_recordFile.is_open()) {
            m_recordFile.close();
        }

        m_isRecording = false;
        m_userInterface.setMessage("Recording stopped");
        std::cout << "Recording stopped" << std::endl;
    }

    // Get current timestamp
    static void getTimestamp(char* timestamp) {
        time_t now = time(nullptr);
        struct tm timeinfo;
        localtime_s(&timeinfo, &now);
        strftime(timestamp, 64, "%Y-%m-%d %H:%M:%S", &timeinfo);
    }

    // Close the application
    void close() {
        // Stop recording if active
        if (m_isRecording) {
            stopRecording();
        }

        // Stop haptic simulation
        stopHapticSimulation();

        // Disconnect from server
        m_networkManager.disconnect();

        std::cout << "Client shutdown complete" << std::endl;
    }

private:
    //--------------------------------------------------------------------------
    // PRIVATE PROPERTIES
    //--------------------------------------------------------------------------
    // Network manager
    NetworkManager m_networkManager;

    // Feedback processor
    FeedbackProcessor m_feedbackProcessor;

    // User interface
    UserInterface m_userInterface;

    // Haptic thread
    std::thread m_hapticThread;

    // Simulation flags
    bool m_simulationRunning;
    bool m_simulationFinished;

    // Device physics simulation properties
    float m_position[3];
    float m_velocity[3];
    float m_force[3];
    float m_velocityDamping;
    float m_deviceMass;

    // Thread safety
    std::mutex m_positionMutex;

    // Recording
    bool m_isRecording = false;
    std::ofstream m_recordFile;
    std::string m_recordingFileName;

    // Packet counter
    int m_packetCounter;
};

//------------------------------------------------------------------------------
// IMPLEMENT FORWARD REFERENCES
//------------------------------------------------------------------------------
// Process feedback packet in NetworkManager
void NetworkManager::processFeedbackPacket(FeedbackPacket* packet) {
    if (m_client) {
        // Pass feedback packet to client
        m_client->processFeedback(*packet);
    }
}

// Handle button events in UserInterface
void UserInterface::onButtonPressed(int id) {
    std::lock_guard<std::mutex> lock(m_uiMutex);

    if (m_client) {
        switch (id) {
        case 0: // Quit button
            exit(0);
            break;
        }
    }
}

