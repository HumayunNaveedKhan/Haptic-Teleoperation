    }
    
    // Update position data
    {
        std::lock_guard<std::mutex> lock(dataMutex);
        std::stringstream ss;
        ss << "Position: ";
        ss << std::fixed << std::setprecision(3);
        ss << "(" << currentPacket.x << ", ";
        ss << currentPacket.y << ", ";
        ss << currentPacket.z << ")";
        labelPositionData->setText(ss.str());
    }
    
    // Update force data
    {
        std::lock_guard<std::mutex> lock(dataMutex);
        std::stringstream ss;
        ss << "Force: ";
        ss << std::fixed << std::setprecision(3);
        ss << "(" << currentFeedback.fx << ", ";
        ss << currentFeedback.fy << ", ";
        ss << currentFeedback.fz << ")";
        labelForceData->setText(ss.str());
    }
    
    // Update latency information
    {
        std::stringstream ss;
        ss << "Latency: " << std::fixed << std::setprecision(2);
        ss << averageLatency << " ms";
        labelLatency->setText(ss.str());
    }
    
    // Update error information
    {
        std::stringstream ss;
        ss << "Position Error: " << std::fixed << std::setprecision(4);
        ss << averagePositionError << " m";
        labelError->setText(ss.str());
    }
    
    // Update frequency counter
    {
        std::stringstream ss;
        ss << "Graphics: " << std::fixed << std::setprecision(0);
        ss << freqCounterGraphics.getFrequency() << " Hz\n";
        ss << "Haptics: " << freqCounterHaptics.getFrequency() << " Hz\n";
        ss << "Network: " << freqCounterNetwork.getFrequency() << " Hz";
        if (labelRates) {
            labelRates->setText(ss.str());
        }
    }
    
    // Update sliders
    positionScaling = sliderPositionScale->getValue();
    forceScaling = sliderForceScale->getValue();
    
    // Update force vector visualization
    if (forceVector) {
        cVector3d force(currentFeedback.fx, currentFeedback.fy, currentFeedback.fz);
        cVector3d pos(currentPacket.x, currentPacket.y, currentPacket.z);
        
        // Scale force for better visualization
        force *= 0.1 * forceScaling;
        
        forceVector->setLocalPos(pos);
        forceVector->setDirection(force);
        forceVector->setEnabled(force.length() > 0.001);
    }
    
    // Update position error vector visualization
    if (positionErrorVector) {
        cVector3d commandedPos(currentPacket.x, currentPacket.y, currentPacket.z);
        cVector3d actualPos(currentFeedback.px, currentFeedback.py, currentFeedback.pz);
        cVector3d errorVector = actualPos - commandedPos;
        
        // Scale error for better visualization
        errorVector *= 5.0;
        
        positionErrorVector->setLocalPos(commandedPos);
        positionErrorVector->setDirection(errorVector);
        positionErrorVector->setEnabled(errorVector.length() > 0.001);
    }
}

void updateGraphs(void) {
    // Only update if GUI is fully visible
    if (currentGuiMode != GUI_FULL) {
        return;
    }
    
    const int MAX_GRAPH_POINTS = 100;
    const double GRAPH_WIDTH = 280.0;
    const double GRAPH_HEIGHT = 70.0;
    const double X_SPACING = GRAPH_WIDTH / MAX_GRAPH_POINTS;
    
    // Clear existing graph data
    positionGraph->clear();
    forceGraph->clear();
    latencyGraph->clear();
    errorGraph->clear();
    
    // Update position graph - last MAX_GRAPH_POINTS packets
    {
        std::lock_guard<std::mutex> lock(dataMutex);
        int numPoints = std::min(static_cast<int>(sentPacketsHistory.size()), MAX_GRAPH_POINTS);
        
        if (numPoints > 0) {
            // Find min/max values for scaling
            float minX = sentPacketsHistory[sentPacketsHistory.size() - numPoints].x;
            float maxX = minX;
            float minY = sentPacketsHistory[sentPacketsHistory.size() - numPoints].y;
            float maxY = minY;
            float minZ = sentPacketsHistory[sentPacketsHistory.size() - numPoints].z;
            float maxZ = minZ;
            
            for (size_t i = sentPacketsHistory.size() - numPoints; i < sentPacketsHistory.size(); i++) {
                minX = std::min(minX, sentPacketsHistory[i].x);
                maxX = std::max(maxX, sentPacketsHistory[i].x);
                minY = std::min(minY, sentPacketsHistory[i].y);
                maxY = std::max(maxY, sentPacketsHistory[i].y);
                minZ = std::min(minZ, sentPacketsHistory[i].z);
                maxZ = std::max(maxZ, sentPacketsHistory[i].z);
            }
            
            // Add a small margin
            float xRange = std::max(0.001f, maxX - minX) * 1.1f;
            float yRange = std::max(0.001f, maxY - minY) * 1.1f;
            float zRange = std::max(0.001f, maxZ - minZ) * 1.1f;
            
            minX -= xRange * 0.05f;
            maxX += xRange * 0.05f;
            minY -= yRange * 0.05f;
            maxY += yRange * 0.05f;
            minZ -= zRange * 0.05f;
            maxZ += zRange * 0.05f;
            
            // Plot the data
            for (int i = 0; i < numPoints; i++) {
                double x = i * X_SPACING;
                const Packet& pkt = sentPacketsHistory[sentPacketsHistory.size() - numPoints + i];
                
                // Normalize to graph height
                double yX = ((pkt.x - minX) / (maxX - minX)) * GRAPH_HEIGHT;
                double yY = ((pkt.y - minY) / (maxY - minY)) * GRAPH_HEIGHT;
                double yZ = ((pkt.z - minZ) / (maxZ - minZ)) * GRAPH_HEIGHT;
                
                // Add points for each dimension
                positionGraph->newVertex(x, yX);
                positionGraph->newVertex(x, yY);
                positionGraph->newVertex(x, yZ);
            }
        }
    }
    
    // Update force graph
    {
        std::lock_guard<std::mutex> lock(dataMutex);
        int numPoints = std::min(static_cast<int>(receivedPacketsHistory.size()), MAX_GRAPH_POINTS);
        
        if (numPoints > 0) {
            // Find min/max values for scaling
            float minFx = receivedPacketsHistory[receivedPacketsHistory.size() - numPoints].fx;
            float maxFx = minFx;
            float minFy = receivedPacketsHistory[receivedPacketsHistory.size() - numPoints].fy;
            float maxFy = minFy;
            float minFz = receivedPacketsHistory[receivedPacketsHistory.size() - numPoints].fz;
            float maxFz = minFz;
            
            for (size_t i = receivedPacketsHistory.size() - numPoints; i < receivedPacketsHistory.size(); i++) {
                minFx = std::min(minFx, receivedPacketsHistory[i].fx);
                maxFx = std::max(maxFx, receivedPacketsHistory[i].fx);
                minFy = std::min(minFy, receivedPacketsHistory[i].fy);
                maxFy = std::max(maxFy, receivedPacketsHistory[i].fy);
                minFz = std::min(minFz, receivedPacketsHistory[i].fz);
                maxFz = std::max(maxFz, receivedPacketsHistory[i].fz);
            }
            
            // Add a small margin
            float fxRange = std::max(0.001f, maxFx - minFx) * 1.1f;
            float fyRange = std::max(0.001f, maxFy - minFy) * 1.1f;
            float fzRange = std::max(0.001f, maxFz - minFz) * 1.1f;
            
            minFx -= fxRange * 0.05f;
            maxFx += fxRange * 0.05f;
            minFy -= fyRange * 0.05f;
            maxFy += fyRange * 0.05f;
            minFz -= fzRange * 0.05f;
            maxFz += fzRange * 0.05f;
            
            // Plot the data
            for (int i = 0; i < numPoints; i++) {
                double x = i * X_SPACING;
                const FeedbackPacket& pkt = receivedPacketsHistory[receivedPacketsHistory.size() - numPoints + i];
                
                // Normalize to graph height
                double yFx = ((pkt.fx - minFx) / (maxFx - minFx)) * GRAPH_HEIGHT;
                double yFy = ((pkt.fy - minFy) / (maxFy - minFy)) * GRAPH_HEIGHT;
                double yFz = ((pkt.fz - minFz) / (maxFz - minFz)) * GRAPH_HEIGHT;
                
                // Add points for each dimension
                forceGraph->newVertex(x, yFx);
                forceGraph->newVertex(x, yFy);
                forceGraph->newVertex(x, yFz);
            }
        }
    }
    
    // Update latency graph
    {
        int numPoints = std::min(static_cast<int>(latencyHistory.size()), MAX_GRAPH_POINTS);
        
        if (numPoints > 0) {
            // Find min/max values for scaling
            double minLatency = latencyHistory[latencyHistory.size() - numPoints];
            double maxLatency = minLatency;
            
            for (size_t i = latencyHistory.size() - numPoints; i < latencyHistory.size(); i++) {
                minLatency = std::min(minLatency, latencyHistory[i]);
                maxLatency = std::max(maxLatency, latencyHistory[i]);
            }
            
            // Add a small margin
            double latencyRange = std::max(0.1, maxLatency - minLatency) * 1.1;
            minLatency = std::max(0.0, minLatency - latencyRange * 0.05);
            maxLatency += latencyRange * 0.05;
            
            // Plot the data
            for (int i = 0; i < numPoints; i++) {
                double x = i * X_SPACING;
                double latency = latencyHistory[latencyHistory.size() - numPoints + i];
                
                // Normalize to graph height
                double y = ((latency - minLatency) / (maxLatency - minLatency)) * GRAPH_HEIGHT;
                
                latencyGraph->newVertex(x, y);
            }
        }
    }
    
    // Update error graph
    {
        int numPoints = std::min(static_cast<int>(positionErrorHistory.size()), MAX_GRAPH_POINTS);
        
        if (numPoints > 0) {
            // Find min/max values for scaling
            double minError = positionErrorHistory[positionErrorHistory.size() - numPoints];
            double maxError = minError;
            
            for (size_t i = positionErrorHistory.size() - numPoints; i < positionErrorHistory.size(); i++) {
                minError = std::min(minError, positionErrorHistory[i]);
                maxError = std::max(maxError, positionErrorHistory[i]);
            }
            
            // Add a small margin
            double errorRange = std::max(0.0001, maxError - minError) * 1.1;
            minError = std::max(0.0, minError - errorRange * 0.05);
            maxError += errorRange * 0.05;
            
            // Plot the data
            for (int i = 0; i < numPoints; i++) {
                double x = i * X_SPACING;
                double error = positionErrorHistory[positionErrorHistory.size() - numPoints + i];
                
                // Normalize to graph height
                double y = ((error - minError) / (maxError - minError)) * GRAPH_HEIGHT;
                
                errorGraph->newVertex(x, y);
            }
        }
    }
}

void handleGUIEvents(void) {
    // Check calibrate button
    if (buttonCalibrate->getState() == true) {
        buttonCalibrate->setState(false);
        calibrateDevice();
    }
    
    // Check connect button
    if (buttonConnect->getState() == true) {
        buttonConnect->setState(false);
        connectToServer();
    }
    
    // Check disconnect button
    if (buttonDisconnect->getState() == true) {
        buttonDisconnect->setState(false);
        disconnectFromServer();
    }
    
    // Check record checkbox
    if (checkBoxRecord->getState() != isRecording) {
        if (checkBoxRecord->getState()) {
            startRecording();
        } else {
            stopRecording();
        }
    }
    
    // Check replay checkbox
    if (checkBoxReplay->getState() != isReplaying) {
        if (checkBoxReplay->getState()) {
            startReplay();
        } else {
            stopReplay();
        }
    }
    
    // Check GUI visibility checkbox
    if (checkBoxShowGui->getState()) {
        // Toggle between minimal and full GUI
        if (currentGuiMode == GUI_HIDDEN) {
            currentGuiMode = GUI_MINIMAL;
        } else if (currentGuiMode == GUI_MINIMAL) {
            currentGuiMode = GUI_FULL;
        } else {
            currentGuiMode = GUI_MINIMAL;
        }
    } else {
        currentGuiMode = GUI_HIDDEN;
    }
}

void calibrateDevice(void) {
    if (hapticDevice) {
        logMessage("Calibrating haptic device...");
        hapticDevice->calibrate();
        logMessage("Calibration complete");
    } else {
        logMessage("No haptic device connected");
    }
}

void connectToServer(void) {
    if (!networkConnected) {
        logMessage("Connecting to server at " + std::string(DST_IP) + ":" + std::to_string(DST_PORT) + "...");
        
        // Start network communication thread
        networkRunning = true;
        networkThread = new std::thread(networkCommunication);
    } else {
        logMessage("Already connected");
    }
}

void disconnectFromServer(void) {
    if (networkConnected) {
        logMessage("Disconnecting from server...");
        
        // Stop network thread
        networkRunning = false;
        
        // Wait for thread to terminate
        if (networkThread && networkThread->joinable()) {
            networkThread->join();
            delete networkThread;
            networkThread = nullptr;
        }
        
        networkConnected = false;
        logMessage("Disconnected from server");
    } else {
        logMessage("Not connected");
    }
}

void startRecording(void) {
    if (!isRecording) {
        logMessage("Starting recording...");
        
        // Open record file
        std::string filename = "haptic_recording_" + std::to_string(time(nullptr)) + ".dat";
        recordFile.open(filename, std::ios::binary);
        
        if (recordFile.is_open()) {
            isRecording = true;
            recordedData.clear();
            
            // Store starting time
            LARGE_INTEGER frequency, startTime;
            QueryPerformanceFrequency(&frequency);
            QueryPerformanceCounter(&startTime);
            replayStartTime = (double)startTime.QuadPart / frequency.QuadPart;
            
            logMessage("Recording started. Saving to " + filename);
            checkBoxRecord->setCheck(true);
        } else {
            logMessage("Failed to open recording file");
            checkBoxRecord->setCheck(false);
        }
    }
}

void stopRecording(void) {
    if (isRecording) {
        logMessage("Stopping recording...");
        
        // Close record file
        if (recordFile.is_open()) {
            recordFile.close();
        }
        
        isRecording = false;
        logMessage("Recording stopped. Captured " + std::to_string(recordedData.size()) + " packets");
        checkBoxRecord->setCheck(false);
    }
}

void startReplay(void) {
    if (!isReplaying && !recordedData.empty()) {
        logMessage("Starting replay...");
        
        // Reset replay index
        replayIndex = 0;
        
        // Record current time as replay start
        LARGE_INTEGER frequency, startTime;
        QueryPerformanceFrequency(&frequency);
        QueryPerformanceCounter(&startTime);
        replayStartTime = (double)startTime.QuadPart / frequency.QuadPart;
        
        isReplaying = true;
        logMessage("Replay started. Playing " + std::to_string(recordedData.size()) + " packets");
        checkBoxReplay->setCheck(true);
    } else if (recordedData.empty()) {
        logMessage("No recorded data available for replay");
        checkBoxReplay->setCheck(false);
    }
}

void stopReplay(void) {
    if (isReplaying) {
        logMessage("Stopping replay...");
        isReplaying = false;
        logMessage("Replay stopped");
        checkBoxReplay->setCheck(false);
    }
}

//------------------------------------------------------------------------------
// MAIN HAPTIC LOOP
//------------------------------------------------------------------------------
void updateHaptics(void) {
    // simulation in now running
    simulationRunning = true;
    simulationFinished = false;

    // main haptic simulation loop
    while(simulationRunning) {
        // signal frequency counter
        freqCounterHaptics.signal(1);

        // read position from device
        cVector3d position;
        hapticDevice->getPosition(position);
        
        // Scale position for workspace scaling
        position *= positionScaling;

        // read orientation from device
        cMatrix3d rotation;
        hapticDevice->getRotation(rotation);

        // read gripper position
        double gripperAngle;
        hapticDevice->getGripperAngleRad(gripperAngle);

        // read linear velocity from device
        cVector3d linearVelocity;
        hapticDevice->getLinearVelocity(linearVelocity);

        // process force feedback
        cVector3d force(0, 0, 0);
        
        {
            // Lock mutex to safely access feedback data
            std::lock_guard<std::mutex> lock(dataMutex);
            
            // If we have feedback from server, apply it
            if (networkConnected && packetsReceived > 0) {
                force.set(currentFeedback.fx, currentFeedback.fy, currentFeedback.fz);
                
                // Scale force based on user setting
                force *= forceScaling;
                
                // Safety: Clamp force to device maximum
                double forceMagnitude = force.length();
                if (forceMagnitude > hapticDeviceMaxStiffness) {
                    force *= hapticDeviceMaxStiffness / forceMagnitude;
                }
            }
        }

        // send forces to device
        hapticDevice->setForce(force);
    }
    
    // exit haptics thread
    simulationFinished = true;
}

