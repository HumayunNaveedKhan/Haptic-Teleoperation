//------------------------------------------------------------------------------
// HAPTIC CLIENT CLASS
//------------------------------------------------------------------------------
class HapticClient {
public:
    // Constructor
    HapticClient()
        : m_simulationRunning(false),
        m_simulationFinished(true),
        m_analyticsActive(false),
        m_position{ 0.0f, 0.0f, 0.0f },
        m_force{ 0.0f, 0.0f, 0.0f },
        m_velocityDamping(0.95f),
        m_deviceMass(1.0f)
    {
        // Set up references
        m_networkManager.setClient(this);
        m_feedbackProcessor.setClient(this);
        m_consoleInterface.setClient(this);
        m_analyticsInterface.setClient(this);
        m_magnetsVisualizer.setClient(this);

        // Initialize packet counter
        m_packetCounter = 0;

        // Get timestamp for file naming
        char timestamp[64];
        getTimestamp(timestamp);
        std::string timeStr(timestamp);
        std::replace(timeStr.begin(), timeStr.end(), ':', '-');

        // Initialize recording file name
        m_recordingFileName = "haptic_recording_" + timeStr + ".csv";

        // Initialize velocity
        m_velocity[0] = m_velocity[1] = m_velocity[2] = 0.0f;
    }

    // Destructor
    ~HapticClient() {
        close();
    }

    // Initialize
    bool initialize() {
        // Initialize network manager
        if (!m_networkManager.initialize()) {
            std::cerr << "Failed to initialize network manager" << std::endl;
            return false;
        }

        // Initialize feedback processor
        if (!m_feedbackProcessor.initialize()) {
            std::cerr << "Failed to initialize feedback processor" << std::endl;
            return false;
        }

        // Initialize console interface
        if (!m_consoleInterface.initialize()) {
            std::cerr << "Failed to initialize console interface" << std::endl;
            return false;
        }

        // Initialize analytics interface
        if (!m_analyticsInterface.initialize()) {
            std::cerr << "Failed to initialize analytics interface" << std::endl;
            return false;
        }

        // Initialize magnets visualizer
        if (!m_magnetsVisualizer.initialize()) {
            std::cerr << "Failed to initialize magnets visualizer" << std::endl;
            // This is not critical, so we don't return false
        }

        // Connect to server
        if (!m_networkManager.connect(DEFAULT_SERVER_IP, DST_PORT)) {
            std::cerr << "Failed to connect to server" << std::endl;
            // Don't return false here, we can connect later
        }

        return true;
    }

    // Run the client
    void run() {
        std::cout << "Starting haptic teleoperation client..." << std::endl;

        // Start haptic simulation
        startHapticSimulation();

        // Main loop
        bool running = true;
        auto lastUpdate = std::chrono::high_resolution_clock::now();

        while (running) {
            // Calculate elapsed time
            auto currentTime = std::chrono::high_resolution_clock::now();
            auto elapsedTime = std::chrono::duration<float>(currentTime - lastUpdate).count();
            lastUpdate = currentTime;

            // Process user input and update UI state
            processInput();

            // Update interfaces
            updateInterfaces();

            // Send haptic device position to server
            sendPositionData();

            // Render the appropriate interface
            if (m_analyticsActive) {
                m_analyticsInterface.render();
            }
            else {
                m_consoleInterface.render();
            }

            // Sleep to limit update rate
            std::this_thread::sleep_for(std::chrono::milliseconds(50));
        }

        // Cleanup when done
        close();
    }

    // Process feedback from network
    void processFeedback(const FeedbackPacket& feedback) {
        // Pass to feedback processor
        m_feedbackProcessor.processFeedback(feedback);

        // Update interfaces with new data
        updateInterfaceData();
    }

    // Start haptic simulation
    void startHapticSimulation() {
        if (m_simulationRunning) {
            return;  // Already running
        }

        m_simulationRunning = true;
        m_simulationFinished = false;

        // Start haptic thread
        m_hapticThread = std::thread(&HapticClient::hapticLoop, this);
    }

    // Stop haptic simulation
    void stopHapticSimulation() {
        if (!m_simulationRunning) {
            return;  // Not running
        }

        m_simulationRunning = false;

        // Wait for haptic thread to finish
        if (m_hapticThread.joinable()) {
            m_hapticThread.join();
        }

        m_simulationFinished = true;
    }

    // Toggle analytics view
    void toggleAnalyticsView() {
        m_analyticsActive = !m_analyticsActive;
        m_analyticsInterface.setVisible(m_analyticsActive);
    }

    // Toggle 3D visualization
    void toggle3DVisualization() {
        m_magnetsVisualizer.setVisible(!m_magnetsVisualizer.isVisible());
    }

    // Set feedback type
    void setFeedbackType(FeedbackType type) {
        m_feedbackProcessor.setFeedbackType(type);
    }

    // Enable/disable feedback
    void setFeedbackEnabled(bool enabled) {
        m_feedbackProcessor.setFeedbackEnabled(enabled);
    }

    // Set haptic stiffness
    void setHapticStiffness(double stiffness) {
        m_feedbackProcessor.setStiffness(stiffness);
    }

    // Set haptic damping
    void setHapticDamping(double damping) {
        m_feedbackProcessor.setDamping(damping);
    }

    // Save data to CSV
    void saveDataToCSV() {
        if (m_feedbackProcessor.saveDataToCSV(m_recordingFileName)) {
            std::string message = "Data saved to " + m_recordingFileName;
            m_consoleInterface.setMessage(message);
        }
        else {
            m_consoleInterface.setMessage("Failed to save data");
        }
    }

    // Reset position
    void resetPosition() {
        std::lock_guard<std::mutex> lock(m_positionMutex);
        m_position[0] = m_position[1] = m_position[2] = 0.0f;
        m_velocity[0] = m_velocity[1] = m_velocity[2] = 0.0f;
    }

    // Configure server IP
    void configureServerIP() {
        system("cls");
        std::cout << "===== SERVER IP CONFIGURATION =====\n\n";
        std::cout << "Current server IP: " << m_networkManager.getServerIP() << "\n";
        std::cout << "Enter new server IP (or press Enter to keep current): ";

        char buffer[16];
        std::cin.getline(buffer, 16);

        if (strlen(buffer) > 0) {
            m_networkManager.setServerIP(buffer);
            std::cout << "\nServer IP updated to: " << m_networkManager.getServerIP() << "\n";

            // Attempt to reconnect
            m_networkManager.disconnect();
            if (m_networkManager.connect(m_networkManager.getServerIP(), DST_PORT)) {
                std::cout << "Successfully reconnected to server\n";
            }
            else {
                std::cout << "Failed to connect to new server IP\n";
            }
        }

        std::cout << "\nPress any key to continue...";
        _getch();
    }

private:
    // Process user input
    void processInput() {
        if (_kbhit()) {
            char key = _getch();

            // Handle global keys
            switch (key) {
            case 'a':
            case 'A':
                toggleAnalyticsView();
                break;

            case 'v':
            case 'V':
                toggle3DVisualization();
                break;

            case 'q':
            case 'Q':
                exit(0);
                break;

            case 'f':
            case 'F':
                setFeedbackEnabled(!m_feedbackProcessor.isFeedbackEnabled());
                break;

            case 't':
            case 'T': {
                FeedbackType currentType = m_feedbackProcessor.getFeedbackType();
                FeedbackType newType = static_cast<FeedbackType>((currentType + 1) % 3);
                setFeedbackType(newType);
                break;
            }

            case '+':
                setHapticStiffness(m_feedbackProcessor.getStiffness() + 10.0);
                break;

            case '-':
                setHapticStiffness(std::max(0.0, m_feedbackProcessor.getStiffness() - 10.0));
                break;

            case 'd':
            case 'D':
                setHapticDamping(m_feedbackProcessor.getDamping() + 5.0);
                break;

            case 'c':
            case 'C':
                setHapticDamping(std::max(0.0, m_feedbackProcessor.getDamping() - 5.0));
                break;

            case 's':
            case 'S':
                saveDataToCSV();
                break;

            case 'r':
            case 'R':
                resetPosition();
                break;

            case 'i':
            case 'I':
                configureServerIP();
                break;

                // Handle analytics-specific keys when analytics is active
            case '1':
            case '2':
            case '3':
            case '4':
                if (m_analyticsActive) {
                    m_analyticsInterface.setTab(static_cast<AnalyticsTab>(key - '1'));
                }
                break;
            }
        }
    }

    // Update interfaces
    void updateInterfaces() {
        m_consoleInterface.update();
        m_analyticsInterface.update();
    }

    // Update interface data with latest values
    void updateInterfaceData() {
        // Get current data
        float posX, posY, posZ;
        m_feedbackProcessor.getTargetPosition(posX, posY, posZ);

        float forceX, forceY, forceZ;
        m_feedbackProcessor.getCurrentForce(forceX, forceY, forceZ);

        int packetsSent, packetsReceived;
        m_networkManager.getPacketStats(packetsSent, packetsReceived);

        float latency = m_feedbackProcessor.getAverageLatency();
        float error = m_feedbackProcessor.getPositionError();

        double stiffness = m_feedbackProcessor.getStiffness();
        double damping = m_feedbackProcessor.getDamping();
        FeedbackType feedbackType = m_feedbackProcessor.getFeedbackType();
        bool feedbackEnabled = m_feedbackProcessor.isFeedbackEnabled();

        // Get min/max values
        float minPosX, maxPosX, minPosY, maxPosY, minPosZ, maxPosZ;
        m_feedbackProcessor.getMinMaxPosition(minPosX, maxPosX, minPosY, maxPosY, minPosZ, maxPosZ);

        float minForceX, maxForceX, minForceY, maxForceY, minForceZ, maxForceZ;
        m_feedbackProcessor.getMinMaxForce(minForceX, maxForceX, minForceY, maxForceY, minForceZ, maxForceZ);

        // Update console interface
        m_consoleInterface.updatePositionDisplay(posX, posY, posZ);
        m_consoleInterface.updateForceDisplay(forceX, forceY, forceZ);
        m_consoleInterface.updateNetworkStats(packetsSent, packetsReceived, latency);
        m_consoleInterface.updateHapticParams(stiffness, damping, feedbackType, feedbackEnabled);

        // Update analytics interface
        m_analyticsInterface.setPositionData(posX, posY, posZ, minPosX, maxPosX, minPosY, maxPosY, minPosZ, maxPosZ);
        m_analyticsInterface.setForceData(forceX, forceY, forceZ, minForceX, maxForceX, minForceY, maxForceY, minForceZ, maxForceZ);
        m_analyticsInterface.setNetworkData(packetsSent, packetsReceived, latency, error);
        m_analyticsInterface.setHapticParams(stiffness, damping, feedbackType, feedbackEnabled);

        // Update magnets visualizer
        m_magnetsVisualizer.updateDevicePosition(m_position[0], m_position[1], m_position[2]);

        // Create some sphere positions for visualization
        // In a real application, these would come from the physics simulation
        float spherePositions[9] = {  // 3 spheres * 3 coordinates
            0.1f, 0.0f, 0.0f,        // Sphere 1
            0.0f, 0.1f, 0.0f,        // Sphere 2
            0.0f, 0.0f, 0.1f         // Sphere 3
        };
        m_magnetsVisualizer.updateSpherePositions(spherePositions, 3);
    }

    // Main haptic loop
    void hapticLoop() {
        std::cout << "Haptic loop started" << std::endl;

        // Haptic update rate in seconds
        const float updateRate = 1.0f / HAPTIC_RATE_HZ;

        // Timestamp tracking
        auto lastUpdate = std::chrono::high_resolution_clock::now();

        while (m_simulationRunning) {
            // Calculate elapsed time
            auto currentTime = std::chrono::high_resolution_clock::now();
            float dt = std::chrono::duration<float>(currentTime - lastUpdate).count();
            lastUpdate = currentTime;

            // Limit dt to prevent instability
            if (dt > 0.05f) dt = 0.05f;

            // Lock for thread safety
            std::lock_guard<std::mutex> lock(m_positionMutex);

            // Apply force to simulated device 
            // (in real implementation this would interact with a physical haptic device)
            float force[3];
            m_feedbackProcessor.getCurrentForce(force[0], force[1], force[2]);

            // Scale force based on feedback type
            switch (m_feedbackProcessor.getFeedbackType()) {
            case FEEDBACK_POSITION:
                // Force is already set directly
                break;

            case FEEDBACK_FORCE:
                // Use received force directly
                break;

            case FEEDBACK_STIFFNESS_DAMPING:
                // Calculate spring-damper force
                float stiffness = static_cast<float>(m_feedbackProcessor.getStiffness());
                float damping = static_cast<float>(m_feedbackProcessor.getDamping());

                // Spring force (attraction to origin)
                force[0] = -stiffness * m_position[0];
                force[1] = -stiffness * m_position[1];
                force[2] = -stiffness * m_position[2];

                // Damping force
                force[0] -= damping * m_velocity[0];
                force[1] -= damping * m_velocity[1];
                force[2] -= damping * m_velocity[2];
                break;
            }

            // Simple physics simulation
            // F = m * a; a = F / m
            float acceleration[3] = {
                force[0] / m_deviceMass,
                force[1] / m_deviceMass,
                force[2] / m_deviceMass
            };

            // Update velocity (v = v + a * dt)
            m_velocity[0] += acceleration[0] * dt;
            m_velocity[1] += acceleration[1] * dt;
            m_velocity[2] += acceleration[2] * dt;

            // Apply some damping to prevent unbounded movement
            m_velocity[0] *= m_velocityDamping;
            m_velocity[1] *= m_velocityDamping;
            m_velocity[2] *= m_velocityDamping;

            // Update position (p = p + v * dt)
            m_position[0] += m_velocity[0] * dt;
            m_position[1] += m_velocity[1] * dt;
            m_position[2] += m_velocity[2] * dt;

            // Update UI with new position
            m_consoleInterface.updatePositionDisplay(m_position[0], m_position[1], m_position[2]);

            // Sleep to maintain update rate
            std::this_thread::sleep_for(std::chrono::microseconds(static_cast<int>(updateRate * 1000000)));
        }

        std::cout << "Haptic loop stopped" << std::endl;
    }

    // Send position data to server
    void sendPositionData() {
        if (!m_networkManager.isConnected()) {
            return;
        }

        // Lock position data
        std::lock_guard<std::mutex> lock(m_positionMutex);

        // Create packet
        ClientPacket packet;
        packet.packetNumber = ++m_packetCounter;
        packet.x = m_position[0];
        packet.y = m_position[1];
        packet.z = m_position[2];
        packet.delay = 1000.0f / HAPTIC_RATE_HZ; // Time between packets in ms

        // Set timestamps and network info
        getTimestamp(packet.timestamp);
        strcpy_s(packet.srcIP, m_networkManager.getLocalIP());
        strcpy_s(packet.dstIP, m_networkManager.getServerIP());
        packet.srcPort = SRC_PORT;
        packet.dstPort = DST_PORT;

        // Send packet
        m_networkManager.sendPacket(packet);
    }

    // Get current timestamp
    static void getTimestamp(char* timestamp) {
        time_t now = time(nullptr);
        struct tm timeinfo;
        localtime_s(&timeinfo, &now);
        strftime(timestamp, 64, "%Y-%m-%d %H:%M:%S", &timeinfo);
    }

    // Close and cleanup
    void close() {
        // Stop haptic simulation
        stopHapticSimulation();

        // Disconnect from server
        m_networkManager.disconnect();

        // Shutdown magnets visualizer
        m_magnetsVisualizer.shutdown();

        std::cout << "Client shutdown complete" << std::endl;
    }

    // Network manager
    NetworkManager m_networkManager;

    // Feedback processor
    FeedbackProcessor m_feedbackProcessor;

    // User interfaces
    ConsoleInterface m_consoleInterface;
    AnalyticsInterface m_analyticsInterface;
    MagnetsVisualizer m_magnetsVisualizer;

    // Haptic thread
    std::thread m_hapticThread;

    // Simulation flags
    bool m_simulationRunning;
    bool m_simulationFinished;
    bool m_analyticsActive;

    // Device physics simulation properties
    float m_position[3];
    float m_velocity[3];
    float m_force[3];
    float m_velocityDamping;
    float m_deviceMass;

    // Thread safety
    std::mutex m_positionMutex;

    // Recording
    std::string m_recordingFileName;

    // Packet counter
    int m_packetCounter;
};

