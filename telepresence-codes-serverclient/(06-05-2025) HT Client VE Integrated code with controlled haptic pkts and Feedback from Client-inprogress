        m_packetsSent(0),
        m_packetsReceived(0),
        m_latency(0.0f),
        m_stiffness(100.0),
        m_damping(20.0),
        m_feedbackType(FEEDBACK_POSITION),
        m_feedbackEnabled(true),
        m_positionScale(1.0f),
        m_forceScale(1.0f)
