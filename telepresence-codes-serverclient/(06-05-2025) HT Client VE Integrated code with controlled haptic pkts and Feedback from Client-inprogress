void getLocalIP(char* ipBuffer) {
    // This implementation uses GetAdaptersAddresses to get the active IP
    ULONG outBufLen = 0;
    PIP_ADAPTER_ADDRESSES pAddresses = nullptr;
    DWORD dwRetVal = 0;

    // First call to get the required buffer size
    dwRetVal = GetAdaptersAddresses(AF_INET, GAA_FLAG_INCLUDE_PREFIX, nullptr, nullptr, &outBufLen);

    if (dwRetVal == ERROR_BUFFER_OVERFLOW) {
        pAddresses = (IP_ADAPTER_ADDRESSES*)malloc(outBufLen);
        if (pAddresses == nullptr) {
            strcpy_s(ipBuffer, 16, "127.0.0.1");
            return;
        }

        // Second call to get the actual data
        dwRetVal = GetAdaptersAddresses(AF_INET, GAA_FLAG_INCLUDE_PREFIX, nullptr, pAddresses, &outBufLen);

        if (dwRetVal == NO_ERROR) {
            // Iterate through interfaces
            for (PIP_ADAPTER_ADDRESSES pCurrAddresses = pAddresses; pCurrAddresses != nullptr; pCurrAddresses = pCurrAddresses->Next) {
                // Skip loopback adapters
                if (pCurrAddresses->IfType == IF_TYPE_SOFTWARE_LOOPBACK) {
                    continue;
                }

                // Skip adapters that are not operational
                if (pCurrAddresses->OperStatus != IfOperStatusUp) {
                    continue;
                }

                // Get linked IP address
                for (PIP_ADAPTER_UNICAST_ADDRESS pUnicast = pCurrAddresses->FirstUnicastAddress; pUnicast != nullptr; pUnicast = pUnicast->Next) {
                    if (pUnicast->Address.lpSockaddr->sa_family == AF_INET) {
                        sockaddr_in* sa_in = (sockaddr_in*)pUnicast->Address.lpSockaddr;
                        // Convert to string
                        inet_ntop(AF_INET, &(sa_in->sin_addr), ipBuffer, 16);
                        free(pAddresses);
                        return;
                    }
                }
            }
        }

        free(pAddresses);
    }

    // Fallback method using gethostname
    char hostname[256];
    struct addrinfo hints {}, * info = nullptr, * p = nullptr;
    struct sockaddr_in* sockaddr_ipv4;

    if (gethostname(hostname, sizeof(hostname)) == 0) {
        hints.ai_family = AF_INET;
        hints.ai_socktype = SOCK_DGRAM;
        hints.ai_flags = AI_PASSIVE;

        if (getaddrinfo(hostname, nullptr, &hints, &info) == 0) {
            for (p = info; p != nullptr; p = p->ai_next) {
                sockaddr_ipv4 = (struct sockaddr_in*)p->ai_addr;
                inet_ntop(AF_INET, &sockaddr_ipv4->sin_addr, ipBuffer, 16);
                // Skip localhost address
                if (strcmp(ipBuffer, "127.0.0.1") != 0) {
                    freeaddrinfo(info);
                    return;
                }
            }
            freeaddrinfo(info);
        }
    }

    // Default to localhost if we couldn't find any other IP
    strcpy_s(ipBuffer, 16, "127.0.0.1");
}

void getTimestamp(char* timestamp) {
    time_t now = time(0);
    struct tm tstruct;
    localtime_s(&tstruct, &now);
    strftime(timestamp, 64, "%Y-%m-%d %X", &tstruct);
}

bool initializeNetworkSockets() {
    WSADATA wsaData;

    // Initialize Winsock
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        cerr << "WSAStartup failed: " << WSAGetLastError() << endl;
        return false;
    }

    // Create the UDP send socket
    sendSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (sendSocket == INVALID_SOCKET) {
        cerr << "Send socket creation failed: " << WSAGetLastError() << endl;
        WSACleanup();
        return false;
    }

    // Create the UDP receive socket
    receiveSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (receiveSocket == INVALID_SOCKET) {
        cerr << "Receive socket creation failed: " << WSAGetLastError() << endl;
        closesocket(sendSocket);
        WSACleanup();
        return false;
    }

    // Bind receive socket to local port for receiving feedback
    sockaddr_in localAddr;
    localAddr.sin_family = AF_INET;
    localAddr.sin_addr.s_addr = INADDR_ANY;
    localAddr.sin_port = htons(SRC_PORT);

    // Fix: Check the return value directly without comparing to SOCKET_ERROR
        bind(receiveSocket, (sockaddr*)&localAddr, sizeof(localAddr));
        cerr << "Error binding receive socket: " << WSAGetLastError() << endl;
        //closesocket(sendSocket);
        //closesocket(receiveSocket);
        //WSACleanup();
        //return false;
    

    // Set receive socket to non-blocking mode
    u_long mode = 1;
    if (ioctlsocket(receiveSocket, FIONBIO, &mode) != 0) {
        cerr << "Error setting non-blocking mode: " << WSAGetLastError() << endl;
        closesocket(sendSocket);
        closesocket(receiveSocket);
        WSACleanup();
        return false;
    }

    cout << "Network sockets initialized successfully" << endl;
    return true;
}

void closeNetworkSockets() {
    if (sendSocket != INVALID_SOCKET) {
        closesocket(sendSocket);
        sendSocket = INVALID_SOCKET;
    }

    if (receiveSocket != INVALID_SOCKET) {
        closesocket(receiveSocket);
        receiveSocket = INVALID_SOCKET;
    }

    WSACleanup();
    cout << "Network sockets closed" << endl;
}

