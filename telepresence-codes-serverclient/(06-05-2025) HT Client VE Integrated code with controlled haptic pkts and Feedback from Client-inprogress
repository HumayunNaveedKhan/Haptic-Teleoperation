void updateGUI(void) {
    // Update GUI based on current mode
    bool showGui = (currentGuiMode != GUI_HIDDEN);
    guiPanel->setEnabled(showGui);
    graphPanel->setEnabled(showGui && currentGuiMode == GUI_FULL);
    
    // Update device information
    if (hapticDevice) {
        string deviceName;
        hapticDevice->getSpecifications().getModelName(deviceName);
        
        cVector3d pos;
        hapticDevice->getPosition(pos);
        
        std::stringstream ss;
        ss << "Device: " << deviceName << "\n";
        ss << "Max Stiffness: " << hapticDeviceMaxStiffness << " N/m";
        labelDeviceInfo->setText(ss.str());
    } else {
        labelDeviceInfo->setText("No haptic device connected");
    }
    
    // Update network status
    {
        std::stringstream ss;
        ss << "Network: " << (networkConnected ? "Connected" : "Disconnected") << "\n";
        ss << "Local IP: " << SRC_IP << ":" << SRC_PORT << "\n";
