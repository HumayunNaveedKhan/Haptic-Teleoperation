// Adaptive Packet Buffer Class
class AdaptivePacketBuffer {
private:
    std::deque<Packet> packetBuffer;
    std::deque<Packet> processedPackets;
    std::deque<Packet> slidingWindow;
    std::mutex bufferMutex;
    std::mutex processedMutex;
    std::mutex windowMutex;
    std::chrono::steady_clock::time_point lastReleaseTime;
    std::map<int, double> packetTimeGaps;

public:
    AdaptivePacketBuffer() : lastReleaseTime(std::chrono::steady_clock::now()) {}

    // New method to add a packet to processedPackets safely
    void addProcessedPacket(const Packet& packet) {
        std::lock_guard<std::mutex> lock(processedMutex);
        processedPackets.push_back(packet);
        while (processedPackets.size() > MAX_DISPLAY_PACKETS) {
            processedPackets.pop_front();
        }
    }

    void addPacket(const Packet& packet) {
        std::lock_guard<std::mutex> lock(bufferMutex);
        if (!packetBuffer.empty()) {
            auto prevPacket = packetBuffer.back();
            double timeGapMs = std::chrono::duration_cast<std::chrono::duration<double, std::milli>>(
                packet.receiveTime - prevPacket.receiveTime).count();
            packetTimeGaps[packet.packetNumber] = timeGapMs;
        }
        packetBuffer.push_back(packet);
        if (packetBuffer.size() > MAX_BUFFER_SIZE) {
            packetBuffer.pop_front();
        }
        {
            std::lock_guard<std::mutex> windowLock(windowMutex);
            slidingWindow.push_back(packet);
            while (slidingWindow.size() > SLIDING_WINDOW_SIZE) {
                slidingWindow.pop_front();
            }
            calculateDelayStatistics();
        }
    }
    void calculateDelayStatistics() {
        if (slidingWindow.size() < 2) return;
        double sumDelay = 0.0;
        std::vector<double> delays;
        for (size_t i = 1; i < slidingWindow.size(); i++) {
            double delay = std::chrono::duration_cast<std::chrono::duration<double, std::milli>>(
                slidingWindow[i].receiveTime - slidingWindow[i - 1].receiveTime).count();
            sumDelay += delay;
            delays.push_back(delay);
        }
        double avgDelay = sumDelay / delays.size();
        double sumSquaredDiff = 0.0;
        for (double delay : delays) {
            double diff = delay - avgDelay;
            sumSquaredDiff += diff * diff;
        }
        double jitter = sqrt(sumSquaredDiff / delays.size());
        {
            std::lock_guard<std::mutex> statsLock(statsMutex);
            globalPacketStats.avgNetworkDelay = avgDelay;
            globalPacketStats.networkJitter = jitter;
            globalPacketStats.adaptedStiffness = calculateAdaptiveStiffness(jitter, avgDelay);
        }
    }

    void processPackets() {
        auto now = std::chrono::steady_clock::now();
        std::lock_guard<std::mutex> bufferLock(bufferMutex);
        std::lock_guard<std::mutex> processedLock(processedMutex);
        if (!packetBuffer.empty()) {
            double avgTimeMs;
            {
                std::lock_guard<std::mutex> statsLock(statsMutex);
                avgTimeMs = globalPacketStats.avgInterPacketTime;
            }
            if (avgTimeMs <= 0) avgTimeMs = 10.0;
            avgTimeMs *= GLOBAL_RELEASE_RATE_FACTOR;
            auto timeSinceLastRelease = std::chrono::duration<double, std::milli>(
                now - lastReleaseTime).count();
            auto oldestPacket = std::min_element(packetBuffer.begin(), packetBuffer.end(),
                [](const Packet& a, const Packet& b) {
                    return a.packetNumber < b.packetNumber;
                });
            if (timeSinceLastRelease >= avgTimeMs) {
                int delayAmount = 0;
                if (UNIFORM_DELAY_ENABLED) {
                    delayAmount = UNIFORM_DELAY_MS;
                }
                if (RANDOM_DELAY_ENABLED) {
                    delayAmount = randomDelayDist(gen);
                }
                if (delayAmount > 0) {
                    std::this_thread::sleep_for(std::chrono::milliseconds(delayAmount));
                }
                Packet processedPacket = *oldestPacket;
                processedPacket.processingDelay = std::chrono::duration<float, std::milli>(
                    std::chrono::steady_clock::now() - processedPacket.receiveTime).count();
                processedPacket.isProcessed = true;
                {
                    std::lock_guard<std::mutex> lock(deviceMutex);
                    deviceState.targetPos[0] = processedPacket.x;
                    deviceState.targetPos[1] = processedPacket.y;
                    deviceState.targetPos[2] = processedPacket.z;
                }
                {
                    std::lock_guard<std::mutex> statsLock(statsMutex);
                    globalPacketStats.rawDelays.push_back(
                        std::make_pair(processedPacket.packetNumber, processedPacket.delay));
                    globalPacketStats.processedDelays.push_back(
                        std::make_pair(processedPacket.packetNumber, processedPacket.processingDelay));
                    while (globalPacketStats.rawDelays.size() > MAX_GRAPH_POINTS) {
                        globalPacketStats.rawDelays.pop_front();
                    }
                    while (globalPacketStats.processedDelays.size() > MAX_GRAPH_POINTS) {
                        globalPacketStats.processedDelays.pop_front();
                    }
                    globalPacketStats.totalPacketsProcessed++;
                }
                processedPackets.push_back(processedPacket);
                while (processedPackets.size() > MAX_DISPLAY_PACKETS) {
                    processedPackets.pop_front();
                }
                packetBuffer.erase(oldestPacket);
                lastReleaseTime = now;
                if (LOG_TO_CONSOLE) {
                    std::cout << "Processed packet #" << processedPacket.packetNumber
                        << " from " << processedPacket.srcIP << ":" << processedPacket.srcPort
                        << " [" << processedPacket.x << ", " << processedPacket.y << ", " << processedPacket.z << "]"
                        << " Initial delay: " << processedPacket.delay << " ms"
                        << " Processing delay: " << processedPacket.processingDelay << " ms" << std::endl;
                }
                if (LOG_TO_CSV) {
                    logPacketToCSV(processedPacket);
                }
            }
        }
    }

    std::deque<Packet> getBufferedPackets() {
        std::lock_guard<std::mutex> lock(bufferMutex);
        std::deque<Packet> displayPackets;
        int tempIdx = static_cast<int>(packetBuffer.size()) - MAX_DISPLAY_PACKETS;
        int startIdx = (tempIdx > 0) ? tempIdx : 0;
        for (int i = startIdx; i < static_cast<int>(packetBuffer.size()); i++) {
            displayPackets.push_back(packetBuffer[i]);
        }
        return displayPackets;
    }

    std::deque<Packet> getSlidingWindow() {
        std::lock_guard<std::mutex> lock(windowMutex);
        return slidingWindow;
    }

    std::deque<Packet> getProcessedPackets() {
        std::lock_guard<std::mutex> lock(processedMutex);
        return processedPackets;
    }

    double getPacketTimeGap(int packetNumber) {
        auto it = packetTimeGaps.find(packetNumber);
        if (it != packetTimeGaps.end()) {
            return it->second;
        }
        return 0.0;
    }

    size_t getBufferSize() {
        std::lock_guard<std::mutex> lock(bufferMutex);
        return packetBuffer.size();
    }

    size_t getProcessedSize() {
        std::lock_guard<std::mutex> lock(processedMutex);
        return processedPackets.size();
    }

    size_t getSlidingWindowSize() {
        std::lock_guard<std::mutex> lock(windowMutex);
        return slidingWindow.size();
    }
};
AdaptivePacketBuffer adaptiveBuffer;

double calculateAdaptiveStiffness(double jitter, double avgDelay) {
    double stiffness = STIFFNESS_K;
    if (jitter > JITTER_THRESHOLD_MS) {
        double jitterFactor = std::max(0.0, std::min(1.0,
            JITTER_THRESHOLD_MS / (jitter + JITTER_THRESHOLD_MS)));
        double targetStiffness = MIN_STIFFNESS_K +
            jitterFactor * (MAX_STIFFNESS_K - MIN_STIFFNESS_K);
        stiffness = stiffness * (1.0 - STIFFNESS_ADAPTATION_RATE) +
            targetStiffness * STIFFNESS_ADAPTATION_RATE;
    }
    else {
        stiffness = stiffness * (1.0 - STIFFNESS_ADAPTATION_RATE) +
            MAX_STIFFNESS_K * STIFFNESS_ADAPTATION_RATE;
    }
    return stiffness;
}

