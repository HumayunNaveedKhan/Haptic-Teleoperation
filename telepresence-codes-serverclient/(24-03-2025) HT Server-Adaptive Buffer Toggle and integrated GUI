        std::lock_guard<std::mutex> lock(clientMutex);
        clientConnected = lastClient.valid;
        if (clientConnected) {
            strcpy_s(clientIP, lastClient.ipStr);
            clientPort = lastClient.port;
        }
    }
    if (clientConnected) {
        snprintf(statStr, sizeof(statStr), "Connected Client: %s:%d", clientIP, clientPort);
        renderSmallText(x + 0.02f, textY, FONT_MEDIUM, statStr, 0.2f, 0.9f, 0.2f);
    }
    else {
        renderSmallText(x + 0.02f, textY, FONT_MEDIUM, "No Client Connected", 0.9f, 0.3f, 0.3f);
    }
    textY -= TEXT_SPACING;
    snprintf(statStr, sizeof(statStr), "Logging to: %s", CSV_FILENAME.c_str());
    renderSmallText(x + 0.01f, textY, FONT_MEDIUM, statStr);
    textY -= TEXT_SPACING;
    snprintf(statStr, sizeof(statStr), "Active packets: Every %d after %d packets",
        FEEDBACK_ACTIVE_PKTS, PACKET_UTILIZATION_INTERVAL);
    renderSmallText(x + 0.01f, textY, FONT_MEDIUM, statStr, 0.2f, 0.7f, 0.9f);
}

void display() {
    glClearColor(0.05f, 0.05f, 0.1f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(-1.0, 1.0, -1.0, 1.0);
    glMatrixMode(GL_MODELVIEW);
    glLoadIdentity();
    glScalef(scaleFactor, scaleFactor, 1.0f);
    auto bufferedPackets = adaptiveBuffer.getBufferedPackets();
    auto processedPackets = adaptiveBuffer.getProcessedPackets();
    if (!bufferedPackets.empty()) {
        drawPacketVisualization(bufferedPackets, -0.8f, "Incoming Packets", false);
    }
    if (!processedPackets.empty()) {
        drawPacketVisualization(processedPackets, 0.0f, "Processed Packets", true);
    }
    drawHapticStatus(-0.9f, 0.2f);
    char netInfoStr[128];
    snprintf(netInfoStr, sizeof(netInfoStr),
        "Network: Port %d (receive+send) | Release Rate: %.1fx | Walls: %s",
        UDP_PORT, GLOBAL_RELEASE_RATE_FACTOR,
        hapticConfig.wallsEnabled ? "On" : "Off");
    renderSmallText(-0.9f, -0.9f, FONT_MEDIUM, netInfoStr);
    bool useAdaptive;
    {
        std::lock_guard<std::mutex> lock(adaptiveBufferMutex);
        useAdaptive = USE_ADAPTIVE_BUFFER;
    }
    char bufferInfoStr[128];
    snprintf(bufferInfoStr, sizeof(bufferInfoStr),
        "Adaptive Buffering: %s | Window Size: %d packets",
        useAdaptive ? "Enabled" : "Disabled", SLIDING_WINDOW_SIZE);
    renderSmallText(0.1f, -0.9f, FONT_MEDIUM, bufferInfoStr);
    if (showStats) {
        drawStatisticsPanel(0.0f, -0.1f, 0.5f, 0.3f);
    }
    drawFeedbackPanel(-0.9f, -0.8f, 0.8f, 0.3f);
    if (showGraphs) {
        drawDelayGraphs(0.1f, -0.8f, 0.8f, 0.3f);
    }
    if (showJitterAnalysis) {
        drawNetworkJitterAnalysis(0.65f, -0.1f, 0.5f, 0.3f);
    }
    if (showLegend) {
        drawLegendBox(0.7f, 0.7f, LEGEND_WIDTH, LEGEND_HEIGHT);
    }
    if (showHelp) {
        drawHelpScreen();
    }
    glutSwapBuffers();
}

void reshape(int w, int h) {
    windowWidth = w;
    windowHeight = h;
    glViewport(0, 0, windowWidth, windowHeight);
}

void keyboard(unsigned char key, int x, int y) {
    bool hapticEnabled, wallsEnabled;
    double forceScale, Kp, Kd;
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticEnabled = hapticConfig.hapticEnabled;
        wallsEnabled = hapticConfig.wallsEnabled;
        forceScale = hapticConfig.forceScale;
        Kp = hapticConfig.Kp;
        Kd = hapticConfig.Kd;
    }
    switch (key) {
    case 27: // Escape key
        if (showHelp) {
            showHelp = false;
        }
        else {
            cleanup();
            exit(0);
        }
        break;
    case 'f':
    case 'F':
        fullscreen = !fullscreen;
        if (fullscreen) {
            glutFullScreen();
        }
        else {
            glutReshapeWindow(1280, 800);
        }
        break;
    case 'h':
    case 'H':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.hapticEnabled = !hapticConfig.hapticEnabled;
        std::cout << "Haptic feedback "
            << (hapticConfig.hapticEnabled ? "enabled" : "disabled") << std::endl;
    }
    break;
    case 'w':
    case 'W':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.wallsEnabled = !hapticConfig.wallsEnabled;
        std::cout << "Virtual walls "
            << (hapticConfig.wallsEnabled ? "enabled" : "disabled") << std::endl;
    }
    break;
    case 's':
    case 'S':
        showStats = !showStats;
        break;
    case 'g':
    case 'G':
        showGraphs = !showGraphs;
        break;
    case 'j':
    case 'J':
        showJitterAnalysis = !showJitterAnalysis;
        break;
    case 'l':
    case 'L':
        showLegend = !showLegend;
        break;
    case 'v':
    case 'V':
        showVectorVis = !showVectorVis;
        break;
    case 'u':
    case 'U':
        UNIFORM_DELAY_ENABLED = !UNIFORM_DELAY_ENABLED;
        std::cout << "Uniform delay "
            << (UNIFORM_DELAY_ENABLED ? "enabled" : "disabled") << std::endl;
        break;
    case 'r':
    case 'R':
        RANDOM_DELAY_ENABLED = !RANDOM_DELAY_ENABLED;
        std::cout << "Random delay "
            << (RANDOM_DELAY_ENABLED ? "enabled" : "disabled") << std::endl;
        break;
    case 't':
    case 'T':
    {
        std::lock_guard<std::mutex> lock(adaptiveBufferMutex);
        USE_ADAPTIVE_BUFFER = !USE_ADAPTIVE_BUFFER;
        std::cout << "Adaptive buffer "
            << (USE_ADAPTIVE_BUFFER ? "enabled" : "disabled") << std::endl;
    }
    break;
    case '+':
    case '=':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.forceScale *= 1.1;
        std::cout << "Force scaling increased to " << hapticConfig.forceScale << std::endl;
    }
    break;
    case '-':
    case '_':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.forceScale *= 0.9;
        std::cout << "Force scaling decreased to " << hapticConfig.forceScale << std::endl;
    }
    break;
    case 'k':
    case 'K':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.Kp *= 1.1;
        std::cout << "Stiffness increased to " << hapticConfig.Kp << " N/m" << std::endl;
    }
    break;
    case 'i':
    case 'I':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.Kp *= 0.9;
        std::cout << "Stiffness decreased to " << hapticConfig.Kp << " N/m" << std::endl;
    }
    break;
    case 'd':
    case 'D':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.Kd *= 1.1;
        std::cout << "Damping increased to " << hapticConfig.Kd << " Ns/m" << std::endl;
    }
    break;
    case 'a':
    case 'A':
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.Kd *= 0.9;
        std::cout << "Damping decreased to " << hapticConfig.Kd << " Ns/m" << std::endl;
    }
    break;
    case '1': case '2': case '3': case '4': case '5':
    case '6': case '7': case '8': case '9':
        GLOBAL_RELEASE_RATE_FACTOR = (float)(key - '0');
        std::cout << "Global release rate factor set to " << GLOBAL_RELEASE_RATE_FACTOR << std::endl;
        break;
    }
    glutPostRedisplay();
}

void specialKeyboard(int key, int x, int y) {
    switch (key) {
    case GLUT_KEY_F1:
        showHelp = !showHelp;
        break;
    case GLUT_KEY_UP:
        if (UNIFORM_DELAY_ENABLED) {
            UNIFORM_DELAY_MS += 10;
            std::cout << "Uniform delay increased to " << UNIFORM_DELAY_MS << " ms" << std::endl;
        }
        break;
    case GLUT_KEY_DOWN:
        if (UNIFORM_DELAY_ENABLED && UNIFORM_DELAY_MS >= 10) {
            UNIFORM_DELAY_MS -= 10;
            std::cout << "Uniform delay decreased to " << UNIFORM_DELAY_MS << " ms" << std::endl;
        }
        break;
    }
    glutPostRedisplay();
}

void timerCallback(int value) {
    glutPostRedisplay();
    glutTimerFunc(16, timerCallback, 0);
}

int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_RGBA | GLUT_DOUBLE);
    glutInitWindowSize(windowWidth, windowHeight);
    glutCreateWindow("Enhanced Haptic Teleoperation System with Adaptive Buffering");
    glutDisplayFunc(display);
    glutReshapeFunc(reshape);
    glutKeyboardFunc(keyboard);
    glutSpecialFunc(specialKeyboard);
    glutTimerFunc(16, timerCallback, 0);
    if (!initNetwork()) {
        std::cerr << "Failed to initialize network. Exiting..." << std::endl;
        return 1;
    }
    initHapticDevice();
    initCSVFile();
    std::cout << "------------------------------------------------------" << std::endl;
    std::cout << "Enhanced Haptic Teleoperation System with Adaptive Buffering" << std::endl;
    std::cout << "Network Port: " << UDP_PORT << " (for both receiving and sending feedback)" << std::endl;
    std::cout << "Adaptive Buffering: Window Size = " << SLIDING_WINDOW_SIZE << " packets (Toggle with T)" << std::endl;
    std::cout << "Packet Utilization: Marking every " << FEEDBACK_ACTIVE_PKTS
        << " packets after " << PACKET_UTILIZATION_INTERVAL << " as active" << std::endl;
    std::cout << "Press F1 for help, Esc to exit" << std::endl;
    std::cout << "------------------------------------------------------" << std::endl;
    std::thread networkRecvThread(receivePackets);
    networkRecvThread.detach();
    std::thread processingThread(processPacketsThread);
    processingThread.detach();
    std::thread hapticThread(updateHapticState);
    hapticThread.detach();
    std::thread feedbackThread(continuousFeedbackThread);
    feedbackThread.detach();
    glutMainLoop();
    return 0;
}
