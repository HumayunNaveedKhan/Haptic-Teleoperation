void logPacketToCSV(const Packet& packet, const FeedbackPacket* feedback) {
    std::lock_guard<std::mutex> lock(csvMutex);
    if (csvFile.is_open()) {
        csvFile << getCurrentTimestamp() << ","
            << packet.packetNumber << ","
            << packet.srcIP << "," << packet.srcPort << ","
            << packet.dstIP << "," << packet.dstPort << ","
            << std::fixed << std::setprecision(6)
            << packet.x << "," << packet.y << "," << packet.z << ","
            << packet.delay << "," << packet.processingDelay << ",";
        double networkDelay, networkJitter;
        {
            std::lock_guard<std::mutex> statsLock(statsMutex);
            networkDelay = globalPacketStats.avgNetworkDelay;
            networkJitter = globalPacketStats.networkJitter;
        }
        if (feedback) {
            auto feedbackTime = std::chrono::system_clock::to_time_t(
                std::chrono::system_clock::now());
            std::stringstream feedbackTimeStr;
            struct tm feedbackTimeInfo;
            localtime_s(&feedbackTimeInfo, &feedbackTime);
            feedbackTimeStr << std::put_time(&feedbackTimeInfo, "%Y-%m-%d %H:%M:%S");
            csvFile << feedbackTimeStr.str() << ","
                << std::fixed << std::setprecision(6)
                << feedback->force[0] << "," << feedback->force[1] << "," << feedback->force[2] << ","
                << feedback->position[0] << "," << feedback->position[1] << "," << feedback->position[2] << ","
                << feedback->error[0] << "," << feedback->error[1] << "," << feedback->error[2] << ","
                << feedback->stiffness << "," << feedback->damping << ","
                << (feedback->isActive ? "1" : "0") << ","
                << feedback->message << ","
                << networkDelay << "," << networkJitter;
        }
        else {
            csvFile << ",,,,,,,,,,,,,,";
            csvFile << networkDelay << "," << networkJitter;
        }
        csvFile << std::endl;
    }
}

float calculateMagnitude(const Packet& packet) {
    return sqrt(packet.x * packet.x + packet.y * packet.y + packet.z * packet.z);
}

std::string formatTimestampForDisplay(const char* timestamp) {
    std::string ts(timestamp);
    size_t spacePos = ts.find(' ');
    if (spacePos != std::string::npos && spacePos + 1 < ts.length()) {
        return ts.substr(spacePos + 1);
    }
    return ts;
}

void sendFeedback(const sockaddr_in& clientAddr, int packetNumber, const double force[3],
    const double position[3], const double error[3], double stiffness, double damping, bool isActive) {
    if (!FEEDBACK_ENABLED) return;
    std::lock_guard<std::mutex> lock(socketMutex);
    FeedbackPacket feedback;
    feedback.packetNumber = packetNumber;
    memcpy(feedback.force, force, sizeof(double) * 3);
    memcpy(feedback.position, position, sizeof(double) * 3);
    memcpy(feedback.error, error, sizeof(double) * 3);
    feedback.stiffness = stiffness;
    feedback.damping = damping;
    feedback.isActive = isActive;
    feedback.sendTime = std::chrono::steady_clock::now();
    snprintf(feedback.message, sizeof(feedback.message),
        "Force feedback for packet %d (%s)",
        packetNumber,
        isActive ? "ACTIVE" : "passive");
    int result = sendto(recvSocket, (const char*)&feedback, sizeof(feedback), 0,
        (const sockaddr*)&clientAddr, sizeof(clientAddr));
    if (result == SOCKET_ERROR) {
        std::cerr << "Failed to send feedback. Error: " << WSAGetLastError() << std::endl;
    }
    else {
        {
            std::lock_guard<std::mutex> feedbackLock(feedbackMutex);
            feedbackHistory.push_back(feedback);
            while (feedbackHistory.size() > MAX_FEEDBACK_HISTORY) {
                feedbackHistory.pop_front();
            }
            std::lock_guard<std::mutex> statsLock(statsMutex);
            globalPacketStats.totalFeedbackSent++;
        }
        auto processedPackets = adaptiveBuffer.getProcessedPackets();
        for (const auto& packet : processedPackets) {
            if (packet.packetNumber == packetNumber) {
                if (LOG_TO_CSV) {
                    logPacketToCSV(packet, &feedback);
                }
                break;
            }
        }
        if (LOG_TO_CONSOLE && isActive) {
            std::cout << "Sent ACTIVE feedback for packet #" << packetNumber
                << " to " << inet_ntoa(clientAddr.sin_addr) << ":" << ntohs(clientAddr.sin_port)
                << " Force: [" << feedback.force[0] << ", " << feedback.force[1] << ", " << feedback.force[2] << "]"
                << std::endl;
        }
    }
}

void continuousFeedbackThread() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_ABOVE_NORMAL);
    std::cout << "Continuous feedback thread started" << std::endl;
    int feedbackPacketCounter = 0;
    while (true) {
        ClientInfo client;
        bool hasClient = false;
        {
            std::lock_guard<std::mutex> lock(clientMutex);
            if (lastClient.valid) {
                client = lastClient;
                hasClient = true;
            }
        }
        if (hasClient) {
            double currentPos[3], currentForce[3], targetPos[3];
            double posError[3];
            double Kp, Kd;
            {
                std::lock_guard<std::mutex> deviceLock(deviceMutex);
                memcpy(currentPos, deviceState.position, sizeof(double) * 3);
                memcpy(currentForce, deviceState.force, sizeof(double) * 3);
                memcpy(targetPos, deviceState.targetPos, sizeof(double) * 3);
                for (int i = 0; i < 3; i++) {
                    posError[i] = targetPos[i] - currentPos[i];
                }
            }
            {
                std::lock_guard<std::mutex> hapticLock(hapticMutex);
                Kp = hapticConfig.Kp;
                Kd = hapticConfig.Kd;
            }
            feedbackPacketCounter++;
            bool isActive = false;
            if (feedbackPacketCounter > PACKET_UTILIZATION_INTERVAL) {
                if (feedbackPacketCounter <= PACKET_UTILIZATION_INTERVAL + FEEDBACK_ACTIVE_PKTS) {
                    isActive = true;
                }
                else if (feedbackPacketCounter > PACKET_UTILIZATION_INTERVAL + FEEDBACK_ACTIVE_PKTS) {
                    feedbackPacketCounter = 0;
                }
            }
            int packetNumber;
            {
                std::lock_guard<std::mutex> lock(packetCounterMutex);
                packetNumber = globalPacketCounter++;
            }
            sendFeedback(client.addr, packetNumber, currentForce, currentPos, posError, Kp, Kd, isActive);
        }
        std::this_thread::sleep_for(std::chrono::microseconds(PACKET_SEND_INTERVAL_US));
    }
}

bool initNetwork() {
    WSADATA wsaData;
    int result = WSAStartup(MAKEWORD(2, 2), &wsaData);
    if (result != 0) {
        std::cerr << "WSAStartup failed: " << result << std::endl;
        return false;
    }
    {
        std::lock_guard<std::mutex> lock(socketMutex);
        recvSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (recvSocket == INVALID_SOCKET) {
            std::cerr << "Failed to create socket. Error: " << WSAGetLastError() << std::endl;
            WSACleanup();
            return false;
        }
        DWORD timeout = SOCKET_TIMEOUT_MS;
        if (setsockopt(recvSocket, SOL_SOCKET, SO_RCVTIMEO, (const char*)&timeout, sizeof(timeout)) == SOCKET_ERROR) {
            std::cerr << "Failed to set socket timeout. Error: " << WSAGetLastError() << std::endl;
        }
        sockaddr_in serverAddr;
        memset(&serverAddr, 0, sizeof(serverAddr));
        serverAddr.sin_family = AF_INET;
        serverAddr.sin_port = htons(UDP_PORT);
        if (inet_pton(AF_INET, SERVER_IP, &(serverAddr.sin_addr)) != 1) {
            serverAddr.sin_addr.s_addr = INADDR_ANY;
            std::cout << "Using INADDR_ANY for socket binding" << std::endl;
        }
        if (bind(recvSocket, (sockaddr*)&serverAddr, sizeof(serverAddr)) == SOCKET_ERROR) {
            std::cerr << "Failed to bind socket. Error: " << WSAGetLastError() << std::endl;
            closesocket(recvSocket);
            WSACleanup();
            return false;
        }
    }
    char hostname[256];
    if (gethostname(hostname, sizeof(hostname)) == 0) {
        struct addrinfo hints, * res, * p;
        memset(&hints, 0, sizeof(hints));
        hints.ai_family = AF_INET;
        hints.ai_socktype = SOCK_DGRAM;
        if (getaddrinfo(hostname, NULL, &hints, &res) == 0) {
            std::cout << "Available server IP addresses:" << std::endl;
            for (p = res; p != NULL; p = p->ai_next) {
                struct sockaddr_in* addr = (struct sockaddr_in*)p->ai_addr;
                char ipStr[INET_ADDRSTRLEN];
                inet_ntop(AF_INET, &(addr->sin_addr), ipStr, INET_ADDRSTRLEN);
                std::cout << "  - " << ipStr << std::endl;
            }
            freeaddrinfo(res);
        }
    }
    std::cout << "Network initialized, listening on UDP port " << UDP_PORT << std::endl;
    std::cout << "Using same port (" << UDP_PORT << ") for sending feedback responses" << std::endl;
    return true;
}

void receivePackets() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_PACKET_RECEPTION);
    std::cout << "Packet receiver thread started" << std::endl;
    char buffer[MAX_PACKET_SIZE];
    while (true) {
        sockaddr_in clientAddr;
        int clientAddrLen = sizeof(clientAddr);
        int bytesReceived = recvfrom(recvSocket, buffer, MAX_PACKET_SIZE, 0,
            (sockaddr*)&clientAddr, &clientAddrLen);
        if (bytesReceived > 0) {
            {
                std::lock_guard<std::mutex> lock(clientMutex);
                lastClient.addr = clientAddr;
                lastClient.valid = true;
                lastClient.port = ntohs(clientAddr.sin_port);
                lastClient.lastActivity = std::chrono::steady_clock::now();
                inet_ntop(AF_INET, &(clientAddr.sin_addr), lastClient.ipStr, INET_ADDRSTRLEN);
            }
            Packet packet;
            int copySize = bytesReceived;
            if (copySize > (int)sizeof(Packet)) {
                copySize = (int)sizeof(Packet);
            }
            memcpy(&packet, buffer, copySize);
            packet.receiveTime = std::chrono::steady_clock::now();

            bool useAdaptive;
            {
                std::lock_guard<std::mutex> lock(adaptiveBufferMutex);
                useAdaptive = USE_ADAPTIVE_BUFFER;
            }

            if (useAdaptive) {
                adaptiveBuffer.addPacket(packet);
            }
            else {
                // Direct execution
                int delayAmount = 0;
                if (UNIFORM_DELAY_ENABLED) {
                    delayAmount = UNIFORM_DELAY_MS;
                }
                if (RANDOM_DELAY_ENABLED) {
                    delayAmount = randomDelayDist(gen);
                }
                if (delayAmount > 0) {
                    std::this_thread::sleep_for(std::chrono::milliseconds(delayAmount));
                }
                packet.processingDelay = std::chrono::duration<float, std::milli>(
                    std::chrono::steady_clock::now() - packet.receiveTime).count();
                packet.isProcessed = true;
                {
                    std::lock_guard<std::mutex> lock(deviceMutex);
                    deviceState.targetPos[0] = packet.x;
                    deviceState.targetPos[1] = packet.y;
                    deviceState.targetPos[2] = packet.z;
                }
                {
                    std::lock_guard<std::mutex> statsLock(statsMutex);
                    globalPacketStats.rawDelays.push_back(
                        std::make_pair(packet.packetNumber, packet.delay));
                    globalPacketStats.processedDelays.push_back(
                        std::make_pair(packet.packetNumber, packet.processingDelay));
                    while (globalPacketStats.rawDelays.size() > MAX_GRAPH_POINTS) {
                        globalPacketStats.rawDelays.pop_front();
                    }
                    while (globalPacketStats.processedDelays.size() > MAX_GRAPH_POINTS) {
                        globalPacketStats.processedDelays.pop_front();
                    }
                    globalPacketStats.totalPacketsProcessed++;
                }
                // Use new method to add to processed packets
                adaptiveBuffer.addProcessedPacket(packet);
                if (LOG_TO_CONSOLE) {
                    std::cout << "Directly processed packet #" << packet.packetNumber
                        << " from " << packet.srcIP << ":" << packet.srcPort
                        << " [" << packet.x << ", " << packet.y << ", " << packet.z << "]"
                        << " Initial delay: " << packet.delay << " ms"
                        << " Processing delay: " << packet.processingDelay << " ms" << std::endl;
                }
                if (LOG_TO_CSV) {
                    logPacketToCSV(packet);
                }
            }
            {
                std::lock_guard<std::mutex> lock(statsMutex);
                if (globalPacketStats.totalPacketsReceived == 0) {
                    globalPacketStats.firstPacketTime = packet.receiveTime;
                }
                if (globalPacketStats.totalPacketsReceived > 0) {
                    auto timeSinceLastPacket = std::chrono::duration<double, std::milli>(
                        packet.receiveTime - globalPacketStats.lastPacketTime).count();
                    globalPacketStats.packetTimings.push_back(timeSinceLastPacket);
                    while (globalPacketStats.packetTimings.size() > PACKET_HISTORY_SIZE) {
                        globalPacketStats.packetTimings.pop_front();
                    }
                    double sum = 0.0;
                    for (const auto& timing : globalPacketStats.packetTimings) {
                        sum += timing;
                    }
                    globalPacketStats.avgInterPacketTime = sum / globalPacketStats.packetTimings.size();
                }
                globalPacketStats.totalPacketsReceived++;
                globalPacketStats.lastPacketTime = packet.receiveTime;
                auto elapsedSeconds = std::chrono::duration<double>(
                    globalPacketStats.lastPacketTime - globalPacketStats.firstPacketTime).count();
                if (elapsedSeconds > 0) {
                    globalPacketStats.avgReceiveRate = globalPacketStats.totalPacketsReceived / elapsedSeconds;
                }
            }
            if (LOG_TO_CONSOLE) {
                std::cout << "Received packet #" << packet.packetNumber
                    << " from " << lastClient.ipStr << ":" << lastClient.port
                    << " [" << packet.x << ", " << packet.y << ", " << packet.z << "]"
                    << " Delay: " << packet.delay << " ms" << std::endl;
            }
        }
    }
}

void processPacketsThread() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_PROCESSING);
    std::cout << "Packet processor thread started" << std::endl;
    while (true) {
        bool useAdaptive;
        {
            std::lock_guard<std::mutex> lock(adaptiveBufferMutex);
            useAdaptive = USE_ADAPTIVE_BUFFER;
        }
        if (useAdaptive) {
            adaptiveBuffer.processPackets();
            adaptHapticParameters();
        }
        std::this_thread::sleep_for(std::chrono::milliseconds(1));
    }
}

bool initHapticDevice() {
    int deviceID = dhdOpen();
    if (deviceID < 0) {
        std::cerr << "Error: Failed to open haptic device. Error code: " << deviceID << std::endl;
        std::cerr << "Error message: " << dhdErrorGetLastStr() << std::endl;
        std::cout << "Continuing without haptic feedback..." << std::endl;
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.deviceConnected = false;
            hapticConfig.deviceID = -1;
        }
        return false;
    }
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        hapticConfig.deviceConnected = true;
        hapticConfig.deviceID = deviceID;
    }
    dhdEnableForce(DHD_ON);
    std::cout << "Haptic device initialized: " << dhdGetSystemName() << std::endl;
    return true;
}

void updateHapticState() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_HAPTICS);
    while (true) {
        bool hapticEnabled, wallsEnabled;
        double Kp, Kd, maxForce, forceScale;
        double posLimit[3];
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticEnabled = hapticConfig.hapticEnabled && hapticConfig.deviceConnected;
            Kp = hapticConfig.Kp;
            Kd = hapticConfig.Kd;
            maxForce = hapticConfig.maxForce;
            forceScale = hapticConfig.forceScale;
            wallsEnabled = hapticConfig.wallsEnabled;
            memcpy(posLimit, hapticConfig.posLimit, sizeof(double) * 3);
        }
        if (hapticEnabled) {
            double currentPos[3], targetPos[3], velocity[3];
            dhdGetPosition(&currentPos[0], &currentPos[1], &currentPos[2]);
            dhdGetLinearVelocity(&velocity[0], &velocity[1], &velocity[2]);
            {
                std::lock_guard<std::mutex> lock(deviceMutex);
                memcpy(targetPos, deviceState.targetPos, sizeof(double) * 3);
                memcpy(deviceState.position, currentPos, sizeof(double) * 3);
                memcpy(deviceState.velocity, velocity, sizeof(double) * 3);
            }
            double controlForce[3];
            double posError[3];
            for (int i = 0; i < 3; i++) {
                posError[i] = targetPos[i] - currentPos[i];
                controlForce[i] = (Kp * posError[i] - Kd * velocity[i]) * forceScale;
            }
            double wallForce[3] = { 0.0, 0.0, 0.0 };
            if (wallsEnabled) {
                calculateVirtualWallForces(currentPos, velocity, posLimit, wallForce);
            }
            double force[3];
            for (int i = 0; i < 3; i++) {
                force[i] = controlForce[i] + wallForce[i];
            }
            double forceMagnitude = sqrt(force[0] * force[0] + force[1] * force[1] + force[2] * force[2]);
            if (forceMagnitude > maxForce) {
                double scale = maxForce / forceMagnitude;
                force[0] *= scale;
                force[1] *= scale;
                force[2] *= scale;
            }
            dhdSetForce(force[0], force[1], force[2]);
            {
                std::lock_guard<std::mutex> lock(deviceMutex);
                memcpy(deviceState.force, force, sizeof(double) * 3);
            }
        }
        else {
            dhdSetForce(0.0, 0.0, 0.0);
            {
                std::lock_guard<std::mutex> lock(deviceMutex);
                deviceState.force[0] = 0.0;
                deviceState.force[1] = 0.0;
                deviceState.force[2] = 0.0;
            }
        }
        std::this_thread::sleep_for(std::chrono::microseconds(HAPTIC_THREAD_INTERVAL_US));
    }
}

void cleanup() {
    if (dhdGetDeviceCount() > 0) {
        dhdStop();
    }
    {
        std::lock_guard<std::mutex> lock(socketMutex);
        if (recvSocket != INVALID_SOCKET) {
            closesocket(recvSocket);
            recvSocket = INVALID_SOCKET;
        }
    }
    closeCSVFile();
    WSACleanup();
    std::cout << "Application cleaned up successfully" << std::endl;
}

