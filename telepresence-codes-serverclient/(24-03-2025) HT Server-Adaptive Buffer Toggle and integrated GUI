void drawPacketVisualization(const std::deque<Packet>& packets, float xOffset,
    const char* title, bool isProcessed,
    float barWidth = BAR_WIDTH, float maxHeight = BAR_MAX_HEIGHT) {
    renderSmallText(xOffset, 0.9f, FONT_LARGE, title, 0.9f, 0.9f, 1.0f);
    glColor3f(0.4f, 0.4f, 0.4f);
    glBegin(GL_LINES);
    glVertex2f(xOffset - 0.05f, 0.55f);
    glVertex2f(xOffset + 0.65f, 0.55f);
    glVertex2f(xOffset - 0.05f, 0.55f);
    glVertex2f(xOffset - 0.05f, 0.85f);
    glEnd();
    int index = 0;
    for (const auto& packet : packets) {
        float x = xOffset + (index * barWidth * 1.5f);
        float magnitude = calculateMagnitude(packet);
        float normalizedHeight = magnitude * 0.8f;
        if (normalizedHeight > maxHeight) normalizedHeight = maxHeight;
        if (isProcessed) {
            glColor3f(0.2f, 0.8f, 0.2f);
        }
        else {
            glColor3f(0.8f, 0.2f, 0.2f);
        }
        glBegin(GL_QUADS);
        glVertex2f(x, 0.55f);
        glVertex2f(x + barWidth, 0.55f);
        glVertex2f(x + barWidth, 0.55f + normalizedHeight);
        glVertex2f(x, 0.55f + normalizedHeight);
        glEnd();
        if (SHOW_PACKET_NUMBERS) {
            char packetNumStr[16];
            snprintf(packetNumStr, sizeof(packetNumStr), "%d", packet.packetNumber);
            float textY = 0.55f - 0.05f;
            if (index % 2 == 0) {
                textY -= TEXT_Y_OFFSET;
            }
            renderSmallText(x - 0.003f, textY, FONT_SMALL, packetNumStr);
        }
        if (index % TIMESTAMP_DISPLAY_INTERVAL == 0) {
            std::string formattedTime = formatTimestampForDisplay(packet.timestamp);
            renderSmallText(x - 0.02f, 0.70f + normalizedHeight + 0.01f, FONT_SMALL, formattedTime.c_str());
        }
        if (SHOW_TIME_GAPS && index > 0) {
            double timeGap = adaptiveBuffer.getPacketTimeGap(packet.packetNumber);
            if (timeGap > 0) {
                char timeGapStr[32];
                snprintf(timeGapStr, sizeof(timeGapStr), "%.1f ms", timeGap);
                renderSmallText(x - 0.08f, 0.40f, FONT_SMALL, timeGapStr);
            }
        }
        index++;
    }
    if (!packets.empty()) {
        const Packet& latestPacket = packets.back();
        float infoY = 0.30;
        std::ostringstream packetInfo;
        packetInfo << "Latest Packet: #" << latestPacket.packetNumber
            << " | From: " << latestPacket.srcIP << ":" << latestPacket.srcPort
            << " | To: " << latestPacket.dstIP << ":" << latestPacket.dstPort;
        renderSmallText(xOffset + 0.05f, infoY, FONT_MEDIUM, packetInfo.str().c_str());
        infoY -= TEXT_SPACING;
        std::ostringstream vectorInfo;
        vectorInfo << "Position Vector: [" << std::fixed << std::setprecision(3)
            << latestPacket.x << ", " << latestPacket.y << ", " << latestPacket.z << "]"
            << " | Magnitude: " << std::fixed << std::setprecision(3)
            << calculateMagnitude(latestPacket);
        renderSmallText(xOffset + 0.05f, infoY, FONT_MEDIUM, vectorInfo.str().c_str());
        infoY -= TEXT_SPACING;
        std::ostringstream delayInfo;
        if (isProcessed) {
            delayInfo << "Original Delay: " << std::fixed << std::setprecision(2)
                << latestPacket.delay << " ms"
                << " | Processing Delay: " << std::fixed << std::setprecision(2)
                << latestPacket.processingDelay << " ms";
        }
        else {
            delayInfo << "Original Delay: " << std::fixed << std::setprecision(2)
                << latestPacket.delay << " ms";
        }
        renderSmallText(xOffset + 0.05f, infoY, FONT_MEDIUM, delayInfo.str().c_str());
    }
}

void drawNetworkJitterAnalysis(float x, float y, float width, float height) {
    double avgDelay, jitter, adaptedStiffness;
    {
        std::lock_guard<std::mutex> statsLock(statsMutex);
        avgDelay = globalPacketStats.avgNetworkDelay;
        jitter = globalPacketStats.networkJitter;
        adaptedStiffness = globalPacketStats.adaptedStiffness;
    }
    size_t windowSize = adaptiveBuffer.getSlidingWindowSize();
    drawRectangle(x, y, width, height, 0.1f, 0.1f, 0.25f, 0.7f);
    renderSmallText(x + 0.02f, y + height - 0.03f, FONT_LARGE, "Network Jitter Analysis", 0.9f, 0.9f, 1.0f);
    float textY = y + height - 0.07f;
    char statStr[128];
    snprintf(statStr, sizeof(statStr), "Window Size: %zu packets", windowSize);
    renderSmallText(x + 0.02f, textY, FONT_MEDIUM, statStr);
    textY -= TEXT_SPACING;
    snprintf(statStr, sizeof(statStr), "Avg Network Delay: %.2f ms", avgDelay);
    renderSmallText(x + 0.02f, textY, FONT_MEDIUM, statStr);
    textY -= TEXT_SPACING;
    snprintf(statStr, sizeof(statStr), "Network Jitter: %.2f ms", jitter);
    renderSmallText(x + 0.02f, textY, FONT_MEDIUM, statStr,
        jitter > JITTER_THRESHOLD_MS ? 0.9f : 0.2f,
        jitter > JITTER_THRESHOLD_MS ? 0.2f : 0.9f,
        0.2f);
    textY -= TEXT_SPACING;
    snprintf(statStr, sizeof(statStr), "Adapted Stiffness: %.2f N/m (Min: %.1f, Max: %.1f)",
        adaptedStiffness, MIN_STIFFNESS_K, MAX_STIFFNESS_K);
    renderSmallText(x + 0.02f, textY, FONT_MEDIUM, statStr);
    textY -= TEXT_SPACING;
    snprintf(statStr, sizeof(statStr), "Active Feedback: Every %d packets after %d",
        FEEDBACK_ACTIVE_PKTS, PACKET_UTILIZATION_INTERVAL);
    renderSmallText(x + 0.02f, textY, FONT_MEDIUM, statStr);
    textY -= TEXT_SPACING;
    float jitterBarWidth = width - 0.1f;
    float jitterBarHeight = 0.03f;
    float jitterBarX = x + 0.05f;
    float jitterBarY = textY - 0.05f;
    drawRectangle(jitterBarX, jitterBarY, jitterBarWidth, jitterBarHeight, 0.2f, 0.2f, 0.2f);
    float maxJitter = 50.0f;
    float fillWidth = (jitter / maxJitter) * jitterBarWidth;
    if (fillWidth > jitterBarWidth) fillWidth = jitterBarWidth;
    float r = jitter > JITTER_THRESHOLD_MS ? 0.9f : 0.2f;
    float g = jitter > JITTER_THRESHOLD_MS ? 0.3f : 0.9f;
    float b = 0.2f;
    drawRectangle(jitterBarX, jitterBarY, fillWidth, jitterBarHeight, r, g, b, 0.9f, false);
    renderSmallText(jitterBarX, jitterBarY - 0.03f, FONT_SMALL, "0 ms");
    renderSmallText(jitterBarX + jitterBarWidth - 0.05f, jitterBarY - 0.03f, FONT_SMALL, "50+ ms");
    float thresholdX = jitterBarX + (JITTER_THRESHOLD_MS / maxJitter) * jitterBarWidth;
    glColor3f(1.0f, 1.0f, 1.0f);
    glLineWidth(2.0f);
    glBegin(GL_LINES);
    glVertex2f(thresholdX, jitterBarY - 0.01f);
    glVertex2f(thresholdX, jitterBarY + jitterBarHeight + 0.01f);
    glEnd();
    char thresholdStr[32];
    snprintf(thresholdStr, sizeof(thresholdStr), "Threshold (%.1f ms)", JITTER_THRESHOLD_MS);
    renderSmallText(thresholdX - 0.07f, jitterBarY + jitterBarHeight + 0.02f, FONT_SMALL, thresholdStr);
    float stiffBarY = jitterBarY - 0.08f;
    drawRectangle(jitterBarX, stiffBarY, jitterBarWidth, jitterBarHeight, 0.2f, 0.2f, 0.2f);
    float stiffnessRange = MAX_STIFFNESS_K - MIN_STIFFNESS_K;
    float stiffFillWidth = ((adaptedStiffness - MIN_STIFFNESS_K) / stiffnessRange) * jitterBarWidth;
    if (stiffFillWidth > jitterBarWidth) stiffFillWidth = jitterBarWidth;
    if (stiffFillWidth < 0) stiffFillWidth = 0;
    drawRectangle(jitterBarX, stiffBarY, stiffFillWidth, jitterBarHeight, 0.2f, 0.5f, 0.9f, 0.9f, false);
    char minStiffStr[32], maxStiffStr[32];
    snprintf(minStiffStr, sizeof(minStiffStr), "%.0f N/m", MIN_STIFFNESS_K);
    snprintf(maxStiffStr, sizeof(maxStiffStr), "%.0f N/m", MAX_STIFFNESS_K);
    renderSmallText(jitterBarX, stiffBarY - 0.03f, FONT_SMALL, minStiffStr);
    renderSmallText(jitterBarX + jitterBarWidth - 0.1f, stiffBarY - 0.03f, FONT_SMALL, maxStiffStr);
    renderSmallText(jitterBarX, stiffBarY + jitterBarHeight + 0.02f, FONT_SMALL, "Adaptive Stiffness");
}

void draw3DVector(float x, float y, float scale, const float vec[3], const char* label = nullptr) {
    glColor3f(0.5f, 0.5f, 0.5f);
    glBegin(GL_LINES);
    glVertex2f(x - 0.05f, y);
    glVertex2f(x + 0.05f, y);
    glVertex2f(x, y - 0.05f);
    glVertex2f(x, y + 0.05f);
    glEnd();
    glColor3f(0.9f, 0.3f, 0.3f);
    glBegin(GL_LINES);
    glVertex2f(x, y);
    glVertex2f(x + vec[0] * scale, y + vec[1] * scale);
    glEnd();
    glPointSize(5.0f);
    glBegin(GL_POINTS);
    glVertex2f(x + vec[0] * scale, y + vec[1] * scale);
    glEnd();
    if (label) {
        renderSmallText(x - 0.04f, y + 0.08f, FONT_MEDIUM, label);
    }
    char magnitudeStr[64];
    float magnitude = sqrt(vec[0] * vec[0] + vec[1] * vec[1] + vec[2] * vec[2]);
    snprintf(magnitudeStr, sizeof(magnitudeStr), "Mag: %.2f", magnitude);
    renderSmallText(x - 0.04f, y - 0.08f, FONT_SMALL, magnitudeStr);
    char compStr[64];
    snprintf(compStr, sizeof(compStr), "[%.2f, %.2f, %.2f]", vec[0], vec[1], vec[2]);
    renderSmallText(x - 0.04f, y - 0.10f, FONT_SMALL, compStr);
}
