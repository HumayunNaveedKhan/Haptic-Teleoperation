void processFeedbackPacket(const FeedbackPacket& packet)
{
    // Add the packet to the feedback buffer
    {
        std::lock_guard<std::mutex> lock(feedbackMutex);
        feedbackBuffer.push_back(packet);

        // Limit the buffer size
        while (feedbackBuffer.size() > MAX_HISTORY_SIZE) {
            feedbackBuffer.pop_front();
        }
    }

    // Record statistics for the packet
    recordPacketStatistics(packet);
}

void updateActiveFeedback()
{
    // This is called when it's time to utilize packets for feedback (after PACKET_UTILIZATION_INTERVAL)
    std::lock_guard<std::mutex> lock(feedbackMutex);

    // Check if there are enough packets in the buffer
    if (feedbackBuffer.size() < PACKETS_TO_UTILIZE) {
        return;
    }

    // Take the most recent packets to utilize
    std::vector<FeedbackPacket> activePackets;
    for (int i = 0; i < PACKETS_TO_UTILIZE && i < feedbackBuffer.size(); i++) {
        activePackets.push_back(feedbackBuffer[feedbackBuffer.size() - 1 - i]);
    }

    // Calculate averages for force and position
    float avgForce[3] = { 0.0f, 0.0f, 0.0f };
    float avgPosition[3] = { 0.0f, 0.0f, 0.0f };
    float avgError = 0.0f;
    float avgLatency = 0.0f;

    for (const auto& pkt : activePackets) {
        avgForce[0] += pkt.fx;
        avgForce[1] += pkt.fy;
        avgForce[2] += pkt.fz;

        avgPosition[0] += pkt.px;
        avgPosition[1] += pkt.py;
        avgPosition[2] += pkt.pz;

        avgError += pkt.positionError;
        avgLatency += pkt.latency;
    }

    // Compute the averages
    for (int i = 0; i < 3; i++) {
        avgForce[i] /= PACKETS_TO_UTILIZE;
        avgPosition[i] /= PACKETS_TO_UTILIZE;
    }
    avgError /= PACKETS_TO_UTILIZE;
    avgLatency /= PACKETS_TO_UTILIZE;

    // Update the current feedback values
    for (int i = 0; i < 3; i++) {
        currentForce[i] = avgForce[i];
        targetPosition[i] = avgPosition[i];
    }
    positionError = avgError;
    averageLatency = avgLatency;

    // Apply force to the haptic device
    updateHapticForce(cVector3d(currentForce[0], currentForce[1], currentForce[2]));

    // Clear the feedback buffer after processing
    feedbackBuffer.clear();
}

