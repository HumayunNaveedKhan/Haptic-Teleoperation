void recordPacketStatistics(const FeedbackPacket& packet)
{
    // Update the history vectors for graphs
    {
        std::lock_guard<std::mutex> lock(feedbackMutex);

        // Position history
        positionHistory[0].push_back(packet.px);
        positionHistory[1].push_back(packet.py);
        positionHistory[2].push_back(packet.pz);

        // Force history
        forceHistory[0].push_back(packet.fx);
        forceHistory[1].push_back(packet.fy);
        forceHistory[2].push_back(packet.fz);

        // Latency and error history
        latencyHistory.push_back(packet.latency);
        errorHistory.push_back(packet.positionError);

        // Limit the history size
        while (positionHistory[0].size() > MAX_HISTORY_SIZE) {
            for (int i = 0; i < 3; i++) {
                positionHistory[i].erase(positionHistory[i].begin());
                forceHistory[i].erase(forceHistory[i].begin());
            }
            latencyHistory.erase(latencyHistory.begin());
            errorHistory.erase(errorHistory.begin());
        }

        // Update min/max values for position
        minPositionX = std::min(minPositionX, packet.px);
        maxPositionX = std::max(maxPositionX, packet.px);
        minPositionY = std::min(minPositionY, packet.py);
        maxPositionY = std::max(maxPositionY, packet.py);
        minPositionZ = std::min(minPositionZ, packet.pz);
        maxPositionZ = std::max(maxPositionZ, packet.pz);

        // Update min/max values for force
        minForceX = std::min(minForceX, packet.fx);
        maxForceX = std::max(maxForceX, packet.fx);
        minForceY = std::min(minForceY, packet.fy);
        maxForceY = std::max(maxForceY, packet.fy);
        minForceZ = std::min(minForceZ, packet.fz);
        maxForceZ = std::max(maxForceZ, packet.fz);

        // Update min/max values for latency and error
        minLatency = std::min(minLatency, packet.latency);
        maxLatency = std::max(maxLatency, packet.latency);
        minError = std::min(minError, packet.positionError);
        maxError = std::max(maxError, packet.positionError);
    }
}

