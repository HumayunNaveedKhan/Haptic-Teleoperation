int main(int argc, char* argv[])
{
    //--------------------------------------------------------------------------
    // INITIALIZE CHAI3D
    //--------------------------------------------------------------------------
    // Initialize CHAI3D
    cout << endl;
    cout << "-----------------------------------" << endl;
    cout << "ENHANCED HAPTIC TELEOPERATION CLIENT" << endl;
    cout << "-----------------------------------" << endl;
    cout << "Commands:" << endl << endl;
    cout << "[1] - Change feedback mode (position, force, stiffness/damping)" << endl;
    cout << "[2] - Toggle feedback (enabled/disabled)" << endl;
    cout << "[c] - Configure server IP address" << endl;
    cout << "[f] - Toggle fullscreen" << endl;
    cout << "[m] - Toggle mirror display" << endl;
    cout << "[q] - Exit application" << endl;
    cout << endl << endl;

    // Get the current working directory
    resourceRoot = string(RESOURCE_PATH_STANDARD);

    //--------------------------------------------------------------------------
    // OPEN GL - WINDOW DISPLAY
    //--------------------------------------------------------------------------
    // Initialize GLFW library
    if (!glfwInit())
    {
        cout << "Failed to initialize GLFW library" << endl;
        return 1;
    }

    // Set error callback
    glfwSetErrorCallback(errorCallback);

    // Set OpenGL version
    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);

    // Set active stereo mode
    if (stereoMode == C_STEREO_ACTIVE)
    {
        glfwWindowHint(GLFW_STEREO, GL_TRUE);
    }
    else
    {
        glfwWindowHint(GLFW_STEREO, GL_FALSE);
    }

    // Get primary monitor size
    const GLFWvidmode* mode = glfwGetVideoMode(glfwGetPrimaryMonitor());
    int screenW = mode->width;
    int screenH = mode->height;

    // Set the window size
    width = (int)(WINDOW_WIDTH_RATIO * screenW);
    height = (int)(WINDOW_HEIGHT_RATIO * screenH);

    // Create display context
    window = glfwCreateWindow(width, height, "Haptic Teleoperation Client", NULL, NULL);
    if (!window)
    {
        cout << "Failed to create window" << endl;
        glfwTerminate();
        return 1;
    }

    // Get the width and height of the frame buffer
    glfwGetFramebufferSize(window, &width, &height);

    // Set the window position
    int windowPosX = (screenW - width) / 2;
    int windowPosY = (screenH - height) / 2;
    glfwSetWindowPos(window, windowPosX, windowPosY);

    // Make the OpenGL context current
    glfwMakeContextCurrent(window);

    // Initialize GLEW
    glewInit();

    // Set keyboard callback
    glfwSetKeyCallback(window, keyCallback);

    // Set resize callback
    glfwSetWindowSizeCallback(window, windowSizeCallback);

    // Initialize GLUT for the analytics window
    glutInit(&argc, argv);
    initAnalyticsWindow();

    // Set swap interval (vertical synchronization)
    glfwSwapInterval(swapInterval);

    //--------------------------------------------------------------------------
    // WORLD - CAMERA - LIGHTING
    //--------------------------------------------------------------------------

    // Create a new world
    world = new cWorld();

    // Set background color
    world->m_backgroundColor.setWhite();

    // Create a camera and insert it into the virtual world
    camera = new cCamera(world);
    world->addChild(camera);

    // Position and orient the camera
    camera->set(cVector3d(CAMERA_POSITION_X, CAMERA_POSITION_Y, CAMERA_POSITION_Z),    // Position
        cVector3d(CAMERA_LOOKAT_X, CAMERA_LOOKAT_Y, CAMERA_LOOKAT_Z),    // Look at
        cVector3d(CAMERA_UP_X, CAMERA_UP_Y, CAMERA_UP_Z));   // Up direction

    // Set the near and far clipping planes of the camera
    camera->setClippingPlanes(0.01, 10.0);

    // Set stereo mode
    camera->setStereoMode(stereoMode);

    // Set stereo eye separation and focal length
    camera->setStereoEyeSeparation(0.005);
    camera->setStereoFocalLength(0.5);

    // Set vertical mirrored display mode
    camera->setMirrorVertical(mirroredDisplay);

    // Enable multi-pass rendering to handle transparent objects
    camera->setUseMultipassTransparency(true);

    // Create a light source and attach it to the camera
    light = new cSpotLight(world);
    camera->addChild(light);

    // Define the light direction in the camera coordinate system
    light->setLocalPos(cVector3d(LIGHT_POSITION_X, LIGHT_POSITION_Y, LIGHT_POSITION_Z));
    light->setDir(cVector3d(LIGHT_DIRECTION_X, LIGHT_DIRECTION_Y, LIGHT_DIRECTION_Z));

    // Enable light source
    light->setEnabled(true);

    // Set light cone half angle
    light->setCutOffAngleDeg(LIGHT_CONE_ANGLE);

    // Create a background
    background = new cBackground();
    camera->m_backLayer->addChild(background);

    // Create a font
    font = NEW_CFONTCALIBRI20();

    // Create a label to display the haptic and graphic rate of the simulation
    labelRates = new cLabel(font);
    camera->m_frontLayer->addChild(labelRates);

    // Create a label to display information about the client
    labelMessage = new cLabel(font);
    camera->m_frontLayer->addChild(labelMessage);
    labelMessage->m_fontColor.setBlack();

    //--------------------------------------------------------------------------
    // HAPTIC DEVICE
    //--------------------------------------------------------------------------
    // Create a handler
    handler = new cHapticDeviceHandler();

    // Get the first haptic device
    handler->getDevice(hapticDevice, 0);

    // Retrieve information about the haptic device
    if (hapticDevice)
    {
        // Get the specifications of the haptic device
        hapticDeviceMaxStiffness = hapticDevice->getSpecifications().m_maxLinearStiffness;

        // Display a message about the haptic device
        cout << "Haptic device available: " << hapticDevice->getSpecifications().m_modelName << endl;
    }
    else
    {
        // No haptic device found, create a simulated position for demonstration
        cout << "No haptic device found. Using simulated position data." << endl;
        devicePosition.set(0.0, 0.0, 0.0);
    }

    //--------------------------------------------------------------------------
    // MAGNETIC SCENE OBJECTS
    //--------------------------------------------------------------------------
    // Create magnetic spheres
    for (int i = 0; i < NUM_SPHERES; i++)
    {
        // Create sphere
        spheres[i] = new cShapeSphere(SPHERE_RADIUS);
        world->addChild(spheres[i]);

        // Initialize velocity
        sphereVel[i].zero();

        // Set random initial position
        double x = 0.04 * (((double)rand() / RAND_MAX) * 2.0 - 1.0);
        double y = 0.04 * (((double)rand() / RAND_MAX) * 2.0 - 1.0);
        double z = 0.04 * ((double)rand() / RAND_MAX);
        spheres[i]->setLocalPos(x, y, z);

        // Set color based on sphere index
        if (i == 0) spheres[i]->m_material->setRedCrimson();
        else if (i == 1) spheres[i]->m_material->setBlueCornflower();
        else spheres[i]->m_material->setGreenForest();

        // Set physical properties
        spheres[i]->m_material->setStiffness(SPHERE_STIFFNESS);
    }

    //--------------------------------------------------------------------------
    // HAPTIC CURSOR
    //--------------------------------------------------------------------------
    // Create a sphere for haptic device cursor
    deviceCursor = new cShapeSphere(0.01);
    world->addChild(deviceCursor);
    deviceCursor->m_material->setRedIndian();

    //--------------------------------------------------------------------------
    // INITIALIZE NETWORKING
    //--------------------------------------------------------------------------
    // Get the local IP address of this machine
    getLocalIP(SRC_IP);
    cout << "Local IP address: " << SRC_IP << endl;

    // Allow the user to configure the server IP
    configureServerIP();

    // Initialize the sockets for network communication
    if (!initializeNetworkSockets()) {
        cout << "Failed to initialize network sockets. Exiting." << endl;
        return 1;
    }

    // Start the network threads for sending/receiving
    sendNetworkThread = new std::thread(sendNetworkThread_func);
    receiveNetworkThread = new std::thread(receiveNetworkThread_func);

    //--------------------------------------------------------------------------
    // START HAPTICS LOOP
    //--------------------------------------------------------------------------
    // Create a thread which starts the haptic rendering loop
    hapticsThread = new cThread();
    hapticsThread->start(updateHaptics, CTHREAD_PRIORITY_HAPTICS);

    // Start the main graphics rendering loop
    simulationRunning = true;
    simulationFinished = false;

    // Rendering loop
    while (!simulationFinished)
    {
        // Update the graphical scene
        updateGraphics();

        // Swap buffers
        glfwSwapBuffers(window);

        // Process events
        glfwPollEvents();

        // Check if the window should be closed
        if (glfwWindowShouldClose(window))
        {
            simulationFinished = true;
        }

        // Check if a key was pressed in the console window
        if (_kbhit())
        {
            int key = _getch();
            if (key == '1')
            {
                // Change feedback type
                currentFeedbackType = (FeedbackType)(((int)currentFeedbackType + 1) % 3);
                if (currentFeedbackType == FEEDBACK_POSITION)
                    cout << "Feedback mode: POSITION control" << endl;
                else if (currentFeedbackType == FEEDBACK_FORCE)
                    cout << "Feedback mode: FORCE control" << endl;
                else
                    cout << "Feedback mode: STIFFNESS/DAMPING control" << endl;
            }
            else if (key == '2')
            {
                // Toggle feedback
                feedbackEnabled = !feedbackEnabled;
                cout << "Feedback " << (feedbackEnabled ? "enabled" : "disabled") << endl;
            }
            else if (key == 'c' || key == 'C')
            {
                // Configure server IP
                configureServerIP();
            }
            else if (key == 'q' || key == 'Q')
            {
                // Exit application
                simulationFinished = true;
            }
        }

        // Sleep for a short interval to reduce CPU usage
        this_thread::sleep_for(chrono::milliseconds(1));
    }

    //--------------------------------------------------------------------------
    // CLEANUP
    //--------------------------------------------------------------------------
    // Close the haptic loop
    simulationRunning = false;

    // Wait for the haptic loop to terminate
    // Note: we don't use getExitFlag() since it's not available in this version of CHAI3D
    // Instead we'll wait a short time to allow the thread to terminate
    this_thread::sleep_for(chrono::milliseconds(500));

    // Stop the network threads
    networkRunning = false;
    if (sendNetworkThread && sendNetworkThread->joinable()) {
        sendNetworkThread->join();
        delete sendNetworkThread;
        sendNetworkThread = nullptr;
    }
    if (receiveNetworkThread && receiveNetworkThread->joinable()) {
        receiveNetworkThread->join();
        delete receiveNetworkThread;
        receiveNetworkThread = nullptr;
    }

    // Close the sockets
    closeNetworkSockets();

    // Delete resources
    delete hapticsThread;
    delete world;
    delete handler;

    // Close the GLFW window
    glfwDestroyWindow(window);

    // Terminate GLFW library
    glfwTerminate();

    // Exit
    return 0;
}

//==============================================================================
// GRAPHICS LOOP
//==============================================================================
void updateGraphics(void)
{
    // Update the graphical rendering frequency
    freqCounterGraphics.signal(1);

    // Render world
    camera->renderView(width, height);

    // Average haptic force from feedback
    cVector3d force(currentForce[0], currentForce[1], currentForce[2]);
    double forceMagnitude = force.length();

    // Update displayed information
    labelRates->setText(cStr(freqCounterGraphics.getFrequency(), 0) + " Hz / " +
        cStr(freqCounterHaptics.getFrequency(), 0) + " Hz");
    labelRates->setLocalPos((int)(0.5 * (width - labelRates->getWidth())), 15);

    // Display connection and mode information
    string message = "Connected to server: " + string(SERVER_IP) + ":" + to_string(PORT) + "\n";
    message += "Feedback: " + string(feedbackEnabled ? "Enabled" : "Disabled") + " | ";
    message += "Mode: ";
    if (currentFeedbackType == FEEDBACK_POSITION)
        message += "POSITION";
    else if (currentFeedbackType == FEEDBACK_FORCE)
        message += "FORCE";
    else
        message += "STIFFNESS/DAMPING";
    message += "\nLatency: " + cStr(averageLatency, 1) + " ms | ";
    message += "Error: " + cStr(positionError * 1000.0, 1) + " mm | ";
    message += "Force: " + cStr(forceMagnitude, 1) + " N";

    // Display the message with larger font
    labelMessage->setText(message);
    labelMessage->setLocalPos((int)(0.5 * (width - labelMessage->getWidth())), height - 70);

    // Update position of haptic device cursor
    std::lock_guard<std::mutex> lock(devicePositionMutex);
    deviceCursor->setLocalPos(devicePosition);
}

//==============================================================================
// HAPTICS LOOP
//==============================================================================
void updateHaptics(void)
{
    // Simulation clock initialization
    cPrecisionClock clock;
    clock.reset();

    // Haptic simulation loop
    while (simulationRunning)
    {
        // Update the haptic rendering frequency
        freqCounterHaptics.signal(1);

        // Start the timer for the current haptic frame
        clock.start();

        // Read position from haptic device
        cVector3d position;
        if (hapticDevice)
        {
            // Read from the actual haptic device
            hapticDevice->getPosition(position);
        }
        else
        {
            // For simulation, use the last known position
            position = devicePosition;

            // Add some simulated movement (for demonstration when no device is present)
            double time = clock.getCurrentTimeSeconds();
            position.x(0.03 * sin(0.5 * time));
            position.y(0.03 * cos(0.7 * time));
            position.z(0.03 + 0.01 * sin(0.9 * time));
        }

        // Update the device position for visualization
        {
            std::lock_guard<std::mutex> lock(devicePositionMutex);
            devicePosition = position;
        }

        // Apply feedback forces to the haptic device if enabled
        if (feedbackEnabled && hapticDevice)
        {
            // Create a force vector
            cVector3d force(currentForce[0], currentForce[1], currentForce[2]);

            // Apply the force based on the feedback type
            if (currentFeedbackType == FEEDBACK_POSITION)
            {
                // Position control - compute force using stiffness and damping
                cVector3d targetPos(targetPosition[0], targetPosition[1], targetPosition[2]);
                cVector3d deltaPos = targetPos - position;

                // Read velocity
                cVector3d velocity;
                hapticDevice->getLinearVelocity(velocity);

                // Compute force with stiffness and damping
                force = (stiffnessValue * deltaPos) - (dampingValue * velocity);

                // Clamp the force
                double forceMagnitude = force.length();
                if (forceMagnitude > MAX_STIFFNESS)
                {
                    force *= (MAX_STIFFNESS / forceMagnitude);
                }
            }

            // Apply the force to the haptic device
            hapticDevice->setForce(force);
        }
        else if (hapticDevice)
        {
            // If feedback is disabled, set zero force
            hapticDevice->setForce(cVector3d(0.0, 0.0, 0.0));
        }

        // Signal graphic update if analytics window is showing
        if (showConsoleAnalytics && analyticsWindowId != -1)
        {
            glutPostWindowRedisplay(analyticsWindowId);
        }

        // Wait until the next haptic frame
        clock.stop();
        double timeSpent = clock.getCurrentTimeSeconds();
        double timeToWait = 1.0 / HAPTIC_RATE_HZ - timeSpent;
        if (timeToWait > 0.0)
        {
            // Sleep for milliseconds
            std::this_thread::sleep_for(std::chrono::microseconds((int)(timeToWait * 1000000.0)));
        }
    }
}

//==============================================================================
// NETWORK COMMUNICATION
//==============================================================================
void sendNetworkThread_func(void)
{
    // Initialize random number generator
    srand((unsigned int)time(NULL));

    // Initialize sockaddr_in structure
    struct sockaddr_in serverAddr;
    memset(&serverAddr, 0, sizeof(serverAddr));
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(PORT);

    // Convert the server IP string to numeric format
    inet_pton(AF_INET, SERVER_IP, &(serverAddr.sin_addr));

    // Create a buffer for the packet
    char packetBuffer[BUFFER_SIZE];

    // Timing control for consistent packet rate
    auto previousTime = std::chrono::high_resolution_clock::now();
    const int sendIntervalMs = 1000 / HAPTIC_RATE_HZ;

    // Loop until signaled to stop
    while (networkRunning)
    {
        // Create a packet with the current device position
        ClientPacket packet;
        packet.packetNumber = ++packetNumber;

        // Get current position
        {
            std::lock_guard<std::mutex> lock(devicePositionMutex);
            packet.x = (float)devicePosition.x();
            packet.y = (float)devicePosition.y();
            packet.z = (float)devicePosition.z();
        }

        // Add other packet information
        packet.delay = 0.0f;
        strcpy(packet.srcIP, SRC_IP);
        strcpy(packet.dstIP, SERVER_IP);
        packet.srcPort = PORT;
        packet.dstPort = PORT;

        // Add timestamp
        getTimestamp(packet.timestamp);

        // Copy packet to buffer
        memcpy(packetBuffer, &packet, sizeof(ClientPacket));

        // Send packet to server
        {
            std::lock_guard<std::mutex> lock(socketMutex);
            if (sendSocket != INVALID_SOCKET)
            {
                // Send data directly (non-binding method)
                int result = sendto(sendSocket, packetBuffer, sizeof(ClientPacket), 0,
                    (struct sockaddr*)&serverAddr, sizeof(serverAddr));

                if (result != SOCKET_ERROR)
                {
                    // Increment sent packet counter
                    packetsSent++;

                    // Log packet information
                    if (packetsSent % 100 == 0)
                    {
                        std::stringstream logStream;
                        logStream << "SENT #" << packet.packetNumber << " ["
                            << packet.x << ", " << packet.y << ", " << packet.z
                            << "] -> " << packet.dstIP << ":" << packet.dstPort;

                        // Add to sent log queue
                        {
                            std::lock_guard<std::mutex> logLock(logMutex);
                            sentPacketLogs.push_front(logStream.str());
                            if (sentPacketLogs.size() > CONSOLE_LOG_PACKETS)
                                sentPacketLogs.pop_back();
                        }
                    }
                }
                else {
                    // Log error
                    cout << "Send error: " << WSAGetLastError() << endl;
                }
            }
        }

        // Calculate time to wait for next packet send (for consistent rate)
        auto currentTime = std::chrono::high_resolution_clock::now();
        auto elapsedMs = std::chrono::duration_cast<std::chrono::milliseconds>(
            currentTime - previousTime).count();
        if (elapsedMs < sendIntervalMs)
        {
            // Sleep for the remaining time
            std::this_thread::sleep_for(std::chrono::milliseconds(sendIntervalMs - elapsedMs));
        }

        // Update previous time
        previousTime = std::chrono::high_resolution_clock::now();
    }
}

void receiveNetworkThread_func(void)
{
    // Create a buffer for receiving packets
    char packetBuffer[BUFFER_SIZE];

    // Client address information for recvfrom
    struct sockaddr_in clientAddr;
    int clientAddrLen = sizeof(clientAddr);

    // Loop until signaled to stop
    while (networkRunning)
    {
        // Receive packet (this will block until data arrives)
        int bytesReceived = 0;
        {
            std::lock_guard<std::mutex> lock(socketMutex);
            if (receiveSocket != INVALID_SOCKET) {
                bytesReceived = recvfrom(receiveSocket, packetBuffer, BUFFER_SIZE, 0,
                    (struct sockaddr*)&clientAddr, &clientAddrLen);
            }
        }

        // Process the packet if valid
        if (bytesReceived == sizeof(FeedbackPacket))
        {
            // Convert buffer to feedback packet
            FeedbackPacket* packet = (FeedbackPacket*)packetBuffer;

            // Increment received packet counter
            packetsReceived++;

            // Log packet information
            if (packetsReceived % 100 == 0)
            {
                std::stringstream logStream;
                char clientIP[INET_ADDRSTRLEN];
                inet_ntop(AF_INET, &(clientAddr.sin_addr), clientIP, INET_ADDRSTRLEN);

                logStream << "RECEIVED #" << packet->packetNumber << " ["
                    << packet->fx << ", " << packet->fy << ", " << packet->fz
                    << "] <- " << clientIP << ":" << ntohs(clientAddr.sin_port)
                    << " (error: " << packet->positionError << "mm, latency: "
                    << packet->latency << "ms)";

                // Add to received log queue
                {
                    std::lock_guard<std::mutex> logLock(logMutex);
                    receivedPacketLogs.push_front(logStream.str());
                    if (receivedPacketLogs.size() > CONSOLE_LOG_PACKETS)
                        receivedPacketLogs.pop_back();
                }
            }

            // Process the feedback packet (update forces, position targets, etc.)
            processFeedbackPacket(*packet);

            // Increment the feedback counter for adaptive feedback
            feedbackPacketCounter++;

            // Check if it's time to update the active feedback (every PACKET_UTILIZATION_INTERVAL)
            if (feedbackPacketCounter >= PACKET_UTILIZATION_INTERVAL)
            {
                feedbackUpdateReady = true;
                updateActiveFeedback();
                feedbackPacketCounter = 0;
            }
        }
        else if (bytesReceived <= 0)
        {
            // Error or connection closed, add a short delay to avoid spinning
            std::this_thread::sleep_for(std::chrono::milliseconds(10));
        }
    }
}

void getLocalIP(char* ipBuffer)
{
    // Default to loopback address
    strcpy(ipBuffer, "127.0.0.1");

    // Windows-specific code for getting local IP
    WSADATA wsaData;
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        return;
    }

    char hostName[256];
    if (gethostname(hostName, sizeof(hostName)) == 0) {
        struct hostent* host = gethostbyname(hostName);
        if (host != nullptr) {
            struct in_addr addr;
            memcpy(&addr, host->h_addr_list[0], sizeof(struct in_addr));
            strcpy(ipBuffer, inet_ntoa(addr));
        }
    }
}

void getTimestamp(char* timestamp)
{
    // Get current time
    auto now = std::chrono::system_clock::now();
    auto now_c = std::chrono::system_clock::to_time_t(now);
    auto now_ms = std::chrono::duration_cast<std::chrono::milliseconds>(
        now.time_since_epoch()) % 1000;

    // Convert to tm struct
    struct tm timeInfo;
    localtime_s(&timeInfo, &now_c);

    // Format the timestamp string
    sprintf(timestamp, "%04d-%02d-%02d %02d:%02d:%02d.%03d",
        timeInfo.tm_year + 1900, timeInfo.tm_mon + 1, timeInfo.tm_mday,
        timeInfo.tm_hour, timeInfo.tm_min, timeInfo.tm_sec, (int)now_ms.count());
}

bool initializeNetworkSockets()
{
    // Initialize Winsock
    WSADATA wsaData;
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        cout << "WSAStartup failed with error: " << WSAGetLastError() << endl;
        return false;
    }

    // Create the send socket
    sendSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (sendSocket == INVALID_SOCKET) {
        cout << "Error creating send socket" << endl;
        return false;
    }

    // Create the receive socket
    receiveSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (receiveSocket == INVALID_SOCKET) {
        cout << "Error creating receive socket" << endl;
        return false;
    }

    // Set up the receive socket to bind to the specified port
    struct sockaddr_in receiveAddr;
    memset(&receiveAddr, 0, sizeof(receiveAddr));
    receiveAddr.sin_family = AF_INET;
    receiveAddr.sin_port = htons(PORT);
    receiveAddr.sin_addr.s_addr = INADDR_ANY;

    // Bind the receive socket
    if (bind(receiveSocket, (struct sockaddr*)&receiveAddr, sizeof(receiveAddr)) == SOCKET_ERROR) {
        cout << "Error binding receive socket: " << WSAGetLastError() << endl;
        return false;
    }

    cout << "Network sockets initialized successfully" << endl;
    return true;
}

void closeNetworkSockets()
{
    // Close the sockets
    if (sendSocket != INVALID_SOCKET) {
        closesocket(sendSocket);
        sendSocket = INVALID_SOCKET;
    }

    if (receiveSocket != INVALID_SOCKET) {
        closesocket(receiveSocket);
        receiveSocket = INVALID_SOCKET;
    }

    // Cleanup Winsock
    WSACleanup();

    cout << "Network sockets closed" << endl;
}

