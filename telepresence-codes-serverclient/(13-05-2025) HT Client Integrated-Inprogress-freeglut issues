// Utility function to draw a graph in the analytics window
void drawGraph(float x, float y, float width, float height,
    const std::vector<float>& data, float minValue, float maxValue,
    float r, float g, float b, const char* label)
{
    // Draw border
    glColor3f(0.0f, 0.0f, 0.0f);
    glBegin(GL_LINE_LOOP);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();

    // Draw label
    drawText(x, y + height + 0.02f, label);

    // Draw scale values
    char buffer[64];
    sprintf(buffer, "%.2f", maxValue);
    drawText(x - 0.05f, y + height, buffer);
    sprintf(buffer, "%.2f", minValue);
    drawText(x - 0.05f, y, buffer);

    // Draw data line
    if (data.size() >= 2) {
        glColor3f(r, g, b);
        glBegin(GL_LINE_STRIP);

        float valueRange = maxValue - minValue;
        if (valueRange == 0.0f) valueRange = 1.0f;  // Avoid division by zero

        for (size_t i = 0; i < data.size(); i++) {
            float normalizedX = x + width * ((float)i / (data.size() - 1));
            float normalizedY = y + height * ((data[i] - minValue) / valueRange);
            glVertex2f(normalizedX, normalizedY);
        }

        glEnd();
    }
}

