        drawGraph(0.05f, graphStartY - 2 * (graphHeight + graphMargin), graphWidth, graphHeight,
            forceHistory[2], minForceZ, maxForceZ,
            0.0f, 0.0f, 1.0f, "Force Z (Newtons)");

        // Display current force
        sprintf(buffer, "Current Force: [%.4f, %.4f, %.4f] Newtons",
            currentForce[0], currentForce[1], currentForce[2]);
        drawText(0.05f, 0.1f, buffer);

        // Display force magnitude
        float forceMagnitude = sqrt(
            currentForce[0] * currentForce[0] +
            currentForce[1] * currentForce[1] +
            currentForce[2] * currentForce[2]);
        sprintf(buffer, "Force Magnitude: %.4f Newtons", forceMagnitude);
        drawText(0.05f, 0.06f, buffer);
    }
    else if (currentTab == TAB_NETWORK) {
        // Display latency graph
        drawGraph(0.05f, graphStartY, graphWidth, graphHeight,
            latencyHistory, minLatency, maxLatency,
            0.0f, 0.5f, 1.0f, "Network Latency (ms)");

        // Display error graph
        drawGraph(0.05f, graphStartY - graphHeight - graphMargin, graphWidth, graphHeight,
            errorHistory, minError, maxError,
            1.0f, 0.5f, 0.0f, "Position Error (mm)");

        // Display packet send/receive rate
        static auto lastRateTime = std::chrono::high_resolution_clock::now();
        static int lastSent = 0;
        static int lastReceived = 0;
        static float sendRate = 0.0f;
        static float receiveRate = 0.0f;

        auto currentTime = std::chrono::high_resolution_clock::now();
        float deltaTime = std::chrono::duration<float>(currentTime - lastRateTime).count();

        if (deltaTime >= 1.0f) {
            int currentSent = packetsSent.load();
            int currentReceived = packetsReceived.load();

            sendRate = (currentSent - lastSent) / deltaTime;
            receiveRate = (currentReceived - lastReceived) / deltaTime;

            lastSent = currentSent;
            lastReceived = currentReceived;
            lastRateTime = currentTime;
        }

        sprintf(buffer, "Send Rate: %.1f packets/sec | Receive Rate: %.1f packets/sec",
            sendRate, receiveRate);
        drawText(0.05f, 0.1f, buffer);

        // Display network statistics
        sprintf(buffer, "Average Latency: %.2f ms | Average Position Error: %.2f mm",
            averageLatency, positionError * 1000.0f);
        drawText(0.05f, 0.06f, buffer);
    }
    else if (currentTab == TAB_PERFORMANCE) {
        // Display haptic and graphic rendering rates
        sprintf(buffer, "Graphics Rate: %.1f Hz | Haptics Rate: %.1f Hz",
            freqCounterGraphics.getFrequency(), freqCounterHaptics.getFrequency());
        drawText(0.05f, graphStartY, buffer);

        // Display feedback configuration
        sprintf(buffer, "Feedback Mode: %s | Enabled: %s",
            currentFeedbackType == FEEDBACK_POSITION ? "Position" :
            (currentFeedbackType == FEEDBACK_FORCE ? "Force" : "Stiffness/Damping"),
            feedbackEnabled ? "Yes" : "No");
        drawText(0.05f, graphStartY - 0.05f, buffer);

        // Display control parameters
        sprintf(buffer, "Stiffness: %.1f | Damping: %.1f",
            stiffnessValue, dampingValue);
        drawText(0.05f, graphStartY - 0.1f, buffer);

        // Display packet utilization parameters
        sprintf(buffer, "Packet Utilization: %d packets every %d received",
            PACKETS_TO_UTILIZE, PACKET_UTILIZATION_INTERVAL);
        drawText(0.05f, graphStartY - 0.15f, buffer);

        // Display buffer information
        sprintf(buffer, "Feedback Buffer Size: %d / %d",
            (int)feedbackBuffer.size(), MAX_HISTORY_SIZE);
        drawText(0.05f, graphStartY - 0.2f, buffer);
    }

    // Display recent packet logs
    float logY = 0.3f;
    float logLineHeight = 0.017f;

    drawText(0.02f, logY, "Recent Sent Packets:", GLUT_BITMAP_HELVETICA_12);
    logY -= 0.03f;

    {
        std::lock_guard<std::mutex> logLock(logMutex);

        for (const auto& log : sentPacketLogs) {
            glColor3f(0.0f, 0.0f, 0.7f);
            drawText(0.02f, logY, log.c_str(), GLUT_BITMAP_9_BY_15);
            logY -= logLineHeight;
        }

        logY -= 0.01f;
        glColor3f(0.0f, 0.0f, 0.0f);
        drawText(0.02f, logY, "Recent Received Packets:", GLUT_BITMAP_HELVETICA_12);
        logY -= 0.03f;

        for (const auto& log : receivedPacketLogs) {
            glColor3f(0.7f, 0.0f, 0.0f);
            drawText(0.02f, logY, log.c_str(), GLUT_BITMAP_9_BY_15);
            logY -= logLineHeight;
        }
    }

    // Swap buffers
    glutSwapBuffers();
}

void keyboardAnalyticsWindow(unsigned char key, int x, int y)
{
    // Handle keyboard input for analytics window
    if (key == 27 || key == 'q' || key == 'Q') {  // ESC or Q
        // Hide analytics window
        glutHideWindow();
        showConsoleAnalytics = false;
    }
    else if (key >= '1' && key <= '4') {
        // Switch tabs
        currentTab = (AnalyticsTab)(key - '1');
        glutPostRedisplay();
    }
    else if (key == 'c' || key == 'C') {
        // Clear statistics
        std::lock_guard<std::mutex> lock(feedbackMutex);
        clearBuffers();

        // Reset min/max values
        minPositionX = minPositionY = minPositionZ = std::numeric_limits<float>::max();
        maxPositionX = maxPositionY = maxPositionZ = std::numeric_limits<float>::lowest();
        minForceX = minForceY = minForceZ = std::numeric_limits<float>::max();
        maxForceX = maxForceY = maxForceZ = std::numeric_limits<float>::lowest();
        minLatency = minError = std::numeric_limits<float>::max();
        maxLatency = maxError = std::numeric_limits<float>::lowest();

        glutPostRedisplay();
    }
}

void idleAnalyticsWindow()
{
    // Update analytics window if necessary
    if (showConsoleAnalytics) {
        glutPostRedisplay();
    }
}

void closeAnalyticsWindow()
{
    // Close the analytics window
    if (analyticsWindowId != -1) {
        glutDestroyWindow(analyticsWindowId);
        analyticsWindowId = -1;
    }
}
