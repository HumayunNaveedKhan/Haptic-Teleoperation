// Display function
void display() {
    // Clear the screen
    glClearColor(0.05f, 0.05f, 0.1f, 1.0f);
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT);

    // Enable blending for transparency
    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);

    // Set up projection
    glMatrixMode(GL_PROJECTION);
    glLoadIdentity();
    gluOrtho2D(-1.0, 1.0, -1.0, 1.0);

    glMatrixMode(GL_MODELVIEW);
    glLoadIdentity();

    // Apply global scaling if needed
    glScalef(scaleFactor, scaleFactor, 1.0f);

    // Get packet data
    auto bufferedPackets = packetDistributor.getBufferedPackets();
    auto processedPackets = packetDistributor.getProcessedPackets();

    // Draw packet visualizations
    if (!bufferedPackets.empty()) {
        drawPacketVisualization(bufferedPackets, -0.9f, "Incoming Packets", false);
    }

    if (!processedPackets.empty()) {
        drawPacketVisualization(processedPackets, 0.1f, "Processed Packets", true);
    }

    // Draw haptic device status
    drawHapticStatus(-0.9f, 0.0f);

    // Draw network configuration info
    char netInfoStr[128];
    snprintf(netInfoStr, sizeof(netInfoStr),
        "Network: Port %d (receive+send) | Release Rate: %.1fx | Walls: %s",
        UDP_PORT, GLOBAL_RELEASE_RATE_FACTOR,
        ENABLE_VIRTUAL_WALLS ? "On" : "Off");
    renderSmallText(-0.9f, -0.8f, FONT_MEDIUM, netInfoStr);

    // Draw delay settings info
    char delayInfoStr[128];
    snprintf(delayInfoStr, sizeof(delayInfoStr),
        "Uniform Delay: %s | Random Delay: %s",
        UNIFORM_DELAY_ENABLED ? "On" : "Off",
        RANDOM_DELAY_ENABLED ? "On" : "Off");
    renderSmallText(0.1f, -0.8f, FONT_MEDIUM, delayInfoStr);

    // Draw statistics if enabled
    if (showStats) {
        drawStatisticsPanel(0.1f, -0.1f, 0.5f, 0.3f);
    }

    // Draw feedback information
    drawFeedbackPanel(-0.9f, -0.4f, 0.8f, 0.3f);

    // Draw delay graphs if enabled
    if (showGraphs) {
        drawDelayGraphs(0.1f, -0.45f, 0.8f, 0.3f);
    }

    // Draw legend box
    if (showLegend) {
        drawLegendBox(0.7f, 0.3f, LEGEND_WIDTH, LEGEND_HEIGHT);
    }

    // Draw help screen if enabled
    if (showHelp) {
        drawHelpScreen();
    }

    // Swap buffers
    glutSwapBuffers();
}

