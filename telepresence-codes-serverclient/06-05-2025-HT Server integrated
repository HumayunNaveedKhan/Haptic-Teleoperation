// Draw packet visualizations
void drawPacketVisualization(const std::deque<Packet>& packets, float xOffset,
    const char* title, bool isProcessed,
    float barWidth = BAR_WIDTH, float maxHeight = BAR_MAX_HEIGHT) {
    // Draw title 
    renderSmallText(xOffset, 0.9f, FONT_LARGE, title, 0.9f, 0.9f, 1.0f);

    // Draw axis lines
    glColor3f(0.4f, 0.4f, 0.4f);
    glBegin(GL_LINES);
    // Horizontal axis
    glVertex2f(xOffset - 0.05f, 0.35f);
    glVertex2f(xOffset + 0.65f, 0.35f);
    // Vertical axis
    glVertex2f(xOffset - 0.05f, 0.35f);
    glVertex2f(xOffset - 0.05f, 0.65f);
    glEnd();

    // Draw packets as bars
    int index = 0;
    for (const auto& packet : packets) {
        float x = xOffset + (index * barWidth * 1.5f);

        // Calculate bar height based on vector magnitude
        float magnitude = calculateMagnitude(packet);
        float normalizedHeight = magnitude * 0.8f; // Scale to make it visible
        if (normalizedHeight > maxHeight) normalizedHeight = maxHeight;

        // Draw bar - differentiate between incoming and processed
        if (isProcessed) {
            glColor3f(0.2f, 0.8f, 0.2f); // Green for processed
        }
        else {
            glColor3f(0.8f, 0.2f, 0.2f); // Red for incoming
        }

        glBegin(GL_QUADS);
        glVertex2f(x, 0.35f);
        glVertex2f(x + barWidth, 0.35f);
        glVertex2f(x + barWidth, 0.35f + normalizedHeight);
        glVertex2f(x, 0.35f + normalizedHeight);
        glEnd();

        // Draw packet number if enabled
        if (SHOW_PACKET_NUMBERS) {
            char packetNumStr[16];
            snprintf(packetNumStr, sizeof(packetNumStr), "%d", packet.packetNumber);

            // Calculate text position to avoid overlap
            float textY = 0.35f - 0.03f;

            // Stagger text positions to prevent overlap
            if (index % 2 == 0) {
                textY -= TEXT_Y_OFFSET;
            }

            renderSmallText(x - 0.005f, textY, FONT_SMALL, packetNumStr);
        }

        // Show timestamp for some packets to avoid crowding
        if (index % TIMESTAMP_DISPLAY_INTERVAL == 0) {
            std::string formattedTime = formatTimestampForDisplay(packet.timestamp);
            renderSmallText(x - 0.02f, 0.35f + normalizedHeight + 0.01f, FONT_SMALL, formattedTime.c_str());
        }

        // Show time gap between packets if enabled
        if (SHOW_TIME_GAPS && index > 0) {
            double timeGap = packetDistributor.getPacketTimeGap(packet.packetNumber);
            if (timeGap > 0) {
                char timeGapStr[32];
                snprintf(timeGapStr, sizeof(timeGapStr), "%.1f ms", timeGap);
                renderSmallText(x - 0.02f, 0.32f, FONT_SMALL, timeGapStr);
            }
        }

        index++;
    }

    // Add packet info section at the bottom
    if (!packets.empty()) {
        const Packet& latestPacket = packets.back();
        float infoY = 0.28f;

        std::ostringstream packetInfo;
        packetInfo << "Latest Packet: #" << latestPacket.packetNumber
            << " | From: " << latestPacket.srcIP << ":" << latestPacket.srcPort
            << " | To: " << latestPacket.dstIP << ":" << latestPacket.dstPort;

        renderSmallText(xOffset + 0.05f, infoY, FONT_MEDIUM, packetInfo.str().c_str());
        infoY -= TEXT_SPACING;

        std::ostringstream vectorInfo;
        vectorInfo << "Position Vector: [" << std::fixed << std::setprecision(3)
            << latestPacket.x << ", " << latestPacket.y << ", " << latestPacket.z << "]"
            << " | Magnitude: " << std::fixed << std::setprecision(3)
            << calculateMagnitude(latestPacket);

        renderSmallText(xOffset + 0.05f, infoY, FONT_MEDIUM, vectorInfo.str().c_str());
        infoY -= TEXT_SPACING;

        std::ostringstream delayInfo;
        if (isProcessed) {
            delayInfo << "Original Delay: " << std::fixed << std::setprecision(2)
                << latestPacket.delay << " ms"
                << " | Processing Delay: " << std::fixed << std::setprecision(2)
                << latestPacket.processingDelay << " ms";
        }
        else {
            delayInfo << "Original Delay: " << std::fixed << std::setprecision(2)
                << latestPacket.delay << " ms";
        }
        renderSmallText(xOffset + 0.05f, infoY, FONT_MEDIUM, delayInfo.str().c_str());
    }
}

// Draw a 3D vector representation in 2D space
void draw3DVector(float x, float y, float scale, const float vec[3], const char* label = nullptr) {
    // Draw base axes
    glColor3f(0.5f, 0.5f, 0.5f);
    glBegin(GL_LINES);
    // X axis
    glVertex2f(x - 0.05f, y);
    glVertex2f(x + 0.05f, y);
    // Y axis
    glVertex2f(x, y - 0.05f);
    glVertex2f(x, y + 0.05f);
    glEnd();

    // Draw vector
    glColor3f(0.9f, 0.3f, 0.3f); // Red vector
    glBegin(GL_LINES);
    glVertex2f(x, y);
    glVertex2f(x + vec[0] * scale, y + vec[1] * scale);
    glEnd();

    // Draw vector endpoint
    glPointSize(5.0f);
    glBegin(GL_POINTS);
    glVertex2f(x + vec[0] * scale, y + vec[1] * scale);
    glEnd();

    // Draw label if provided
    if (label) {
        renderSmallText(x - 0.04f, y + 0.08f, FONT_MEDIUM, label);
    }

    // Draw magnitude and components
    char magnitudeStr[64];
    float magnitude = sqrt(vec[0] * vec[0] + vec[1] * vec[1] + vec[2] * vec[2]);
    snprintf(magnitudeStr, sizeof(magnitudeStr), "Mag: %.2f", magnitude);
    renderSmallText(x - 0.04f, y - 0.08f, FONT_SMALL, magnitudeStr);

    char compStr[64];
    snprintf(compStr, sizeof(compStr), "[%.2f, %.2f, %.2f]", vec[0], vec[1], vec[2]);
    renderSmallText(x - 0.04f, y - 0.10f, FONT_SMALL, compStr);
}

// Draw haptic device status
void drawHapticStatus(float x, float y) {
    // Get device status
    bool deviceConnected;
    bool hapticEnabled;
    bool wallsEnabled;
    double Kp, Kd, maxForce, forceScale;
    double posLimit[3];
    {
        std::lock_guard<std::mutex> lock(hapticMutex);
        deviceConnected = hapticConfig.deviceConnected;
        hapticEnabled = hapticConfig.hapticEnabled;
        wallsEnabled = hapticConfig.wallsEnabled;
        Kp = hapticConfig.Kp;
        Kd = hapticConfig.Kd;
        maxForce = hapticConfig.maxForce;
        forceScale = hapticConfig.forceScale;
        memcpy(posLimit, hapticConfig.posLimit, sizeof(double) * 3);
    }

    // Background for status section
    drawRectangle(x - 0.05f, y - 0.35f, 0.75f, 0.33f, 0.0f, 0.1f, 0.2f, 0.5f);

    // Title
    renderSmallText(x, y, FONT_LARGE, "Haptic Device Status", 0.9f, 0.9f, 1.0f);
    y -= TEXT_SPACING;

    // Device connection status
    if (deviceConnected) {
        renderSmallText(x, y, FONT_MEDIUM, "Device: Connected", 0.2f, 0.9f, 0.2f);
    }
    else {
        renderSmallText(x, y, FONT_MEDIUM, "Device: Not Connected", 0.9f, 0.2f, 0.2f);
    }
    y -= TEXT_SPACING;

    // Feedback status
    if (hapticEnabled && deviceConnected) {
        renderSmallText(x, y, FONT_MEDIUM, "Feedback: Enabled", 0.2f, 0.9f, 0.2f);
    }
    else {
        renderSmallText(x, y, FONT_MEDIUM, "Feedback: Disabled", 0.9f, 0.6f, 0.2f);
    }
    y -= TEXT_SPACING;

    // Virtual walls status
    if (wallsEnabled) {
        renderSmallText(x, y, FONT_MEDIUM, "Virtual Walls: Enabled", 0.2f, 0.9f, 0.2f);
    }
    else {
        renderSmallText(x, y, FONT_MEDIUM, "Virtual Walls: Disabled", 0.9f, 0.6f, 0.2f);
    }
    y -= TEXT_SPACING;

    // Draw parameters
    char paramStr[128];
    snprintf(paramStr, sizeof(paramStr), "Stiffness (K): %.2f N/m | Damping (B): %.2f Ns/m", Kp, Kd);
    renderSmallText(x, y, FONT_MEDIUM, paramStr);
    y -= TEXT_SPACING;

    snprintf(paramStr, sizeof(paramStr), "Max Force: %.2f N | Force Scale: %.2f", maxForce, forceScale);
    renderSmallText(x, y, FONT_MEDIUM, paramStr);
    y -= TEXT_SPACING;

    snprintf(paramStr, sizeof(paramStr), "Position Limits: [±%.2f, ±%.2f, ±%.2f] m",
        posLimit[0], posLimit[1], posLimit[2]);
    renderSmallText(x, y, FONT_MEDIUM, paramStr);
    y -= TEXT_SPACING;

    // Get current device state
    double currentPos[3], currentForce[3], targetPos[3];
    {
        std::lock_guard<std::mutex> lock(deviceMutex);
        memcpy(currentPos, deviceState.position, sizeof(double) * 3);
        memcpy(currentForce, deviceState.force, sizeof(double) * 3);
        memcpy(targetPos, deviceState.targetPos, sizeof(double) * 3);
    }

    // Convert to float for drawing
    float fPos[3], fForce[3], fTarget[3];
    for (int i = 0; i < 3; i++) {
        fPos[i] = (float)currentPos[i];
        fForce[i] = (float)currentForce[i];
        fTarget[i] = (float)targetPos[i];
    }

    // Draw vectors if vector visualization is enabled
    if (showVectorVis) {
        float vecScale = 5.0f;  // Scale for visualization
        float vecY = y - 0.1f;

        // Current position vector
        draw3DVector(x + 0.15f, vecY, vecScale, fPos, "Device Position");

        // Target position vector
        draw3DVector(x + 0.45f, vecY, vecScale, fTarget, "Target Position");

        // Force vector
        draw3DVector(x + 0.15f, vecY - 0.2f, vecScale / 2.0f, fForce, "Applied Force");
    }
}

// Draw graphs of packet delays
void drawDelayGraphs(float x, float y, float width, float height) {
    // Get delay data
    std::deque<std::pair<int, float>> rawDelays;
    std::deque<std::pair<int, float>> processedDelays;
    {
        std::lock_guard<std::mutex> lock(statsMutex);
        rawDelays = globalPacketStats.rawDelays;
        processedDelays = globalPacketStats.processedDelays;
    }

    // Draw background
    drawRectangle(x, y, width, height, 0.0f, 0.0f, 0.2f, 0.5f);

    // Draw title
    renderSmallText(x + 0.02f, y + height - 0.03f, FONT_MEDIUM, "Delay Analysis", 0.9f, 0.9f, 1.0f);

    // Draw axes
    glColor3f(0.5f, 0.5f, 0.5f);
    glBegin(GL_LINES);
    // X axis
    glVertex2f(x + 0.02f, y + 0.05f);
    glVertex2f(x + width - 0.02f, y + 0.05f);
    // Y axis
    glVertex2f(x + 0.02f, y + 0.05f);
    glVertex2f(x + 0.02f, y + height - 0.05f);
    glEnd();

    // Find maximum delay value for scaling
    float maxDelay = 100.0f;  // Default if no data
    for (const auto& pair : rawDelays) {
        if (pair.second > maxDelay) maxDelay = pair.second;
    }
    for (const auto& pair : processedDelays) {
        if (pair.second > maxDelay) maxDelay = pair.second;
    }
    maxDelay = ceil(maxDelay / 100.0f) * 100.0f;  // Round up to nearest 100ms

    // Draw scale
    char scaleStr[32];
    snprintf(scaleStr, sizeof(scaleStr), "%.0f ms", maxDelay);
    renderSmallText(x + 0.03f, y + height - 0.07f, FONT_SMALL, scaleStr);
    snprintf(scaleStr, sizeof(scaleStr), "0 ms");
    renderSmallText(x + 0.03f, y + 0.04f, FONT_SMALL, scaleStr);

    // Draw original delay graph
    if (!rawDelays.empty()) {
        glColor3f(0.8f, 0.5f, 0.2f);  // Orange
        glBegin(GL_LINE_STRIP);
        float xStep = (width - 0.04f) / MAX_GRAPH_POINTS;
        float yScale = (height - 0.1f) / maxDelay;

        int idx = 0;
        for (const auto& pair : rawDelays) {
            float xPos = x + 0.02f + (idx * xStep);
            float yPos = y + 0.05f + (pair.second * yScale);
            glVertex2f(xPos, yPos);
            idx++;
        }
        glEnd();

        // Label
        renderSmallText(x + 0.1f, y + height - 0.07f, FONT_SMALL, "Original Delay", 0.8f, 0.5f, 0.2f);
    }

    // Draw processed delay graph
    if (!processedDelays.empty()) {
        glColor3f(0.2f, 0.7f, 0.9f);  // Blue
        glBegin(GL_LINE_STRIP);
        float xStep = (width - 0.04f) / MAX_GRAPH_POINTS;
        float yScale = (height - 0.1f) / maxDelay;

        int idx = 0;
        for (const auto& pair : processedDelays) {
            float xPos = x + 0.02f + (idx * xStep);
            float yPos = y + 0.05f + (pair.second * yScale);
            glVertex2f(xPos, yPos);
            idx++;
        }
        glEnd();

        // Label
        renderSmallText(x + 0.25f, y + height - 0.07f, FONT_SMALL, "Processing Delay", 0.2f, 0.7f, 0.9f);
    }

    // Draw delay settings
    float settingsY = y + 0.02f;

    // Uniform delay status
    if (UNIFORM_DELAY_ENABLED) {
        char uniDelayStr[64];
        snprintf(uniDelayStr, sizeof(uniDelayStr), "Uniform Delay: %d ms", UNIFORM_DELAY_MS);
        renderSmallText(x + width - 0.3f, settingsY, FONT_SMALL, uniDelayStr, 0.2f, 0.9f, 0.2f);
    }
    else {
        renderSmallText(x + width - 0.3f, settingsY, FONT_SMALL, "Uniform Delay: Off", 0.7f, 0.7f, 0.7f);
    }
    settingsY += 0.03f;

    // Random delay status
    if (RANDOM_DELAY_ENABLED) {
        char randDelayStr[64];
        snprintf(randDelayStr, sizeof(randDelayStr), "Random Delay: %d-%d ms",
            RANDOM_DELAY_MIN_MS, RANDOM_DELAY_MAX_MS);
        renderSmallText(x + width - 0.3f, settingsY, FONT_SMALL, randDelayStr, 0.2f, 0.9f, 0.2f);
    }
    else {
        renderSmallText(x + width - 0.3f, settingsY, FONT_SMALL, "Random Delay: Off", 0.7f, 0.7f, 0.7f);
    }
}

