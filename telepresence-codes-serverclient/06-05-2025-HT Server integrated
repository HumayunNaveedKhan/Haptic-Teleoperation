// Get current timestamp as string
std::string getCurrentTimestamp() {
    auto now = std::chrono::system_clock::now();
    auto time_t_now = std::chrono::system_clock::to_time_t(now);

    std::stringstream ss;
    struct tm timeinfo;
    localtime_s(&timeinfo, &time_t_now);

    ss << std::put_time(&timeinfo, "%Y-%m-%d %H:%M:%S");
    return ss.str();
}

// Generate timestamp-based filename
std::string generateTimestampedFilename(const std::string& baseFilename, const std::string& extension) {
    auto now = std::chrono::system_clock::now();
    auto time_t_now = std::chrono::system_clock::to_time_t(now);

    std::stringstream ss;
    struct tm timeinfo;
    localtime_s(&timeinfo, &time_t_now);

    ss << baseFilename << "_"
        << std::put_time(&timeinfo, "%Y%m%d_%H%M%S")
        << "." << extension;

    return ss.str();
}

// Get IP address as string from sockaddr_in
std::string getIPString(const sockaddr_in& addr) {
    char ipStr[INET_ADDRSTRLEN];
    inet_ntop(AF_INET, &(addr.sin_addr), ipStr, INET_ADDRSTRLEN);
    return std::string(ipStr);
}

// Calculate forces for virtual walls
void calculateVirtualWallForces(double position[3], double velocity[3], double limits[3], double outForce[3]) {
    const double wallStiffness = 500.0; // Wall stiffness (N/m)
    const double wallDamping = 50.0;    // Wall damping (Ns/m)

    // Initialize output force to zero
    outForce[0] = 0.0;
    outForce[1] = 0.0;
    outForce[2] = 0.0;

    // For each dimension
    for (int i = 0; i < 3; i++) {
        // Check minimum limits (negative)
        if (position[i] < -limits[i]) {
            double penetration = -limits[i] - position[i];
            double vel = velocity[i];

            // Only apply damping if moving further into the wall
            if (vel < 0) {
                outForce[i] += wallStiffness * penetration - wallDamping * vel;
            }
            else {
                outForce[i] += wallStiffness * penetration;
            }
        }
        // Check maximum limits (positive)
        else if (position[i] > limits[i]) {
            double penetration = position[i] - limits[i];
            double vel = velocity[i];

            // Only apply damping if moving further into the wall
            if (vel > 0) {
                outForce[i] -= wallStiffness * penetration + wallDamping * vel;
            }
            else {
                outForce[i] -= wallStiffness * penetration;
            }
        }
    }
}

// Initialize CSV file with headers
