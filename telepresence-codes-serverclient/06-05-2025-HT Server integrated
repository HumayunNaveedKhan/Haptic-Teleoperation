// Measure text width (for proper alignment and prevention of overlap)
float getTextWidth(void* font, const char* string) {
    float width = 0;
    for (const char* c = string; *c != '\0'; c++) {
        width += glutBitmapWidth(font, *c);
    }
    return width / windowWidth; // Normalize to our OpenGL coordinates
}

// Draw a rectangle with optional border
void drawRectangle(float x, float y, float width, float height,
    float r, float g, float b, float alpha = 0.7f,
    bool drawBorder = true, float borderWidth = 1.0f) {
    // Draw filled rectangle
    glColor4f(r, g, b, alpha);
    glBegin(GL_QUADS);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();

    // Draw border if requested
    if (drawBorder) {
        glColor4f(r * 0.8f, g * 0.8f, b * 0.8f, 1.0f);
        glLineWidth(borderWidth);
        glBegin(GL_LINE_LOOP);
        glVertex2f(x, y);
        glVertex2f(x + width, y);
        glVertex2f(x + width, y + height);
        glVertex2f(x, y + height);
        glEnd();
    }
}

