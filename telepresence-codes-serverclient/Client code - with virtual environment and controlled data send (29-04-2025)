// ========================= PACKET STRUCTURE =========================
struct Packet {
    int packetNumber;
    float x, y, z;        // Position
    float fx, fy, fz;     // Force
    float delay;
    char timestamp[64];
    char srcIP[INET_ADDRSTRLEN];
    char dstIP[INET_ADDRSTRLEN];
    int srcPort;
    int dstPort;
};

// Function to get current timestamp in a specific format
void getTimestamp(char* timestamp) {
    time_t now = time(0);
    struct tm tstruct;
    localtime_s(&tstruct, &now);
    strftime(timestamp, 64, "%Y-%m-%d %X", &tstruct);
}

// ========================= HAPTIC FORCE COMPUTATION =========================

// Calculate force feedback from the virtual plane
void calculateVirtualPlaneForce(double pos[3], double vel[3], double force[3]) {
    // Reset forces
    force[0] = 0.0;
    force[1] = 0.0;
    force[2] = 0.0;
    
    if (!virtualPlane.enabled) return;
    
    // Check if tool is penetrating the plane (tool is below plane)
    double penetrationDepth = virtualPlane.position - pos[2];
    
    if (penetrationDepth > 0.0) {
        // Calculate normal force based on penetration depth (spring) and velocity (damping)
        double normalForce = virtualPlane.stiffness * penetrationDepth - virtualPlane.damping * vel[2];
        force[2] = normalForce;
        
        // Calculate friction force tangent to the plane (X and Y directions)
        // Friction is proportional to normal force and depends on tool movement in X-Y plane
        double frictionFactor = virtualPlane.friction * normalForce;
        
        // Simple viscous friction model - friction opposes velocity
        if (vel[0] != 0.0 || vel[1] != 0.0) {
            // Calculate velocity magnitude in XY plane
            double velXYMag = sqrt(vel[0]*vel[0] + vel[1]*vel[1]);
            
            if (velXYMag > 0.0001) {  // Avoid division by very small numbers
                // Normalize and apply friction
                force[0] = -frictionFactor * vel[0] / velXYMag;
                force[1] = -frictionFactor * vel[1] / velXYMag;
            }
        }
    }
}

// Calculate velocity from current and previous positions
void calculateVelocity(double pos[3], double lastPos[3], double vel[3], double timeStep) {
    for (int i = 0; i < 3; i++) {
        vel[i] = (pos[i] - lastPos[i]) / timeStep;
    }
}

// Update tool position and store last position
void updateToolPosition(double pos[3]) {
    std::lock_guard<std::mutex> lock(environmentMutex);
    
    // Store current position as last position
    for (int i = 0; i < 3; i++) {
        hapticTool.lastPosition[i] = hapticTool.position[i];
        hapticTool.position[i] = pos[i];
    }
}

// ========================= HAPTIC DATA SENDER THREAD =========================
void hapticDataSender() {
    WSADATA wsaData;
    SOCKET clientSocket;
    sockaddr_in serverAddr;
    Packet packet;
    int packetNumber = 0;

    // Initialize Winsock
    if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
        std::cerr << "WSAStartup failed: " << WSAGetLastError() << std::endl;
        return;
    }

    // Create the UDP socket
    clientSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (clientSocket == INVALID_SOCKET) {
        std::cerr << "Socket creation failed: " << WSAGetLastError() << std::endl;
        WSACleanup();
        return;
    }

    // Set up the server address
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(DST_PORT);
    if (inet_pton(AF_INET, DST_IP, &serverAddr.sin_addr) <= 0) {
        std::cerr << "Invalid destination IP" << std::endl;
        closesocket(clientSocket);
        WSACleanup();
        return;
    }

    // Initialize the haptic device
    if (dhdOpen() < 0) {
        std::cerr << "Cannot open haptic device: " << dhdErrorGetLastStr() << std::endl;
        closesocket(clientSocket);
        WSACleanup();
        return;
    }

    std::cout << "Haptic device initialized!" << std::endl;
    
    // Enable force feedback
    if (dhdEnableForce(DHD_ON) < 0) {
        std::cerr << "Error enabling force feedback: " << dhdErrorGetLastStr() << std::endl;
    }

    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_OPTION);

    // Time variables for velocity calculation
    auto lastTime = std::chrono::high_resolution_clock::now();
    
    // Sending loop based on selected delay mode
    while (keepRunning) {
        double hx, hy, hz;

        // Get haptic device position
        if (dhdGetPosition(&hx, &hy, &hz) < 0) {
            std::cerr << "Error getting haptic position: " << dhdErrorGetLastStr() << std::endl;
            break;
        }
        
        // Update current time and calculate time step
        auto currentTime = std::chrono::high_resolution_clock::now();
        double timeStep = std::chrono::duration<double>(currentTime - lastTime).count();
        lastTime = currentTime;
        
        // Update tool position
        double currentPosition[3] = {hx, hy, hz};
        updateToolPosition(currentPosition);
        
        // Calculate velocity
        std::lock_guard<std::mutex> lock(environmentMutex);
        calculateVelocity(hapticTool.position, hapticTool.lastPosition, hapticTool.velocity, timeStep);
        
        // Calculate haptic force
        calculateVirtualPlaneForce(hapticTool.position, hapticTool.velocity, hapticTool.force);
        
        // Apply force to the device
        if (dhdSetForce(hapticTool.force[0], hapticTool.force[1], hapticTool.force[2]) < 0) {
            std::cerr << "Error setting force: " << dhdErrorGetLastStr() << std::endl;
        }

        // Fill packet data
        packet.packetNumber = ++packetNumber;
        packet.x = static_cast<float>(hx);
        packet.y = static_cast<float>(hy);
        packet.z = static_cast<float>(hz);
        packet.fx = static_cast<float>(hapticTool.force[0]);
        packet.fy = static_cast<float>(hapticTool.force[1]);
        packet.fz = static_cast<float>(hapticTool.force[2]);

        // Choose delay based on DELAY_MODE
        int currentDelay, currentRate;
        switch (DELAY_MODE) {
        case UNIFORM_DELAY:
            currentDelay = HAPTIC_DELAY_US;
            currentRate = HAPTIC_RATE_HZ;
            packet.delay = HAPTIC_DELAY_US / 1000.0f;
            break;
        case RANDOM_DELAY:
            currentRate = rateDistribution(gen);
            currentDelay = 1000000 / currentRate;
            packet.delay = currentDelay / 1000.0f;
            break;
        }

        getTimestamp(packet.timestamp);
        strcpy_s(packet.srcIP, SRC_IP);
        strcpy_s(packet.dstIP, DST_IP);
        packet.srcPort = SRC_PORT;
        packet.dstPort = DST_PORT;

        // Send packet over UDP
        int sendResult = sendto(clientSocket, reinterpret_cast<char*>(&packet), sizeof(Packet), 0,
            (sockaddr*)&serverAddr, sizeof(serverAddr));

        if (sendResult == SOCKET_ERROR) {
            std::cerr << "Send failed: " << WSAGetLastError() << std::endl;
        }

        // Use the current delay for thread sleep
        std::this_thread::sleep_for(std::chrono::microseconds(currentDelay));
    }

    // Disable force before closing
    dhdEnableForce(DHD_OFF);
    
    // Cleanup
    dhdClose();
    closesocket(clientSocket);
    WSACleanup();
}

// ========================= PARAMETERS CONTROL THREAD =========================
void parameterControlThread() {
    char input;
    std::cout << "\nControl Menu (press key followed by Enter):\n"
              << "1: Increase plane stiffness\n"
              << "2: Decrease plane stiffness\n"
              << "3: Increase plane damping\n"
              << "4: Decrease plane damping\n"
              << "5: Increase plane friction\n"
              << "6: Decrease plane friction\n"
              << "7: Move plane up\n"
              << "8: Move plane down\n"
              << "9: Toggle plane on/off\n"
              << "0: Display current parameters\n"
              << "q: Quit\n";
    
    while (keepRunning) {
        std::cin >> input;
        
        std::lock_guard<std::mutex> lock(environmentMutex);
        
        switch (input) {
            case '1':
                virtualPlane.stiffness = std::min(1.0, virtualPlane.stiffness + 0.1);
                std::cout << "Plane stiffness: " << virtualPlane.stiffness << std::endl;
                break;
            case '2':
                virtualPlane.stiffness = std::max(0.0, virtualPlane.stiffness - 0.1);
                std::cout << "Plane stiffness: " << virtualPlane.stiffness << std::endl;
                break;
            case '3':
                virtualPlane.damping = std::min(1.0, virtualPlane.damping + 0.1);
                std::cout << "Plane damping: " << virtualPlane.damping << std::endl;
                break;
            case '4':
                virtualPlane.damping = std::max(0.0, virtualPlane.damping - 0.1);
                std::cout << "Plane damping: " << virtualPlane.damping << std::endl;
                break;
            case '5':
                virtualPlane.friction = std::min(1.0, virtualPlane.friction + 0.1);
                std::cout << "Plane friction: " << virtualPlane.friction << std::endl;
                break;
            case '6':
                virtualPlane.friction = std::max(0.0, virtualPlane.friction - 0.1);
                std::cout << "Plane friction: " << virtualPlane.friction << std::endl;
                break;
            case '7':
                virtualPlane.position += 0.01;  // Move up 1cm
                std::cout << "Plane position: " << virtualPlane.position << " m" << std::endl;
                break;
            case '8':
                virtualPlane.position -= 0.01;  // Move down 1cm
                std::cout << "Plane position: " << virtualPlane.position << " m" << std::endl;
                break;
            case '9':
                virtualPlane.enabled = !virtualPlane.enabled;
                std::cout << "Plane " << (virtualPlane.enabled ? "enabled" : "disabled") << std::endl;
                break;
            case '0':
                displayParameters();
                break;
            case 'q':
            case 'Q':
                keepRunning = false;
                break;
            default:
                std::cout << "Invalid option\n";
        }
    }
}

int main() {
    // Fetch local IP before starting
    getLocalIP(SRC_IP);

    // Display parameters on console
    displayParameters();

    // Start the haptic data sender thread
    std::thread senderThread(hapticDataSender);
    
    // Start parameter control thread
    std::thread controlThread(parameterControlThread);

    // Wait for threads to finish
    senderThread.join();
    controlThread.join();

    return 0;
}
