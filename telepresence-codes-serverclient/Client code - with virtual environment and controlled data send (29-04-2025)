// ========================= COMMAND PROCESSING =========================
void processCommand(const std::string& cmd) {
    std::istringstream iss(cmd);
    std::string command, subCommand;

    iss >> command;

    if (command == "help") {
        displayHelp();
    }
    else if (command == "quit") {
        keepRunning = false;
        std::cout << "Exiting application...\n";
    }
    else if (command == "plane") {
        iss >> subCommand;

        if (subCommand == "pos") {
            double pos;
            if (iss >> pos) {
                std::lock_guard<std::mutex> lock(environmentMutex);
                virtualPlane.position = pos;
                std::cout << "Plane position set to " << pos << " m\n";
            }
            else {
                std::cout << "Invalid value. Usage: plane pos [value]\n";
            }
        }
        else if (subCommand == "stiff") {
            double stiff;
            if (iss >> stiff) {
                if (stiff >= 0.0 && stiff <= 1.0) {
                    std::lock_guard<std::mutex> lock(environmentMutex);
                    virtualPlane.stiffness = stiff;
                    std::cout << "Plane stiffness set to " << stiff << "\n";
                }
                else {
                    std::cout << "Stiffness must be between 0.0 and 1.0\n";
                }
            }
            else {
                std::cout << "Invalid value. Usage: plane stiff [value]\n";
            }
        }
        else if (subCommand == "damp") {
            double damp;
            if (iss >> damp) {
                if (damp >= 0.0 && damp <= 1.0) {
                    std::lock_guard<std::mutex> lock(environmentMutex);
                    virtualPlane.damping = damp;
                    std::cout << "Plane damping set to " << damp << "\n";
                }
                else {
                    std::cout << "Damping must be between 0.0 and 1.0\n";
                }
            }
            else {
                std::cout << "Invalid value. Usage: plane damp [value]\n";
            }
        }
        else if (subCommand == "fric") {
            double fric;
            if (iss >> fric) {
                if (fric >= 0.0 && fric <= 1.0) {
                    std::lock_guard<std::mutex> lock(environmentMutex);
                    virtualPlane.friction = fric;
                    std::cout << "Plane friction set to " << fric << "\n";
                }
                else {
                    std::cout << "Friction must be between 0.0 and 1.0\n";
                }
            }
            else {
                std::cout << "Invalid value. Usage: plane fric [value]\n";
            }
        }
        else if (subCommand == "on") {
            std::lock_guard<std::mutex> lock(environmentMutex);
            virtualPlane.enabled = true;
            std::cout << "Virtual plane enabled\n";
        }
        else if (subCommand == "off") {
            std::lock_guard<std::mutex> lock(environmentMutex);
            virtualPlane.enabled = false;
            std::cout << "Virtual plane disabled\n";
        }
        else {
            std::cout << "Unknown plane command. Type 'help' for available commands.\n";
        }
    }
    else if (command == "tool") {
        iss >> subCommand;

        if (subCommand == "size") {
            double size;
            if (iss >> size) {
                if (size > 0.0) {
                    std::lock_guard<std::mutex> lock(environmentMutex);
                    hapticTool.size = size / 1000.0;  // Convert mm to meters
                    std::cout << "Tool size set to " << size << " mm\n";
                }
                else {
                    std::cout << "Size must be positive\n";
                }
            }
            else {
                std::cout << "Invalid value. Usage: tool size [value_in_mm]\n";
            }
        }
        else if (subCommand == "mass") {
            double mass;
            if (iss >> mass) {
                if (mass > 0.0) {
                    std::lock_guard<std::mutex> lock(environmentMutex);
                    hapticTool.mass = mass / 1000.0;  // Convert g to kg
                    std::cout << "Tool mass set to " << mass << " g\n";
                }
                else {
                    std::cout << "Mass must be positive\n";
                }
            }
            else {
                std::cout << "Invalid value. Usage: tool mass [value_in_g]\n";
            }
        }
        else {
            std::cout << "Unknown tool command. Type 'help' for available commands.\n";
        }
    }
    else if (command == "status") {
        std::lock_guard<std::mutex> lock(environmentMutex);
        std::cout << "\n========== SYSTEM STATUS ==========\n";
        std::cout << "Virtual Plane:\n";
        std::cout << "  Enabled:    " << (virtualPlane.enabled ? "Yes" : "No") << "\n";
        std::cout << "  Position:   " << virtualPlane.position << " m\n";
        std::cout << "  Stiffness:  " << virtualPlane.stiffness << "\n";
        std::cout << "  Damping:    " << virtualPlane.damping << "\n";
        std::cout << "  Friction:   " << virtualPlane.friction << "\n";
        std::cout << "Haptic Tool:\n";
        std::cout << "  Size:       " << hapticTool.size * 1000.0 << " mm\n";
        std::cout << "  Mass:       " << hapticTool.mass * 1000.0 << " g\n";
        std::cout << "  Position:   (" << hapticTool.position[0] << ", "
            << hapticTool.position[1] << ", " << hapticTool.position[2] << ") m\n";
        std::cout << "  Force:      (" << hapticTool.force[0] << ", "
            << hapticTool.force[1] << ", " << hapticTool.force[2] << ") N\n";
        std::cout << "==================================\n";
    }
    else {
        std::cout << "Unknown command. Type 'help' for available commands.\n";
    }
}

// ========================= MAIN FUNCTION =========================
int main(int argc, char** argv) {
    // Get local IP address
    getLocalIP(SRC_IP);

    // Display system configuration
    displayParameters();

    // Initialize OpenGL and create window
    initGraphics(argc, argv);

    // Start haptic data sender thread
    std::thread senderThread(hapticDataSender);

    // Start haptic data receiver thread if configured as server
    std::thread receiverThread;
    if (IS_SERVER) {
        receiverThread = std::thread(hapticDataReceiver);
    }

    // Display help information
    displayHelp();

    // Start GLUT main loop in a separate thread
    std::thread glutThread([]() {
        glutMainLoop();
        });

    // Main console loop for command processing
    std::string input;
    while (keepRunning) {
        std::cout << "> ";
        std::getline(std::cin, input);

        if (!input.empty()) {
            processCommand(input);
        }
    }

    // Wait for threads to finish
    if (senderThread.joinable()) {
        senderThread.join();
    }

    if (IS_SERVER && receiverThread.joinable()) {
        receiverThread.join();
    }

    // Exit with success
    return 0;
}
