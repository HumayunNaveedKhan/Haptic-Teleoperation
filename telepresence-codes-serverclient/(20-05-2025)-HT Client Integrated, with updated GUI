void initializeWinsock() {
    WSADATA wsaData;
    int result = WSAStartup(MAKEWORD(2, 2), &wsaData);
    if (result != 0) {
        handleError("WSAStartup failed with error: " + to_string(result));
        return;
    }
    logMessage("Winsock initialized successfully");
}

void setupSocket(SOCKET& s, int port, int maxRetries) {
    for (int attempt = 1; attempt <= maxRetries; ++attempt) {
        s = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (s == INVALID_SOCKET) {
            logMessage("Attempt " + to_string(attempt) + ": Socket creation failed with error: " + to_string(WSAGetLastError()));
            if (attempt == maxRetries) {
                handleError("Socket creation failed after " + to_string(maxRetries) + " attempts");
                return;
            }
            continue;
        }
        sockaddr_in clientAddr;
        memset(&clientAddr, 0, sizeof(clientAddr));
        clientAddr.sin_family = AF_INET;
        clientAddr.sin_port = htons(port);
        if (inet_pton(AF_INET, CLIENT_IP, &clientAddr.sin_addr) <= 0) {
            closesocket(s);
            logMessage("Attempt " + to_string(attempt) + ": Invalid client IP address: " + string(CLIENT_IP));
            if (attempt == maxRetries) {
                handleError("Invalid client IP address: " + string(CLIENT_IP));
                return;
            }
            continue;
        }
        int bindResult = ::bind(s, (sockaddr*)&clientAddr, sizeof(clientAddr));
        if (bindResult == SOCKET_ERROR) {
            int error = WSAGetLastError();
            closesocket(s);
            logMessage("Attempt " + to_string(attempt) + ": Bind failed on port " + to_string(port) + " with error: " + to_string(error));
            if (attempt == maxRetries) {
                handleError("Bind failed on port " + to_string(port) + " after " + to_string(maxRetries) + " attempts");
                return;
            }
            continue;
        }
        int rcvbuf = SOCKET_RCVBUF_SIZE;
        setsockopt(s, SOL_SOCKET, SO_RCVBUF, (char*)&rcvbuf, sizeof(rcvbuf));
        logMessage("Socket bound to " + string(CLIENT_IP) + ":" + to_string(port));
        return;
    }
}

void logRawPacket(const char* buffer, int size) {
    stringstream ss;
    ss << "Raw packet data (" << size << " bytes): ";
    for (int i = 0; i < min(size, 32); i++) {
        ss << hex << setfill('0') << setw(2) << (unsigned char)buffer[i] << " ";
    }
    if (size > 32) ss << "...";
    logMessage(ss.str());
}

void updateAdaptiveParameters() {
    lock_guard<mutex> lock(bufferMutex);
    if (errorBuffer.empty()) {
        adaptiveDamping = 0.0;
        adaptiveStiffness = 0.0;
        logMessage("No error data for adaptive parameters");
        return;
    }
    cVector3d meanError(0.0, 0.0, 0.0);
    for (const auto& err : errorBuffer) {
        meanError += err;
    }
    meanError /= static_cast<double>(errorBuffer.size());
    cVector3d variance(0.0, 0.0, 0.0);
    for (const auto& err : errorBuffer) {
        cVector3d diff = err - meanError;
        //variance += diff * diff;
    }
    variance /= static_cast<double>(errorBuffer.size());
    double totalVariance = variance.length();
    double avgDamping = dampingBuffer.empty() ? 0.0 :
        accumulate(dampingBuffer.begin(), dampingBuffer.end(), 0.0) / dampingBuffer.size();
    double avgStiffness = stiffnessBuffer.empty() ? 0.0 :
        accumulate(stiffnessBuffer.begin(), dampingBuffer.end(), 0.0) / dampingBuffer.size();
    adaptiveDamping = avgDamping * (1.0 - ERROR_VARIANCE_SCALE * totalVariance);
    adaptiveStiffness = avgStiffness * (1.0 - ERROR_VARIANCE_SCALE * totalVariance);
    adaptiveDamping = max(0.0, min(adaptiveDamping, MAX_DAMPING));
    adaptiveStiffness = max(0.0, min(adaptiveStiffness, MAX_STIFFNESS));
    logMessage("Updated adaptive parameters: Damping=" + to_string(adaptiveDamping) +
        " N·s/m, Stiffness=" + to_string(adaptiveStiffness) + " N/m");
}

void networkCommunication() {
    logMessage("Network thread started");
    sockaddr_in serverAddr;
    memset(&serverAddr, 0, sizeof(serverAddr));
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(SEND_PORT);
    if (inet_pton(AF_INET, SERVER_IP, &serverAddr.sin_addr) <= 0) {
        handleError("Invalid server IP address: " + string(SERVER_IP));
        running = false;
        return;
    }
    char recvBuffer[BUFFER_SIZE];
    sockaddr_in senderAddr;
    int senderAddrSize = sizeof(senderAddr);
    SetThreadPriority(GetCurrentThread(), networkThreadPriority);
    fd_set readSet;
    timeval timeout;
    timeout.tv_sec = 0;
    timeout.tv_usec = SOCKET_TIMEOUT_MS * 1000;
    auto lastAdaptiveUpdate = chrono::steady_clock::now();
    auto lastSendTime = chrono::steady_clock::now();
    random_device rd;
    mt19937 gen(rd());
    while (running) {
        auto loopStart = chrono::steady_clock::now();
        bool shouldSend = false;
        double currentInterval = packetIntervalMs;
        int currentMaxPackets = maxPacketsToSend;
        bool currentRawMode = false;
        {
            lock_guard<mutex> lock(controlMutex);
            shouldSend = sendPacketsEnabled && (maxPacketsToSend == 0 || packetCount < maxPacketsToSend);
            currentInterval = rawModeEnabled ? 0.0 : packetIntervalMs;
            currentMaxPackets = maxPacketsToSend;
            currentRawMode = rawModeEnabled;
        }
        if (shouldSend || currentRawMode) {
            auto now = chrono::steady_clock::now();
            auto elapsedMs = chrono::duration_cast<chrono::milliseconds>(now - lastSendTime).count();
            if (elapsedMs >= currentInterval) {
                auto sendTime = chrono::duration_cast<chrono::milliseconds>(
                    chrono::system_clock::now().time_since_epoch()).count();
                cVector3d position;
                bool validPosition = hapticDevice ? hapticDevice->getPosition(position) : false;
                if (validPosition) {
                    OutgoingPacket packet;
                    memset(&packet, 0, sizeof(packet));
                    packet.packetNumber = ++packetCount;
                    packet.x = static_cast<float>(position.x());
                    packet.y = static_cast<float>(position.y());
                    packet.z = static_cast<float>(position.z());
                    packet.delay = currentRawMode ? 0.0f : 1000.0f / HAPTIC_RATE_HZ;
                    getCurrentTimestamp(packet.timestamp, sizeof(packet.timestamp));
                    strcpy_s(packet.srcIP, CLIENT_IP);
                    strcpy_s(packet.dstIP, SERVER_IP);
                    packet.srcPort = SEND_PORT;
                    packet.dstPort = SEND_PORT;
                    int sendResult = sendto(sock, (char*)&packet, sizeof(packet), 0,
                        (sockaddr*)&serverAddr, sizeof(serverAddr));
                    if (sendResult == SOCKET_ERROR) {
                        failedSends++;
                        logMessage("Send failed: " + to_string(WSAGetLastError()));
                    }
                    else {
                        successfulSends++;
                        lastPacketTime = sendTime;
                        logMessage("SENT #" + to_string(packet.packetNumber) + " | Position: (" +
                            to_string(packet.x) + ", " + to_string(packet.y) + ", " + to_string(packet.z) +
                            ") | " + packet.timestamp);
                        // Update graph data
                        lock_guard<mutex> lock(graphMutex);
                        auto elapsedSec = chrono::duration_cast<chrono::seconds>(now - graphStartTime).count();
                        int index = elapsedSec % GRAPH_WINDOW;
                        sentPacketCounts[index]++;
                        sendDelays[index] = elapsedMs;
                    }
                    lastSendTime = now;
                    // Apply random/uniform delay
                    if (!currentRawMode && packetDelayMax > packetDelayMin) {
                        uniform_real_distribution<double> dist(packetDelayMin, packetDelayMax);
                        double delay = dist(gen);
                        this_thread::sleep_for(chrono::microseconds(static_cast<int>(delay * 1000)));
                    }
                }
                else {
                    failedSends++;
                    logMessage("Failed to read haptic position");
                }
            }
        }
        bool shouldReceive = false;
        {
            lock_guard<mutex> lock(controlMutex);
            shouldReceive = receiveFeedbackEnabled || rawModeEnabled;
        }
        if (shouldReceive) {
            FD_ZERO(&readSet);
            FD_SET(sock, &readSet);
            int selectResult = select(0, &readSet, nullptr, nullptr, &timeout);
            if (selectResult > 0 && FD_ISSET(sock, &readSet)) {
                int recvResult = recvfrom(sock, recvBuffer, BUFFER_SIZE, 0,
                    (sockaddr*)&senderAddr, &senderAddrSize);
                if (recvResult > 0) {
                    logMessage("Received " + to_string(recvResult) + " bytes from " +
                        string(inet_ntoa(senderAddr.sin_addr)) + ":" + to_string(ntohs(senderAddr.sin_port)) +
                        " on port " + to_string(RECV_PORT));
                    logRawPacket(recvBuffer, recvResult);
                    if (recvResult >= sizeof(IncomingPacket)) {
                        IncomingPacket* packet = reinterpret_cast<IncomingPacket*>(recvBuffer);
                        logMessage("Packet contents: packetNumber=" + to_string(packet->packetNumber) +
                            ", isActive=" + to_string(packet->isActive) +
                            ", force=[" + to_string(packet->force[0]) + ", " +
                            to_string(packet->force[1]) + ", " + to_string(packet->force[2]) + "]" +
                            ", timestamp=" + string(packet->timestamp));
                        if (packet->isActive) {
                            lock_guard<mutex> lock(forceFeedbackMutex);
                            cVector3d force(packet->force[0], packet->force[1], packet->force[2]);
                            if (force.length() > MAX_FORCE) {
                                force = force * (MAX_FORCE / force.length());
                            }
                            {
                                lock_guard<mutex> bufferLock(bufferMutex);
                                forceBuffer.push_back(force);
                                stiffnessBuffer.push_back(packet->stiffness);
                                dampingBuffer.push_back(packet->damping);
                                errorBuffer.push_back(cVector3d(packet->error[0], packet->error[1], packet->error[2]));
                                if (forceBuffer.size() > FORCE_PACKET_WINDOW) {
                                    forceBuffer.erase(forceBuffer.begin());
                                    stiffnessBuffer.erase(stiffnessBuffer.begin());
                                    dampingBuffer.erase(dampingBuffer.begin());
                                    errorBuffer.erase(errorBuffer.begin());
                                }
                                cVector3d avgForce(0, 0, 0);
                                for (const auto& f : forceBuffer) {
                                    avgForce += f;
                                }
                                avgForce /= static_cast<double>(forceBuffer.size());
                                forceFeedback = avgForce;
                            }
                            lastStiffness = packet->stiffness;
                            lastDamping = packet->damping;
                            lastError.set(packet->error[0], packet->error[1], packet->error[2]);
                            auto recvTime = chrono::duration_cast<chrono::milliseconds>(
                                chrono::system_clock::now().time_since_epoch()).count();
                            if (packet->packetNumber == packetCount) {
                                double latency = recvTime - lastPacketTime;
                                if (latencyCount == 0) {
                                    avgLatency = latency;
                                }
                                else {
                                    avgLatency = (avgLatency * latencyCount + latency) / (latencyCount + 1);
                                }
                                latencyCount++;
                                // Update graph data
                                lock_guard<mutex> lock(graphMutex);
                                auto elapsedSec = chrono::duration_cast<chrono::seconds>(chrono::steady_clock::now() - graphStartTime).count();
                                int index = elapsedSec % GRAPH_WINDOW;
                                receivedPacketCounts[index]++;
                                receiveDelays[index] = latency;
                            }
                            successfulReceives++;
                            newForceFeedback = true;
                            logMessage("RECEIVED #" + to_string(packet->packetNumber) + " | Force: (" +
                                to_string(forceFeedback.x()) + ", " + to_string(forceFeedback.y()) + ", " +
                                to_string(forceFeedback.z()) + ") | Stiffness: " + to_string(packet->stiffness) +
                                " | Damping: " + to_string(packet->damping) + " | Timestamp: " + packet->timestamp);
                        }
                        else {
                            logMessage("Received inactive packet, ignoring");
                            lock_guard<mutex> lock(forceFeedbackMutex);
                            newForceFeedback = false;
                        }
                    }
                    else {
                        failedReceives++;
                        logMessage("Received packet too small: " + to_string(recvResult) + " bytes (expected >= " +
                            to_string(sizeof(IncomingPacket)) + ")");
                    }
                }
                else {
                    failedReceives++;
                    logMessage("Receive failed on port " + to_string(RECV_PORT) + ": " + to_string(WSAGetLastError()));
                }
            }
            else {
                timeoutReceives++;
                logMessage("Receive timeout on port " + to_string(RECV_PORT) + " (" + to_string(timeoutReceives) + " total)");
                lock_guard<mutex> lock(forceFeedbackMutex);
                newForceFeedback = false;
            }
            // Fallback port handling
            FD_ZERO(&readSet);
            FD_SET(fallbackSock, &readSet);
            int fallbackSelectResult = select(0, &readSet, nullptr, nullptr, &timeout);
            if (fallbackSelectResult > 0 && FD_ISSET(fallbackSock, &readSet)) {
                int recvResult = recvfrom(fallbackSock, recvBuffer, BUFFER_SIZE, 0,
                    (sockaddr*)&senderAddr, &senderAddrSize);
                if (recvResult > 0) {
                    logMessage("Received " + to_string(recvResult) + " bytes from " +
                        string(inet_ntoa(senderAddr.sin_addr)) + ":" + to_string(ntohs(senderAddr.sin_port)) +
                        " on port " + to_string(FALLBACK_PORT));
                    logRawPacket(recvBuffer, recvResult);
                    if (recvResult >= sizeof(IncomingPacket)) {
                        IncomingPacket* packet = reinterpret_cast<IncomingPacket*>(recvBuffer);
                        logMessage("Packet contents: packetNumber=" + to_string(packet->packetNumber) +
                            ", isActive=" + to_string(packet->isActive) +
                            ", force=[" + to_string(packet->force[0]) + ", " +
                            to_string(packet->force[1]) + ", " + to_string(packet->force[2]) + "]" +
                            ", timestamp=" + string(packet->timestamp));
                        if (packet->isActive) {
                            lock_guard<mutex> lock(forceFeedbackMutex);
                            cVector3d force(packet->force[0], packet->force[1], packet->force[2]);
                            if (force.length() > MAX_FORCE) {
                                force = force * (MAX_FORCE / force.length());
                            }
                            {
                                lock_guard<mutex> bufferLock(bufferMutex);
                                forceBuffer.push_back(force);
                                stiffnessBuffer.push_back(packet->stiffness);
                                dampingBuffer.push_back(packet->damping);
                                errorBuffer.push_back(cVector3d(packet->error[0], packet->error[1], packet->error[2]));
                                if (forceBuffer.size() > FORCE_PACKET_WINDOW) {
                                    forceBuffer.erase(forceBuffer.begin());
                                    stiffnessBuffer.erase(stiffnessBuffer.begin());
                                    dampingBuffer.erase(dampingBuffer.begin());
                                    errorBuffer.erase(errorBuffer.begin());
                                }
                                cVector3d avgForce(0, 0, 0);
                                for (const auto& f : forceBuffer) {
                                    avgForce += f;
                                }
                                avgForce /= static_cast<double>(forceBuffer.size());
                                forceFeedback = avgForce;
                            }
                            lastStiffness = packet->stiffness;
                            lastDamping = packet->damping;
                            lastError.set(packet->error[0], packet->error[1], packet->error[2]);
                            auto recvTime = chrono::duration_cast<chrono::milliseconds>(
                                chrono::system_clock::now().time_since_epoch()).count();
                            if (packet->packetNumber == packetCount) {
                                double latency = recvTime - lastPacketTime;
                                if (latencyCount == 0) {
                                    avgLatency = latency;
                                }
                                else {
                                    avgLatency = (avgLatency * latencyCount + latency) / (latencyCount + 1);
                                }
                                latencyCount++;
                                // Update graph data
                                lock_guard<mutex> lock(graphMutex);
                                auto elapsedSec = chrono::duration_cast<chrono::seconds>(chrono::steady_clock::now() - graphStartTime).count();
                                int index = elapsedSec % GRAPH_WINDOW;
                                receivedPacketCounts[index]++;
                                receiveDelays[index] = latency;
                            }
                            successfulReceives++;
                            newForceFeedback = true;
                            logMessage("RECEIVED #" + to_string(packet->packetNumber) + " | Force: (" +
                                to_string(forceFeedback.x()) + ", " + to_string(forceFeedback.y()) + ", " +
                                to_string(forceFeedback.z()) + ") | Stiffness: " + to_string(packet->stiffness) +
                                " | Damping: " + to_string(packet->damping) + " | Timestamp: " + packet->timestamp);
                        }
                        else {
                            logMessage("Received inactive packet on fallback port, ignoring");
                            lock_guard<mutex> lock(forceFeedbackMutex);
                            newForceFeedback = false;
                        }
                    }
                    else {
                        failedReceives++;
                        logMessage("Received packet too small on fallback port: " + to_string(recvResult) + " bytes (expected >= " +
                            to_string(sizeof(IncomingPacket)) + ")");
                    }
                }
                else {
                    failedReceives++;
                    logMessage("Receive failed on port " + to_string(FALLBACK_PORT) + ": " + to_string(WSAGetLastError()));
                }
            }
        }
        auto now = chrono::steady_clock::now();
        auto elapsedMs = chrono::duration_cast<chrono::milliseconds>(now - lastAdaptiveUpdate).count();
        if (elapsedMs >= ADAPTIVE_UPDATE_MS && USE_ADAPTIVE_DAMPING && !currentRawMode) {
            updateAdaptiveParameters();
            lastAdaptiveUpdate = now;
        }
        auto loopEnd = chrono::high_resolution_clock::now();
        auto elapsed = chrono::duration_cast<chrono::microseconds>(loopEnd - loopStart);
        auto sleepTime = chrono::microseconds(1000000 / HAPTIC_RATE_HZ) - elapsed;
        if (sleepTime.count() > 0 && !currentRawMode) {
            this_thread::sleep_for(sleepTime);
        }
    }
    logMessage("Network thread exiting");
}

void hapticLoop() {
    logMessage("Haptic thread started");
    SetThreadPriority(GetCurrentThread(), hapticThreadPriority);
    cVector3d lastVelocity(0.0, 0.0, 0.0);
    bool flagHapticsEnabled = false;
    cPrecisionClock clock;
    clock.reset();
    simulationRunning = true;
    simulationFinished = false;
    if (hapticDevice) {
        if (!hapticDevice->open()) {
            logMessage("Failed to open haptic device in hapticLoop");
            hapticDevice = nullptr;
            useVirtualEnvironment = true;
        }
        if (!hapticDevice->calibrate()) {
            logMessage("Haptic device calibration failed in hapticLoop");
        }
    }
    while (hapticRunning) {
        auto loopStart = chrono::high_resolution_clock::now();
        clock.stop();
        double timeInterval = cMin(0.001, clock.getCurrentTimeSeconds());
        clock.reset();
        clock.start();
        cVector3d force(0.0, 0.0, 0.0);
        double damping = 0.0;
        bool button = false;
        if (hapticDevice) {
            if (!hapticDevice->getUserSwitch(0, button)) {
                logMessage("Failed to read user switch");
            }
        }
        if (button) {
            useVirtualEnvironment = !useVirtualEnvironment;
            logMessage("Switched to " + string(useVirtualEnvironment ? "Virtual Environment" : "Network") + " mode");
            while (hapticDevice && hapticDevice->getUserSwitch(0, button) && button) {
                cSleepMs(10);
            }
        }
        if (useVirtualEnvironment) {
            cVector3d position;
            bool validPosition = hapticDevice ? hapticDevice->getPosition(position) : false;
            if (validPosition) {
                const double WALL_GROUND = 0.0 + SPHERE_RADIUS;
                const double WALL_LEFT = -0.1;
                const double WALL_RIGHT = 0.2;
                const double WALL_FRONT = 0.08;
                const double WALL_BACK = -0.08;
                cVector3d sphereFce[NUM_SPHERES];
                for (int i = 0; i < NUM_SPHERES; i++) {
                    sphereFce[i].zero();
                }
                for (int i = 0; i < NUM_SPHERES; i++) {
                    cVector3d force;
                    cVector3d pos0 = spheres[i]->getLocalPos();
                    for (int j = i + 1; j < NUM_SPHERES; j++) {
                        force.zero();
                        cVector3d pos1 = spheres[j]->getLocalPos();
                        cVector3d dir01 = pos1 - pos0;
                        double distance = dir01.length();
                        if (distance > 1e-8) {
                            dir01 /= distance;
                        }
                        else {
                            dir01.zero();
                        }
                        if (!button) {
                            if ((distance < 2.5 * SPHERE_RADIUS) && (distance > 2.0 * SPHERE_RADIUS)) {
                                force += (-K_MAGNET * (distance - 2.5 * SPHERE_RADIUS) * dir01);
                            }
                        }
                        if (distance < 2.0 * SPHERES_RADIUS) {
                            force += (SPHERE_STIFFNESS * (distance - 2.0 * SPHERE_RADIUS) * dir01);
                        }
                        sphereFce[i] += force;
                        sphereFce[j] += (-force);
                    }
                    if (pos0.z() < WALL_GROUND) {
                        sphereFce[i] += cVector3d(0.0, 0.0, SPHERE_STIFFNESS * (WALL_GROUND - pos0.z()));
                    }
                    if (pos0.y() < WALL_LEFT) {
                        sphereFce[i] += cVector3d(0.0, SPHERE_STIFFNESS * (WALL_LEFT - pos0.y()), 0.0);
                    }
                    if (pos0.y() > WALL_RIGHT) {
                        sphereFce[i] += cVector3d(0.0, SPHERE_STIFFNESS * (WALL_RIGHT - pos0.y()), 0.0);
                    }
                    if (pos0.x() < WALL_BACK) {
                        sphereFce[i] += cVector3d(SPHERE_STIFFNESS * (WALL_BACK - pos0.x()), 0.0, 0.0);
                    }
                    if (pos0.x() > WALL_FRONT) {
                        sphereFce[i] += cVector3d(SPHERE_STIFFNESS * (WALL_FRONT - pos0.x()), 0.0, 0.0);
                    }
                }
                cVector3d dirHapticSphere = spheres[0]->getLocalPos() - position;
                cVector3d forceSphere = -SPHERE_STIFFNESS * dirHapticSphere;
                force = HAPTIC_STIFFNESS * dirHapticSphere;
                sphereFce[0] += forceSphere;
                for (int i = 0; i < NUM_SPHERES; i++) {
                    cVector3d sphereAcc = (sphereFce[i] / SPHERE_MASS) + cVector3d(0.0, 0.0, -9.81);
                    sphereVel[i] = K_DAMPING * (sphereVel[i] + timeInterval * sphereAcc);
                    cVector3d spherePos = spheres[i]->getLocalPos() + timeInterval * sphereVel[i] + (timeInterval * timeInterval) * sphereAcc;
                    spheres[i]->setLocalPos(spherePos);
                }
                if (!flagHapticsEnabled) {
                    if (force.length() < 1.0) {
                        flagHapticsEnabled = true;
                    }
                    else {
                        force.zero();
                    }
                }
                double stiffnessRatio = 1.0;
                if (hapticDeviceMaxStiffness < HAPTIC_STIFFNESS) {
                    stiffnessRatio = hapticDeviceMaxStiffness / HAPTIC_STIFFNESS;
                }
                force *= stiffnessRatio;
            }
        }
        else {
            bool shouldApplyFeedback = false;
            {
                lock_guard<mutex> lock(controlMutex);
                shouldApplyFeedback = applyHapticFeedback || rawModeEnabled;
            }
            if (shouldApplyFeedback) {
                lock_guard<mutex> lock(forceFeedbackMutex);
                logMessage("Acquired forceFeedbackMutex in hapticLoop");
                if (newForceFeedback) {
                    force = forceFeedback;
                    damping = USE_ADAPTIVE_DAMPING ? adaptiveDamping : lastDamping;
                }
            }
        }
        if (hapticDevice) {
            cVector3d velocity;
            if (hapticDevice->getLinearVelocity(velocity)) {
                if (!useVirtualEnvironment && newForceFeedback && (applyHapticFeedback || rawModeEnabled)) {
                    force -= damping * velocity;
                }
                lastVelocity = velocity;
            }
            if (force.length() > 0.0) {
                if (!hapticDevice->setForce(force)) {
                    logMessage("Failed to set force on haptic device");
                }
            }
            else {
                if (!hapticDevice->setForce(cVector3d(0, 0, 0))) {
                    logMessage("Failed to set zero force on haptic device");
                }
            }
        }
        freqCounterHaptics.signal(1);
        auto loopEnd = chrono::high_resolution_clock::now();
        auto elapsed = chrono::duration_cast<chrono::microseconds>(loopEnd - loopStart);
        auto sleepTime = chrono::microseconds(1000000 / HAPTIC_RATE_HZ) - elapsed;
        if (sleepTime.count() > 0 && !rawModeEnabled) {
            this_thread::sleep_for(sleepTime);
        }
    }
    if (hapticDevice) {
        hapticDevice->close();
    }
    simulationFinished = true;
    logMessage("Haptic thread exiting");
}

void controlGUI() {
    logMessage("Control GUI thread started");
    glfwMakeContextCurrent(controlWindow);
    controlWorld = new cWorld();
    if (!controlWorld) {
        handleError("Failed to create control world");
        controlRunning = false;
        return;
    }
    controlWorld->m_backgroundColor.setGrayLevel(0.9);
    controlCamera = new cCamera(controlWorld);
    if (!controlCamera) {
        handleError("Failed to create control camera");
        controlRunning = false;
        return;
    }
    controlWorld->addChild(controlCamera);
    // Set orthographic view with single width parameter
    double aspect = (double)controlWidth / controlHeight;
    controlCamera->setOrthographicView(200.0 * aspect); // Width scaled by aspect ratio
    controlCamera->set(cVector3d(0, 0, 10), cVector3d(0, 0, 0), cVector3d(0, 1, 0));
    controlFont = NEW_CFONTCALIBRI20();
    if (!controlFont) {
        handleError("Failed to create control font");
        controlRunning = false;
        return;
    }

    // Initialize graphs
    for (int i = 0; i < GRAPH_WINDOW; i++) {
        cShapeBox* sentBar = new cShapeBox(1, 1, 0.1);
        cShapeBox* receivedBar = new cShapeBox(1, 1, 0.1);
        cShapeLine* delayLine = new cShapeLine(cVector3d(0, 0, 0), cVector3d(0, 0, 0));
        if (!sentBar || !receivedBar || !delayLine) {
            handleError("Failed to create graph elements");
            controlRunning = false;
            return;
        }
        sentBar->m_material->setBlue();
        receivedBar->m_material->setRed();
        delayLine->m_material->setGreen();
        controlWorld->addChild(sentBar);
        controlWorld->addChild(receivedBar);
        controlWorld->addChild(delayLine);
        sentPacketBars.push_back(sentBar);
        receivedPacketBars.push_back(receivedBar);
        delayLines.push_back(delayLine);
    }

    // Initialize control labels
    vector<string> controlNames = {
        "Send Packets: ON", "Receive Feedback: ON", "Apply Haptic: ON", "Raw Mode: OFF",
        "Net Priority: TIME_CRITICAL", "Hap Priority: TIME_CRITICAL",
        "Delay Min: 0.0 ms", "Delay Max: 0.0 ms", "Max Packets: 0",
        "Packet Interval: 1.0 ms", "Feedback Window: 5"
    };
    for (int i = 0; i < controlNames.size(); i++) {
        cLabel* label = new cLabel(controlFont);
        if (!label) {
            handleError("Failed to create control label");
            controlRunning = false;
            return;
        }
        label->m_fontColor.setBlack();
        label->setText(controlNames[i]);
        controlCamera->m_frontLayer->addChild(label);
        controlLabels.push_back(label);
    }

    controlWindowSizeCallback(controlWindow, controlWidth, controlHeight);

    while (controlRunning && !glfwWindowShouldClose(controlWindow)) {
        glfwMakeContextCurrent(controlWindow);
        updateControlGraphics();
        glfwSwapBuffers(controlWindow);
        glfwPollEvents();
        freqCounterControlGraphics.signal(1);
    }

    logMessage("Control GUI thread exiting");
}

void controlWindowSizeCallback(GLFWwindow* a_window, int a_width, int a_height) {
    controlWidth = a_width;
    controlHeight = a_height;
    if (controlCamera) {
        double aspect = (double)controlWidth / controlHeight;
        controlCamera->setOrthographicView(200.0 * aspect); // Width scaled by aspect ratio
    }
    // Position control labels
    for (size_t i = 0; i < controlLabels.size(); i++) {
        controlLabels[i]->setLocalPos(10, controlHeight - 20 - i * 30);
    }
    // Position graphs
    double barWidth = controlWidth / (double)GRAPH_WINDOW;
    double maxHeight = controlHeight * 0.3;
    for (int i = 0; i < GRAPH_WINDOW; i++) {
        sentPacketBars[i]->setLocalPos(i * barWidth + barWidth / 2, maxHeight / 2, 0);
        receivedPacketBars[i]->setLocalPos(i * barWidth + barWidth / 2, maxHeight * 1.5, 0);
        delayLines[i]->setLocalPos(i * barWidth, maxHeight * 2.5, 0);
    }
}

