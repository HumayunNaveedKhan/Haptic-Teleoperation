            labelMode->setText("Mode: " + string(useVirtualEnvironment ? "VE" : "Network"));
        }
        if (labelPackets) {
            labelPackets->setText("Packets: Sent=" + to_string(packetCount) + " (OK=" + to_string(successfulSends) +
                ", Fail=" + to_string(failedSends) + ") | Recv=" + to_string(successfulReceives) +
                " (Fail=" + to_string(failedReceives) + ", TO=" + to_string(timeoutReceives) + ")");
        }
