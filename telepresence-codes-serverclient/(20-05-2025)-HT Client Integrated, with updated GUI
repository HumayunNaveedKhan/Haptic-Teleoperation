    if (a_action != GLFW_PRESS) return;
    if (a_key == GLFW_KEY_ESCAPE || a_key == GLFW_KEY_Q) {
        glfwSetWindowShouldClose(a_window, GLFW_TRUE);
    }
}

void controlMouseButtonCallback(GLFWwindow* a_window, int a_button, int a_action, int a_mods) {
    if (a_button == GLFW_MOUSE_BUTTON_LEFT && a_action == GLFW_PRESS) {
        double x, y;
        glfwGetCursorPos(a_window, &x, &y);
        y = controlHeight - y; // Invert y-coordinate
        lock_guard<mutex> lock(controlMutex);
        for (size_t i = 0; i < controlLabels.size(); i++) {
            cLabel* label = controlLabels[i];
            int lx = label->getLocalPos().x();
            int ly = label->getLocalPos().y();
            int lw = label->getWidth();
            int lh = label->getHeight();
            if (x >= lx && x <= lx + lw && y >= ly && y <= ly + lh) {
                if (i == 0) {
                    sendPacketsEnabled = !sendPacketsEnabled;
                    label->setText("Send Packets: " + string(sendPacketsEnabled ? "ON" : "OFF"));
                }
                else if (i == 1) {
                    receiveFeedbackEnabled = !receiveFeedbackEnabled;
                    label->setText("Receive Feedback: " + string(receiveFeedbackEnabled ? "ON" : "OFF"));
                }
                else if (i == 2) {
                    applyHapticFeedback = !applyHapticFeedback;
                    label->setText("Apply Haptic: " + string(applyHapticFeedback ? "ON" : "OFF"));
                }
                else if (i == 3) {
                    rawModeEnabled = !rawModeEnabled;
                    label->setText("Raw Mode: " + string(rawModeEnabled ? "ON" : "OFF"));
                }
                else if (i == 4) {
                    networkThreadPriority = (networkThreadPriority == THREAD_PRIORITY_TIME_CRITICAL) ?
                        THREAD_PRIORITY_NORMAL : THREAD_PRIORITY_TIME_CRITICAL;
                    label->setText("Net Priority: " + string(networkThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? "TIME_CRITICAL" : "NORMAL"));
                    SetThreadPriority(GetCurrentThread(), networkThreadPriority);
                }
                else if (i == 5) {
                    hapticThreadPriority = (hapticThreadPriority == THREAD_PRIORITY_TIME_CRITICAL) ?
                        THREAD_PRIORITY_NORMAL : THREAD_PRIORITY_TIME_CRITICAL;
                    label->setText("Hap Priority: " + string(hapticThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? "TIME_CRITICAL" : "NORMAL"));
                }
                else if (i == 6) {
                    packetDelayMin += 1.0;
                    if (packetDelayMin > packetDelayMax) packetDelayMin = packetDelayMax;
                    label->setText("Delay Min: " + to_string_with_precision(packetDelayMin, 1) + " ms");
                }
                else if (i == 7) {
                    packetDelayMax += 1.0;
                    label->setText("Delay Max: " + to_string_with_precision(packetDelayMax, 1) + " ms");
                }
                else if (i == 8) {
                    maxPacketsToSend += 100;
                    label->setText("Max Packets: " + to_string(maxPacketsToSend));
                }
                else if (i == 9) {
                    packetIntervalMs += 0.1;
                    label->setText("Packet Interval: " + to_string_with_precision(packetIntervalMs, 1) + " ms");
                }
                else if (i == 10) {
                    FORCE_PACKET_WINDOW++;
                    label->setText("Feedback Window: " + to_string(FORCE_PACKET_WINDOW));
                }
                break;
            }
        }
    }
}

void updateControlGraphics() {
    // Update graphs
    lock_guard<mutex> lock(graphMutex);
    double maxHeight = controlHeight * 0.3;
    double barWidth = controlWidth / (double)GRAPH_WINDOW;
    int maxPackets = *max_element(sentPacketCounts.begin(), sentPacketCounts.end());
    maxPackets = max(maxPackets, *max_element(receivedPacketCounts.begin(), receivedPacketCounts.end()));
    maxPackets = max(maxPackets, 1);
    double maxDelay = *max_element(sendDelays.begin(), sendDelays.end());
    maxDelay = max(maxDelay, *max_element(receiveDelays.begin(), receiveDelays.end()));
    maxDelay = max(maxDelay, 1.0);
    for (int i = 0; i < GRAPH_WINDOW; i++) {
        double sentHeight = (sentPacketCounts[i] / (double)maxPackets) * maxHeight;
        double receivedHeight = (receivedPacketCounts[i] / (double)maxPackets) * maxHeight;
        // Remove old bars
        controlWorld->removeChild(sentPacketBars[i]);
        controlWorld->removeChild(receivedPacketBars[i]);
        // Create new bars with updated sizes
        sentPacketBars[i] = new cShapeBox(barWidth - 2, sentHeight, 0.1);
        receivedPacketBars[i] = new cShapeBox(barWidth - 2, receivedHeight, 0.1);
        sentPacketBars[i]->m_material->setBlue();
        receivedPacketBars[i]->m_material->setRed();
        sentPacketBars[i]->setLocalPos(i * barWidth + barWidth / 2, maxHeight / 2, 0);
        receivedPacketBars[i]->setLocalPos(i * barWidth + barWidth / 2, maxHeight * 1.5, 0);
        controlWorld->addChild(sentPacketBars[i]);
        controlWorld->addChild(receivedPacketBars[i]);
        // Update line endpoints
        double delayY = (sendDelays[i] / maxDelay) * maxHeight;
        delayLines[i]->m_pointA = cVector3d(i * barWidth, maxHeight * 2.5, 0);
        delayLines[i]->m_pointB = cVector3d(i * barWidth, maxHeight * 2.5 + delayY, 0);
    }

    if (controlWorld) {
        controlWorld->updateShadowMaps(false, false);
    }
    if (controlCamera) {
        controlCamera->renderView(controlWidth, controlHeight);
    }
    glFinish();
    GLenum err = glGetError();
    if (err != GL_NO_ERROR) {
        logMessage("Control OpenGL Error: " + to_string(err));
    }
}

void cleanupSocket() {
    if (sock != INVALID_SOCKET) {
        closesocket(sock);
        sock = INVALID_SOCKET;
    }
    if (fallbackSock != INVALID_SOCKET) {
        closesocket(fallbackSock);
        fallbackSock = INVALID_SOCKET;
    }
    WSACleanup();
    logMessage("Sockets closed and Winsock cleaned up");
}

void getCurrentTimestamp(char* buffer, size_t size) {
    auto now = chrono::system_clock::now();
    auto time = chrono::system_clock::to_time_t(now);
    auto ms = chrono::duration_cast<chrono::milliseconds>(now.time_since_epoch()) % 1000;
    struct tm tstruct;
    localtime_s(&tstruct, &time);
    char temp[64];
    strftime(temp, sizeof(temp), "%Y-%m-%d %H:%M:%S", &tstruct);
    snprintf(buffer, size, "%s.%03lld", temp, (long long)ms.count());
}

