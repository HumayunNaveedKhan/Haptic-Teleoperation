    glVertex2f(xOffset, graphY - GRAPH_HEIGHT);
    glVertex2f(xOffset, graphY); // Y-axis
    glVertex2f(xOffset, graphY - GRAPH_HEIGHT);
    glVertex2f(xOffset + graphWidth, graphY - GRAPH_HEIGHT); // X-axis
