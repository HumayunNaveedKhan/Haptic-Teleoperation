    glBegin(GL_QUADS);
    for (size_t i = 0; i < static_cast<size_t>(GRAPH_WINDOW); i++) {
        if (receivedPacketCounts[i] > 0) {
            float barX = xOffset + i * BAR_WIDTH + BAR_WIDTH * 0.5f; // Offset to avoid overlap with sent bars
            float receivedHeight = (receivedPacketCounts[i] / (float)maxReceivedPackets) * GRAPH_HEIGHT;
            glColor3f(COLOR_RECEIVED.r, COLOR_RECEIVED.g, COLOR_RECEIVED.b);
            glVertex2f(barX, graphY - GRAPH_HEIGHT);
            glVertex2f(barX + BAR_WIDTH * 0.45f, graphY - GRAPH_HEIGHT);
            glVertex2f(barX + BAR_WIDTH * 0.45f, graphY - GRAPH_HEIGHT + receivedHeight);
            glVertex2f(barX, graphY - GRAPH_HEIGHT + receivedHeight);
        }
    }
    glEnd();

    // Draw Axis Labels
    drawText(xOffset - 30, graphY - 5, "Packets");
    drawText(xOffset + graphWidth + 5, graphY - GRAPH_HEIGHT - 5, "Time (s)");

    yOffset -= (GRAPH_HEIGHT + SECTION_SPACING);

    // Graph 3: Packet Delays
    drawText(xOffset, yOffset, "Packet Delays (ms)", TITLE_FONT);
    yOffset -= TEXT_HEIGHT;

    double maxDelay = *max_element(sendDelays.begin(), sendDelays.end());
    maxDelay = std::max(maxDelay, *max_element(receiveDelays.begin(), receiveDelays.end()));
    maxDelay = std::max(maxDelay, 1.0);

    // Draw Grid
    drawGrid(xOffset, graphY - 2 * GRAPH_HEIGHT, graphWidth, GRAPH_HEIGHT, 5, COLOR_GRID);

    // Draw Axes
    glColor3f(COLOR_AXIS.r, COLOR_AXIS.g, COLOR_AXIS.b);
    glBegin(GL_LINES);
    glVertex2f(xOffset, graphY - 2 * GRAPH_HEIGHT);
    glVertex2f(xOffset, graphY - GRAPH_HEIGHT); // Y-axis
    glVertex2f(xOffset, graphY - 2 * GRAPH_HEIGHT);
    glVertex2f(xOffset + graphWidth, graphY - 2 * GRAPH_HEIGHT); // X-axis
    glEnd();

    // Draw Send Delay Line (Blue)
    glColor3f(COLOR_SENT.r, COLOR_SENT.g, COLOR_SENT.b);
    glBegin(GL_LINE_STRIP);
    for (size_t i = 0; i < static_cast<size_t>(GRAPH_WINDOW); i++) {
        float x = xOffset + i * BAR_WIDTH;
        float y = graphY - 2 * GRAPH_HEIGHT + (float)(sendDelays[i] / maxDelay) * GRAPH_HEIGHT;
        glVertex2f(x + BAR_WIDTH / 2, y);
    }
    glEnd();

    // Draw Receive Delay Line (Red)
    glColor3f(COLOR_RECEIVED.r, COLOR_RECEIVED.g, COLOR_RECEIVED.b);
    glBegin(GL_LINE_STRIP);
    for (size_t i = 0; i < static_cast<size_t>(GRAPH_WINDOW); i++) {
        float x = xOffset + i * BAR_WIDTH;
        float y = graphY - 2 * GRAPH_HEIGHT + (float)(receiveDelays[i] / maxDelay) * GRAPH_HEIGHT;
        glVertex2f(x + BAR_WIDTH / 2, y);
    }
    glEnd();

    // Draw Axis Labels
    drawText(xOffset - 30, graphY - GRAPH_HEIGHT - 5, "Delay (ms)");
    drawText(xOffset + graphWidth + 5, graphY - 2 * GRAPH_HEIGHT - 5, "Time (s)");

    yOffset -= (GRAPH_HEIGHT + SECTION_SPACING);

    // Section 2: Haptic Feedback
    drawText(xOffset, yOffset, "Haptic Feedback", TITLE_FONT);
    yOffset -= TEXT_HEIGHT * 2;
    drawText(xOffset, yOffset, "Force: (" + to_string_with_precision(forceFeedback.x(), 2) + ", " +
        to_string_with_precision(forceFeedback.y(), 2) + ", " +
        to_string_with_precision(forceFeedback.z(), 2) + ") N");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "Stiffness: " + to_string_with_precision(lastStiffness, 2) + " N/m");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "Damping: " + to_string_with_precision(lastDamping, 2) + " N·s/m");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "Error: (" + to_string_with_precision(lastError.x(), 4) + ", " +
        to_string_with_precision(lastError.y(), 4) + ", " +
        to_string_with_precision(lastError.z(), 4) + ")");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "Position: (" + to_string_with_precision(position.x(), 4) + ", " +
        to_string_with_precision(position.y(), 4) + ", " +
        to_string_with_precision(position.z(), 4) + ") m");
    yOffset -= SECTION_SPACING;

    // Section 3: Controls
    drawText(xOffset, yOffset, "Controls", TITLE_FONT);
    yOffset -= TEXT_HEIGHT * 2;

    float statusX = xOffset + 200;
    drawText(xOffset, yOffset, "[1] Send Packets");
    drawCircle(statusX, yOffset, STATUS_RADIUS, sendPacketsEnabled ? COLOR_ON : COLOR_OFF);
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[2] Receive Feedback");
    drawCircle(statusX, yOffset, STATUS_RADIUS, receiveFeedbackEnabled ? COLOR_ON : COLOR_OFF);
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[3] Apply Haptic");
    drawCircle(statusX, yOffset, STATUS_RADIUS, applyHapticFeedback ? COLOR_ON : COLOR_OFF);
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[4] Raw Mode");
    drawCircle(statusX, yOffset, STATUS_RADIUS, rawModeEnabled ? COLOR_ON : COLOR_OFF);
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[5] Net Priority: " + string(networkThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? "TIME_CRITICAL" : "NORMAL"));
    drawCircle(statusX, yOffset, STATUS_RADIUS, networkThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? COLOR_ON : COLOR_OFF);
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[6] Hap Priority: " + string(hapticThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? "TIME_CRITICAL" : "NORMAL"));
    drawCircle(statusX, yOffset, STATUS_RADIUS, hapticThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? COLOR_ON : COLOR_OFF);
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[7] Delay Min: " + to_string_with_precision(packetDelayMin, 1) + " ms");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[8] Delay Max: " + to_string_with_precision(packetDelayMax, 1) + " ms");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[9] Max Packets: " + to_string(maxPacketsToSend));
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[0] Packet Interval: " + to_string_with_precision(packetIntervalMs, 1) + " ms");
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[w] Feedback Window: " + to_string(FORCE_PACKET_WINDOW));
    yOffset -= TEXT_HEIGHT;
    drawText(xOffset, yOffset, "[q] or [Esc] Exit");

    // Section 4: Real-Time Packet Coordinates (Right Side)
    yOffset = glutHeight - MARGIN;
    drawText(rightOffset, yOffset, "Latest Packet Data", TITLE_FONT);
    yOffset -= TEXT_HEIGHT * 2;

    // Latest Sent Packet (Position)
    static cVector3d lastSentPosition(0.0, 0.0, 0.0);
    if (successfulSends > 0) {
        cVector3d pos;
        if (hapticDevice && hapticDevice->getPosition(pos)) {
            lastSentPosition = pos;
        }
    }
    drawText(rightOffset, yOffset, "Last Sent Packet:");
    yOffset -= TEXT_HEIGHT;
    drawText(rightOffset, yOffset, "Position: (" + to_string_with_precision(lastSentPosition.x(), 4) + ", " +
        to_string_with_precision(lastSentPosition.y(), 4) + ", " +
        to_string_with_precision(lastSentPosition.z(), 4) + ") m");
    yOffset -= TEXT_HEIGHT * 2;

    // Latest Received Packet (Force)
    static cVector3d lastReceivedForce(0.0, 0.0, 0.0);
    if (newForceFeedback) {
        lock_guard<mutex> lock(forceFeedbackMutex);
        lastReceivedForce = forceFeedback;
    }
    drawText(rightOffset, yOffset, "Last Received Packet:");
    yOffset -= TEXT_HEIGHT;
    drawText(rightOffset, yOffset, "Force: (" + to_string_with_precision(lastReceivedForce.x(), 2) + ", " +
        to_string_with_precision(lastReceivedForce.y(), 2) + ", " +
        to_string_with_precision(lastReceivedForce.z(), 2) + ") N");

    glutSwapBuffers();
}

void glutReshape(int width, int height) {
    glutWidth = width;
    glutHeight = max(height, 1);
    glViewport(0, 0, glutWidth, glutHeight);
    glutPostRedisplay();
}

void glutKeyboard(unsigned char key, int x, int y) {
    lock_guard<mutex> lock(controlMutex);
    switch (key) {
    case '1':
        sendPacketsEnabled = !sendPacketsEnabled;
        logMessage("Send Packets: " + string(sendPacketsEnabled ? "ON" : "OFF"));
        break;
    case '2':
        receiveFeedbackEnabled = !receiveFeedbackEnabled;
        logMessage("Receive Feedback: " + string(receiveFeedbackEnabled ? "ON" : "OFF"));
        break;
    case '3':
        applyHapticFeedback = !applyHapticFeedback;
        logMessage("Apply Haptic: " + string(applyHapticFeedback ? "ON" : "OFF"));
        break;
    case '4':
        rawModeEnabled = !rawModeEnabled;
        logMessage("Raw Mode: " + string(rawModeEnabled ? "ON" : "OFF"));
        break;
    case '5':
        networkThreadPriority = (networkThreadPriority == THREAD_PRIORITY_TIME_CRITICAL) ?
            THREAD_PRIORITY_NORMAL : THREAD_PRIORITY_TIME_CRITICAL;
        logMessage("Net Priority: " + string(networkThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? "TIME_CRITICAL" : "NORMAL"));
        SetThreadPriority(GetCurrentThread(), networkThreadPriority);
        break;
    case '6':
        hapticThreadPriority = (hapticThreadPriority == THREAD_PRIORITY_TIME_CRITICAL) ?
            THREAD_PRIORITY_NORMAL : THREAD_PRIORITY_TIME_CRITICAL;
        logMessage("Hap Priority: " + string(hapticThreadPriority == THREAD_PRIORITY_TIME_CRITICAL ? "TIME_CRITICAL" : "NORMAL"));
        break;
    case '7':
        packetDelayMin += 1.0;
        if (packetDelayMin > packetDelayMax) packetDelayMin = packetDelayMax;
        logMessage("Delay Min: " + to_string_with_precision(packetDelayMin, 1) + " ms");
        break;
    case '8':
        packetDelayMax += 1.0;
        logMessage("Delay Max: " + to_string_with_precision(packetDelayMax, 1) + " ms");
        break;
    case '9':
        maxPacketsToSend += 100;
        logMessage("Max Packets: " + to_string(maxPacketsToSend));
        break;
    case '0':
        packetIntervalMs += 0.1;
        logMessage("Packet Interval: " + to_string_with_precision(packetIntervalMs, 1) + " ms");
        break;
    case 'w':
        FORCE_PACKET_WINDOW++;
        logMessage("Feedback Window: " + to_string(FORCE_PACKET_WINDOW));
        break;
    case 27:
    case 'q':
        running = false;
        glutDestroyWindow(glutWindow);
        break;
    }
    glutPostRedisplay();
}

void updateGraphics() {
    if (!camera) return;
    labelRates->setText("Graphics: " + to_string((int)freqCounterGraphics.getFrequency()) +
        " Hz  |  Haptics: " + to_string((int)freqCounterHaptics.getFrequency()) + " Hz");
    labelMessage->setText("Press gripper to toggle between Network and Virtual Environment mode");
    labelRates->setLocalPos(10, height - 30, 0);
    labelMessage->setLocalPos(10, height - 60, 0);
    camera->renderView(width, height);
    GLenum err = glGetError();
    if (err != GL_NO_ERROR) {
        logMessage("OpenGL Error: " + to_string(err));
    }
}

void windowSizeCallback(GLFWwindow* a_window, int a_width, int a_height) {
    width = a_width;
    height = a_height;
}

void errorCallback(int a_error, const char* a_description) {
    logMessage("GLFW Error " + to_string(a_error) + ": " + string(a_description));
}

void keyCallback(GLFWwindow* a_window, int a_key, int a_scancode, int a_action, int a_mods) {
    if (a_action != GLFW_PRESS) return;
    if (a_key == GLFW_KEY_F) {
        fullscreen = !fullscreen;
        if (fullscreen) {
            const GLFWvidmode* mode = glfwGetVideoMode(glfwGetPrimaryMonitor());
            glfwSetWindowMonitor(a_window, glfwGetPrimaryMonitor(), 0, 0, mode->width, mode->height, mode->refreshRate);
        }
        else {
            glfwSetWindowMonitor(a_window, nullptr, 100, 100, 1280, 720, 0);
        }
    }
    else if (a_key == GLFW_KEY_M) {
        if (camera) {
            mirroredDisplay = !mirroredDisplay;
            camera->setMirrorVertical(mirroredDisplay);
        }
    }
    else if (a_key == GLFW_KEY_Q || a_key == GLFW_KEY_ESCAPE) {
        glfwSetWindowShouldClose(a_window, GLFW_TRUE);
    }
}

void close() {
    running = false;
    hapticRunning = false;
}
