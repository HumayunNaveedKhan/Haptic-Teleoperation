// Helper functions
void drawText(float x, float y, const string& text, void* font = GLUT_BITMAP_HELVETICA_12, Color color = COLOR_TEXT) {
    glColor3f(color.r, color.g, color.b);
    glRasterPos2f(x, y);
    for (char c : text) {
        glutBitmapCharacter(font, c);
    }
}

void drawCircle(float x, float y, float radius, Color color, bool filled = true) {
    glColor3f(color.r, color.g, color.b);
    glBegin(filled ? GL_TRIANGLE_FAN : GL_LINE_LOOP);
    for (int i = 0; i < 360; i++) {
        float rad = i * 3.14159265f / 180.0f;
        glVertex2f(x + cos(rad) * radius, y + sin(rad) * radius);
    }
    glEnd();
}

void drawRect(float x, float y, float width, float height, Color color, bool filled = true) {
    glColor3f(color.r, color.g, color.b);
    glBegin(filled ? GL_QUADS : GL_LINE_LOOP);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();
}
void drawGrid(float x, float y, float width, float height, int numHLines, Color color) {
    glColor3f(color.r, color.g, color.b);
    glBegin(GL_LINES);
    for (int i = 1; i < numHLines; i++) {
        float ly = y + (i * height / numHLines);
        glVertex2f(x, ly);
        glVertex2f(x + width, ly);
    }
    glEnd();
}

