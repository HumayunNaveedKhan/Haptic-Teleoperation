        double damping = USE_ADAPTIVE_DAMPING ? adaptiveDamping : lastDamping;
        if (labelStiffness) {
            labelStiffness->setText("Stiffness: " + to_string_with_precision(stiffness, 2) + " N/m");
        }
        if (labelDamping) {
            labelDamping->setText("Damping: " + to_string_with_precision(damping, 2) + " N·s/m");
        }
        if (labelError) {
            labelError->setText("Error: [" + to_string_with_precision(lastError.x(), 4) + ", " +
                to_string_with_precision(lastError.y(), 4) + ", " +
                to_string_with_precision(lastError.z(), 4) + "] m");
        }
        if (labelPosition) {
            cVector3d position;
            if (hapticDevice && hapticDevice->getPosition(position)) {
                labelPosition->setText("Position: [" + to_string_with_precision(position.x(), 4) + ", " +
                    to_string_with_precision(position.y(), 4) + ", " +
                    to_string_with_precision(position.z(), 4) + "] m");
            }
            else {
                labelPosition->setText("Position: [N/A, N/A, N/A] m");
