    yOffset -= TEXT_HEIGHT;

    float graphY = yOffset - GRAPH_HEIGHT;
    int maxSentPackets = *max_element(sentPacketCounts.begin(), sentPacketCounts.end());
    maxSentPackets = max(maxSentPackets, 1);

