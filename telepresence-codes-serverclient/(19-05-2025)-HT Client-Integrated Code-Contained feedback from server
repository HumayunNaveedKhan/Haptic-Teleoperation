    logMessage("Creating GLFW window...");
    window = glfwCreateWindow(w, h, "Haptic Teleoperation with Virtual Environment", nullptr, nullptr);
    if (!window) {
        handleError("Failed to create GLFW window");
        glfwTerminate();
        return 1;
    }
    logMessage("GLFW window created successfully");
    glfwGetWindowSize(window, &width, &height);
    glfwSetWindowPos(window, x, y);
    glfwSetKeyCallback(window, keyCallback);
    glfwSetWindowSizeCallback(window, windowSizeCallback);
    glfwMakeContextCurrent(window);
    glfwSwapInterval(swapInterval);

    // Initialize GLEW
    logMessage("Initializing GLEW...");
    GLenum glewErr = glewInit();
    if (glewErr != GLEW_OK) {
        logMessage("GLEW initialization failed: " + string((const char*)glewGetErrorString(glewErr)));
        logMessage("Continuing without GLEW extensions");
    }
    else {
        logMessage("GLEW initialized successfully");
    }

    // Initialize Winsock
    logMessage("Initializing Winsock...");
    initializeWinsock();

    // Set up sockets
