#include "chai3d.h"
#include <GLFW/glfw3.h>
#include <winsock2.h>
#include <ws2tcpip.h>
#include <thread>
#include <chrono>
#include <ctime>
#include <iostream>
#include <iomanip>

// Link with Winsock library (for Visual Studio)
#pragma comment(lib, "Ws2_32.lib")

using namespace chai3d;

// Network configuration
#define SERVER_IP   "127.0.0.1"    // Server IP address (IPv4)
#define SERVER_PORT 5001          // Server UDP port to send to
#define LOCAL_PORT  5002          // Local UDP port to bind and receive on

// Global variables for CHAI3D world and device
cWorld* world;
cCamera* camera;
cDirectionalLight* light;
cShapeSphere* toolSphere;      // Sphere representing the haptic tool position
cShapeSphere* obstacleSphere;  // Sphere representing an obstacle (repulsive sphere)
cHapticDeviceHandler* handler;
cGenericHapticDevicePtr hapticDevice;

// Simulation control flags
bool simulationRunning = false;
bool simulationFinished = false;

// Haptic simulation parameters
double sphereRadius       = 0.02;   // radius of both spheres (meters)
double boundarySize       = 0.2;    // half-width of cubic boundary (meters)
double wallStiffness      = 1000.0; // spring stiffness for virtual walls (N/m)
double magnetMaxForce     = 5.0;    // max repulsion force at contact (N)
double magnetMaxDistance  = 0.05;   // effective range of magnetic repulsion (m)

// UDP networking variables
SOCKET udpSocket = INVALID_SOCKET;
sockaddr_in serverAddr;
sockaddr_in localAddr;

// Packet data structures
#pragma pack(push, 1)
struct PositionPacket {
    unsigned int seq;
    double x;
    double y;
    double z;
};
struct ForcePacket {
    unsigned int seq;
    double fx;
    double fy;
    double fz;
};
#pragma pack(pop)

// Forward declarations of thread functions
void updateHaptics();
void udpReceiveLoop();

int main(int argc, char** argv) 
{
    // Initialize GLFW (OpenGL context for rendering)
    if (!glfwInit()) {
        std::cerr << "Failed to initialize GLFW" << std::endl;
        return -1;
    }
    GLFWwindow* window = glfwCreateWindow(800, 600, "Haptic Teleoperation - AppVE", nullptr, nullptr);
    if (!window) {
        std::cerr << "Failed to create GLFW window" << std::endl;
        glfwTerminate();
        return -1;
    }
    glfwMakeContextCurrent(window);
    glfwSwapInterval(1);  // Enable vsync

    // Create a new CHAI3D world and camera
    world = new cWorld();
    world->m_backgroundColor.setBlack();               // Set background to black
    camera = new cCamera(world);
    world->addChild(camera);
    camera->setLocalPos(0.0, 0.0, 0.5);                // Position the camera (x,y,z)
    camera->setLookAt(0.0, 0.0, 0.0);                  // Camera looks at the origin
    camera->setClippingPlanes(0.01, 10.0);

    // Add a directional light source to the camera
    light = new cDirectionalLight(world);
    camera->addChild(light);
    light->setEnabled(true);
    light->setDir(-1.0, 0.0, -0.5);  // Light direction (toward scene)

    // Create a small sphere to represent the haptic tool's position
    toolSphere = new cShapeSphere(sphereRadius);
    world->addChild(toolSphere);
    toolSphere->m_material->setGrayLight();  // light gray color
    toolSphere->setLocalPos(0.0, 0.0, 0.0);   // start at origin

    // Create another sphere as a fixed obstacle that repels the tool
    obstacleSphere = new cShapeSphere(sphereRadius);
    world->addChild(obstacleSphere);
    obstacleSphere->m_material->setRed();    // color it red for visibility
    obstacleSphere->setLocalPos(0.2, 0.0, 0.0); // place obstacle at some offset

    // Initialize haptic device
    handler = new cHapticDeviceHandler();
    handler->getDevice(hapticDevice, 0);
    if (!hapticDevice) {
        std::cerr << "No haptic device found!" << std::endl;
        glfwTerminate();
        return -1;
    }
    hapticDevice->open();  // Open connection to the device
    // Device is ready for force feedback
    // (We assume one-to-one scaling of device workspace to world coordinates)

    // Initialize WinSock (UDP networking)
    WSADATA wsaData;
    if (WSAStartup(MAKEWORD(2,2), &wsaData) != 0) {
        std::cerr << "WSAStartup failed" << std::endl;
        glfwTerminate();
        return -1;
    }
    udpSocket = socket(AF_INET, SOCK_DGRAM, 0);
    if (udpSocket == INVALID_SOCKET) {
        std::cerr << "Failed to create UDP socket, error " 
                  << WSAGetLastError() << std::endl;
        WSACleanup();
        glfwTerminate();
        return -1;
    }
    // Configure server address (target for position packets)
    memset(&serverAddr, 0, sizeof(serverAddr));
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(SERVER_PORT);
    inet_pton(AF_INET, SERVER_IP, &serverAddr.sin_addr);
    // Configure local address and bind socket for receiving force packets
    memset(&localAddr, 0, sizeof(localAddr));
    localAddr.sin_family = AF_INET;
    localAddr.sin_port = htons(LOCAL_PORT);
    localAddr.sin_addr.s_addr = htonl(INADDR_ANY);
    if (::bind(udpSocket, (sockaddr*)&localAddr, sizeof(localAddr)) == SOCKET_ERROR) {
        std::cerr << "Failed to bind UDP socket, error " 
                  << WSAGetLastError() << std::endl;
        closesocket(udpSocket);
        WSACleanup();
        glfwTerminate();
        return -1;
    }

    // Launch UDP receive thread (asynchronous force feedback listener)
    std::thread recvThread(udpReceiveLoop);

    // Launch haptic simulation thread
    cThread* hapticsThread = new cThread();
    hapticsThread->start(updateHaptics, CTHREAD_PRIORITY_HAPTICS);

    // Graphic rendering loop
    while (!glfwWindowShouldClose(window)) {
        // Render the 3D world
        camera->renderView(800, 600);
        glfwSwapBuffers(window);
        glfwPollEvents();
        // Break the loop if simulation has ended (e.g., user signaled exit)
        if (!simulationRunning) {
            break;
        }
    }

    // Shutdown signal for threads
    simulationRunning = false;
    // Wait for haptics thread to finish
    while (!simulationFinished) {
        cSleepMs(100);
    }

    // Clean up networking thread and socket
    closesocket(udpSocket);        // this will interrupt a blocking recvfrom
    if (recvThread.joinable()) {
        recvThread.join();
    }
    WSACleanup();

    // Close haptic device
    if (hapticDevice) {
        hapticDevice->close();
    }

    // Clean up GLFW
    glfwDestroyWindow(window);
    glfwTerminate();
    return 0;
}

// Haptic simulation loop (runs in separate high-frequency thread)
void updateHaptics() 
{
    simulationRunning = true;
    simulationFinished = false;

    // Variables for device position and force
    cVector3d position;
    cVector3d force;
    unsigned int sequence = 0;  // packet sequence counter

    // Main haptics loop
    while (simulationRunning) {
        // Read current device position (in device coordinates, assumed ~meters)
        hapticDevice->getPosition(position);
        // Update the graphical tool sphere to match device position
        toolSphere->setLocalPos(position);

        // Compute net force for haptic feedback
        force.zero();

        // **Magnetic repulsion from obstacle sphere**
        cVector3d obstaclePos = obstacleSphere->getLocalPos();
        double dist = position.distance(obstaclePos);
        double contactDist = 2 * sphereRadius;           // distance at contact (two radii)
        double effectiveRange = contactDist + magnetMaxDistance;
        if (dist < effectiveRange) {
            // Direction from obstacle to tool
            cVector3d dir = position - obstaclePos;
            if (dir.length() > 0) {
                dir.normalize();
            }
            // Compute repulsion force magnitude (linear falloff with distance)
            double penetration = effectiveRange - dist;
            double ratio = penetration / magnetMaxDistance;
            if (ratio > 1.0) ratio = 1.0;
            double forceMag = magnetMaxForce * ratio;
            // Add repulsive force (push tool away from obstacle)
            force.add(forceMag * dir);
        }

        // **Virtual wall boundaries (axis-aligned limits)**
        double px = position.x();
        double py = position.y();
        double pz = position.z();
        double bound = boundarySize;
        if (px >  bound) force.x -= wallStiffness * (px - bound);
        if (px < -bound) force.x -= wallStiffness * (px + bound);
        if (py >  bound) force.y -= wallStiffness * (py - bound);
        if (py < -bound) force.y -= wallStiffness * (py + bound);
        if (pz >  bound) force.z -= wallStiffness * (pz - bound);
        if (pz < -bound) force.z -= wallStiffness * (pz + bound);

        // Apply the computed force to the haptic device
        hapticDevice->setForce(force);

        // Send current position to the remote server via UDP
        PositionPacket posPkt;
        posPkt.seq = sequence++;
        posPkt.x  = position.x();
        posPkt.y  = position.y();
        posPkt.z  = position.z();
        sendto(udpSocket, (const char*)&posPkt, sizeof(posPkt), 0,
               (sockaddr*)&serverAddr, sizeof(serverAddr));

        // (Optional) sleep or yield to control loop rate, if needed.
        // cSleepMs(1);
    }

    simulationFinished = true;
}

// UDP receive loop for force feedback (runs in its own thread)
void udpReceiveLoop() 
{
    char recvBuffer[1024];
    sockaddr_in senderAddr;
    int senderLen = sizeof(senderAddr);

    // Loop until simulation ends or socket is closed
    while (simulationRunning) {
        int bytes = recvfrom(udpSocket, recvBuffer, sizeof(recvBuffer), 0,
                              (sockaddr*)&senderAddr, &senderLen);
        if (bytes == SOCKET_ERROR) {
            int err = WSAGetLastError();
            if (err == WSAEINTR || err == WSAENOTSOCK) {
                // Interrupted by socket closure
                break;
            }
            if (err == WSAEWOULDBLOCK) {
                // Would block (no data available yet)
                continue;
            }
            std::cerr << "UDP recvfrom error " << err << std::endl;
            break;
        }
        if (bytes >= sizeof(ForcePacket)) {
            // Parse the received force packet
            ForcePacket forcePkt;
            memcpy(&forcePkt, recvBuffer, sizeof(ForcePacket));
            // Convert sender address to human-readable form
            char senderIP[INET_ADDRSTRLEN];
            inet_ntop(AF_INET, &senderAddr.sin_addr, senderIP, INET_ADDRSTRLEN);
            unsigned short senderPort = ntohs(senderAddr.sin_port);
            unsigned short localPort  = ntohs(localAddr.sin_port);
            // Timestamp for logging (HH:MM:SS.mmm)
            auto now = std::chrono::system_clock::now();
            auto ms  = std::chrono::duration_cast<std::chrono::milliseconds>(
                           now.time_since_epoch()) % 1000;
            std::time_t t = std::chrono::system_clock::to_time_t(now);
            std::tm localTm;
            localtime_s(&localTm, &t);
            std::cout << std::put_time(&localTm, "%H:%M:%S")
                      << '.' << std::setw(3) << std::setfill('0') << ms.count()
                      << " - Received force packet #" << forcePkt.seq
                      << " from " << senderIP << ":" << senderPort
                      << " to local port " << localPort
                      << " | Force = (" << forcePkt.fx << ", " << forcePkt.fy << ", " << forcePkt.fz << ")"
                      << std::endl;
            // (The received force feedback is currently not applied to the device)
        }
        // Ignore packets that are smaller than expected ForcePacket
    }
}
