//------------------------------------------------------------------------------
// CONFIGURATION PARAMETERS
//------------------------------------------------------------------------------

// Network Settings
const char SRC_IP[] = "169.254.50.63";           // Client IP address
const char DST_IP[] = "169.254.213.206";         // Server IP address
const int SEND_PORT = 4000;                      // Port for sending position data to server
const int RECV_PORT = 4001;                      // Port for receiving force feedback from server
const int BUFFER_SIZE = 1024;                    // Packet buffer size (bytes)

// Haptic Device Settings
const int HAPTIC_RATE_HZ = 1000;                 // Haptic loop update rate (Hz)
const double SPHERE_RADIUS = 0.007;              // Radius of virtual spheres (meters)
const int NUM_SPHERES = 2;                       // Number of spheres in the scene

// Force Feedback Parameters
cVector3d forceFeedback(0.0, 0.0, 0.0);          // Force vector to be applied
bool newForceFeedback = false;                   // Flag for new force data
int forcePacketsReceived = 0;                    // Counter for received force packets
int successfulSends = 0;                        // Counter for successful packet sends
int failedSends = 0;                            // Counter for failed packet sends
int packetCount = 0;                            // Total packets sent

// Control Parameters
std::mutex forceFeedbackMutex;                  // Mutex for force feedback data
const int FEEDBACK_DISPLAY_RATE_MS = 1;       // Feedback console update rate (ms)
bool simulationRunning = false;                 // Haptic simulation running flag
bool simulationFinished = true;                 // Haptic simulation finished flag
volatile bool networkRunning = true;            // Network thread running flag
volatile bool feedbackRunning = true;           // Feedback display thread running flag

// Display Settings
cStereoMode stereoMode = C_STEREO_DISABLED;     // Stereo display mode
bool fullscreen = false;                        // Fullscreen display flag
bool mirroredDisplay = false;                   // Vertical mirroring flag
int swapInterval = 1;                           // Vertical synchronization interval

// Packet Structures
struct OutgoingPacket {
    int packetNumber;
    float x, y, z;
    float delay;
    char timestamp[64];
    char srcIP[INET_ADDRSTRLEN];
    char dstIP[INET_ADDRSTRLEN];
    int srcPort;                                // SEND_PORT
    int dstPort;                                // SEND_PORT (server's listening port)
};

struct IncomingPacket {
    int packetNumber;        // Must match outgoing packet number
    double force[3];         // Force vector (x,y,z)
    double position[3];      // Current device position
    double error[3];         // Position error
    double stiffness;        // Current stiffness value used (K)
    double damping;          // Current damping value used (B)
    bool isActive;           // Flag indicating if this is an "active" packet
    char message[64];        // Message/status
    char timestamp[64];      // Timestamp from server
};

//------------------------------------------------------------------------------
// GLOBAL VARIABLES
//------------------------------------------------------------------------------
cWorld* world;                                  // Virtual world
cCamera* camera;                                // Camera for rendering
cSpotLight* light;                              // Light source
cHapticDeviceHandler* handler;                  // Haptic device handler
cGenericHapticDevicePtr hapticDevice;           // Haptic device
double hapticDeviceMaxStiffness;                // Maximum stiffness of haptic device
cShapeSphere* spheres[NUM_SPHERES];             // Sphere objects
cVector3d sphereVel[NUM_SPHERES];               // Linear velocity of spheres
cBackground* background;                        // Colored background
cFontPtr font;                                  // Font for text rendering
cLabel* labelRates;                             // Label for simulation rates
cLabel* labelMessage;                           // Label for informational message
cLabel* labelNetwork;                           // Label for network status
cFrequencyCounter freqCounterGraphics;          // Graphic rate counter
cFrequencyCounter freqCounterHaptics;           // Haptic rate counter
cThread* hapticsThread;                         // Haptic thread
std::thread* feedbackThread = nullptr;          // Feedback display thread
GLFWwindow* window = NULL;                      // Window display context
int width = 0;                                  // Window width
int height = 0;                                 // Window height
string resourceRoot;                            // Root resource path
SOCKET sock = INVALID_SOCKET;                   // Network socket

