    // Keyboard handling function for controls
    void keyboard(unsigned char key, int x, int y) {
        switch (key) {
        case 'q':
        case 'Q':
            // Quit the application
            exit(0);
            break;

        case 'f':
        case 'F':
            // Toggle feedback
            FEEDBACK_ENABLED = !FEEDBACK_ENABLED;
            std::cout << "Feedback " << (FEEDBACK_ENABLED ? "enabled" : "disabled") << std::endl;
            break;

        case 'h':
        case 'H':
            // Toggle haptic feedback
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.hapticEnabled = !hapticConfig.hapticEnabled;
            std::cout << "Haptic feedback " << (hapticConfig.hapticEnabled ? "enabled" : "disabled") << std::endl;
        }
        break;

        case '+':
        case '=':
            // Increase release rate
            GLOBAL_RELEASE_RATE_FACTOR *= 1.1f;
            std::cout << "Release rate factor: " << GLOBAL_RELEASE_RATE_FACTOR << std::endl;
            break;

        case '-':
        case '_':
            // Decrease release rate
            GLOBAL_RELEASE_RATE_FACTOR *= 0.9f;
            if (GLOBAL_RELEASE_RATE_FACTOR < 0.1f) GLOBAL_RELEASE_RATE_FACTOR = 0.1f;
            std::cout << "Release rate factor: " << GLOBAL_RELEASE_RATE_FACTOR << std::endl;
            break;

        case '[':
            // Decrease force gain
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.Kp *= 0.9;
            if (hapticConfig.Kp < 10.0) hapticConfig.Kp = 10.0;
            std::cout << "Force gain (Kp): " << hapticConfig.Kp << std::endl;
        }
        break;

        case ']':
            // Increase force gain
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.Kp *= 1.1;
            if (hapticConfig.Kp > 500.0) hapticConfig.Kp = 500.0;
            std::cout << "Force gain (Kp): " << hapticConfig.Kp << std::endl;
        }
        break;

        case 'm':
        case 'M':
            // Increase force scale
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.forceScale *= 1.1;
            if (hapticConfig.forceScale > 5.0) hapticConfig.forceScale = 5.0;
            std::cout << "Force scale: " << hapticConfig.forceScale << std::endl;
        }
        break;

        case 'n':
        case 'N':
            // Decrease force scale
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.forceScale *= 0.9;
            if (hapticConfig.forceScale < 0.1) hapticConfig.forceScale = 0.1;
            std::cout << "Force scale: " << hapticConfig.forceScale << std::endl;
        }
        break;
        }

        // Request display refresh
        glutPostRedisplay();
    }

    // Timer function for GLUT to refresh display
    void timer(int value) {
        glutPostRedisplay();
        glutTimerFunc(16, timer, 0); // ~60 fps refresh rate
    }

    // Main function
    int main(int argc, char* argv[]) {
        // Initialize GLUT for visualization
        glutInit(&argc, argv);
        glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB | GLUT_DEPTH);
        glutInitWindowSize(1024, 768);
        glutCreateWindow("Haptic Teleoperation System");

        // Set up background color
        glClearColor(0.05f, 0.05f, 0.1f, 1.0f);

        // Register callbacks
        glutDisplayFunc(display);
        glutKeyboardFunc(keyboard);
        glutTimerFunc(16, timer, 0);

        // Initialize Winsock
        WSADATA wsaData;
        if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
            std::cerr << "WSAStartup failed" << std::endl;
            return 1;
        }

        // Create UDP server thread
        std::thread serverThread(udpServerThread);
        serverThread.detach(); // Let it run in the background

        // Create packet processing thread
        std::thread processingThread(packetProcessingThread);
        processingThread.detach();

        // Create haptic device thread
        std::thread hapticThread(hapticDeviceThread);
        hapticThread.detach();

        // Start GLUT main loop
        glutMainLoop();

        // Clean up Winsock before exit
        WSACleanup();

        return 0;
    }
