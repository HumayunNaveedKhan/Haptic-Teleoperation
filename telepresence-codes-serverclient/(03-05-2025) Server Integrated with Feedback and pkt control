// Update packet statistics in UDP server
void updatePacketStats(const Packet& packet) {
    std::lock_guard<std::mutex> lock(statsMutex);

    auto currentTime = std::chrono::steady_clock::now();

    if (globalPacketStats.totalPacketsReceived == 0) {
        globalPacketStats.firstPacketTime = currentTime;
        globalPacketStats.lastPacketTime = currentTime;
    }
    else {
        // Calculate time between packets
        double interPacketTimeMs = std::chrono::duration<double, std::milli>(
            currentTime - globalPacketStats.lastPacketTime).count();

        // Add to history
        globalPacketStats.packetTimings.push_back(interPacketTimeMs);

        // Maintain history size
        while (globalPacketStats.packetTimings.size() > PACKET_HISTORY_SIZE) {
            globalPacketStats.packetTimings.pop_front();
        }

        // Calculate average from history
        double sum = 0;
        for (double timing : globalPacketStats.packetTimings) {
            sum += timing;
        }
        globalPacketStats.avgInterPacketTime = sum / globalPacketStats.packetTimings.size();

        globalPacketStats.lastPacketTime = currentTime;
    }

    globalPacketStats.totalPacketsReceived++;

    // Calculate average receive rate
    auto duration = std::chrono::duration<double>(currentTime - globalPacketStats.firstPacketTime).count();
    if (duration > 0) {
        globalPacketStats.avgReceiveRate = globalPacketStats.totalPacketsReceived / duration;
    }
}

    // Haptic device thread function
    void hapticDeviceThread() {
        // Set thread priority to time-critical
        SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_HAPTICS);

        // Initialize Force Dimension haptic device
        int deviceID = -1;
        bool deviceConnected = false;

        // Try to open the first available device
        deviceID = dhdOpen();

        if (deviceID >= 0) {
            std::cout << "Connected to haptic device: " << dhdGetSystemName() << std::endl;
            deviceConnected = true;

            // Update device status
            {
                std::lock_guard<std::mutex> lock(hapticMutex);
                hapticConfig.deviceConnected = true;
                hapticConfig.deviceID = deviceID;
            }

            // Enable force feedback
            dhdEnableForce(DHD_ON);

            // Main haptic loop
            while (deviceConnected) {
                // Read device position and velocity
                double pos[3], vel[3], force[3] = { 0.0, 0.0, 0.0 };
                double targetPos[3];

                if (dhdGetPosition(&pos[0], &pos[1], &pos[2]) < 0) {
                    std::cerr << "Error: Cannot get device position" << std::endl;
                    break;
                }

                if (dhdGetLinearVelocity(&vel[0], &vel[1], &vel[2]) < 0) {
                    std::cerr << "Error: Cannot get device velocity" << std::endl;
                    break;
                }

                // Get haptic config and target position
                {
                    std::lock_guard<std::mutex> lock1(deviceMutex);
                    std::lock_guard<std::mutex> lock2(hapticMutex);

                    // Update device state
                    for (int i = 0; i < 3; i++) {
                        deviceState.position[i] = pos[i];
                        deviceState.velocity[i] = vel[i];
                    }

                    // Get target position
                    for (int i = 0; i < 3; i++) {
                        targetPos[i] = deviceState.targetPos[i];
                    }

                    // Calculate position error and force
                    if (hapticConfig.hapticEnabled) {
                        for (int i = 0; i < 3; i++) {
                            // PD control: force = Kp * (target - current) - Kd * velocity
                            double error = targetPos[i] - pos[i];
                            force[i] = hapticConfig.Kp * error - hapticConfig.Kd * vel[i];
                            force[i] *= hapticConfig.forceScale;  // Apply user-adjustable scaling
                        }

                        // Apply force limits
                        double forceMag = sqrt(force[0] * force[0] + force[1] * force[1] + force[2] * force[2]);
                        if (forceMag > hapticConfig.maxForce) {
                            double scale = hapticConfig.maxForce / forceMag;
                            for (int i = 0; i < 3; i++) {
                                force[i] *= scale;
                            }
                        }

                        // Update force state
                        for (int i = 0; i < 3; i++) {
                            deviceState.force[i] = force[i];
                        }
                    }
                    else {
                        // Reset forces if haptics disabled
                        for (int i = 0; i < 3; i++) {
                            deviceState.force[i] = 0.0;
                            force[i] = 0.0;
                        }
                    }
                }

                // Apply force to device if enabled
                if (hapticConfig.hapticEnabled) {
                    if (dhdSetForce(force[0], force[1], force[2]) < 0) {
                        std::cerr << "Error: Cannot set force" << std::endl;
                    }
                }
                else {
                    dhdSetForce(0.0, 0.0, 0.0);  // Ensure no force when disabled
                }

                // Sleep to prevent CPU overload
                std::this_thread::sleep_for(std::chrono::milliseconds(1));
            }

            // Disable forces and close device when thread ends
            dhdSetForce(0.0, 0.0, 0.0);
            dhdClose();
        }
        else {
            std::cerr << "Failed to connect to haptic device. Error: " << dhdErrorGetLastStr() << std::endl;
        }

        // Update status when disconnected
        {
            std::lock_guard<std::mutex> lock(hapticMutex);
            hapticConfig.deviceConnected = false;
            hapticConfig.deviceID = -1;
        }
    }

    // UDP server thread function - FIXED to properly receive packets
    void udpServerThread() {
        // Set thread priority
        SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_PACKET_RECEPTION);

        WSADATA wsaData;
        if (WSAStartup(MAKEWORD(2, 2), &wsaData) != 0) {
            std::cerr << "WSAStartup failed" << std::endl;
            return;
        }

        // Create socket
        SOCKET serverSocket = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
        if (serverSocket == INVALID_SOCKET) {
            std::cerr << "Socket creation failed with error: " << WSAGetLastError() << std::endl;
            WSACleanup();
            return;
        }

        // Bind socket to address and port
        sockaddr_in serverAddr;
        serverAddr.sin_family = AF_INET;
        serverAddr.sin_port = htons(UDP_PORT);
        serverAddr.sin_addr.s_addr = INADDR_ANY;

        if (bind(serverSocket, (sockaddr*)&serverAddr, sizeof(serverAddr)) == SOCKET_ERROR) {
            std::cerr << "Bind failed with error: " << WSAGetLastError() << std::endl;
            closesocket(serverSocket);
            WSACleanup();
            return;
        }

        std::cout << "UDP server started and listening on port " << UDP_PORT << std::endl;

        // Set socket to non-blocking mode for better performance
        u_long mode = 1;
        if (ioctlsocket(serverSocket, FIONBIO, &mode) == SOCKET_ERROR) {
            std::cerr << "Failed to set non-blocking mode: " << WSAGetLastError() << std::endl;
        }

        char buffer[MAX_PACKET_SIZE];
        sockaddr_in clientAddr;
        int clientAddrSize = sizeof(clientAddr);

        // Main receiving loop
        while (true) {
            // Clear the buffer
            memset(buffer, 0, MAX_PACKET_SIZE);

            // Receive data - use recvfrom correctly
            int bytesReceived = recvfrom(serverSocket, buffer, MAX_PACKET_SIZE, 0,
                (sockaddr*)&clientAddr, &clientAddrSize);

            if (bytesReceived == SOCKET_ERROR) {
                int error = WSAGetLastError();
                if (error != WSAEWOULDBLOCK) {
                    std::cerr << "recvfrom failed with error: " << error << std::endl;
                }
                // Small delay to prevent CPU hogging in non-blocking mode
                std::this_thread::sleep_for(std::chrono::milliseconds(1));
                continue;
            }

            if (bytesReceived > 0) {
                // Try to parse the received data as a Packet
                if (bytesReceived >= sizeof(Packet)) {
                    Packet* receivedPacket = reinterpret_cast<Packet*>(buffer);

                    // Set the reception timestamp
                    receivedPacket->receiveTime = std::chrono::steady_clock::now();

                    // Get IP addresses as strings
                    inet_ntop(AF_INET, &(clientAddr.sin_addr), receivedPacket->srcIP, INET_ADDRSTRLEN);
                    inet_ntop(AF_INET, &(serverAddr.sin_addr), receivedPacket->dstIP, INET_ADDRSTRLEN);

                    // Set ports
                    receivedPacket->srcPort = ntohs(clientAddr.sin_port);
                    receivedPacket->dstPort = UDP_PORT;

                    // Add to packet distributor and update stats
                    packetDistributor.addPacket(*receivedPacket);
                    updatePacketStats(*receivedPacket);

                    // If haptic feedback is enabled, send a response
                    {
                        std::lock_guard<std::mutex> lock(deviceMutex);
                        double error[3] = {
                            deviceState.targetPos[0] - deviceState.position[0],
                            deviceState.targetPos[1] - deviceState.position[1],
                            deviceState.targetPos[2] - deviceState.position[2]
                        };

                        sendFeedback(clientAddr, receivedPacket->packetNumber,
                            deviceState.force, deviceState.position, error);
                    }
                }
                else {
                    std::cerr << "Received incomplete packet: " << bytesReceived << " bytes" << std::endl;
                }
            }
        }

        // Cleanup
        closesocket(serverSocket);
        WSACleanup();
    }

    // Process packets thread
    void packetProcessingThread() {
        // Set thread priority
        SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_PROCESSING);

        while (true) {
            packetDistributor.processPackets();
            std::this_thread::sleep_for(std::chrono::milliseconds(5)); // Adjust as needed
        }
    }

