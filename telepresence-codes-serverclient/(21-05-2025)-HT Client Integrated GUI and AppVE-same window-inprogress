        drawText(x - 5, delayGraphY - 15, to_string(i * TIME_WINDOW_S / 5.0), GLUT_BITMAP_HELVETICA_10);
    }
    drawText(X_OFFSET + GRAPH_WIDTH + 5, delayGraphY - 5, "Time (s)");

    glBegin(GL_LINE_STRIP);
    glColor3f(COLOR_SENT.r, COLOR_SENT.g, COLOR_SENT.b);
    for (const auto& pkt : localSentPackets) {
        if (pkt.timestamp < timeWindowStart || pkt.timestamp > now) continue;
        auto timeSinceStart = chrono::duration_cast<chrono::microseconds>(pkt.timestamp - timeWindowStart).count() / 1e6;
        float x = X_OFFSET + (timeSinceStart / TIME_WINDOW_S) * GRAPH_WIDTH;
        float y = delayGraphY + min(static_cast<float>(pkt.delay / maxDelay) * GRAPH_HEIGHT, GRAPH_HEIGHT);
        glVertex2f(x, y);
    }
    glEnd();

    glBegin(GL_LINE_STRIP);
    glColor3f(COLOR_RECEIVED.r, COLOR_RECEIVED.g, COLOR_RECEIVED.b);
    for (const auto& pkt : localReceivedPackets) {
        if (pkt.timestamp < timeWindowStart || pkt.timestamp > now) continue;
        auto timeSinceStart = chrono::duration_cast<chrono::microseconds>(pkt.timestamp - timeWindowStart).count() / 1e6;
        float x = X_OFFSET + (timeSinceStart / TIME_WINDOW_S) * GRAPH_WIDTH;
        float y = delayGraphY + min(static_cast<float>(pkt.delay / maxDelay) * GRAPH_HEIGHT, GRAPH_HEIGHT);
        glVertex2f(x, y);
    }
    glEnd();

    yOffset -= (GRAPH_HEIGHT + SECTION_SPACING);

    // Haptic Feedback
    drawText(X_OFFSET, yOffset, "Haptic Feedback", TITLE_FONT);
    yOffset -= TEXT_HEIGHT * 2;
    drawText(X_OFFSET, yOffset, "Force: (" + to_string_with_precision(forceFeedback.x(), 2) + ", " +
        to_string_with_precision(forceFeedback.y(), 2) + ", " +
        to_string_with_precision(forceFeedback.z(), 2) + ") N");
