        glVertex2f(x, graphY);
        glVertex2f(x + BAR_WIDTH, graphY);
        glVertex2f(x + BAR_WIDTH, graphY + height);
        glVertex2f(x, graphY + height);
    }
    glEnd();

    yOffset -= (GRAPH_HEIGHT + SECTION_SPACING);

    // Packet Delays Graph
    drawText(X_OFFSET, yOffset, "Packet Delays (ms)", TITLE_FONT);
    yOffset -= TEXT_HEIGHT;

    float delayGraphY = yOffset - GRAPH_HEIGHT;
