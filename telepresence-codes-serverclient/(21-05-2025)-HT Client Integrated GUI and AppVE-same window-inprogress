    drawText(X_OFFSET, yOffset, "[0] Packet Interval: " + to_string_with_precision(packetIntervalMs, 1) + " ms");
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "[w] Feedback Window: " + to_string(FORCE_PACKET_WINDOW));
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "[f] Toggle Full Screen");
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "[m] Toggle Mirror");
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "[q] or [Esc] Exit");

    // Latest Packet Data
    yOffset = Y_OFFSET_INITIAL;
    drawText(RIGHT_OFFSET, yOffset, "Latest Packet Data", TITLE_FONT);
    yOffset -= TEXT_HEIGHT * 2;

    static cVector3d lastSentPosition(0.0, 0.0, 0.0);
    if (successfulSends > 0) {
        cVector3d pos;
        if (hapticDevice && hapticDevice->getPosition(pos)) {
            lastSentPosition = pos;
        }
    }
    drawText(RIGHT_OFFSET, yOffset, "Last Sent Packet:");
    yOffset -= TEXT_HEIGHT;
    drawText(RIGHT_OFFSET, yOffset, "Position: (" + to_string_with_precision(lastSentPosition.x(), 4) + ", " +
        to_string_with_precision(lastSentPosition.y(), 4) + ", " +
        to_string_with_precision(lastSentPosition.z(), 4) + ") m");
    yOffset -= TEXT_HEIGHT * 2;

    static cVector3d lastReceivedForce(0.0, 0.0, 0.0);
    if (newForceFeedback) {
        lock_guard<mutex> lock(forceFeedbackMutex);
        lastReceivedForce = forceFeedback;
    }
    drawText(RIGHT_OFFSET, yOffset, "Last Received Packet:");
    yOffset -= TEXT_HEIGHT;
    drawText(RIGHT_OFFSET, yOffset, "Force: (" + to_string_with_precision(lastReceivedForce.x(), 2) + ", " +
        to_string_with_precision(lastReceivedForce.y(), 2) + ", " +
        to_string_with_precision(lastReceivedForce.z(), 2) + ") N");

    glutSwapBuffers();
}

void glutReshape(int width, int height) {
    glutWidth = width;
    glutHeight = max(height, 1);
    glViewport(0, 0, glutWidth, glutHeight);
    glutPostRedisplay();
}

void glutKeyboard(unsigned char key, int x, int y) {
    switch (key) {
    case 'f':
        if (isFullScreen) {
            glutReshapeWindow(windowedWidth, windowedHeight);
            glutPositionWindow(windowPosX, windowPosY);
            isFullScreen = false;
        }
        else {
            windowedWidth = glutGet(GLUT_WINDOW_WIDTH);
            windowedHeight = glutGet(GLUT_WINDOW_HEIGHT);
            windowPosX = glutGet(GLUT_WINDOW_X);
            windowPosY = glutGet(GLUT_WINDOW_Y);
            glutFullScreen();
            isFullScreen = true;
        }
        break;
    case 'm':
        if (camera) {
            mirroredDisplay = !mirroredDisplay;
            camera->setMirrorVertical(mirroredDisplay);
        }
        break;
    case '1':
        sendPacketsEnabled = !sendPacketsEnabled;
        logMessage("Send Packets: " + string(sendPacketsEnabled ? "Enabled" : "Disabled"));
        break;
    case '2':
        receiveFeedbackEnabled = !receiveFeedbackEnabled;
        logMessage("Receive Feedback: " + string(receiveFeedbackEnabled ? "Enabled" : "Disabled"));
        break;
    case '3':
        applyHapticFeedback = !applyHapticFeedback;
        logMessage("Apply Haptic Feedback: " + string(applyHapticFeedback ? "Enabled" : "Disabled"));
        break;
    case '4':
        rawModeEnabled = !rawModeEnabled;
        logMessage("Raw Mode: " + string(rawModeEnabled ? "Enabled" : "Disabled"));
        break;
    case '5':
        networkThreadPriority = (networkThreadPriority == THREAD_PRIORITY_ABOVE_NORMAL)
            ? THREAD_PRIORITY_NORMAL : THREAD_PRIORITY_ABOVE_NORMAL;
        if (networkThreadHandle) {
            SetThreadPriority(networkThreadHandle, networkThreadPriority);
        }
        logMessage("Network Thread Priority: " + string(networkThreadPriority == THREAD_PRIORITY_ABOVE_NORMAL ? "ABOVE_NORMAL" : "NORMAL"));
        break;
    case '6':
        hapticThreadPriority = (hapticThreadPriority == THREAD_PRIORITY_ABOVE_NORMAL)
            ? THREAD_PRIORITY_NORMAL : THREAD_PRIORITY_ABOVE_NORMAL;
        if (hapticThreadHandle) {
            SetThreadPriority(hapticThreadHandle, hapticThreadPriority);
        }
        logMessage("Haptic Thread Priority: " + string(hapticThreadPriority == THREAD_PRIORITY_ABOVE_NORMAL ? "ABOVE_NORMAL" : "NORMAL"));
        break;
    case '7':
        packetDelayMin = (packetDelayMin >= 9.9) ? 0.0 : packetDelayMin + 0.1;
        logMessage("Packet Delay Min: " + to_string_with_precision(packetDelayMin, 1) + " ms");
        break;
    case '8':
        packetDelayMax = (packetDelayMax >= 9.9) ? 0.0 : packetDelayMax + 0.1;
        logMessage("Packet Delay Max: " + to_string_with_precision(packetDelayMax, 1) + " ms");
        break;
    case '9':
        maxPacketsToSend = (maxPacketsToSend >= 1000) ? 0 : maxPacketsToSend + 10;
        logMessage("Max Packets to Send: " + to_string(maxPacketsToSend));
        break;
    case '0':
        packetIntervalMs = (packetIntervalMs >= 9.9) ? 0.0 : packetIntervalMs + 0.1;
        logMessage("Packet Interval: " + to_string_with_precision(packetIntervalMs, 1) + " ms");
        break;
    case 'w':
    {
        lock_guard<mutex> lock(bufferMutex);
        FORCE_PACKET_WINDOW = (FORCE_PACKET_WINDOW >= 100) ? 10 : FORCE_PACKET_WINDOW + 10;
        while (forceBuffer.size() > FORCE_PACKET_WINDOW) {
            forceBuffer.erase(forceBuffer.begin());
            stiffnessBuffer.erase(stiffnessBuffer.begin());
            dampingBuffer.erase(dampingBuffer.begin());
            errorBuffer.erase(errorBuffer.begin());
        }
        logMessage("Force Packet Window: " + to_string(FORCE_PACKET_WINDOW));
    }
    break;
    case 'q':
    case 27:
        running = false;
        hapticRunning = false;
        logMessage("Exit requested");
        exit(0);
        break;
    }
    glutPostRedisplay();
}

void updateGraphics() {
    if (!camera) return;
    labelRates->setText("Graphics: " + to_string((int)freqCounterGraphics.getFrequency()) +
        " Hz  |  Haptics: " + to_string((int)freqCounterHaptics.getFrequency()) + " Hz");
    labelMessage->setText("Press gripper to toggle between Network and Virtual Environment mode");
    labelRates->setLocalPos(10, glutHeight - 30, 0);
    labelMessage->setLocalPos(10, glutHeight - 60, 0);
    camera->renderView(glutWidth / 2, glutHeight);
    GLenum err = glGetError();
    if (err != GL_NO_ERROR) {
        logMessage("OpenGL Error: " + to_string(err));
    }
    freqCounterGraphics.signal(1);
}

void timerCallback(int value) {
    glutPostRedisplay();
    glutTimerFunc(33, timerCallback, 0);
}

int main(int argc, char* argv[]) {
    timeBeginPeriod(1);
    logMessage("===== Haptic Teleoperation Client with Virtual Environment =====");
    logMessage("Client IP: " + string(CLIENT_IP));
    logMessage("Server IP: " + string(SERVER_IP));
    logMessage("Send Port: " + to_string(SEND_PORT));
    logMessage("Receive Port: " + to_string(RECV_PORT) + " (Fallback: " + to_string(FALLBACK_PORT) + ")");
    logMessage("Haptic Rate: " + to_string(HAPTIC_RATE_HZ) + " Hz");
    logMessage("Expected IncomingPacket size: " + to_string(sizeof(IncomingPacket)) + " bytes");
    logMessage("Force Packet Window: " + to_string(FORCE_PACKET_WINDOW) + " packets");
    logMessage("Adaptive Update Interval: " + to_string(ADAPTIVE_UPDATE_MS) + " ms");
    logMessage("Adaptive Damping: " + string(USE_ADAPTIVE_DAMPING ? "Enabled" : "Disabled"));
    logMessage("Press Ctrl+C or close console to exit");
    logMessage("Keyboard Options:");
    logMessage("[f] - Toggle full screen mode");
    logMessage("[m] - Toggle vertical mirroring");
    logMessage("[q] - Exit application");
    logMessage("[1] - Toggle Send Packets");
    logMessage("[2] - Toggle Receive Feedback");
    logMessage("[3] - Toggle Apply Haptic");
    logMessage("[4] - Toggle Raw Mode");
    logMessage("[5] - Toggle Network Priority");
    logMessage("[6] - Toggle Haptic Priority");
    logMessage("[7] - Increase Delay Min");
    logMessage("[8] - Increase Delay Max");
    logMessage("[9] - Increase Max Packets");
    logMessage("[0] - Increase Packet Interval");
    logMessage("[w] - Increase Feedback Window");
    logMessage("Gripper Button: Toggle between Network and Virtual Environment mode");
    logMessage("===============================================================");

    initializeWinsock();
    setupSocket(sock, RECV_PORT, 3);
    setupSocket(fallbackSock, FALLBACK_PORT, 3);

    logMessage("Initializing haptic device...");
    handler = new cHapticDeviceHandler();
    if (!handler) {
        logMessage("Failed to create haptic device handler. Running in VE mode only.");
        useVirtualEnvironment = true;
    }
    else {
        handler->getDevice(hapticDevice, 0);
        if (!hapticDevice) {
            logMessage("No haptic device found. Running in VE mode only.");
            useVirtualEnvironment = true;
        }
        else {
            if (!hapticDevice->open()) {
                logMessage("Failed to open haptic device. Running in VE mode only.");
                hapticDevice = nullptr;
                useVirtualEnvironment = true;
            }
            else {
                cHapticDeviceInfo info = hapticDevice->getSpecifications();
                logMessage("Haptic device opened: " + info.m_modelName);
                if (!hapticDevice->calibrate()) {
                    logMessage("Haptic device calibration failed");
                }
                hapticDeviceMaxStiffness = info.m_maxLinearStiffness;
            }
        }
    }

    logMessage("Initializing virtual environment...");
    world = new cWorld();
    if (!world) {
        handleError("Failed to create world");
        return 1;
    }
    world->m_backgroundColor.setWhite();
    camera = new cCamera(world);
    if (!camera) {
        handleError("Failed to create camera");
        return 1;
    }
    world->addChild(camera);
    camera->set(cVector3d(0.20, 0.00, 0.10), cVector3d(0.00, 0.00, 0.05), cVector3d(0.00, 0.00, 1.00));
    camera->setClippingPlanes(0.01, 10.0);
    camera->setStereoMode(stereoMode);
    camera->setStereoEyeSeparation(0.03);
    camera->setStereoFocalLength(1.8);
    camera->setMirrorVertical(mirroredDisplay);
    light = new cSpotLight(world);
    if (!light) {
        handleError("Failed to create light");
        return 1;
    }
    world->addChild(light);
    light->setEnabled(true);
    light->setLocalPos(0.0, 0.3, 0.4);
    light->setDir(0.0, -0.25, -0.4);
    light->setShadowMapEnabled(true);
    light->m_shadowMap->setQualityHigh();
    world->setShadowIntensity(0.3);
    light->setCutOffAngleDeg(30);

    plane = new cMesh();
    if (!plane) {
        handleError("Failed to create plane mesh");
        return 1;
    }
    world->addChild(plane);
    cCreateMap(plane, 0.2, 1.0, 20, 20);
    plane->setUseDisplayList(true);
    plane->m_material->setWhite();

    for (int i = 0; i < NUM_SPHERES; i++) {
        spheres[i] = new cShapeSphere(SPHERE_RADIUS);
        if (!spheres[i]) {
            handleError("Failed to create sphere " + to_string(i));
            return 1;
        }
        world->addChild(spheres[i]);
        spheres[i]->setLocalPos(0.8 * SPHERE_RADIUS * (double)(i + 2) * cos(1.0 * (double)(i)),
            0.8 * SPHERE_RADIUS * (double)(i + 2) * sin(1.0 * (double)(i)),
            SPHERE_RADIUS);
        spheres[i]->m_material->setWhite();
        sphereVel[i].zero();
    }

    font = NEW_CFONTCALIBRI20();
    if (!font) {
        handleError("Failed to create font");
        return 1;
    }
    labelRates = new cLabel(font);
    if (!labelRates) {
        handleError("Failed to create labelRates");
        return 1;
    }
    labelRates->m_fontColor.setBlack();
    camera->m_frontLayer->addChild(labelRates);

    labelMessage = new cLabel(font);
    if (!labelMessage) {
        handleError("Failed to create labelMessage");
        return 1;
    }
    labelMessage->m_fontColor.setBlack();
    labelMessage->setText("Press gripper to toggle between Network and Virtual Environment mode");
    camera->m_frontLayer->addChild(labelMessage);

    background = new cBackground();
    if (!background) {
        handleError("Failed to create background");
        return 1;
    }
    camera->m_backLayer->addChild(background);
    background->setFixedAspectRatio(true);
    string bgPath = RESOURCE_PATH("D:\chai3d-3.2.0\bin\resources\images\HHRCM background.png");
    bool fileload = background->loadFromFile(bgPath);
    if (!fileload) {
        logMessage("Background image failed to load at " + bgPath + ". Continuing without background.");
        camera->m_backLayer->removeChild(background);
        background = nullptr;
    }

    forceBuffer.reserve(FORCE_PACKET_WINDOW);
    stiffnessBuffer.reserve(FORCE_PACKET_WINDOW);
    dampingBuffer.reserve(FORCE_PACKET_WINDOW);
    errorBuffer.reserve(FORCE_PACKET_WINDOW);

    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_RGBA | GLUT_DOUBLE | GLUT_DEPTH);
    glutInitWindowSize(windowedWidth, windowedHeight);
    glutInitWindowPosition(windowPosX, windowPosY);
    mainWindow = glutCreateWindow("Haptic Teleoperation");
    glClearColor(COLOR_BG.r, COLOR_BG.g, COLOR_BG.b, 1.0f);
    glutDisplayFunc(glutDisplay);
    glutReshapeFunc(glutReshape);
    glutKeyboardFunc(glutKeyboard);
    glutTimerFunc(33, timerCallback, 0);

    graphStartTime = chrono::steady_clock::now();
    networkThread = thread(networkCommunication);
    hapticThread = thread(hapticLoop);

    glutMainLoop();

    running = false;
    hapticRunning = false;
    while (!simulationFinished) { cSleepMs(100); }
    if (networkThread.joinable()) networkThread.join();
    if (hapticThread.joinable()) hapticThread.join();
    if (hapticThread.joinable()) hapticThread.join();

    // Cleanup GLUT
    glutDestroyWindow(mainWindow);

    // Cleanup CHAI3D resources
    logMessage("Cleaning up CHAI3D resources...");
    if (labelMessage) {
        camera->m_frontLayer->removeChild(labelMessage);
        delete labelMessage;
        labelMessage = nullptr;
    }
    if (labelRates) {
        camera->m_frontLayer->removeChild(labelRates);
        delete labelRates;
        labelRates = nullptr;
    }
    if (background) {
        camera->m_backLayer->removeChild(background);
        delete background;
        background = nullptr;
    }
    for (int i = 0; i < NUM_SPHERES; i++) {
        if (spheres[i]) {
            world->removeChild(spheres[i]);
            delete spheres[i];
            spheres[i] = nullptr;
        }
    }
    if (plane) {
        world->removeChild(plane);
        delete plane;
        plane = nullptr;
    }
    if (light) {
        world->removeChild(light);
        delete light;
        light = nullptr;
    }
    if (camera) {
        world->removeChild(camera);
        delete camera;
        camera = nullptr;
    }
    if (world) {
        delete world;
        world = nullptr;
    }
    if (handler) {
        if (hapticDevice) {
            hapticDevice->close();
            hapticDevice = nullptr;
        }
        delete handler;
        handler = nullptr;
    }

    // Cleanup sockets
    logMessage("Cleaning up network sockets...");
    cleanupSocket();

    // Close log file
    if (logFile.is_open()) {
        logMessage("Closing log file...");
        logFile.close();
    }

    // Reset Windows timer resolution
    timeEndPeriod(1);

    logMessage("Application terminated successfully");
    return 0;
}
