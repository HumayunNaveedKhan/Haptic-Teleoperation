    const double MAX_FORCE_MAG = 5.0;
    const double MIN_MAX_DELAY = 10.0;

    vector<PacketData> localSentPackets, localReceivedPackets;
    double maxDelay = MIN_MAX_DELAY;
    {
        lock_guard<mutex> lock(packetHistoryMutex);
        localSentPackets = sentPackets;
        localReceivedPackets = receivedPackets;
        for (const auto& pkt : localSentPackets) {
            maxDelay = max(maxDelay, pkt.delay);
        }
        for (const auto& pkt : localReceivedPackets) {
            maxDelay = max(maxDelay, pkt.delay);
        }
    }
    maxDelay = max(maxDelay, MIN_MAX_DELAY);

    float yOffset = Y_OFFSET_INITIAL;

    // Network Statistics
    drawText(X_OFFSET, yOffset, "Network Statistics", TITLE_FONT);
    yOffset -= TEXT_HEIGHT * 2;

    cVector3d position(0.0, 0.0, 0.0);
    if (hapticDevice) {
        hapticDevice->getPosition(position);
    }
    drawText(X_OFFSET, yOffset, "Mode: " + string(useVirtualEnvironment ? "Virtual Environment" : "Network"));
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "Packets Sent: " + to_string(successfulSends) + " (Failed: " + to_string(failedSends) + ")");
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "Packets Received: " + to_string(successfulReceives) + " (Failed: " + to_string(failedReceives) + ")");
    yOffset -= TEXT_HEIGHT;
    drawText(X_OFFSET, yOffset, "Avg Latency: " + to_string_with_precision(avgLatency, 1) + " ms");
    yOffset -= SECTION_SPACING;

    // Packet Magnitudes Graph
    drawText(X_OFFSET, yOffset, "Packet Magnitudes (Last 100 Packets)", TITLE_FONT);
    yOffset -= TEXT_HEIGHT;

    float graphY = yOffset - GRAPH_HEIGHT;
    auto now = chrono::steady_clock::now();
    auto timeWindowStart = now - chrono::duration_cast<chrono::microseconds>(chrono::duration<double>(TIME_WINDOW_S));

    drawGrid(X_OFFSET, graphY, GRAPH_WIDTH, GRAPH_HEIGHT, 5, COLOR_GRID);

    glColor3f(COLOR_AXIS.r, COLOR_AXIS.g, COLOR_AXIS.b);
    glBegin(GL_LINES);
    glVertex2f(X_OFFSET, graphY); glVertex2f(X_OFFSET, graphY + GRAPH_HEIGHT);
    glVertex2f(X_OFFSET + GRAPH_WIDTH, graphY); glVertex2f(X_OFFSET + GRAPH_WIDTH, graphY + GRAPH_HEIGHT);
    glVertex2f(X_OFFSET, graphY); glVertex2f(X_OFFSET + GRAPH_WIDTH, graphY);
    glEnd();

    glColor3f(COLOR_SENT.r, COLOR_SENT.g, COLOR_SENT.b);
    for (int i = 0; i <= 5; i++) {
        float y = graphY + (i / 5.0f) * GRAPH_HEIGHT;
        glBegin(GL_LINES);
        glVertex2f(X_OFFSET - 5, y); glVertex2f(X_OFFSET, y);
        glEnd();
        drawText(X_OFFSET - 50, y - 5, to_string_with_precision(i * MAX_POSITION_MAG / 5.0, 2), GLUT_BITMAP_HELVETICA_10, COLOR_SENT);
    }
    drawText(X_OFFSET - 60, graphY + GRAPH_HEIGHT + 5, "Position (m)", GLUT_BITMAP_HELVETICA_12, COLOR_SENT);

    glColor3f(COLOR_RECEIVED.r, COLOR_RECEIVED.g, COLOR_RECEIVED.b);
    for (int i = 0; i <= 5; i++) {
        float y = graphY + (i / 5.0f) * GRAPH_HEIGHT;
        glBegin(GL_LINES);
        glVertex2f(X_OFFSET + GRAPH_WIDTH, y); glVertex2f(X_OFFSET + GRAPH_WIDTH + 5, y);
        glEnd();
        drawText(X_OFFSET + GRAPH_WIDTH + 10, y - 5, to_string_with_precision(i * MAX_FORCE_MAG / 5.0, 1), GLUT_BITMAP_HELVETICA_10, COLOR_RECEIVED);
    }
    drawText(X_OFFSET + GRAPH_WIDTH + 10, graphY + GRAPH_HEIGHT + 5, "Force (N)", GLUT_BITMAP_HELVETICA_12, COLOR_RECEIVED);

    glColor3f(COLOR_AXIS.r, COLOR_AXIS.g, COLOR_AXIS.b);
    for (int i = 0; i <= 5; i++) {
        float x = X_OFFSET + (i / 5.0f) * GRAPH_WIDTH;
        drawText(x - 5, graphY - 15, to_string(i * TIME_WINDOW_S / 5.0), GLUT_BITMAP_HELVETICA_10);
    }
    drawText(X_OFFSET + GRAPH_WIDTH + 5, graphY - 5, "Time (s)");

    glBegin(GL_QUADS);
    glColor3f(COLOR_SENT.r, COLOR_SENT.g, COLOR_SENT.b);
    for (const auto& pkt : localSentPackets) {
        if (pkt.timestamp < timeWindowStart || pkt.timestamp > now) continue;
        auto timeSinceStart = chrono::duration_cast<chrono::microseconds>(pkt.timestamp - timeWindowStart).count() / 1e6;
        float x = X_OFFSET + (timeSinceStart / TIME_WINDOW_S) * GRAPH_WIDTH;
        float height = min(static_cast<float>(pkt.magnitude / MAX_POSITION_MAG) * GRAPH_HEIGHT, GRAPH_HEIGHT);
        glVertex2f(x, graphY);
        glVertex2f(x + BAR_WIDTH, graphY);
        glVertex2f(x + BAR_WIDTH, graphY + height);
        glVertex2f(x, graphY + height);
    }
    glColor3f(COLOR_RECEIVED.r, COLOR_RECEIVED.g, COLOR_RECEIVED.b);
