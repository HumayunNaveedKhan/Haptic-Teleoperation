//------------------------------------------------------------------------------
// Packet Logging
//------------------------------------------------------------------------------
void logPacket(const ClientPacket& packet, bool isSent) {
    std::lock_guard<std::mutex> lock(logMutex);

    std::stringstream ss;
    ss << (isSent ? "SENT" : "RCVD") << " | Pkt#: " << packet.packetNumber
        << " | Pos: (" << std::fixed << std::setprecision(3)
        << packet.x << ", " << packet.y << ", " << packet.z << ")"
        << " | From: " << packet.srcIP << ":" << packet.srcPort
        << " | To: " << packet.dstIP << ":" << packet.dstPort;

    if (isSent) {
        sentPacketLogs.push_back(ss.str());
        if (sentPacketLogs.size() > CONSOLE_LOG_PACKETS) {
            sentPacketLogs.pop_front();
        }
    }
}

void logPacket(const FeedbackPacket& packet, bool isSent) {
    std::lock_guard<std::mutex> lock(logMutex);

    std::stringstream ss;
    ss << (isSent ? "SENT" : "RCVD") << " | Pkt#: " << packet.packetNumber
        << " | Force: (" << std::fixed << std::setprecision(3)
        << packet.fx << ", " << packet.fy << ", " << packet.fz << ")"
        << " | Pos: (" << packet.px << ", " << packet.py << ", " << packet.pz << ")"
        << " | Err: " << packet.positionError
        << " | Lat: " << packet.latency << "ms";

    if (!isSent) {
        receivedPacketLogs.push_back(ss.str());
        if (receivedPacketLogs.size() > CONSOLE_LOG_PACKETS) {
            receivedPacketLogs.pop_front();
        }
    }
}

//------------------------------------------------------------------------------
// Feedback Processing Functions
//------------------------------------------------------------------------------
void processFeedbackPacket(const FeedbackPacket& packet) {
    // Lock the feedback buffer
    std::lock_guard<std::mutex> lock(feedbackMutex);

    // Add packet to buffer
    feedbackBuffer.push_back(packet);

    // Keep buffer size reasonable
    while (feedbackBuffer.size() > MAX_HISTORY_SIZE) {
        feedbackBuffer.pop_front();
    }

    // Increment feedback packet counter
    feedbackPacketCounter++;

    // Check if it's time to update feedback (every PACKET_UTILIZATION_INTERVAL packets)
    if (feedbackPacketCounter >= PACKET_UTILIZATION_INTERVAL) {
        feedbackUpdateReady = true;
        feedbackPacketCounter = 0;  // Reset counter
    }

    // Update statistics for all received packets (not just applied ones)
    updateFeedbackStatistics(packet);

    // Log the packet
    logPacket(packet, false);
}

void updateFeedbackStatistics(const FeedbackPacket& packet) {
    // Update min/max values for position
    minPositionX = std::min(minPositionX, packet.px);
    maxPositionX = std::max(maxPositionX, packet.px);
    minPositionY = std::min(minPositionY, packet.py);
    maxPositionY = std::max(maxPositionY, packet.py);
    minPositionZ = std::min(minPositionZ, packet.pz);
    maxPositionZ = std::max(maxPositionZ, packet.pz);

    // Update min/max values for force
    minForceX = std::min(minForceX, packet.fx);
    maxForceX = std::max(maxForceX, packet.fx);
    minForceY = std::min(minForceY, packet.fy);
    maxForceY = std::max(maxForceY, packet.fy);
    minForceZ = std::min(minForceZ, packet.fz);
    maxForceZ = std::max(maxForceZ, packet.fz);

    // Update min/max values for latency and error
    minLatency = std::min(minLatency, packet.latency);
    maxLatency = std::max(maxLatency, packet.latency);
    minError = std::min(minError, packet.positionError);
    maxError = std::max(maxError, packet.positionError);

    // Update average latency (smoothed)
    averageLatency = 0.9f * averageLatency + 0.1f * packet.latency;

    // Update history for graphs (with limiting to avoid memory issues)
    positionHistory[0].push_back(packet.px);
    positionHistory[1].push_back(packet.py);
    positionHistory[2].push_back(packet.pz);

    forceHistory[0].push_back(packet.fx);
    forceHistory[1].push_back(packet.fy);
    forceHistory[2].push_back(packet.fz);

    latencyHistory.push_back(packet.latency);
    errorHistory.push_back(packet.positionError);

    // Limit size of history arrays
    for (int i = 0; i < 3; i++) {
        while (positionHistory[i].size() > MAX_HISTORY_SIZE) {
            positionHistory[i].erase(positionHistory[i].begin());
        }
        while (forceHistory[i].size() > MAX_HISTORY_SIZE) {
            forceHistory[i].erase(forceHistory[i].begin());
        }
    }

    while (latencyHistory.size() > MAX_HISTORY_SIZE) {
        latencyHistory.erase(latencyHistory.begin());
    }

    while (errorHistory.size() > MAX_HISTORY_SIZE) {
        errorHistory.erase(errorHistory.begin());
    }
}

void applyAdaptiveFeedback() {
    // Only proceed if it's time to update feedback
    if (!feedbackUpdateReady) {
        return;
    }

    // Lock the feedback buffer
    std::lock_guard<std::mutex> lock(feedbackMutex);

    // Only proceed if we have enough packets
    if (feedbackBuffer.size() < PACKETS_TO_UTILIZE) {
        feedbackUpdateReady = false;
        return;
    }

    cout << "Applying adaptive feedback from " << PACKETS_TO_UTILIZE << " packets" << endl;

    // Average the last PACKETS_TO_UTILIZE packets for smooth control
    float avgForce[3] = { 0.0f, 0.0f, 0.0f };
    float avgPosition[3] = { 0.0f, 0.0f, 0.0f };
    float avgError = 0.0f;

    // Get the most recent PACKETS_TO_UTILIZE packets
    size_t startIndex = feedbackBuffer.size() - PACKETS_TO_UTILIZE;
    for (size_t i = 0; i < PACKETS_TO_UTILIZE; i++) {
        const FeedbackPacket& packet = feedbackBuffer[startIndex + i];

        // Sum forces
        avgForce[0] += packet.fx;
        avgForce[1] += packet.fy;
        avgForce[2] += packet.fz;

        // Sum positions
        avgPosition[0] += packet.px;
        avgPosition[1] += packet.py;
        avgPosition[2] += packet.pz;

        // Sum error
        avgError += packet.positionError;
    }

    // Calculate averages
    for (int i = 0; i < 3; i++) {
        avgForce[i] /= PACKETS_TO_UTILIZE;
        avgPosition[i] /= PACKETS_TO_UTILIZE;
    }
    avgError /= PACKETS_TO_UTILIZE;

    // Apply the averaged values
    for (int i = 0; i < 3; i++) {
        currentForce[i] = avgForce[i];
        targetPosition[i] = avgPosition[i];
    }
    positionError = avgError;

    // Reset the update flag
    feedbackUpdateReady = false;

    // Update sphere positions in visualization based on server data
    for (int i = 0; i < NUM_SPHERES && i < 3; i++) {
        // Simple mapping of sphere positions - in a real implementation this would be more sophisticated
        // Here we're just using the target position as the position of the first sphere
        // and offsetting the others for visualization
        if (i == 0) {
            spheres[i]->setLocalPos(cVector3d(targetPosition[0], targetPosition[1], targetPosition[2]));
        }
        else {
            // Position other spheres around the first one
            double angle = (double)i * 2.0 * M_PI / (NUM_SPHERES - 1);
            double r = 3.0 * SPHERE_RADIUS;
            spheres[i]->setLocalPos(cVector3d(
                targetPosition[0] + r * cos(angle),
                targetPosition[1] + r * sin(angle),
                targetPosition[2]
            ));
        }
    }
}

