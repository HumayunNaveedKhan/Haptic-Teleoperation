void drawGraph(int x, int y, int width, int height,
    const std::vector<float>& data, float minVal, float maxVal,
    float r, float g, float b) {
    if (data.empty()) return;

    // Ensure min != max to avoid division by zero
    if (fabs(maxVal - minVal) < 0.0001f) {
        maxVal = minVal + 0.0001f;
    }

    // Draw border
    glColor3f(0.5f, 0.5f, 0.5f);
    glBegin(GL_LINE_LOOP);
    glVertex2i(x, y);
    glVertex2i(x + width, y);
    glVertex2i(x + width, y + height);
    glVertex2i(x, y + height);
    glEnd();

    // Draw graph line
    glColor3f(r, g, b);
    glBegin(GL_LINE_STRIP);

    int numPoints = min((int)data.size(), width - 2);
    for (int i = 0; i < numPoints; i++) {
        float dataVal = data[data.size() - numPoints + i];
        float normalized = (dataVal - minVal) / (maxVal - minVal);
        int dataY = y + (int)(normalized * height);

        glVertex2i(x + i + 1, dataY);
    }

    glEnd();

    // Draw min/max labels
    glColor3f(0.0f, 0.0f, 0.0f);
    char buffer[50];

    sprintf_s(buffer, "%.2f", maxVal);
    renderText(x - 40, y + height - 10, buffer);

    sprintf_s(buffer, "%.2f", minVal);
    renderText(x - 40, y + 5, buffer);

    // Draw current value
    if (!data.empty()) {
        sprintf_s(buffer, "Current: %.2f", data.back());
        renderText(x + width - 100, y + height - 15, buffer);
    }
}
