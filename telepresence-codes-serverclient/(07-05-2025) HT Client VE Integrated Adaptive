// Thread function for sending packets to server
void sendNetworkThread_func(void) {
    sockaddr_in serverAddr;
    ClientPacket packet;

    // Set up the server address
    serverAddr.sin_family = AF_INET;
    serverAddr.sin_port = htons(PORT);
    if (inet_pton(AF_INET, SERVER_IP, &serverAddr.sin_addr) <= 0) {
        cerr << "Invalid destination IP" << endl;
        return;
    }

    cout << "Send thread initialized. Sending to " << SERVER_IP << ":" << PORT << endl;

    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);

    // Sending loop based on haptic rate
    while (networkRunning) {
        // Get haptic device position directly
        cVector3d position;
        if (hapticDevice && hapticDevice->getPosition(position)) {
            // Fill packet data
            packet.packetNumber = ++packetNumber;
            packet.x = static_cast<float>(position.x());
            packet.y = static_cast<float>(position.y());
            packet.z = static_cast<float>(position.z());
            packet.delay = 1000.0f / HAPTIC_RATE_HZ;

            getTimestamp(packet.timestamp);
            strcpy_s(packet.srcIP, SRC_IP);
            strcpy_s(packet.dstIP, SERVER_IP);
            packet.srcPort = PORT;
            packet.dstPort = PORT;

            // Send packet over UDP using send socket
            std::lock_guard<std::mutex> lock(socketMutex);
            if (sendSocket != INVALID_SOCKET) {
                int result = sendto(sendSocket, reinterpret_cast<char*>(&packet), sizeof(ClientPacket), 0,
                    (sockaddr*)&serverAddr, sizeof(serverAddr));

                if (result != SOCKET_ERROR) {
                    packetsSent++;
                    logPacket(packet, true);
                }
            }

            // Update device cursor position in 3D visualization
            if (deviceCursor) {
                deviceCursor->setLocalPos(position);
            }
        }

        // Sleep for the appropriate interval to match haptic rate
        std::this_thread::sleep_for(chrono::microseconds(1000000 / HAPTIC_RATE_HZ));
    }

    cout << "Send thread stopped" << endl;
}

// Thread function for receiving feedback packets from server
void receiveNetworkThread_func(void) {
    char recvBuffer[BUFFER_SIZE];
    sockaddr_in senderAddr;
    int senderAddrLen = sizeof(senderAddr);

    cout << "Receive thread initialized. Listening on port " << PORT << endl;

    // Set thread priority
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_ABOVE_NORMAL);

    // Receiving loop
    while (networkRunning) {
        // Lock for socket operations
        socketMutex.lock();

        // Check if socket is valid
        if (receiveSocket != INVALID_SOCKET) {
            // Receive packet from socket - create a local variable for senderAddrLen
            int tempAddrLen = senderAddrLen;
            int bytesReceived = recvfrom(
                receiveSocket,
                recvBuffer,
                BUFFER_SIZE,
                0,
                (sockaddr*)&senderAddr,
                &tempAddrLen
            );

            // Update the actual senderAddrLen with the value potentially modified by recvfrom
            senderAddrLen = tempAddrLen;

            socketMutex.unlock();

            if (bytesReceived > 0) {
                packetsReceived++;

                // Process feedback packet
                if (bytesReceived == sizeof(FeedbackPacket)) {
                    FeedbackPacket* feedbackPacket = reinterpret_cast<FeedbackPacket*>(recvBuffer);
                    processFeedbackPacket(*feedbackPacket);
                }
            }
            else if (bytesReceived == SOCKET_ERROR) {
                int error = WSAGetLastError();
                if (error != WSAEWOULDBLOCK) {
                    cerr << "Error receiving packet: " << error << endl;
                }
            }
        }
        else {
            socketMutex.unlock();
        }

        // Sleep briefly to avoid hogging CPU
        std::this_thread::sleep_for(chrono::milliseconds(1));
    }

    cout << "Receive thread stopped" << endl;
}

