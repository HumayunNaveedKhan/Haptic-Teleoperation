void drawGraph(float x, float y, float width, float height,
    const std::vector<float>& data, float minVal, float maxVal,
    GLfloat r, GLfloat g, GLfloat b) {
    if (data.empty()) return;

    // Ensure min != max to avoid division by zero
    if (fabs(maxVal - minVal) < 0.0001f) {
        maxVal = minVal + 0.0001f;
    }

    // Set color
    glColor3f(r, g, b);

    // Draw border
    glBegin(GL_LINE_LOOP);
    glVertex2f(x, y);
    glVertex2f(x + width, y);
    glVertex2f(x + width, y + height);
    glVertex2f(x, y + height);
    glEnd();

    // Draw graph line
    glBegin(GL_LINE_STRIP);
    float xStep = width / (data.size() - 1);

    for (size_t i = 0; i < data.size(); i++) {
        float xPos = x + i * xStep;
        float normalizedY = (data[i] - minVal) / (maxVal - minVal);
        float yPos = y + normalizedY * height;
        glVertex2f(xPos, yPos);
    }
    glEnd();

    // Draw axis labels
    char buffer[50];
    glColor3f(0.0f, 0.0f, 0.0f);

    // Y-axis labels (min and max)
    sprintf_s(buffer, "%.2f", maxVal);
    drawText(x - 40, y + height - 10, buffer);

    sprintf_s(buffer, "%.2f", minVal);
    drawText(x - 40, y + 5, buffer);

    // Current value label
    sprintf_s(buffer, "Current: %.2f", data.back());
    drawText(x + width - 100, y + height - 20, buffer);
}

void drawText(float x, float y, const char* text) {
    glRasterPos2f(x, y);
    for (const char* c = text; *c != '\0'; c++) {
        glutBitmapCharacter(GLUT_BITMAP_8_BY_13, *c);
    }
}

