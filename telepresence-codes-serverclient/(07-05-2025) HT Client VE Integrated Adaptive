void windowSizeCallback(GLFWwindow* a_window, int a_width, int a_height)
{
    // update window size
    width = a_width;
    height = a_height;

    // update position of message label
    labelMessage->setLocalPos((int)(0.5 * (width - labelMessage->getWidth())), 50);
}

void errorCallback(int a_error, const char* a_description)
{
    cout << "Error: " << a_description << endl;
}

void keyCallback(GLFWwindow* a_window, int a_key, int a_scancode, int a_action, int a_mods)
{
    // filter calls that only include a key press
    if ((a_action != GLFW_PRESS) && (a_action != GLFW_REPEAT))
    {
        return;
    }

    // option - exit
    if ((a_key == GLFW_KEY_ESCAPE) || (a_key == GLFW_KEY_Q))
    {
        glfwSetWindowShouldClose(a_window, GLFW_TRUE);
    }

    // option - toggle fullscreen
    else if (a_key == GLFW_KEY_F)
    {
        // toggle state variable
        fullscreen = !fullscreen;

        // get handle to monitor
        GLFWmonitor* monitor = glfwGetPrimaryMonitor();

        // get information about monitor
        const GLFWvidmode* mode = glfwGetVideoMode(monitor);

        // set fullscreen or window mode
        if (fullscreen)
        {
            glfwSetWindowMonitor(window, monitor, 0, 0, mode->width, mode->height, mode->refreshRate);
            glfwSwapInterval(swapInterval);
        }
        else
        {
            int w = WINDOW_WIDTH_RATIO * mode->height;
            int h = WINDOW_HEIGHT_RATIO * mode->height;
            int x = 0.5 * (mode->width - w);
            int y = 0.5 * (mode->height - h);
            glfwSetWindowMonitor(window, NULL, x, y, w, h, mode->refreshRate);
            glfwSwapInterval(swapInterval);
        }
    }

    // option - toggle vertical mirroring
    else if (a_key == GLFW_KEY_M)
    {
        mirroredDisplay = !mirroredDisplay;
        camera->setMirrorVertical(mirroredDisplay);
    }

    // option - toggle console analytics
    else if (a_key == GLFW_KEY_A)
    {
        showConsoleAnalytics = !showConsoleAnalytics;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }

    // option - toggle graphical analytics
    else if (a_key == GLFW_KEY_G)
    {
        // If window not created yet, create it
        if (analyticsWindowId < 0) {
            initAnalyticsWindow();
        }
        else {
            // Toggle visibility by destroying/recreating
            glutDestroyWindow(analyticsWindowId);
            analyticsWindowId = -1;

            // If it was destroyed, recreate it
            if (analyticsWindowId < 0) {
                initAnalyticsWindow();
            }
        }
    }

    // option - toggle feedback type
    else if (a_key == GLFW_KEY_T)
    {
        currentFeedbackType = static_cast<FeedbackType>((currentFeedbackType + 1) % 3);
        string typeName;
        switch (currentFeedbackType) {
        case FEEDBACK_POSITION: typeName = "Position"; break;
        case FEEDBACK_FORCE: typeName = "Force"; break;
        case FEEDBACK_STIFFNESS_DAMPING: typeName = "Stiffness/Damping"; break;
        }
        cout << "Feedback type changed to: " << typeName << endl;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }

    // option - toggle feedback enabled
    else if (a_key == GLFW_KEY_F && a_mods & GLFW_MOD_SHIFT)
    {
        feedbackEnabled = !feedbackEnabled;
        cout << "Feedback " << (feedbackEnabled ? "enabled" : "disabled") << endl;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }

    // option - adjust stiffness
    else if (a_key == GLFW_KEY_EQUAL || a_key == GLFW_KEY_KP_ADD) // Plus key
    {
        stiffnessValue = std::min(stiffnessValue + 10.0, MAX_STIFFNESS);
        cout << "Stiffness: " << stiffnessValue << endl;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }
    else if (a_key == GLFW_KEY_MINUS || a_key == GLFW_KEY_KP_SUBTRACT) // Minus key
    {
        stiffnessValue = std::max(0.0, stiffnessValue - 10.0);
        cout << "Stiffness: " << stiffnessValue << endl;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }

    // option - adjust damping
    else if (a_key == GLFW_KEY_D)
    {
        dampingValue = std::min(dampingValue + 5.0, MAX_DAMPING);
        cout << "Damping: " << dampingValue << endl;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }
    else if (a_key == GLFW_KEY_C)
    {
        dampingValue = std::max(0.0, dampingValue - 5.0);
        cout << "Damping: " << dampingValue << endl;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }

    // option - configure server IP
    else if (a_key == GLFW_KEY_I)
    {
        // Temporarily pause rendering
        bool wasAnalyticsActive = showConsoleAnalytics;
        showConsoleAnalytics = false;

        configureServerIP();

        showConsoleAnalytics = wasAnalyticsActive;
        if (showConsoleAnalytics) {
            displayConsoleAnalytics();
        }
    }
}

