#pragma comment(lib,"ws2_32.lib")
#pragma comment(lib,"winmm.lib")

using namespace chai3d;

namespace cfg {
    constexpr uint16_t UDP_PORT = 4000;
    constexpr int RING_SZ = 8192;
}

#pragma pack(push,1)
struct C2S { uint32_t seq; float sx, sy, sz, sfx, sfy, sfz; double ts; };
struct S2C { uint32_t seq; float mx, my, mz; double ts; };
#pragma pack(pop)

struct LogEntry { int testCase; uint32_t seq; double ts; float x, y, z; bool isSend; };

std::atomic<bool> g_running{ true };
std::atomic<int> g_activeCase{ 0 };
std::atomic<int> g_logCounter{ 0 };

template<typename T, int N>
struct Ring {
    std::atomic<int> head{ 0 }, tail{ 0 };
    T buf[N];
    bool push(const T& v) {
        int h = head.load(), n = (h + 1) % N;
        if (n == tail.load()) return false;
        buf[h] = v; head.store(n); return true;
    }
    bool pop(T& o) {
        int t = tail.load();
        if (t == head.load()) return false;
        o = buf[t]; tail.store((t + 1) % N); return true;
    }
};

Ring<LogEntry, cfg::RING_SZ> g_logRing;

void loggerThread() {
    std::ofstream file("server_data.csv");
    file << "Case,Type,Sequence,Timestamp,X,Y,Z\n";
    LogEntry e;
    while (g_running || g_logRing.pop(e)) {
        if (g_logRing.pop(e)) {
            file << e.testCase << "," << (e.isSend ? "SENT" : "RECV") << "," << e.seq << ","
                 << std::fixed << std::setprecision(4) << e.ts << "," << e.x << "," << e.y << "," << e.z << "\n";
            if (++g_logCounter >= 2000) { 
                file.flush();
                printf("Test Case %d Logged Successfully.\n", g_activeCase.load());
                g_activeCase = 0; 
            }
        } else std::this_thread::sleep_for(std::chrono::milliseconds(10));
    }
    file.close();
}

void hapticThread() {
    WSADATA wsa; WSAStartup(MAKEWORD(2, 2), &wsa);
    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    SOCKADDR_IN localAddr{}; localAddr.sin_family = AF_INET;
    localAddr.sin_addr.s_addr = INADDR_ANY;
    localAddr.sin_port = htons(cfg::UDP_PORT);
    bind(sock, (SOCKADDR*)&localAddr, sizeof(localAddr));
    u_long nb = 1; ioctlsocket(sock, FIONBIO, &nb);

    SOCKADDR_IN clientAddr{}; int clen = sizeof(clientAddr);
    uint32_t txSeq = 0;
    auto start_time = std::chrono::high_resolution_clock::now();

    while (g_running) {
        auto t0 = std::chrono::high_resolution_clock::now();
        double now = std::chrono::duration<double, std::ratio<1, 1000>>(t0 - start_time).count();

        C2S rp;
        if (recvfrom(sock, (char*)&rp, sizeof(rp), 0, (SOCKADDR*)&clientAddr, &clen) == sizeof(rp)) {
            if (g_activeCase > 0) g_logRing.push({ g_activeCase, rp.seq, now, rp.sx, rp.sy, rp.sz, false });
        }

        if (clientAddr.sin_addr.s_addr != 0) {
            S2C out{ ++txSeq, 0.01f, 0.01f, 0.01f, now };
            sendto(sock, (char*)&out, sizeof(out), 0, (SOCKADDR*)&clientAddr, sizeof(clientAddr));
            if (g_activeCase > 0) g_logRing.push({ g_activeCase, out.seq, now, out.mx, out.my, out.mz, true });
        }

        std::this_thread::sleep_until(t0 + std::chrono::microseconds(1000));
    }
    closesocket(sock);
}

void onKey(GLFWwindow* w, int key, int, int action, int) {
    if (action != GLFW_PRESS) return;
    if (key == GLFW_KEY_1) { g_logCounter = 0; g_activeCase = 1; printf("Case 1 Recording...\n"); }
    if (key == GLFW_KEY_2) { g_logCounter = 0; g_activeCase = 2; printf("Case 2 Recording...\n"); }
    if (key == GLFW_KEY_3) { g_logCounter = 0; g_activeCase = 3; printf("Case 3 Recording...\n"); }
    if (key == GLFW_KEY_ESCAPE) g_running = false;
}

int main() {
    std::thread t1(hapticThread), t2(loggerThread);
    if (!glfwInit()) return -1;
    GLFWwindow* window = glfwCreateWindow(640, 480, "Server", NULL, NULL);
    glfwSetKeyCallback(window, onKey);
    while (!glfwWindowShouldClose(window) && g_running) {
        glfwPollEvents();
        std::this_thread::sleep_for(std::chrono::milliseconds(16));
    }
    g_running = false; t1.join(); t2.join();
    glfwTerminate();
    return 0;
}
