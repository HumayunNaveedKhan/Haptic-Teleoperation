// ═════════════════════════════════════════════════════════════════════════════
//  WIRE PACKET  (38 bytes, packed, little-endian)
// ═════════════════════════════════════════════════════════════════════════════
#pragma pack(push,1)
struct HapticPacket
{
    double  ts;              // ms since sender start
    float   x, y, z;      // position  (metres)
    float   mag;             // sqrt(x²+y²+z²)
    float   fx, fy, fz;     // force feedback (N)  – zero if unused
    uint8_t btn;             // button bitmask
    uint8_t flags;           // bit0 = hasFeedback
};
#pragma pack(pop)
static_assert(sizeof(HapticPacket) == 38, "packet size");

