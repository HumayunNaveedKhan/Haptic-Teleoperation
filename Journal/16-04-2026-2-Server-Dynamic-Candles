static App* g_app = nullptr;

static void onKey(GLFWwindow* w, int key, int, int action, int)
{
    if (action != GLFW_PRESS || !g_app) return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_T: {
        bool v = !g_app->txEnabled; g_app->txEnabled.store(v);
        printf("[NET] TX (send to client): %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_R: {
        bool v = !g_app->rxEnabled; g_app->rxEnabled.store(v);
        printf("[NET] RX (receive from client): %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_F: {
        bool v = !g_app->fbEnabled; g_app->fbEnabled.store(v);
        printf("[FB]  Force feedback to local Falcon: %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_EQUAL: case GLFW_KEY_KP_ADD: {
        double v = std::min(g_app->candleMs.load() * 1.122, cfg::CANDLE_MS_MAX);
        g_app->candleMs.store(v);
        printf("[UI] Window: %.1fms (%.1f/s)\n", v, 1000.0 / v); break;
    }
    case GLFW_KEY_MINUS: case GLFW_KEY_KP_SUBTRACT: {
        double v = std::max(g_app->candleMs.load() / 1.122, cfg::CANDLE_MS_MIN);
        g_app->candleMs.store(v);
        printf("[UI] Window: %.1fms (%.1f/s)\n", v, 1000.0 / v); break;
    }
    case GLFW_KEY_LEFT_BRACKET:
        g_app->candleMs.store(cfg::CANDLE_MS_MIN);
        printf("[UI] MAX RATE 1ms\n"); break;
    case GLFW_KEY_RIGHT_BRACKET:
        g_app->candleMs.store(cfg::CANDLE_MS_MAX);
        printf("[UI] MIN RATE 1000ms\n"); break;
    default: break;
    }
}
static void onFbSize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_fbW = w; g_fbH = h; }

// ═════════════════════════════════════════════════════════════════════════════
//  MAIN
// ═════════════════════════════════════════════════════════════════════════════
int main()
{
    WSADATA wsa{}; WSAStartup(MAKEWORD(2, 2), &wsa);

    App app; g_app = &app;
    detectLocalIP(app.localIP, sizeof(app.localIP));

    printf("╔══════════════════════════════════════════════╗\n");
    printf("║       HapticCandlestick  SERVER              ║\n");
    printf("╠══════════════════════════════════════════════╣\n");
    printf("║  Server IP : %-30s  ║\n", app.localIP);
    printf("║  Client IP : %-30s  ║\n", cfg::CLIENT_IP);
    printf("║  UDP Port  : %-30d  ║\n", cfg::NET_PORT);
    printf("╠══════════════════════════════════════════════╣\n");
    printf("║  T   toggle TX (send to client)              ║\n");
    printf("║  R   toggle RX (receive from client)         ║\n");
    printf("║  F   toggle force feedback to local Falcon   ║\n");
    printf("║  +/- candle window step                      ║\n");
    printf("║  [   1ms window  (1000 bars/s)               ║\n");
    printf("║  ]   1000ms window  (1 bar/s)                ║\n");
    printf("║  ESC quit                                    ║\n");
    printf("╚══════════════════════════════════════════════╝\n\n");

    WSACleanup();   // main cleanup; network thread does its own WSAStartup

    std::thread tHaptic([&] { hapticThread(app); });
    std::thread tAgg([&] { aggregatorThread(app); });
    std::thread tNet([&] { networkThread(app); });

    if (!glfwInit()) {
        app.running = false;
        tHaptic.join(); tAgg.join(); tNet.join(); return 1;
    }

    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);
    glfwWindowHint(GLFW_SAMPLES, 4);

    char wtitle[128];
    snprintf(wtitle, sizeof(wtitle),
        "SERVER  %s  →  CLIENT %s  |  Port %d",
        app.localIP, cfg::CLIENT_IP, cfg::NET_PORT);

    GLFWwindow* win = glfwCreateWindow(cfg::WIN_W, cfg::WIN_H, wtitle, nullptr, nullptr);
    if (!win) {
        glfwTerminate(); app.running = false;
        tHaptic.join(); tAgg.join(); tNet.join(); return 1;
    }

    glfwMakeContextCurrent(win);
    glfwSwapInterval(1);
    glfwSetKeyCallback(win, onKey);
    glfwSetFramebufferSizeCallback(win, onFbSize);
    glfwGetFramebufferSize(win, &g_fbW, &g_fbH);

    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glEnable(GL_LINE_SMOOTH); glHint(GL_LINE_SMOOTH_HINT, GL_NICEST);
    glEnable(GL_MULTISAMPLE);

    // Chart layout (side by side)
    // LEFT  chart: x=[0.01 .. 0.49]  LOCAL  (TX)
    // RIGHT chart: x=[0.51 .. 0.99]  REMOTE (RX)
    const float LCL = 0.01f, LCR = 0.49f;  // left chart left/right
    const float RCL = 0.51f, RCR = 0.99f;  // right chart left/right
    const float CMB = 0.10f, CMT = 0.82f;  // chart margin bottom/top

    while (!glfwWindowShouldClose(win))
    {
        glfwGetFramebufferSize(win, &g_fbW, &g_fbH);
        glViewport(0, 0, g_fbW, g_fbH);
        glClearColor(0.05f, 0.07f, 0.10f, 1.f);
        glClear(GL_COLOR_BUFFER_BIT);

        glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        // ── Snapshot ──────────────────────────────────────────────────────
        std::deque<Candle> localSnap, remoteSnap;
        Candle localLive{}, remoteLive{};
        bool localLO = false, remoteLO = false;
        {
            std::lock_guard<std::mutex> lk(app.localMtx);
            localSnap = app.localCandles; localLive = app.localLive; localLO = app.localLiveOpen;
        }
        {
            std::lock_guard<std::mutex> lk(app.remoteMtx);
            remoteSnap = app.remoteCandles; remoteLive = app.remoteLive; remoteLO = app.remoteLiveOpen;
        }
        if (localLO)  localSnap.push_back(localLive);
        if (remoteLO) remoteSnap.push_back(remoteLive);

        float lMag = app.lmag.load(std::memory_order_relaxed);
        float rMag = app.rmag.load(std::memory_order_relaxed);

        // ── Draw divider ──────────────────────────────────────────────────
        glLineWidth(1.5f); glColor3f(0.25f, 0.30f, 0.40f);
        glBegin(GL_LINES);
        glVertex2f(0.50f, 0.0f); glVertex2f(0.50f, 1.0f);
        glEnd();

        // ── Left chart: LOCAL / TX ────────────────────────────────────────
        drawChart(localSnap, localLO, lMag,
            LCL, LCR, CMB, CMT,
            "LOCAL (TX -> CLIENT)",
            0.35f, 0.88f, 0.45f);   // green title

        // ── Right chart: REMOTE / RX ──────────────────────────────────────
        drawChart(remoteSnap, remoteLO, rMag,
            RCL, RCR, CMB, CMT,
            "REMOTE (RX <- CLIENT)",
            0.40f, 0.65f, 0.98f);   // blue title

        // ── INFO PANEL ────────────────────────────────────────────────────
        fillRect(0.0f, 0.83f, 1.0f, 1.0f, 0.06f, 0.08f, 0.12f, 0.95f);
        glLineWidth(0.8f); glColor3f(0.20f, 0.24f, 0.32f);
        glBegin(GL_LINES); glVertex2f(0, 0.83f); glVertex2f(1, 0.83f); glEnd();
        glBegin(GL_LINES); glVertex2f(0.5f, 0.83f); glVertex2f(0.5f, 1.0f); glEnd();

        float row1y = 0.968f * g_fbH, row2y = 0.918f * g_fbH, row3y = 0.862f * g_fbH;
        char buf[96];

        // LOCAL side (left half of panel)
        drawTextPx(0.02f * g_fbW, row1y, "LOCAL HAPTIC (TX)", 0.30f, 0.78f, 0.38f);
        float lx = app.lx.load(), ly_ = app.ly.load(), lz = app.lz.load(), lm = app.lmag.load();
        snprintf(buf, sizeof(buf), "X:%+.4f", lx); drawTextPx(0.02f * g_fbW, row2y, buf, 0.38f, 0.88f, 0.42f);
        snprintf(buf, sizeof(buf), "Y:%+.4f", ly_); drawTextPx(0.11f * g_fbW, row2y, buf, 0.38f, 0.62f, 0.95f);
        snprintf(buf, sizeof(buf), "Z:%+.4f", lz);  drawTextPx(0.20f * g_fbW, row2y, buf, 0.95f, 0.60f, 0.20f);
        snprintf(buf, sizeof(buf), "Mag:%.4fm (%.2fmm)", lm, lm * 1000);
        drawTextPx(0.29f * g_fbW, row2y, buf, 1.0f, 0.92f, 0.30f);
        // TX/FB status
        snprintf(buf, sizeof(buf), "TX:%s  FB:%s  Sent:%llu",
            app.txEnabled ? "ON " : "OFF",
            app.fbEnabled ? "ON " : "OFF",
            (unsigned long long)app.pktsSent.load());
        drawTextPx(0.02f * g_fbW, row3y, buf,
            app.txEnabled ? 0.25f : 0.55f,
            app.txEnabled ? 0.88f : 0.45f,
            app.txEnabled ? 0.40f : 0.40f);

        // REMOTE side (right half of panel)
        drawTextPx(0.52f * g_fbW, row1y, "REMOTE HAPTIC (RX)", 0.35f, 0.60f, 0.95f);
        float rx = app.rx_.load(), ry = app.ry_.load(), rz = app.rz_.load(), rm = app.rmag.load();
        // Stale detection: if last rx was >500ms ago, dim it
        double staleMs = app.clock.ms() - app.lastRxMs.load();
        float stale = (staleMs > 500.0) ? 0.4f : 1.0f;
        snprintf(buf, sizeof(buf), "X:%+.4f", rx); drawTextPx(0.52f * g_fbW, row2y, buf, 0.38f * stale, 0.88f * stale, 0.42f * stale);
        snprintf(buf, sizeof(buf), "Y:%+.4f", ry); drawTextPx(0.61f * g_fbW, row2y, buf, 0.38f * stale, 0.62f * stale, 0.95f * stale);
        snprintf(buf, sizeof(buf), "Z:%+.4f", rz); drawTextPx(0.70f * g_fbW, row2y, buf, 0.95f * stale, 0.60f * stale, 0.20f * stale);
        snprintf(buf, sizeof(buf), "Mag:%.4fm (%.2fmm)", rm, rm * 1000);
        drawTextPx(0.79f * g_fbW, row2y, buf, 1.0f * stale, 0.92f * stale, 0.30f * stale);
        // RX status
        snprintf(buf, sizeof(buf), "RX:%s  Recv:%llu  Lag:%.0fms",
            app.rxEnabled ? "ON " : "OFF",
            (unsigned long long)app.pktsRecv.load(), staleMs);
        drawTextPx(0.52f * g_fbW, row3y, buf,
            app.rxEnabled ? 0.30f : 0.55f,
            app.rxEnabled ? 0.65f : 0.45f,
            app.rxEnabled ? 0.95f : 0.40f);

        // IP row at very top of panel
        snprintf(buf, sizeof(buf), "SERVER: %s   CLIENT: %s   PORT: %d   +/-/[/]= window",
            app.localIP, cfg::CLIENT_IP, cfg::NET_PORT);
        drawTextPx(0.02f * g_fbW, (0.985f) * g_fbH, buf, 0.40f, 0.44f, 0.55f);

        // Demo stripe
        if (app.demoMode) {
            fillRect(0, 0, 0.004f, 1, 0.95f, 0.65f, 0.10f, 0.8f);
            drawTextPx(0.006f * g_fbW, 0.5f * g_fbH, "DEMO", 0.95f, 0.65f, 0.10f);
        }

        glfwSwapBuffers(win);
        glfwPollEvents();
    }

    app.running = false;
    tHaptic.join(); tAgg.join(); tNet.join();
    glfwDestroyWindow(win); glfwTerminate();
    printf("Server shutdown. Sent:%llu  Recv:%llu\n",
        (unsigned long long)app.pktsSent.load(),
        (unsigned long long)app.pktsRecv.load());
    return 0;
}
