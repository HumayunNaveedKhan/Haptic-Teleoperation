static const int FS = 2; // font scale
static const int GW = 5 * FS, GH = 7 * FS, GGAP = 1 * FS;

static void drawTextPx(float px, float py, const char* str,
    float r = 1, float g2 = 1, float b = 1, float a = 1)
{
    if (!str || !str[0]) return;
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity();
    glOrtho(0, g_fbW, 0, g_fbH, -1, 1);
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();
    glColor4f(r, g2, b, a);
    glBegin(GL_QUADS);
    float cx = px;
    for (const char* p = str; *p; ++p) {
        int c = (unsigned char)*p;
        if (c < 32 || c>126) { cx += GW + GGAP; continue; }
        const uint8_t* col = GLYPHS[c - 32];
        for (int ci = 0; ci < 5; ++ci) {
            uint8_t bits = col[ci];
            for (int ri = 0; ri < 7; ++ri) {
                if (bits & (1 << ri)) {
                    float x0 = cx + ci * FS, y0 = py + (6 - ri) * FS;
                    float x1 = x0 + FS, y1 = y0 + FS;
                    glVertex2f(x0, y0); glVertex2f(x1, y0);
                    glVertex2f(x1, y1); glVertex2f(x0, y1);
                }
            }
        }
        cx += GW + GGAP;
    }
    glEnd();
    glMatrixMode(GL_PROJECTION); glPopMatrix();
    glMatrixMode(GL_MODELVIEW); glPopMatrix();
    glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
    glMatrixMode(GL_MODELVIEW); glLoadIdentity();
}

// ═════════════════════════════════════════════════════════════════════════════
//  RENDER HELPERS
// ═════════════════════════════════════════════════════════════════════════════
static void fillRect(float x0, float y0, float x1, float y1,
    float r, float g2, float b, float a = 1)
{
    glColor4f(r, g2, b, a);
    glBegin(GL_QUADS);
    glVertex2f(x0, y0); glVertex2f(x1, y0);
    glVertex2f(x1, y1); glVertex2f(x0, y1);
    glEnd();
}

static inline float yOf(float m, float yb, float yt) {
    float t = (m - cfg::YMIN) / (cfg::YMAX - cfg::YMIN);
    return yb + t * (yt - yb);
}

static void drawCandle(float xc, float hw, float oY, float clY,
    float hY, float lY, bool bull, float alpha)
{
    if (bull) glColor4f(0.114f, 0.722f, 0.416f, alpha);
    else     glColor4f(0.902f, 0.220f, 0.220f, alpha);
    float top = std::max(oY, clY), bot = std::min(oY, clY);
    float bh = top - bot; if (bh < 0.0010f) bh = 0.0010f;
    glBegin(GL_QUADS);
    glVertex2f(xc - hw, bot); glVertex2f(xc + hw, bot);
    glVertex2f(xc + hw, bot + bh); glVertex2f(xc - hw, bot + bh);
    glEnd();
    glLineWidth(1.4f);
    glBegin(GL_LINES);
    glVertex2f(xc, bot + bh); glVertex2f(xc, hY);
    glVertex2f(xc, bot);   glVertex2f(xc, lY);
    glEnd();
}

// Draw one complete chart panel in the given X band [panelL..panelR] normalised
static void drawChart(
    const std::deque<Candle>& snap, bool liveOpen,
    float liveMag,
    float panelL, float panelR,
    float MB_n, float MT_n,
    const char* title, float tr, float tg, float tb)
{
    float CW = panelR - panelL, CH = MT_n - MB_n;
    float slot = CW / (float)cfg::VISIBLE;
    float hw = slot * 0.34f;
    int nTotal = (int)snap.size();

    // Background
    fillRect(panelL, MB_n, panelR, MT_n, 0.09f, 0.11f, 0.15f);

    // Grid
    glLineWidth(0.5f); glColor4f(0.25f, 0.29f, 0.38f, 0.6f);
    glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float gy = MB_n + CH * ((float)i / cfg::Y_DIVS);
        glVertex2f(panelL, gy); glVertex2f(panelR, gy);
    }
    for (int i = 0; i <= cfg::VISIBLE; i += 5) {
        float gx = panelL + slot * i;
        glVertex2f(gx, MB_n); glVertex2f(gx, MT_n);
    }
    glEnd();

    // Mid-axis
    float midY = yOf(cfg::YMID, MB_n, MT_n);
    glLineWidth(1.2f); glColor4f(0.45f, 0.55f, 0.75f, 0.85f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(1, 0xF0F0);
    glBegin(GL_LINES);
    glVertex2f(panelL, midY); glVertex2f(panelR, midY);
    glEnd();
    glDisable(GL_LINE_STIPPLE);

    // Y ticks + labels
    glLineWidth(1.0f); glColor4f(0.50f, 0.55f, 0.65f, 0.8f);
    glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float gy = MB_n + CH * ((float)i / cfg::Y_DIVS);
        glVertex2f(panelL, gy); glVertex2f(panelL - 0.012f, gy);
    }
    glEnd();
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float frac = (float)i / cfg::Y_DIVS;
        float val = cfg::YMIN + frac * (cfg::YMAX - cfg::YMIN);
        float gy = MB_n + CH * frac;
        char lb[12]; snprintf(lb, sizeof(lb), "%.1f", val * 1000.0f);
        drawTextPx((panelL - 0.065f) * g_fbW, gy * g_fbH - 7, lb, 0.55f, 0.60f, 0.72f);
    }
    drawTextPx((panelL - 0.065f) * g_fbW, MT_n * g_fbH + 8, "mm", 0.45f, 0.50f, 0.62f);

    // Candles
    for (int si = 0; si < cfg::VISIBLE; ++si) {
        int ci = nTotal - cfg::VISIBLE + si;
        if (ci < 0) continue;
        const Candle& c = snap[ci];
        float xc = panelL + (si + 0.5f) * slot;
        drawCandle(xc, hw,
            yOf(c.open, MB_n, MT_n), yOf(c.close, MB_n, MT_n),
            yOf(c.high, MB_n, MT_n), yOf(c.low, MB_n, MT_n),
            c.bull, (ci == nTotal - 1 && liveOpen) ? 0.55f : 1.0f);
    }

    // Live crosshair
    float cy = yOf(liveMag, MB_n, MT_n);
    cy = std::max(MB_n + 0.001f, std::min(MT_n - 0.001f, cy));
    glLineWidth(1.0f); glColor4f(1.0f, 0.85f, 0.20f, 0.80f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(2, 0xAAAA);
    glBegin(GL_LINES); glVertex2f(panelL, cy); glVertex2f(panelR, cy); glEnd();
    glDisable(GL_LINE_STIPPLE);

    // Frame
    glLineWidth(1.2f); glColor3f(0.40f, 0.44f, 0.54f);
    glBegin(GL_LINE_LOOP);
    glVertex2f(panelL, MB_n); glVertex2f(panelR, MB_n);
    glVertex2f(panelR, MT_n); glVertex2f(panelL, MT_n);
    glEnd();

    // X-axis ticks + timestamps
    glLineWidth(1.0f); glColor3f(0.40f, 0.44f, 0.54f);
    glBegin(GL_LINES);
    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        float gx = panelL + (si + 0.5f) * slot;
        glVertex2f(gx, MB_n); glVertex2f(gx, MB_n - 0.012f);
    }
    glEnd();
    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        int ci = nTotal - cfg::VISIBLE + si;
        float gx = panelL + (si + 0.5f) * slot;
        char lb[16];
        if (ci >= 0 && ci < nTotal) snprintf(lb, sizeof(lb), "%.1fs", snap[ci].t0 / 1000.0);
        else snprintf(lb, sizeof(lb), "---");
        drawTextPx(gx * g_fbW - 14, (MB_n - 0.058f) * g_fbH, lb, 0.50f, 0.55f, 0.65f);
    }

    // Panel title
    drawTextPx((panelL + CW * 0.35f) * g_fbW, (MT_n + 0.010f) * g_fbH,
        title, tr, tg, tb);
}

