namespace cfg
{
    // Window
    constexpr int    WIN_W = 1400;
    constexpr int    WIN_H = 800;

    // Chart
    constexpr int    MAX_CANDLES = 80;       // candles shown at once
    constexpr double CANDLE_MS_DEF = 150.0;    // default ms per candle
    constexpr double CANDLE_MS_MIN = 30.0;
    constexpr double CANDLE_MS_MAX = 2000.0;
    constexpr double YSMOOTH = 0.05;     // Y-range EMA smoothing
    constexpr double YPAD = 0.10;     // 10% padding top/bottom

    // Haptic
    constexpr double HAPTIC_HZ = 1000.0;   // target poll rate
    constexpr double FORCE_K = 0.0;       // spring N/m (0 = no force)
    constexpr double FORCE_MAX = 3.0;       // Falcon max ~3 N

    // Network (UDP broadcast)
    constexpr int    NET_PORT = 9000;
    constexpr int    NET_EVERY = 5;         // send every Nth sample (~200 Hz)

    // Ring buffer  (must be power of 2)
    constexpr int    RING_SZ = 4096;
