}

static inline float yOf(float m, float yb, float yt) {
    return yb + ((m - cfg::YMIN) / (cfg::YMAX - cfg::YMIN)) * (yt - yb);
}

static void drawCandle(float xc, float hw, float oY, float clY,
    float hY, float lY, bool bull, float alpha) {
    if (bull) glColor4f(0.114f, 0.722f, 0.416f, alpha);
    else     glColor4f(0.902f, 0.220f, 0.220f, alpha);
    float top = std::max(oY, clY), bot = std::min(oY, clY);
    float bh = top - bot; if (bh < 0.001f) bh = 0.001f;
    glBegin(GL_QUADS);
    glVertex2f(xc - hw, bot); glVertex2f(xc + hw, bot); glVertex2f(xc + hw, bot + bh); glVertex2f(xc - hw, bot + bh);
    glEnd();
    glLineWidth(1.4f); glBegin(GL_LINES);
    glVertex2f(xc, bot + bh); glVertex2f(xc, hY); glVertex2f(xc, bot); glVertex2f(xc, lY);
    glEnd();
}

static void drawChart(const std::deque<Candle>& snap, bool liveOpen, float liveMag,
    float pL, float pR, float MB, float MT,
    const char* title, float tr, float tg, float tb) {
    float CW = pR - pL, CH = MT - MB;
    float slot = CW / (float)cfg::VISIBLE, hw = slot * 0.34f;
    int nTotal = (int)snap.size();
    fillRect(pL, MB, pR, MT, 0.09f, 0.11f, 0.15f);
    glLineWidth(0.5f); glColor4f(0.25f, 0.29f, 0.38f, 0.6f); glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) { float gy = MB + CH * ((float)i / cfg::Y_DIVS); glVertex2f(pL, gy); glVertex2f(pR, gy); }
    for (int i = 0; i <= cfg::VISIBLE; i += 5) { float gx = pL + slot * i; glVertex2f(gx, MB); glVertex2f(gx, MT); }
    glEnd();
    float midY = yOf((cfg::YMIN + cfg::YMAX) * 0.5f, MB, MT);
    glLineWidth(1.2f); glColor4f(0.45f, 0.55f, 0.75f, 0.85f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(1, 0xF0F0);
    glBegin(GL_LINES); glVertex2f(pL, midY); glVertex2f(pR, midY); glEnd();
    glDisable(GL_LINE_STIPPLE);
    glLineWidth(1.0f); glColor4f(0.50f, 0.55f, 0.65f, 0.8f); glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) { float gy = MB + CH * ((float)i / cfg::Y_DIVS); glVertex2f(pL, gy); glVertex2f(pL - 0.012f, gy); }
    glEnd();
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float frac = (float)i / cfg::Y_DIVS, val = cfg::YMIN + frac * (cfg::YMAX - cfg::YMIN);
        char lb[12]; snprintf(lb, sizeof(lb), "%.1f", val * 1000.0f);
        drawTextPx((pL - 0.065f) * g_fbW, (MB + CH * frac) * g_fbH - 7, lb, 0.55f, 0.60f, 0.72f);
    }
    drawTextPx((pL - 0.065f) * g_fbW, MT * g_fbH + 8, "mm", 0.45f, 0.50f, 0.62f);
    for (int si = 0; si < cfg::VISIBLE; ++si) {
        int ci = nTotal - cfg::VISIBLE + si; if (ci < 0) continue;
        const Candle& c = snap[ci]; float xc = pL + (si + 0.5f) * slot;
        drawCandle(xc, hw, yOf(c.open, MB, MT), yOf(c.close, MB, MT),
            yOf(c.high, MB, MT), yOf(c.low, MB, MT), c.bull,
            (ci == nTotal - 1 && liveOpen) ? 0.55f : 1.0f);
    }
    float cy = yOf(liveMag, MB, MT);
    cy = std::max(MB + 0.001f, std::min(MT - 0.001f, cy));
    glLineWidth(1.0f); glColor4f(1.0f, 0.85f, 0.20f, 0.80f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(2, 0xAAAA);
    glBegin(GL_LINES); glVertex2f(pL, cy); glVertex2f(pR, cy); glEnd();
    glDisable(GL_LINE_STIPPLE);
    glLineWidth(1.2f); glColor3f(0.40f, 0.44f, 0.54f); glBegin(GL_LINE_LOOP);
    glVertex2f(pL, MB); glVertex2f(pR, MB); glVertex2f(pR, MT); glVertex2f(pL, MT); glEnd();
    glLineWidth(1.0f); glColor3f(0.40f, 0.44f, 0.54f); glBegin(GL_LINES);
    for (int si = 0; si < cfg::VISIBLE; si += 5) { float gx = pL + (si + 0.5f) * slot; glVertex2f(gx, MB); glVertex2f(gx, MB - 0.012f); }
    glEnd();
    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        int ci = nTotal - cfg::VISIBLE + si; float gx = pL + (si + 0.5f) * slot; char lb[16];
        if (ci >= 0 && ci < nTotal) snprintf(lb, sizeof(lb), "%.1fs", snap[ci].t0 / 1000.0);
        else snprintf(lb, sizeof(lb), "---");
        drawTextPx(gx * g_fbW - 14, (MB - 0.025f) * g_fbH, lb, 0.50f, 0.55f, 0.65f);
    }
    drawTextPx((pL + CW * 0.30f) * g_fbW, (MT + 0.005f) * g_fbH, title, tr, tg, tb);
}

// ─── Coloured ON/OFF badge ────────────────────────────────────────────────────
static void drawBadge(float px, float py, const char* label, bool on,
    float onR = 0.20f, float onG = 0.85f, float onB = 0.35f) {
    float r = on ? onR : 0.60f, g2 = on ? onG : 0.30f, b = on ? onB : 0.28f;
    drawTextPx(px, py, label, r, g2, b);
}

// ═════════════════════════════════════════════════════════════════════════════
//  STATUS PANEL  (bottom 26 % of window)
//  Rows (bottom→top): IP | DELAY | COORDS | CONTROLS
// ═════════════════════════════════════════════════════════════════════════════
static void drawStatusPanel(App& app) {
    const float PNL = cfg::PNL, PNH = cfg::PNH;
    float panH = PNH - PNL;

    fillRect(0, PNL, 1, PNH, 0.05f, 0.07f, 0.11f, 0.97f);
    glLineWidth(1.0f); glColor3f(0.22f, 0.26f, 0.36f);
    glBegin(GL_LINES); glVertex2f(0, PNH); glVertex2f(1, PNH); glEnd();
    glBegin(GL_LINES); glVertex2f(0.50f, PNL); glVertex2f(0.50f, PNH); glEnd();

    float r1 = (PNL + panH * 0.88f) * g_fbH;   // headers
    float r2 = (PNL + panH * 0.68f) * g_fbH;   // X Y Z
    float r3 = (PNL + panH * 0.50f) * g_fbH;   // mag + stats
    float r4 = (PNL + panH * 0.32f) * g_fbH;   // delay row
    float r5 = (PNL + panH * 0.12f) * g_fbH;   // controls / IP

    char buf[128];
    double nowMs = app.clock.ms();

    // ═══ LEFT panel: REMOTE (server RX) ════════════════════════════════════
    drawTextPx(0.02f * g_fbW, r1, "REMOTE HAPTIC  [SERVER RX]", 0.35f, 0.58f, 0.95f);

    float rx = app.rx_.load(), ry = app.ry_.load(), rz = app.rz_.load(), rm = app.rmag.load();
    double staleMs = nowMs - app.lastRxMs.load();
    double avgGap = app.avgRxGapMs.load();
    float sf = (staleMs > 500.0) ? 0.35f : 1.0f;
    snprintf(buf, sizeof(buf), "X:%+.4f", rx);
    drawTextPx(0.02f * g_fbW, r2, buf, 0.38f * sf, 0.88f * sf, 0.42f * sf);
    snprintf(buf, sizeof(buf), "Y:%+.4f", ry);
    drawTextPx(0.11f * g_fbW, r2, buf, 0.38f * sf, 0.62f * sf, 0.95f * sf);
    snprintf(buf, sizeof(buf), "Z:%+.4f", rz);
    drawTextPx(0.20f * g_fbW, r2, buf, 0.95f * sf, 0.60f * sf, 0.20f * sf);
    snprintf(buf, sizeof(buf), "Mag:%.4fm (%.2fmm)", rm, rm * 1000);
    drawTextPx(0.29f * g_fbW, r2, buf, 1.0f * sf, 0.92f * sf, 0.30f * sf);

    snprintf(buf, sizeof(buf), "Recv:%llu", (unsigned long long)app.pktsRecv.load());
    drawTextPx(0.02f * g_fbW, r3, buf, 0.50f, 0.55f, 0.65f);
    drawTextPx(0.14f * g_fbW, r3, "RX:", 0.55f, 0.60f, 0.70f);
    drawBadge(0.18f * g_fbW, r3, app.rxEnabled ? "ON" : "OFF", app.rxEnabled);
    drawTextPx(0.24f * g_fbW, r3, "FB:", 0.55f, 0.60f, 0.70f);
    drawBadge(0.28f * g_fbW, r3, app.fbEnabled ? "ON" : "OFF", app.fbEnabled, 0.90f, 0.60f, 0.10f);

    // ── Delay row (left) ────────────────────────────────────────────────────
    float lagR, lagG, lagB;
    if (staleMs < 20.0) { lagR = 0.20f; lagG = 0.90f; lagB = 0.35f; }
    else if (staleMs < 100.0) { lagR = 0.95f; lagG = 0.80f; lagB = 0.10f; }
    else { lagR = 0.95f; lagG = 0.25f; lagB = 0.20f; }
    snprintf(buf, sizeof(buf), "Rx lag:%.0fms", staleMs);
    drawTextPx(0.02f * g_fbW, r4, buf, lagR, lagG, lagB);
    snprintf(buf, sizeof(buf), "Avg gap:%.1fms", avgGap);
    drawTextPx(0.14f * g_fbW, r4, buf, 0.55f, 0.62f, 0.78f);
    // Lag bar (0..200ms)
    float lagFrac = (float)std::min(staleMs / 200.0, 1.0);
    fillRect(0.02f, r4 / g_fbH - 0.020f, 0.02f + lagFrac * 0.46f, r4 / g_fbH - 0.013f, lagR, lagG, lagB, 0.75f);
    fillRect(0.02f, r4 / g_fbH - 0.020f, 0.48f, r4 / g_fbH - 0.013f, 0.18f, 0.20f, 0.28f, 0.40f);
    // Link status word
    drawTextPx(0.35f * g_fbW, r4, staleMs < 500.0 ? "LINK UP" : "LINK DOWN",
        staleMs < 500.0 ? 0.15f : 0.95f, staleMs < 500.0 ? 0.85f : 0.25f, staleMs < 500.0 ? 0.30f : 0.20f);

    // ── Controls row (left) ──────────────────────────────────────────────────
    bool axX = app.axisX, axY = app.axisY, axZ = app.axisZ;
    drawTextPx(0.02f * g_fbW, r5, "AXES:", 0.55f, 0.60f, 0.70f);
    drawBadge(0.085f * g_fbW, r5, axX ? "X" : "x", axX, 0.30f, 0.90f, 0.40f);
    drawBadge(0.125f * g_fbW, r5, axY ? "Y" : "y", axY, 0.35f, 0.60f, 0.98f);
    drawBadge(0.165f * g_fbW, r5, axZ ? "Z" : "z", axZ, 0.98f, 0.65f, 0.20f);
    snprintf(buf, sizeof(buf), "Cnd:%.1fms", app.candleMs.load());
    drawTextPx(0.22f * g_fbW, r5, buf, 0.55f, 0.65f, 0.80f);

    // ═══ RIGHT panel: LOCAL (client TX) ════════════════════════════════════
    drawTextPx(0.52f * g_fbW, r1, "LOCAL HAPTIC  [TX -> SERVER]", 0.30f, 0.80f, 0.38f);

    float lx = app.lx.load(), ly_ = app.ly.load(), lz = app.lz.load(), lm = app.lmag.load();
    snprintf(buf, sizeof(buf), "X:%+.4f", lx);
    drawTextPx(0.52f * g_fbW, r2, buf, axX ? 0.38f : 0.22f, axX ? 0.88f : 0.38f, axX ? 0.42f : 0.22f);
    snprintf(buf, sizeof(buf), "Y:%+.4f", ly_);
    drawTextPx(0.61f * g_fbW, r2, buf, axY ? 0.38f : 0.22f, axY ? 0.62f : 0.38f, axY ? 0.95f : 0.22f);
    snprintf(buf, sizeof(buf), "Z:%+.4f", lz);
    drawTextPx(0.70f * g_fbW, r2, buf, axZ ? 0.95f : 0.22f, axZ ? 0.60f : 0.38f, axZ ? 0.20f : 0.22f);
    snprintf(buf, sizeof(buf), "Mag:%.4fm (%.2fmm)", lm, lm * 1000);
    drawTextPx(0.79f * g_fbW, r2, buf, 1.0f, 0.92f, 0.30f);

    snprintf(buf, sizeof(buf), "Sent:%llu", (unsigned long long)app.pktsSent.load());
    drawTextPx(0.52f * g_fbW, r3, buf, 0.50f, 0.55f, 0.65f);
    drawTextPx(0.64f * g_fbW, r3, "TX:", 0.55f, 0.60f, 0.70f);
    drawBadge(0.68f * g_fbW, r3, app.txEnabled ? "ON" : "OFF", app.txEnabled);

    // ── Delay / link row (right): mirrored bar ───────────────────────────────
    snprintf(buf, sizeof(buf), "Link idle:%.0fms", staleMs);
    drawTextPx(0.52f * g_fbW, r4, buf, lagR, lagG, lagB);
    fillRect(0.52f, r4 / g_fbH - 0.020f, 0.52f + lagFrac * 0.46f, r4 / g_fbH - 0.013f, lagR, lagG, lagB, 0.75f);
    fillRect(0.52f, r4 / g_fbH - 0.020f, 0.98f, r4 / g_fbH - 0.013f, 0.18f, 0.20f, 0.28f, 0.40f);

    // ── IP + key legend (right) ─────────────────────────────────────────────
    snprintf(buf, sizeof(buf), "CLIENT:%s  SERVER:%s  PORT:%d",
        app.localIP, cfg::PEER_IP, cfg::NET_PORT);
    drawTextPx(0.52f * g_fbW, r5, buf, 0.38f, 0.42f, 0.52f);

    // Key hint strip at very bottom
    drawTextPx(0.015f * g_fbW, 0.012f * g_fbH,
        "T:TX  R:RX  F:FB  X/Y/Z:axis  +/-:candle  [:min  ]:max  ESC:quit",
        0.32f, 0.36f, 0.48f);

    if (app.demoMode) {
        fillRect(0, 0, 0.004f, 1, 0.95f, 0.65f, 0.10f, 0.80f);
        drawTextPx(0.006f * g_fbW, 0.5f * g_fbH, "DEMO", 0.95f, 0.65f, 0.10f);
    }
}

// ═════════════════════════════════════════════════════════════════════════════
//  GLFW CALLBACKS
// ═════════════════════════════════════════════════════════════════════════════
static App* g_app = nullptr;

static void onKey(GLFWwindow* w, int key, int, int action, int) {
    if (action != GLFW_PRESS || !g_app) return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_T: { bool v = !g_app->txEnabled; g_app->txEnabled.store(v); break; }
    case GLFW_KEY_R: { bool v = !g_app->rxEnabled; g_app->rxEnabled.store(v); break; }
    case GLFW_KEY_F: { bool v = !g_app->fbEnabled; g_app->fbEnabled.store(v); break; }
    case GLFW_KEY_X: {
        bool v = !g_app->axisX; g_app->axisX.store(v);
        printf("[AXIS] X: %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_Y: {
        bool v = !g_app->axisY; g_app->axisY.store(v);
        printf("[AXIS] Y: %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_Z: {
        bool v = !g_app->axisZ; g_app->axisZ.store(v);
        printf("[AXIS] Z: %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_EQUAL:case GLFW_KEY_KP_ADD: {
        double v = std::min(g_app->candleMs.load() * 1.122, cfg::CANDLE_MS_MAX);
        g_app->candleMs.store(v); break;
    }
    case GLFW_KEY_MINUS:case GLFW_KEY_KP_SUBTRACT: {
        double v = std::max(g_app->candleMs.load() / 1.122, cfg::CANDLE_MS_MIN);
        g_app->candleMs.store(v); break;
    }
    case GLFW_KEY_LEFT_BRACKET:  g_app->candleMs.store(cfg::CANDLE_MS_MIN); break;
    case GLFW_KEY_RIGHT_BRACKET: g_app->candleMs.store(cfg::CANDLE_MS_MAX); break;
    default:break;
    }
}
static void onFbSize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_fbW = w; g_fbH = h; }

// ═════════════════════════════════════════════════════════════════════════════
//  MAIN
// ═════════════════════════════════════════════════════════════════════════════
int main() {
    WSADATA wsa{}; WSAStartup(MAKEWORD(2, 2), &wsa);
    App app; g_app = &app; detectLocalIP(app.localIP, sizeof(app.localIP));

    printf("=== HapticCandlestick CLIENT ===\n");
    printf("Local : %s   Peer: %s   Port: %d\n", app.localIP, cfg::PEER_IP, cfg::NET_PORT);
    printf("Keys  : T R F X Y Z +/- [ ] ESC\n\n");
    WSACleanup();

    std::thread tHaptic([&] {hapticThread(app); });
    std::thread tAgg([&] {aggregatorThread(app); });
    std::thread tNet([&] {networkThread(app); });

    if (!glfwInit()) { app.running = false; tHaptic.join(); tAgg.join(); tNet.join(); return 1; }
    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2); glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);
    glfwWindowHint(GLFW_SAMPLES, 4);

    char wtitle[128]; snprintf(wtitle, sizeof(wtitle),
        "CLIENT %s  <-  SERVER %s  |  Port %d",
        app.localIP, cfg::PEER_IP, cfg::NET_PORT);
    GLFWwindow* win = glfwCreateWindow(cfg::WIN_W, cfg::WIN_H, wtitle, nullptr, nullptr);
    if (!win) { glfwTerminate(); app.running = false; tHaptic.join(); tAgg.join(); tNet.join(); return 1; }

    glfwMakeContextCurrent(win); glfwSwapInterval(1);
    glfwSetKeyCallback(win, onKey); glfwSetFramebufferSizeCallback(win, onFbSize);
    glfwGetFramebufferSize(win, &g_fbW, &g_fbH);

    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glEnable(GL_LINE_SMOOTH); glHint(GL_LINE_SMOOTH_HINT, GL_NICEST);
    glEnable(GL_MULTISAMPLE);

    // Client layout: LEFT = remote (server RX), RIGHT = local (client TX)
    const float RCL = 0.07f, RCR = 0.49f;   // left  = remote
    const float LCL = 0.51f, LCR = 0.93f;   // right = local

    while (!glfwWindowShouldClose(win)) {
        glfwGetFramebufferSize(win, &g_fbW, &g_fbH);
        glViewport(0, 0, g_fbW, g_fbH);
        glClearColor(0.05f, 0.07f, 0.10f, 1.f); glClear(GL_COLOR_BUFFER_BIT);
        glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        std::deque<Candle> localSnap, remoteSnap;
        Candle localLive{}, remoteLive{}; bool lLO = false, rLO = false;
        {
            std::lock_guard<std::mutex> lk(app.localMtx);
            localSnap = app.localCandles; localLive = app.localLive; lLO = app.localLiveOpen;
        }
        {
            std::lock_guard<std::mutex> lk(app.remoteMtx);
            remoteSnap = app.remoteCandles; remoteLive = app.remoteLive; rLO = app.remoteLiveOpen;
        }
        if (lLO) localSnap.push_back(localLive);
        if (rLO) remoteSnap.push_back(remoteLive);

        // Centre divider
        glLineWidth(1.5f); glColor3f(0.25f, 0.30f, 0.40f);
        glBegin(GL_LINES); glVertex2f(0.50f, cfg::PNH); glVertex2f(0.50f, 1.0f); glEnd();

        drawChart(remoteSnap, rLO, app.rmag.load(),
            RCL, RCR, cfg::CMB, cfg::CMT,
            "REMOTE  (RX <- SERVER)", 0.40f, 0.65f, 0.98f);
        drawChart(localSnap, lLO, app.lmag.load(),
            LCL, LCR, cfg::CMB, cfg::CMT,
            "LOCAL  (TX -> SERVER)", 0.35f, 0.88f, 0.45f);

        drawStatusPanel(app);

        glfwSwapBuffers(win); glfwPollEvents();
    }

    app.running = false;
    tHaptic.join(); tAgg.join(); tNet.join();
    glfwDestroyWindow(win); glfwTerminate();
    printf("Client shutdown. Sent:%llu  Recv:%llu\n",
        (unsigned long long)app.pktsSent.load(),
        (unsigned long long)app.pktsRecv.load());
    return 0;
}

