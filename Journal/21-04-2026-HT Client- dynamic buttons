// ─── Wire packet (38 bytes) ──────────────────────────────────────────────────
#pragma pack(push,1)
struct HapticPacket { double ts; float x, y, z, mag, fx, fy, fz; uint8_t btn, flags; };
#pragma pack(pop)
static_assert(sizeof(HapticPacket) == 38, "pkt");

struct Sample { double ts; float x, y, z, mag; uint8_t btn; };
struct Candle { double t0, t1; float open, close, high, low; bool bull; };

template<typename T, int N>
struct Ring {
    static_assert((N& (N - 1)) == 0, "pow2");
    alignas(64) std::atomic<int> head{ 0 }; alignas(64) std::atomic<int> tail{ 0 };
    std::array<T, N> buf{};
    bool push(const T& v) {
        int h = head.load(std::memory_order_relaxed), n = (h + 1) & (N - 1);
        if (n == tail.load(std::memory_order_acquire)) return false;
        buf[h] = v; head.store(n, std::memory_order_release); return true;
    }
    bool pop(T& o) {
        int t = tail.load(std::memory_order_relaxed);
        if (t == head.load(std::memory_order_acquire)) return false;
        o = buf[t]; tail.store((t + 1) & (N - 1), std::memory_order_release); return true;
    }
    int size() const {
        int h = head.load(std::memory_order_acquire), t = tail.load(std::memory_order_acquire);
        return (h - t + N) & (N - 1);
    }
};

struct Timer {
    LARGE_INTEGER freq, start;
    Timer() { QueryPerformanceFrequency(&freq); reset(); }
    void reset() { QueryPerformanceCounter(&start); }
    double ms() const {
        LARGE_INTEGER n; QueryPerformanceCounter(&n);
        return double(n.QuadPart - start.QuadPart) * 1000.0 / double(freq.QuadPart);
    }
};

static void detectLocalIP(char* buf, int len) {
    SOCKET s = socket(AF_INET, SOCK_DGRAM, 0);
    if (s == INVALID_SOCKET) { strncpy(buf, "unknown", len); return; }
    sockaddr_in r{}; r.sin_family = AF_INET; r.sin_port = htons(80);
    inet_pton(AF_INET, "8.8.8.8", &r.sin_addr);
    if (connect(s, (sockaddr*)&r, sizeof(r)) == 0) {
        sockaddr_in l{}; int ls = sizeof(l); getsockname(s, (sockaddr*)&l, &ls);
        inet_ntop(AF_INET, &l.sin_addr, buf, len);
    }
    else strncpy(buf, "unknown", len);
    closesocket(s);
}

