struct App
{
    std::atomic<bool>     running{ true };
    Timer                 clock;

    Ring<Sample, cfg::RING_SZ> ring;
    Ring<Sample, 512>          netRing;

    std::mutex            mtx;
    std::deque<Candle>    candles;
    Candle                live{};
    bool                  liveOpen{ false };

    // Instantaneous values – shown in info panel
    std::atomic<float>    hx{ 0 }, hy{ 0 }, hz{ 0 }, hmag{ 0 };
    std::atomic<double>   hts{ 0 };
    std::atomic<uint8_t>  hbtn{ 0 };

    std::atomic<double>   candleMs{ cfg::CANDLE_MS_DEF };

    std::atomic<bool>     netEnabled{ true };
    std::atomic<uint64_t> netPkts{ 0 };

    bool demoMode{ false };
};

// ═════════════════════════════════════════════════════════════════════════════
//  HAPTIC THREAD
// ═════════════════════════════════════════════════════════════════════════════
void hapticThread(App& app)
{
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    timeBeginPeriod(1);

    cHapticDeviceHandler handler;
    cGenericHapticDevicePtr dev;
    handler.getDevice(dev, 0);

    bool hasDevice = (dev != nullptr);
    if (hasDevice) { dev->open(); dev->calibrate(); }
    else { app.demoMode = true; printf("[HAPTIC] Demo mode.\n"); }

    const double periodUs = 1000000.0 / cfg::HAPTIC_HZ;
    cVector3d zeroForce(0, 0, 0);
    double demoPhase = 0.0;

    while (app.running)
    {
        auto t0 = std::chrono::high_resolution_clock::now();
        float x, y, z, mag; uint8_t btn = 0;

        if (hasDevice)
        {
            cVector3d pos;
            dev->getPosition(pos);
            x = (float)pos.x(); y = (float)pos.y(); z = (float)pos.z();
            mag = (float)pos.length();
            bool b[4]{}; for (int i = 0; i < 4; ++i) dev->getUserSwitch(i, b[i]);
            btn = (b[0] ? 1 : 0) | (b[1] ? 2 : 0) | (b[2] ? 4 : 0) | (b[3] ? 8 : 0);
            if (cfg::FORCE_K > 0.0) {
                cVector3d f = pos * (-cfg::FORCE_K);
                double fl = f.length();
                if (fl > cfg::FORCE_MAX && fl > 0.0) f *= (cfg::FORCE_MAX / fl);
                dev->setForce(f);
            }
            else { dev->setForce(zeroForce); }
        }
        else
        {
            demoPhase += (2.0 * M_PI) / cfg::HAPTIC_HZ;
            x = 0.035f * (float)sin(demoPhase);
            y = 0.025f * (float)cos(demoPhase * 1.37);
            z = 0.018f * (float)sin(demoPhase * 0.73 + 1.0) + 0.010f * (float)sin(demoPhase * 4.1);
            mag = sqrtf(x * x + y * y + z * z);
        }

        Sample s{ app.clock.ms(), x,y,z,mag,btn };
        app.ring.push(s);
        app.netRing.push(s);
        app.hx.store(x, std::memory_order_relaxed);
        app.hy.store(y, std::memory_order_relaxed);
        app.hz.store(z, std::memory_order_relaxed);
        app.hmag.store(mag, std::memory_order_relaxed);
        app.hbtn.store(btn, std::memory_order_relaxed);
        app.hts.store(s.ts, std::memory_order_relaxed);

        auto target = t0 + std::chrono::microseconds((long long)periodUs);
        while (std::chrono::high_resolution_clock::now() < target) _mm_pause();
    }
    if (hasDevice) dev->close();
    timeEndPeriod(1);
}

// ═════════════════════════════════════════════════════════════════════════════
//  AGGREGATOR THREAD
// ═════════════════════════════════════════════════════════════════════════════
void aggregatorThread(App& app)
{
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_ABOVE_NORMAL);
    Sample s{};
    double winOpen = 0; float cO = 0, cC = 0, cH = 0, cL = 1e9f; bool started = false;
    double jMean = 1.0, jJit = 0.0, jLast = 0.0;

    while (app.running)
    {
        bool any = false;
        while (app.ring.pop(s))
        {
            any = true; float mag = s.mag;
            if (jLast > 0.0) {
                double iv = s.ts - jLast, dv = fabs(iv - jMean);
                jMean += 0.01 * (iv - jMean); jJit += 0.01 * (dv - jJit);
            }
            jLast = s.ts;
            double dur = app.candleMs.load() * (1.0 + std::min(jJit / 2.0, 2.0));

            if (!started) { winOpen = s.ts; cO = cC = cH = cL = mag; started = true; }
            else {
                cC = mag;
                if (mag > cH) cH = mag;
                if (mag < cL) cL = mag;
                if (s.ts - winOpen >= dur) {
                    Candle c{ winOpen,s.ts,cO,cC,cH,cL,(cC > cO) };
                    {
                        std::lock_guard<std::mutex> lk(app.mtx);
                        app.candles.push_back(c);
                        if ((int)app.candles.size() > cfg::MAX_CANDLES)
                            app.candles.pop_front();
                    }
                    started = false;
                }
            }
            {
                std::lock_guard<std::mutex> lk(app.mtx);
                app.live = { winOpen,s.ts,cO,cC,cH,cL,(cC > cO) };
                app.liveOpen = started;
            }
        }
        if (!any) std::this_thread::sleep_for(std::chrono::microseconds(200));
    }
}

// ═════════════════════════════════════════════════════════════════════════════
//  NETWORK THREAD
// ═════════════════════════════════════════════════════════════════════════════
void networkThread(App& app)
{
    WSADATA wsa{}; if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) return;
    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    if (sock == INVALID_SOCKET) { WSACleanup(); return; }
    BOOL bc = TRUE; setsockopt(sock, SOL_SOCKET, SO_BROADCAST, (char*)&bc, sizeof(bc));
    sockaddr_in dst{}; dst.sin_family = AF_INET;
    dst.sin_port = htons((u_short)cfg::NET_PORT);
    dst.sin_addr.s_addr = INADDR_BROADCAST;
    Sample s{}; int cnt = 0;
    while (app.running) {
        if (app.netRing.pop(s)) {
            if (app.netEnabled && (++cnt % cfg::NET_EVERY == 0)) {
                sendto(sock, (char*)&s, sizeof(s), 0, (sockaddr*)&dst, sizeof(dst));
                app.netPkts.fetch_add(1, std::memory_order_relaxed);
            }
        }
        else std::this_thread::sleep_for(std::chrono::microseconds(500));
    }
    closesocket(sock); WSACleanup();
}

