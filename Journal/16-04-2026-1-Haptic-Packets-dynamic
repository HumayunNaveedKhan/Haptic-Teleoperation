// Chart area margins in normalised [0..1]
// Left margin wide enough for Y labels, bottom for X labels
static const float ML = 0.07f;   // left   (Y-axis labels)
static const float MR = 0.97f;   // right
static const float MB = 0.10f;   // bottom (X-axis timestamps)
static const float MT = 0.82f;   // top    (info panel below this)

static void fillRect(float x0, float y0, float x1, float y1,
    float r, float g2, float b, float a = 1.f)
{
    glColor4f(r, g2, b, a);
    glBegin(GL_QUADS);
    glVertex2f(x0, y0); glVertex2f(x1, y0);
    glVertex2f(x1, y1); glVertex2f(x0, y1);
    glEnd();
}

static void drawCandle(float xc, float hw,
    float oY, float clY, float hY, float lY,
    bool bull, float alpha)
{
    if (bull) glColor4f(0.114f, 0.722f, 0.416f, alpha);
    else     glColor4f(0.902f, 0.220f, 0.220f, alpha);
    float top = std::max(oY, clY), bot = std::min(oY, clY);
    float bh = top - bot; if (bh < 0.0010f) bh = 0.0010f;
    glBegin(GL_QUADS);
    glVertex2f(xc - hw, bot); glVertex2f(xc + hw, bot);
    glVertex2f(xc + hw, bot + bh); glVertex2f(xc - hw, bot + bh);
    glEnd();
    glLineWidth(1.4f);
    glBegin(GL_LINES);
    glVertex2f(xc, bot + bh); glVertex2f(xc, hY);
    glVertex2f(xc, bot);    glVertex2f(xc, lY);
    glEnd();
}

// Convert a magnitude value to chart Y in [0..1] using the FIXED Y range
static inline float yOf(float m)
{
    float t = (m - cfg::YMIN) / (cfg::YMAX - cfg::YMIN);
    return MB + t * (MT - MB);
}

// ═════════════════════════════════════════════════════════════════════════════
//  GLFW CALLBACKS
// ═════════════════════════════════════════════════════════════════════════════
static App* g_app = nullptr;

static void onKey(GLFWwindow* w, int key, int, int action, int)
{
    if (action != GLFW_PRESS || !g_app) return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_EQUAL: case GLFW_KEY_KP_ADD: {
        // Multiply by ~1.122 (half-semitone) → 12 presses = 10×
        double v = std::min(g_app->candleMs.load() * 1.122, cfg::CANDLE_MS_MAX);
        g_app->candleMs.store(v);
        printf("[UI] Candle window: %.1f ms  (%.1f bars/sec)\n",
            v, 1000.0 / v); break;
    }
    case GLFW_KEY_MINUS: case GLFW_KEY_KP_SUBTRACT: {
        double v = std::max(g_app->candleMs.load() / 1.122, cfg::CANDLE_MS_MIN);
        g_app->candleMs.store(v);
        printf("[UI] Candle window: %.1f ms  (%.1f bars/sec)\n",
            v, 1000.0 / v); break;
    }
    case GLFW_KEY_LEFT_BRACKET: {  // [ → minimum window = 1 ms (max rate 1000 Hz)
        g_app->candleMs.store(cfg::CANDLE_MS_MIN);
        printf("[UI] MAX RATE: 1 ms per bar (1000 bars/sec)\n"); break;
    }
    case GLFW_KEY_RIGHT_BRACKET: { // ] → maximum window = 1000 ms (min rate 1 Hz)
        g_app->candleMs.store(cfg::CANDLE_MS_MAX);
        printf("[UI] MIN RATE: 1000 ms per bar (1 bar/sec)\n"); break;
    }
    case GLFW_KEY_N: {
        bool en = !g_app->netEnabled.load(); g_app->netEnabled.store(en);
        printf("[UI] Net: %s\n", en ? "ON" : "OFF"); break;
    }
    default: break;
    }
}
static void onFbSize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_fbW = w; g_fbH = h; }

// ═════════════════════════════════════════════════════════════════════════════
//  MAIN
// ═════════════════════════════════════════════════════════════════════════════
int main()
{
    App app; g_app = &app;
    printf("=== HapticCandlestick ===  50-slot fixed window\n");
    printf("+/-  finer candle window step  (1 ms .. 1000 ms)\n");
    printf("[    set 1 ms window   = 1000 bars/sec (MAX rate)\n");
    printf("]    set 1000 ms window = 1 bar/sec    (MIN rate)\n");
    printf("N    toggle UDP network  |  ESC quit\n");
    printf("Default window: %.0f ms  (%.0f bars/sec)\n\n",
        cfg::CANDLE_MS_DEF, 1000.0 / cfg::CANDLE_MS_DEF);

    std::thread tHaptic([&] { hapticThread(app); });
    std::thread tAgg([&] { aggregatorThread(app); });
    std::thread tNet([&] { networkThread(app); });

    if (!glfwInit()) {
        app.running = false;
        tHaptic.join(); tAgg.join(); tNet.join(); return 1;
    }

    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);
    glfwWindowHint(GLFW_SAMPLES, 4);

    GLFWwindow* win = glfwCreateWindow(cfg::WIN_W, cfg::WIN_H,
        "Haptic Candlestick  |  50 slots  |  Novint Falcon / CHAI3D  |  1ms-1000ms window",
        nullptr, nullptr);
    if (!win) {
        glfwTerminate(); app.running = false;
        tHaptic.join(); tAgg.join(); tNet.join(); return 1;
    }

    glfwMakeContextCurrent(win);
    glfwSwapInterval(1);
    glfwSetKeyCallback(win, onKey);
    glfwSetFramebufferSizeCallback(win, onFbSize);
    glfwGetFramebufferSize(win, &g_fbW, &g_fbH);

    glEnable(GL_BLEND);
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glEnable(GL_LINE_SMOOTH);
    glHint(GL_LINE_SMOOTH_HINT, GL_NICEST);
    glEnable(GL_MULTISAMPLE);


    // ── Render loop ────────────────────────────────────────────────────────
    while (!glfwWindowShouldClose(win))
    {
        glfwGetFramebufferSize(win, &g_fbW, &g_fbH);
        glViewport(0, 0, g_fbW, g_fbH);
        glClearColor(0.07f, 0.09f, 0.13f, 1.f);
        glClear(GL_COLOR_BUFFER_BIT);

        // Normalised ortho
        glMatrixMode(GL_PROJECTION); glLoadIdentity();
        glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        // ── Snapshot ──────────────────────────────────────────────────────
        std::deque<Candle> snap;
        Candle live{}; bool liveOpen = false;
        {
            std::lock_guard<std::mutex> lk(app.mtx);
            snap = app.candles; live = app.live; liveOpen = app.liveOpen;
        }
        // Append live (forming) candle as the rightmost slot
        if (liveOpen) snap.push_back(live);

        int nTotal = (int)snap.size();

        // ── Layout constants ──────────────────────────────────────────────
        const float CW = MR - ML;
        const float CH = MT - MB;
        // Fixed slot width based on VISIBLE count (never changes)
        const float slot = CW / (float)cfg::VISIBLE;
        const float hw = slot * 0.34f;    // candle body half-width

        // ── Chart background ──────────────────────────────────────────────
        fillRect(ML, MB, MR, MT, 0.09f, 0.11f, 0.15f);

        // ── Fixed Y grid lines ────────────────────────────────────────────
        glLineWidth(0.5f);
        glColor4f(0.25f, 0.29f, 0.38f, 0.6f);
        glBegin(GL_LINES);
        for (int i = 0; i <= cfg::Y_DIVS; ++i) {
            float gy = MB + CH * ((float)i / cfg::Y_DIVS);
            glVertex2f(ML, gy); glVertex2f(MR, gy);
        }
        // Vertical grid every 5 slots
        for (int i = 0; i <= cfg::VISIBLE; i += 5) {
            float gx = ML + slot * i;
            glVertex2f(gx, MB); glVertex2f(gx, MT);
        }
        glEnd();

        // ── Static mid-axis line (bright, fixed at YMID) ──────────────────
        float midY = yOf(cfg::YMID);
        glLineWidth(1.2f);
        glColor4f(0.45f, 0.55f, 0.75f, 0.85f);
        glEnable(GL_LINE_STIPPLE);
        glLineStipple(1, 0xF0F0);
        glBegin(GL_LINES);
        glVertex2f(ML, midY); glVertex2f(MR, midY);
        glEnd();
        glDisable(GL_LINE_STIPPLE);

        // ── Y-axis labels (fixed, always the same) ────────────────────────
        // Left tick marks + text labels
        glLineWidth(1.0f);
        glColor4f(0.50f, 0.55f, 0.65f, 0.8f);
        glBegin(GL_LINES);
        for (int i = 0; i <= cfg::Y_DIVS; ++i) {
            float gy = MB + CH * ((float)i / cfg::Y_DIVS);
            glVertex2f(ML, gy); glVertex2f(ML - 0.012f, gy);
        }
        glEnd();

        // Y labels: value in mm (convert metres to mm for readability)
        for (int i = 0; i <= cfg::Y_DIVS; ++i) {
            float frac = (float)i / cfg::Y_DIVS;
            float val = cfg::YMIN + frac * (cfg::YMAX - cfg::YMIN);
            float gy = MB + CH * frac;
            char buf[16]; snprintf(buf, sizeof(buf), "%.1f", val * 1000.0f);  // mm
            // pixel coords: x near left margin, y centred on grid line
            float px = (ML - 0.065f) * g_fbW;
            float py = gy * g_fbH - 7.0f;    // -7 to vertically centre the glyph
            drawTextPx(px, py, buf, 0.65f, 0.70f, 0.80f);
        }
        // "mm" unit label on the Y axis
        drawTextPx((ML - 0.065f) * g_fbW, MT * g_fbH + 8, "mag(mm)", 0.55f, 0.60f, 0.72f);

        // ── Candles – placed in fixed slots, newest on right ──────────────
        // Slot 0 = leftmost, slot VISIBLE-1 = rightmost
        // If we have fewer than VISIBLE candles, fill from the right.
        // i.e. candle[nTotal-1] → slot VISIBLE-1
        //      candle[nTotal-2] → slot VISIBLE-2  etc.
        for (int slot_i = 0; slot_i < cfg::VISIBLE; ++slot_i)
        {
            // Which candle index maps to this slot?
            int candleIdx = nTotal - cfg::VISIBLE + slot_i;
            if (candleIdx < 0) continue;   // slot not yet filled

            const Candle& c = snap[candleIdx];
            float xc = ML + (slot_i + 0.5f) * slot;
            float oY = yOf(c.open);
            float clY = yOf(c.close);
            float hY = yOf(c.high);
            float lY = yOf(c.low);

            bool isLive = (candleIdx == nTotal - 1) && liveOpen;
            drawCandle(xc, hw, oY, clY, hY, lY, c.bull, isLive ? 0.55f : 1.0f);
        }

        // ── Live magnitude crosshair (yellow dashed, moves) ───────────────
        float liveMag = app.hmag.load(std::memory_order_relaxed);
        float cy = yOf(liveMag);
        cy = std::max(MB + 0.001f, std::min(MT - 0.001f, cy));
        glLineWidth(1.0f);
        glColor4f(1.0f, 0.85f, 0.20f, 0.80f);
        glEnable(GL_LINE_STIPPLE); glLineStipple(2, 0xAAAA);
        glBegin(GL_LINES); glVertex2f(ML, cy); glVertex2f(MR, cy); glEnd();
        glDisable(GL_LINE_STIPPLE);

        // ── Axis frame ────────────────────────────────────────────────────
        glLineWidth(1.2f);
        glColor3f(0.40f, 0.44f, 0.54f);
        glBegin(GL_LINE_LOOP);
        glVertex2f(ML, MB); glVertex2f(MR, MB);
        glVertex2f(MR, MT); glVertex2f(ML, MT);
        glEnd();

        // ── X-axis: timestamps below each 5th slot ────────────────────────
        // Ticks every 5 slots
        glLineWidth(1.0f);
        glColor3f(0.40f, 0.44f, 0.54f);
        glBegin(GL_LINES);
        for (int slot_i = 0; slot_i < cfg::VISIBLE; slot_i += 5) {
            float gx = ML + (slot_i + 0.5f) * slot;
            glVertex2f(gx, MB); glVertex2f(gx, MB - 0.012f);
        }
        glEnd();

        // Timestamp text under every 5th slot
        for (int slot_i = 0; slot_i < cfg::VISIBLE; slot_i += 5)
        {
            int candleIdx = nTotal - cfg::VISIBLE + slot_i;
            float gx = ML + (slot_i + 0.5f) * slot;
            char buf[20];
            if (candleIdx >= 0 && candleIdx < nTotal)
            {
                // Show time in seconds since start, 1 decimal place
                double tSec = snap[candleIdx].t0 / 1000.0;
                snprintf(buf, sizeof(buf), "%.1fs", tSec);
            }
            else
            {
                snprintf(buf, sizeof(buf), "---");
            }
            float px = gx * g_fbW - 14.0f;   // centre roughly on the tick
            float py = (MB - 0.058f) * g_fbH;
            drawTextPx(px, py, buf, 0.55f, 0.60f, 0.72f);
        }
        // "time" axis label
        drawTextPx((ML + CW * 0.44f) * g_fbW, (MB - 0.085f) * g_fbH,
            "time (s)", 0.50f, 0.55f, 0.68f);

        // ── INFO PANEL  (below chart, above bottom edge) ───────────────────
        // Panel background
        fillRect(0.0f, 0.83f, 1.0f, 1.0f, 0.08f, 0.10f, 0.15f, 0.95f);
        // Separator line
        glLineWidth(0.8f); glColor3f(0.25f, 0.28f, 0.36f);
        glBegin(GL_LINES);
        glVertex2f(0.0f, 0.83f); glVertex2f(1.0f, 0.83f);
        glEnd();

        float ix = app.hx.load(std::memory_order_relaxed);
        float iy = app.hy.load(std::memory_order_relaxed);
        float iz = app.hz.load(std::memory_order_relaxed);
        float im = app.hmag.load(std::memory_order_relaxed);
        double its = app.hts.load(std::memory_order_relaxed);
        uint8_t ibtn = app.hbtn.load(std::memory_order_relaxed);

        // ── Three info rows ───────────────────────────────────────────────
        //   row1 (top)    : section headers / labels
        //   row2 (middle) : live x y z mag  +  timestamp
        //   row3 (bottom) : packet rate  +  net stats
        float row1y = 0.968f * g_fbH;   // header labels
        float row2y = 0.920f * g_fbH;   // x y z mag timestamp
        float row3y = 0.865f * g_fbH;   // rate  +  network

        char buf[64];

        // ── Row 1: section headers ────────────────────────────────────────
        drawTextPx(0.02f * g_fbW, row1y, "INSTANTANEOUS PACKET",
            0.45f, 0.50f, 0.62f);
        drawTextPx(0.60f * g_fbW, row1y, "PACKET RATE",
            0.45f, 0.50f, 0.62f);
        drawTextPx(0.82f * g_fbW, row1y, "NETWORK",
            0.45f, 0.50f, 0.62f);

        // ── Row 2: live x y z mag + timestamp ────────────────────────────
        // X  (green)
        snprintf(buf, sizeof(buf), "X: %+.4f m", ix);
        drawTextPx(0.02f * g_fbW, row2y, buf, 0.40f, 0.88f, 0.45f);
        // Y  (blue)
        snprintf(buf, sizeof(buf), "Y: %+.4f m", iy);
        drawTextPx(0.16f * g_fbW, row2y, buf, 0.40f, 0.65f, 0.98f);
        // Z  (orange)
        snprintf(buf, sizeof(buf), "Z: %+.4f m", iz);
        drawTextPx(0.30f * g_fbW, row2y, buf, 0.98f, 0.62f, 0.22f);
        // Magnitude  (yellow-white)
        snprintf(buf, sizeof(buf), "Mag: %.4f m  (%.2f mm)", im, im * 1000.0f);
        drawTextPx(0.44f * g_fbW, row2y, buf, 1.0f, 0.92f, 0.35f);
        // Timestamp
        snprintf(buf, sizeof(buf), "T: %.3f s", its / 1000.0);
        drawTextPx(0.72f * g_fbW, row2y, buf, 0.70f, 0.75f, 0.88f);

        // ── Row 3: packet rate + network ─────────────────────────────────
        double curMs = app.candleMs.load(std::memory_order_relaxed);
        double barsHz = 1000.0 / curMs;   // bars per second

        // Logarithmic position on 1–1000 ms scale for the rate bar
        // log10(1)=0, log10(1000)=3  → normalise to [0..1]
        float  logFrac = (float)((log10(curMs) - 0.0) / 3.0);
        logFrac = std::max(0.0f, std::min(1.0f, logFrac));

        // Rate bar background outline
        float bx0 = 0.02f * g_fbW, bx1 = 0.55f * g_fbW;
        float by0 = row3y - 2, by1 = row3y + float(GLYPH_H) + 4;
        glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity();
        glOrtho(0, g_fbW, 0, g_fbH, -1, 1);
        glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();

        // Background track
        glColor4f(0.18f, 0.22f, 0.30f, 1.0f);
        glBegin(GL_QUADS);
        glVertex2f(bx0, by0); glVertex2f(bx1, by0);
        glVertex2f(bx1, by1); glVertex2f(bx0, by1);
        glEnd();

        // Fill: colour shifts cyan (fast/left) → amber (slow/right)
        float barX1 = bx0 + (bx1 - bx0) * logFrac;
        // At logFrac=0 (1ms=1000Hz) → pure cyan; at logFrac=1 (1000ms=1Hz) → amber
        float br = logFrac;
        float bg2 = 0.75f;
        float bb = 1.0f - logFrac;
        glColor4f(br, bg2, bb, 0.85f);
        glBegin(GL_QUADS);
        glVertex2f(bx0, by0); glVertex2f(barX1, by0);
        glVertex2f(barX1, by1); glVertex2f(bx0, by1);
        glEnd();

        // Outline
        glColor4f(0.35f, 0.40f, 0.52f, 0.8f);
        glBegin(GL_LINE_LOOP);
        glVertex2f(bx0, by0); glVertex2f(bx1, by0);
        glVertex2f(bx1, by1); glVertex2f(bx0, by1);
        glEnd();

        // Tick marks at 1, 10, 100, 1000 ms
        glColor4f(0.45f, 0.50f, 0.62f, 0.6f);
        glBegin(GL_LINES);
        for (int ms_tick : {1, 2, 5, 10, 20, 50, 100, 200, 500, 1000}) {
            float fx = (float)((log10((double)ms_tick)) / 3.0);
            float tx = bx0 + (bx1 - bx0) * fx;
            glVertex2f(tx, by0); glVertex2f(tx, by0 - 5);
        }
        glEnd();

        glMatrixMode(GL_PROJECTION); glPopMatrix();
        glMatrixMode(GL_MODELVIEW);  glPopMatrix();
        // restore normalised ortho
        glMatrixMode(GL_PROJECTION); glLoadIdentity();
        glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        // Rate text overlaid on bar
        if (barsHz >= 100.0)
            snprintf(buf, sizeof(buf), "%.0f ms = %.0f bars/s", curMs, barsHz);
        else if (barsHz >= 10.0)
            snprintf(buf, sizeof(buf), "%.1f ms = %.1f bars/s", curMs, barsHz);
        else
            snprintf(buf, sizeof(buf), "%.0f ms = %.2f bars/s", curMs, barsHz);
        // dark text on bar for contrast
        drawTextPx(bx0 + 4, row3y, buf, 0.05f, 0.05f, 0.08f);   // shadow
        drawTextPx(bx0 + 3, row3y + 1, buf, 1.0f, 1.0f, 1.0f);    // white on top

        // Endpoint labels
        drawTextPx(bx0 - 1, row3y - float(GLYPH_H) - 4, "1ms",
            0.30f, 0.85f, 0.95f);
        drawTextPx(bx1 - 22, row3y - float(GLYPH_H) - 4, "1000ms",
            0.95f, 0.75f, 0.25f);

        // Shortcut hint
        drawTextPx(0.57f * g_fbW, row3y, "+/- step  [ max  ] min",
            0.38f, 0.42f, 0.52f);

        // Net packets + button state
        snprintf(buf, sizeof(buf), "Pkts:%llu  Btn:%X",
            (unsigned long long)app.netPkts.load(), ibtn);
        drawTextPx(0.82f * g_fbW, row3y, buf,
            app.netEnabled ? 0.22f : 0.40f,
            app.netEnabled ? 0.88f : 0.45f,
            app.netEnabled ? 0.42f : 0.40f);

        // ── Demo mode stripe ──────────────────────────────────────────────
        if (app.demoMode)
        {
            fillRect(0.0f, 0.0f, 0.005f, 1.0f, 0.95f, 0.65f, 0.10f, 0.8f);
            drawTextPx(0.008f * g_fbW, 0.50f * g_fbH, "DEMO", 0.95f, 0.65f, 0.10f);
        }

        glfwSwapBuffers(win);
        glfwPollEvents();
    }

    app.running = false;
    tHaptic.join(); tAgg.join(); tNet.join();
    glfwDestroyWindow(win); glfwTerminate();
    printf("Shutdown. Packets sent: %llu\n", (unsigned long long)app.netPkts.load());
    return 0;
}

/*
 * UDP receiver (Python, any LAN machine):
 *   import socket, struct
 *   s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
 *   s.bind(('', 9000))
 *   while True:
 *       data, _ = s.recvfrom(64)
 *       ts,x,y,z,mag,btn = struct.unpack('<dffffB', data[:25])
 *       print(f'{ts/1000:8.3f}s  x={x*1000:+7.3f}  y={y*1000:+7.3f}  '
 *             f'z={z*1000:+7.3f}  mag={mag*1000:6.3f}mm')
 */
