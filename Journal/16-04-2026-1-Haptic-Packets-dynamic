// Scale: 2 = 10×14 px glyphs (good at 1400px wide), 1 = 5×7 tiny
static const int FONT_SCALE = 2;
static const int GLYPH_W = 5 * FONT_SCALE;   // pixels per glyph incl. gap
static const int GLYPH_H = 7 * FONT_SCALE;
static const int GLYPH_GAP = 1 * FONT_SCALE;

// Draw string at pixel position (px, py = bottom-left of first glyph).
// Uses pixel-space ortho internally; restores normalised ortho on exit.
static void drawTextPx(float px, float py, const char* str,
    float r = 1.f, float g2 = 1.f, float b = 1.f, float a = 1.f)
{
    if (!str || !str[0]) return;

    // Switch to pixel-space ortho
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity();
    glOrtho(0, g_fbW, 0, g_fbH, -1, 1);
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();

    glColor4f(r, g2, b, a);
    glBegin(GL_QUADS);

    float cx = px;
    for (const char* p = str; *p; ++p)
    {
        int c = (unsigned char)*p;
        if (c < 32 || c > 126) { cx += GLYPH_W + GLYPH_GAP; continue; }
        const uint8_t* col = GLYPHS[c - 32];

        for (int col_i = 0; col_i < 5; ++col_i)
        {
            uint8_t bits = col[col_i];
            for (int row_i = 0; row_i < 7; ++row_i)
            {
                if (bits & (1 << row_i))
                {
                    // col_i  left→right (bit0 = leftmost column of glyph)
                    // row_i  bit0 = top of glyph, but OpenGL Y goes up,
                    //        so invert: row 0 → top = py + (6)*scale
                    float x0 = cx + col_i * FONT_SCALE;
                    float y0 = py + (6 - row_i) * FONT_SCALE;
                    float x1 = x0 + FONT_SCALE;
                    float y1 = y0 + FONT_SCALE;
                    glVertex2f(x0, y0); glVertex2f(x1, y0);
                    glVertex2f(x1, y1); glVertex2f(x0, y1);
                }
            }
        }
        cx += GLYPH_W + GLYPH_GAP;
    }
    glEnd();

    // Restore normalised ortho
    glMatrixMode(GL_PROJECTION); glPopMatrix();
    glMatrixMode(GL_MODELVIEW);  glPopMatrix();
    glMatrixMode(GL_PROJECTION); glLoadIdentity();
    glOrtho(0, 1, 0, 1, -1, 1);
    glMatrixMode(GL_MODELVIEW); glLoadIdentity();
}

