    float rttG = (rtt < 5) ? 0.90f : (rtt < 20) ? 0.85f : 0.25f;
    float rttB = (rtt < 5) ? 0.30f : (rtt < 20) ? 0.10f : 0.15f;
    snprintf(buf, sizeof(buf), "RTT:%.1fms  Avg:%.1fms  Recv:%llu  #RX:%u  Loss:%llu",
        rtt, avgRtt, (unsigned long long)g_recv.load(),
        (unsigned)g_lastRxSeq.load(),
        (unsigned long long)g_pktLoss.load());
    drawText(0.52f * g_W, r4, buf, rttR, rttG, rttB);
    float lf = (float)std::min(rtt / 50.0, 1.0);
    rect(0.52f, r4 / g_H - 0.022f, 0.52f + 0.46f * lf, r4 / g_H - 0.012f, rttR, rttG, rttB, 0.80f);
    rect(0.52f, r4 / g_H - 0.022f, 0.98f, r4 / g_H - 0.012f, 0.15f, 0.18f, 0.24f, 0.40f);
    snprintf(buf, sizeof(buf), "Client:%s  Port:%d  Cnd:%.0fms",
        g_clientIP, cfg::UDP_PORT, g_candleMs.load());
