// ── Normal text (fs=2 default) ────────────────────────────────────────────────
static void drawText(float px, float py, const char* s,
    float r = 1, float g = 1, float b = 1, float a = 1, int fs = 2) {
    if (!s || !s[0])return;
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity(); glOrtho(0, g_W, 0, g_H, -1, 1);
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();
    glColor4f(r, g, b, a); glBegin(GL_QUADS);
    int gw = 5 * fs, ggap = fs;
    float cx = px;
    for (const char* p = s; *p; ++p) {
        int c = (unsigned char)*p; if (c < 32 || c>126) { cx += gw + ggap; continue; }
        const uint8_t* col = GLYPHS[c - 32];
        for (int ci = 0; ci < 5; ++ci) {
            uint8_t bits = col[ci];
            for (int ri = 0; ri < 7; ++ri) {
                if (bits & (1 << ri)) {
                    float x0 = cx + ci * fs, y0 = py + (6 - ri) * fs, x1 = x0 + fs, y1 = y0 + fs;
                    glVertex2f(x0, y0); glVertex2f(x1, y0); glVertex2f(x1, y1); glVertex2f(x0, y1);
                }
            }
        }
        cx += gw + ggap;
    }
    glEnd();
    glMatrixMode(GL_PROJECTION); glPopMatrix();
    glMatrixMode(GL_MODELVIEW); glPopMatrix();
    glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
    glMatrixMode(GL_MODELVIEW); glLoadIdentity();
}

// ── Vertical text (rotated 90° CCW, reads bottom-to-top), fs=1 ───────────────
// px,py = bottom-centre of the first character
static void drawTextVert(float px, float py, const char* s,
    float r = 1, float g2 = 1, float b = 1, float a = 1, int fs = 1) {
    if (!s || !s[0])return;
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity(); glOrtho(0, g_W, 0, g_H, -1, 1);
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();
    glColor4f(r, g2, b, a); glBegin(GL_QUADS);
    int gw = 5 * fs, ggap = fs;
    float cy = py;                         // each char advances upward
    for (const char* p = s; *p; ++p) {
        int c = (unsigned char)*p; if (c < 32 || c>126) { cy += gw + ggap; continue; }
        const uint8_t* col = GLYPHS[c - 32];
        // Normal glyph: col[ci] bit ri → pixel (cx+ci, cy+(6-ri))
        // Rotated 90° CCW: map ci→y-axis(up), ri→x-axis(left)
        //   new_x = px - (6-ri)*fs
        //   new_y = cy + ci*fs
        for (int ci = 0; ci < 5; ++ci) {
            uint8_t bits = col[ci];
            for (int ri = 0; ri < 7; ++ri) {
                if (bits & (1 << ri)) {
                    float x0 = px - (6 - ri) * fs, y0 = cy + ci * fs;
                    float x1 = x0 + fs, y1 = y0 + fs;
                    glVertex2f(x0, y0); glVertex2f(x1, y0); glVertex2f(x1, y1); glVertex2f(x0, y1);
                }
            }
        }
        cy += gw + ggap;
    }
    glEnd();
    glMatrixMode(GL_PROJECTION); glPopMatrix();
    glMatrixMode(GL_MODELVIEW); glPopMatrix();
    glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
    glMatrixMode(GL_MODELVIEW); glLoadIdentity();
}

static void rect(float x0, float y0, float x1, float y1, float r, float g, float b, float a = 1) {
    glColor4f(r, g, b, a); glBegin(GL_QUADS);
    glVertex2f(x0, y0); glVertex2f(x1, y0); glVertex2f(x1, y1); glVertex2f(x0, y1); glEnd();
}
static inline float yOf(float m, float yb, float yt) {
    return yb + ((m - cfg::YMIN) / (cfg::YMAX - cfg::YMIN)) * (yt - yb);
}

// ═════════════════════════════════════════════════════════════════════════════
//  CHART  (with packet labels + timestamp/seq on x-axis)
// ═════════════════════════════════════════════════════════════════════════════
static void drawChart(const std::deque<Candle>& snap, bool liveOpen, float liveMag,
    float pL, float pR, float MB, float MT,
    const char* title, float tr, float tg, float tb) {
    float CW = pR - pL, CH = MT - MB;
    float slot = CW / (float)cfg::VISIBLE, hw = slot * 0.34f;
    int nT = (int)snap.size();

    rect(pL, MB, pR, MT, 0.08f, 0.10f, 0.14f);

    // grid
    glLineWidth(0.5f); glColor4f(0.22f, 0.26f, 0.35f, 0.6f); glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float gy = MB + CH * ((float)i / cfg::Y_DIVS);
        glVertex2f(pL, gy); glVertex2f(pR, gy);
    }
    for (int i = 0; i <= cfg::VISIBLE; i += 5) {
        float gx = pL + slot * i;
        glVertex2f(gx, MB); glVertex2f(gx, MT);
    }
    glEnd();
    // midline
    float midY = yOf((cfg::YMIN + cfg::YMAX) * 0.5f, MB, MT);
    glLineWidth(1.0f); glColor4f(0.40f, 0.50f, 0.70f, 0.7f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(1, 0xF0F0);
    glBegin(GL_LINES); glVertex2f(pL, midY); glVertex2f(pR, midY); glEnd();
    glDisable(GL_LINE_STIPPLE);
    // Y axis ticks + labels
    glLineWidth(1.0f); glColor4f(0.45f, 0.50f, 0.60f, 0.8f); glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float gy = MB + CH * ((float)i / cfg::Y_DIVS);
        glVertex2f(pL, gy); glVertex2f(pL - 0.010f, gy);
    }
    glEnd();
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float frac = (float)i / cfg::Y_DIVS, val = cfg::YMIN + frac * (cfg::YMAX - cfg::YMIN);
        char lb[12]; snprintf(lb, sizeof(lb), "%.0fmm", val * 1000.0f);
        drawText((pL - 0.065f) * g_W, (MB + CH * frac) * g_H - 7, lb, 0.50f, 0.55f, 0.68f, 1, 1);
    }

    // ── Candles ──────────────────────────────────────────────────────────────
    for (int si = 0; si < cfg::VISIBLE; ++si) {
        int ci = nT - cfg::VISIBLE + si; if (ci < 0)continue;
        const Candle& c = snap[ci];
        float xc = pL + (si + 0.5f) * slot;
        float oY = yOf(c.open, MB, MT), clY = yOf(c.close, MB, MT);
        float hY = yOf(c.high, MB, MT), lY = yOf(c.low, MB, MT);
        float alpha = (ci == nT - 1 && liveOpen) ? 0.55f : 1.0f;

        // candle body + wick
        if (c.bull)glColor4f(0.11f, 0.72f, 0.42f, alpha);
        else       glColor4f(0.90f, 0.22f, 0.22f, alpha);
        float top = std::max(oY, clY), bot = std::min(oY, clY);
        float bh = top - bot; if (bh < 0.001f)bh = 0.001f;
        glBegin(GL_QUADS);
        glVertex2f(xc - hw, bot); glVertex2f(xc + hw, bot);
        glVertex2f(xc + hw, bot + bh); glVertex2f(xc - hw, bot + bh); glEnd();
        glLineWidth(1.3f); glBegin(GL_LINES);
        glVertex2f(xc, bot + bh); glVertex2f(xc, hY);
        glVertex2f(xc, bot);   glVertex2f(xc, lY); glEnd();

        // ── VERTICAL PACKET LABEL above the wick ─────────────────────────
        // Show the ending seq number for this candle (last 4 digits, rotated 90°)
        char seqLabel[8];
        snprintf(seqLabel, sizeof(seqLabel), "%04u", c.seqEnd % 10000);
        float labelX = xc * g_W;          // horizontal centre of candle (px)
        float labelY = hY * g_H + 3.0f;     // 3px above the wick top
        // Colour: dim for old candles, brighter for recent
        float age = (float)(nT - 1 - ci);
        float brightness = std::max(0.35f, 1.0f - age * 0.03f);
        drawTextVert(labelX, labelY, seqLabel,
            brightness * 0.7f, brightness * 0.9f, brightness * 0.5f, 0.85f, 1);
    }

    // live price line
    float cy = yOf(liveMag, MB, MT); cy = std::max(MB + 0.001f, std::min(MT - 0.001f, cy));
    glLineWidth(1.0f); glColor4f(1.0f, 0.85f, 0.20f, 0.80f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(2, 0xAAAA);
    glBegin(GL_LINES); glVertex2f(pL, cy); glVertex2f(pR, cy); glEnd();
    glDisable(GL_LINE_STIPPLE);

    // live price value label
    char pvLabel[16]; snprintf(pvLabel, sizeof(pvLabel), "%.1fmm", liveMag * 1000.0f);
    drawText(pR * g_W + 4, cy * g_H - 7, pvLabel, 1.0f, 0.85f, 0.20f, 0.90f, 1);

    // chart border
    glLineWidth(1.0f); glColor3f(0.35f, 0.40f, 0.50f); glBegin(GL_LINE_LOOP);
    glVertex2f(pL, MB); glVertex2f(pR, MB); glVertex2f(pR, MT); glVertex2f(pL, MT); glEnd();

    // ── X-axis: every 5 candles → timestamp (row1) + packet seq (row2) ───
    glLineWidth(0.8f); glColor3f(0.35f, 0.40f, 0.50f); glBegin(GL_LINES);
    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        float gx = pL + (si + 0.5f) * slot;
        glVertex2f(gx, MB); glVertex2f(gx, MB - 0.014f);
    }
    glEnd();

    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        int ci = nT - cfg::VISIBLE + si;
        float gx = pL + (si + 0.5f) * slot;
        float xt = gx * g_W - 16;

        // Row 1: timestamp in ms
        char t1[16];
        if (ci >= 0 && ci < nT) {
            double t_ms = snap[ci].t1;  // end time of this candle
            int h = (int)(t_ms / 3600000);
            int m = (int)(fmod(t_ms, 3600000) / 60000);
            int s2 = (int)(fmod(t_ms, 60000) / 1000);
            int ms = (int)fmod(t_ms, 1000);
            if (h > 0) snprintf(t1, sizeof(t1), "%02d:%02d:%02d.%03d", h, m, s2, ms);
            else     snprintf(t1, sizeof(t1), "%02d:%02d.%03d", m, s2, ms);
        }
        else snprintf(t1, sizeof(t1), "--:--");
        drawText(xt, (MB - 0.022f) * g_H, t1, 0.55f, 0.60f, 0.70f, 1, 1);

        // Row 2: packet seq number
        char t2[16];
        if (ci >= 0 && ci < nT) snprintf(t2, sizeof(t2), "P#%05u", snap[ci].seqEnd);
        else              snprintf(t2, sizeof(t2), "P#-----");
        drawText(xt, (MB - 0.040f) * g_H, t2, 0.35f, 0.75f, 0.50f, 1, 1);
    }

    // chart title
    drawText((pL + CW * 0.28f) * g_W, (MT + 0.006f) * g_H, title, tr, tg, tb);
}

