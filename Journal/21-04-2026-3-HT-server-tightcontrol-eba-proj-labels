//  DELAY PANEL  (drawn between charts and status)
// ═════════════════════════════════════════════════════════════════════════════
static void drawDelayPanel() {
    bool on = g_delayEnabled.load();
    double dc = g_delayConst.load(), dj = g_delayJitter.load();
    int    qdepth = g_delayQDepth.load();
    uint64_t loss = g_pktLoss.load();
    double lastD = g_lastAppliedDelayMs.load();

    // thin strip just below chart area
    float py0 = cfg::CMB - 0.065f, py1 = cfg::CMB - 0.002f;
    rect(0, py0, 1, py1, 0.06f, 0.08f, 0.12f, 0.95f);
    glLineWidth(0.8f); glColor3f(0.20f, 0.25f, 0.35f);
    glBegin(GL_LINES); glVertex2f(0, py1); glVertex2f(1, py1); glEnd();
    glBegin(GL_LINES); glVertex2f(0, py0); glVertex2f(1, py0); glEnd();

    float midY = (py0 + py1) * 0.5f;
    float textY = midY * g_H - 7;
    char buf[128];

    // LEFT: delay mode indicator
    float dr = on ? 0.95f : 0.35f, dg = on ? 0.30f : 0.55f, db = on ? 0.20f : 0.40f;
    drawText(0.01f * g_W, textY, on ? "[DELAY ON ]" : "[DELAY OFF]", dr, dg, db, 1, 2);

    // constant delay bar
    drawText(0.14f * g_W, textY, "CONST:", 0.65f, 0.65f, 0.75f, 1, 2);
    snprintf(buf, sizeof(buf), "%5.0fms", dc);
    drawText(0.22f * g_W, textY, buf, 0.30f, 0.82f, 0.95f, 1, 2);
    // bar (0..500ms)
    float bL = 0.29f, bR = 0.44f, bY0 = py0 + 0.006f, bY1 = py1 - 0.006f;
    rect(bL, bY0, bR, bY1, 0.14f, 0.16f, 0.22f, 0.9f);
    float cf = (float)std::min(dc / cfg::DELAY_MAX_CONST, 1.0);
    rect(bL, bY0, bL + (bR - bL) * cf, bY1, 0.20f, 0.70f, 0.95f, 0.85f);
    snprintf(buf, sizeof(buf), "0          500ms");
    drawText(bL * g_W, (py0 - 0.002f) * g_H, buf, 0.30f, 0.35f, 0.45f, 1, 1);

    // random jitter bar
    drawText(0.45f * g_W, textY, "JITTER:", 0.65f, 0.65f, 0.75f, 1, 2);
    snprintf(buf, sizeof(buf), "0-%4.0fms", dj);
    drawText(0.53f * g_W, textY, buf, 0.95f, 0.72f, 0.20f, 1, 2);
    float jL = 0.61f, jR = 0.72f;
    rect(jL, bY0, jR, bY1, 0.14f, 0.16f, 0.22f, 0.9f);
    float jf = (float)std::min(dj / cfg::DELAY_MAX_JITTER, 1.0);
    rect(jL, bY0, jL + (jR - jL) * jf, bY1, 0.95f, 0.68f, 0.18f, 0.85f);
    snprintf(buf, sizeof(buf), "0     200ms");
    drawText(jL * g_W, (py0 - 0.002f) * g_H, buf, 0.30f, 0.35f, 0.45f, 1, 1);

    // RIGHT: queue + loss stats
    snprintf(buf, sizeof(buf), "Queued:%3d  Lost:%6llu  Last:%.1fms",
        qdepth, (unsigned long long)loss, lastD);
    drawText(0.73f * g_W, textY, buf,
        qdepth > 10 ? 0.95f : 0.50f, qdepth > 10 ? 0.30f : 0.65f, 0.50f, 1, 2);

    // key legend
    drawText(0.01f * g_W, (py0 + 0.001f) * g_H,
        "D:toggle  ,.  const +/-5ms  N M  jitter +/-5ms",
        0.28f, 0.32f, 0.42f, 1, 1);
}

