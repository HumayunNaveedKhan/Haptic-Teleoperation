    // ── RIGHT: Slave ──────────────────────────────────────────────────────
    drawText(0.52f * g_W, r1, "SLAVE  [remote RX]", 0.35f, 0.58f, 0.95f);
    float rx = g_rx, ry = g_ry, rz = g_rz, rm = g_rmag;
