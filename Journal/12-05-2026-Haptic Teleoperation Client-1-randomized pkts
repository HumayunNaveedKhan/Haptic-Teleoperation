static void drawChart(const std::deque<Candle>& snap, bool liveOpen, float liveMag, float pL, float pR, float MB, float MT, const char* title, float tr, float tg, float tb) {
    float CW = pR - pL, CH = MT - MB, slot = CW / (float)cfg::VISIBLE, hw = slot * 0.34f;
    int nT = (int)snap.size();
    rect(pL, MB, pR, MT, 0.08f, 0.10f, 0.14f);
    glLineWidth(0.5f); glColor4f(0.22f, 0.26f, 0.35f, 0.6f); glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) { float gy = MB + CH * ((float)i / cfg::Y_DIVS); glVertex2f(pL, gy); glVertex2f(pR, gy); }
    for (int i = 0; i <= cfg::VISIBLE; i += 5) { float gx = pL + slot * i; glVertex2f(gx, MB); glVertex2f(gx, MT); }
    glEnd();
    float midY = yOf((cfg::YMIN + cfg::YMAX) * 0.5f, MB, MT);
    glLineWidth(1.0f); glColor4f(0.40f, 0.50f, 0.70f, 0.7f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(1, 0xF0F0);
    glBegin(GL_LINES); glVertex2f(pL, midY); glVertex2f(pR, midY); glEnd(); glDisable(GL_LINE_STIPPLE);
    glLineWidth(1.0f); glColor4f(0.45f, 0.50f, 0.60f, 0.8f); glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) { float gy = MB + CH * ((float)i / cfg::Y_DIVS); glVertex2f(pL, gy); glVertex2f(pL - 0.010f, gy); }
    glEnd();
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float frac = (float)i / cfg::Y_DIVS, val = cfg::YMIN + frac * (cfg::YMAX - cfg::YMIN);
        char lb[12]; snprintf(lb, sizeof(lb), "%.0fmm", val * 1000.0f);
        drawText((pL - 0.065f) * g_W, (MB + CH * frac) * g_H - 7, lb, 0.50f, 0.55f, 0.68f, 1, 1);
    }
    for (int si = 0; si < cfg::VISIBLE; ++si) {
        int ci = nT - cfg::VISIBLE + si; if (ci < 0)continue;
        const Candle& c = snap[ci]; float xc = pL + (si + 0.5f) * slot;
        float oY = yOf(c.open, MB, MT), clY = yOf(c.close, MB, MT), hY = yOf(c.high, MB, MT), lY = yOf(c.low, MB, MT);
        float alpha = (ci == nT - 1 && liveOpen) ? 0.55f : 1.0f;
        if (c.bull)glColor4f(0.11f, 0.72f, 0.42f, alpha); else glColor4f(0.90f, 0.22f, 0.22f, alpha);
        float top = (std::max)(oY, clY), bot = (std::min)(oY, clY), bh = top - bot; if (bh < 0.001f)bh = 0.001f;
        glBegin(GL_QUADS); glVertex2f(xc - hw, bot); glVertex2f(xc + hw, bot); glVertex2f(xc + hw, bot + bh); glVertex2f(xc - hw, bot + bh); glEnd();
        glLineWidth(1.3f); glBegin(GL_LINES); glVertex2f(xc, bot + bh); glVertex2f(xc, hY); glVertex2f(xc, bot); glVertex2f(xc, lY); glEnd();
        char seqLabel[8]; snprintf(seqLabel, sizeof(seqLabel), "%04u", c.seqEnd % 10000);
        float age = (float)(nT - 1 - ci), brightness = (std::max)(0.35f, 1.0f - age * 0.03f);
        drawTextVert(xc * g_W, hY * g_H + 3.0f, seqLabel, brightness * 0.7f, brightness * 0.9f, brightness * 0.5f, 0.85f, 1);
    }
    float cy = yOf(liveMag, MB, MT); cy = (std::max)(MB + 0.001f, (std::min)(MT - 0.001f, cy));
    glLineWidth(1.0f); glColor4f(1.0f, 0.85f, 0.20f, 0.80f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(2, 0xAAAA);
    glBegin(GL_LINES); glVertex2f(pL, cy); glVertex2f(pR, cy); glEnd(); glDisable(GL_LINE_STIPPLE);
    char pvLabel[16]; snprintf(pvLabel, sizeof(pvLabel), "%.1fmm", liveMag * 1000.0f);
    drawText(pR * g_W + 4, cy * g_H - 7, pvLabel, 1.0f, 0.85f, 0.20f, 0.90f, 1);
    glLineWidth(1.0f); glColor3f(0.35f, 0.40f, 0.50f); glBegin(GL_LINE_LOOP);
    glVertex2f(pL, MB); glVertex2f(pR, MB); glVertex2f(pR, MT); glVertex2f(pL, MT); glEnd();
    glLineWidth(0.8f); glColor3f(0.35f, 0.40f, 0.50f); glBegin(GL_LINES);
    for (int si = 0; si < cfg::VISIBLE; si += 5) { float gx = pL + (si + 0.5f) * slot; glVertex2f(gx, MB); glVertex2f(gx, MB - 0.014f); }
    glEnd();
    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        int ci = nT - cfg::VISIBLE + si; float gx = pL + (si + 0.5f) * slot; float xt = gx * g_W - 16;
        char t1[16], t2[16];
        if (ci >= 0 && ci < nT) {
            double t_ms = snap[ci].t1; int h = (int)(t_ms / 3600000);
            int m = (int)(fmod(t_ms, 3600000) / 60000); int s2 = (int)(fmod(t_ms, 60000) / 1000); int ms = (int)fmod(t_ms, 1000);
            if (h > 0)snprintf(t1, sizeof(t1), "%02d:%02d:%02d.%03d", h, m, s2, ms);
            else snprintf(t1, sizeof(t1), "%02d:%02d.%03d", m, s2, ms);
            snprintf(t2, sizeof(t2), "P#%05u", snap[ci].seqEnd);
        }
        else { snprintf(t1, sizeof(t1), "--:--"); snprintf(t2, sizeof(t2), "P#-----"); }
        drawText(xt, (MB - 0.022f) * g_H, t1, 0.55f, 0.60f, 0.70f, 1, 1);
        drawText(xt, (MB - 0.040f) * g_H, t2, 0.35f, 0.75f, 0.50f, 1, 1);
    }
    drawText((pL + CW * 0.28f) * g_W, (MT + 0.006f) * g_H, title, tr, tg, tb);
}

static void drawStatusPanel() {
    float pH = cfg::PNH - cfg::PNL;
    rect(0, cfg::PNL, 1, cfg::PNH, 0.05f, 0.07f, 0.11f, 0.97f);
    glLineWidth(0.8f); glColor3f(0.20f, 0.24f, 0.32f);
    glBegin(GL_LINES); glVertex2f(0, cfg::PNH); glVertex2f(1, cfg::PNH); glEnd();
    glBegin(GL_LINES); glVertex2f(0.5f, cfg::PNL); glVertex2f(0.5f, cfg::PNH); glEnd();
    float r1 = (cfg::PNL + pH * 0.87f) * g_H, r2 = (cfg::PNL + pH * 0.67f) * g_H;
    float r3 = (cfg::PNL + pH * 0.48f) * g_H, r4 = (cfg::PNL + pH * 0.28f) * g_H, r5 = (cfg::PNL + pH * 0.10f) * g_H;
    char buf[128];

    drawText(0.02f * g_W, r1, "SLAVE  [local TX]", 0.35f, 0.58f, 0.95f);
    float lx = g_lx, ly_ = g_ly, lz = g_lz, lm = g_lmag;
    snprintf(buf, sizeof(buf), "Pos  X:%+.4f  Y:%+.4f  Z:%+.4f   |%.4fm", lx, ly_, lz, lm);
    drawText(0.02f * g_W, r2, buf, 0.35f, 0.62f, 0.95f);
    float fx = g_fx, fy = g_fy, fz = g_fz, fm = g_fmag;
    snprintf(buf, sizeof(buf), "Force X:%+.2f  Y:%+.2f  Z:%+.2f  N   |%.2fN  Kp=%.0f", fx, fy, fz, fm, tele::Kp);
    drawText(0.02f * g_W, r3, buf, 0.90f, 0.40f, 0.30f);

    snprintf(buf, sizeof(buf), "Send Jitter Queue: %d pkts", g_sendQDepth.load());
    drawText(0.02f * g_W, r4, buf, 0.95f, 0.30f, 0.30f);

    drawText(0.02f * g_W, r5, "1:FF  +/-:candle  ESC:quit  (NETWORK JITTER AUTO ON)", 0.32f, 0.36f, 0.48f, 1, 1);

    drawText(0.52f * g_W, r1, "MASTER  [remote RX]", 0.30f, 0.82f, 0.40f);
    float rx = g_rx, ry = g_ry, rz = g_rz, rm = g_rmag;
    snprintf(buf, sizeof(buf), "Pos  X:%+.4f  Y:%+.4f  Z:%+.4f   |%.4fm", rx, ry, rz, rm);
    drawText(0.52f * g_W, r2, buf, 0.28f, 0.82f, 0.38f);
    float ex = (float)(tele::pos_master[0] - tele::pos_slave[0]);
    float em = sqrtf(ex * ex + tele::pos_master[1] * tele::pos_master[1] + tele::pos_master[2] * tele::pos_master[2]);
    snprintf(buf, sizeof(buf), "Err X:%+.4f   |%.4fm", ex, em);
    drawText(0.52f * g_W, r3, buf, 0.70f, 0.65f, 0.25f);
    snprintf(buf, sizeof(buf), "Recv:%llu  #RX:%u  Loss:%llu",
        (unsigned long long)g_recv.load(), (unsigned)g_lastRxSeq.load(), (unsigned long long)g_pktLoss.load());
    drawText(0.52f * g_W, r4, buf, 0.70f, 0.70f, 0.70f);
    snprintf(buf, sizeof(buf), "Server:%s  Port:%d  Cnd:%.0fms", g_serverIP, cfg::UDP_PORT, g_candleMs.load());
    drawText(0.52f * g_W, r5, buf, 0.35f, 0.55f, 0.40f);
}

static void onKey(GLFWwindow* w, int key, int, int action, int) {
    if (action != GLFW_PRESS)return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_1: tele::useFF = !tele::useFF; break;
    case GLFW_KEY_EQUAL:case GLFW_KEY_KP_ADD: g_candleMs.store((std::min)(g_candleMs.load() * 1.122, cfg::CANDLE_MS_MAX)); break;
    case GLFW_KEY_MINUS:case GLFW_KEY_KP_SUBTRACT: g_candleMs.store((std::max)(g_candleMs.load() / 1.122, cfg::CANDLE_MS_MIN)); break;
    default:break;
    }
}
static void onResize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_W = w; g_H = h; }

int main() {
    std::thread tH(hapticThread), tA(aggregatorThread);
    if (!glfwInit()) { g_running = false; tH.join(); tA.join(); return 1; }
    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);
    glfwWindowHint(GLFW_SAMPLES, 4);
    GLFWwindow* win = glfwCreateWindow(cfg::WIN_W, cfg::WIN_H, "SLAVE: Jitter Send Node", nullptr, nullptr);
    if (!win) { glfwTerminate(); g_running = false; tH.join(); tA.join(); return 1; }
    glfwMakeContextCurrent(win); glfwSwapInterval(1);
    glfwSetKeyCallback(win, onKey); glfwSetFramebufferSizeCallback(win, onResize);
    glfwGetFramebufferSize(win, &g_W, &g_H);
    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glEnable(GL_LINE_SMOOTH); glHint(GL_LINE_SMOOTH_HINT, GL_NICEST);
    glEnable(GL_MULTISAMPLE);

    const float LCL = 0.08f, LCR = 0.49f, RCL = 0.51f, RCR = 0.92f;

    while (!glfwWindowShouldClose(win)) {
        glfwGetFramebufferSize(win, &g_W, &g_H);
        glViewport(0, 0, g_W, g_H);
        glClearColor(0.05f, 0.07f, 0.10f, 1.f); glClear(GL_COLOR_BUFFER_BIT);
        glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        std::deque<Candle> sSnap, mSnap; Candle sLive{}, mLive{}; bool sLO = false, mLO = false;
        { std::lock_guard<std::mutex> lk(g_slaveMtx); sSnap = g_slaveCandles; sLive = g_slaveLive; sLO = g_slaveLO; }
        { std::lock_guard<std::mutex> lk(g_masterMtx); mSnap = g_masterCandles; mLive = g_masterLive; mLO = g_masterLO; }
        if (sLO)sSnap.push_back(sLive);
        if (mLO)mSnap.push_back(mLive);

        glLineWidth(1.5f); glColor3f(0.22f, 0.28f, 0.38f);
        glBegin(GL_LINES); glVertex2f(0.5f, cfg::PNH); glVertex2f(0.5f, 1.0f); glEnd();

        drawChart(sSnap, sLO, g_lmag.load(), LCL, LCR, cfg::CMB, cfg::CMT, "SLAVE position |m|  [seq labels above candles]", 0.35f, 0.58f, 0.95f);
        drawChart(mSnap, mLO, g_rmag.load(), RCL, RCR, cfg::CMB, cfg::CMT, "MASTER position |m|  [seq labels above candles]", 0.28f, 0.82f, 0.38f);

        drawStatusPanel();
        glfwSwapBuffers(win); glfwPollEvents();
    }

    g_running = false; tH.join(); tA.join();
    glfwDestroyWindow(win); glfwTerminate();
    return 0;
}
