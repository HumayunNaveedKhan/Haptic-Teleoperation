struct HRTimer {
    LARGE_INTEGER freq, start;
    HRTimer() { QueryPerformanceFrequency(&freq); reset(); }
    void reset() { QueryPerformanceCounter(&start); }
    double ms()const {
        LARGE_INTEGER n; QueryPerformanceCounter(&n);
        return double(n.QuadPart - start.QuadPart) * 1000.0 / double(freq.QuadPart);
    }
};

// ============================================================
//  HAPTIC THREAD
// ============================================================
void hapticThread() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    timeBeginPeriod(1);

    cHapticDeviceHandler handler; cGenericHapticDevicePtr dev;
    handler.getDevice(dev, 0);
    bool has = (dev != nullptr);
    if (has) { dev->open(); dev->calibrate(); }
    else printf("[SLAVE] Demo mode.\n");

    WSADATA wsa; WSAStartup(MAKEWORD(2, 2), &wsa);
    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);

    SOCKADDR_IN srvAddr{}; srvAddr.sin_family = AF_INET;
    srvAddr.sin_port = htons(cfg::UDP_PORT);
    inet_pton(AF_INET, cfg::SERVER_IP, &srvAddr.sin_addr);
    strncpy(g_serverIP, cfg::SERVER_IP, sizeof(g_serverIP));

    SOCKADDR_IN laddr{}; laddr.sin_family = AF_INET;
    laddr.sin_port = htons(cfg::UDP_PORT); laddr.sin_addr.s_addr = INADDR_ANY;
    bind(sock, (SOCKADDR*)&laddr, sizeof(laddr));
    u_long nb = 1; ioctlsocket(sock, FIONBIO, &nb);

    HRTimer clk; double demoPhase = 0;
    C2S pktOut{}; uint32_t txSeq = 0;
    SOCKADDR_IN from{}; int fl = sizeof(from);

    std::mt19937 rng(std::random_device{}());
    std::uniform_real_distribution<double> dist(cfg::MIN_JITTER_MS, cfg::MAX_JITTER_MS);

    while (g_running) {
        auto t0 = std::chrono::high_resolution_clock::now();
        double nowMs = clk.ms();
        float x, y, z;

        if (has) {
            cVector3d pos; dev->getPosition(pos);
            x = (float)pos.x(); y = (float)pos.y(); z = (float)pos.z();
        }
        else {
            demoPhase += (2.0 * M_PI) / cfg::HAPTIC_HZ;
            x = 0.028f * (float)sin(demoPhase * 1.10f + 0.5f);
            y = 0.020f * (float)cos(demoPhase * 0.90f);
            z = 0.015f * (float)sin(demoPhase * 1.30f + 2.0f);
        }
        tele::pos_slave[0] = x; tele::pos_slave[1] = y; tele::pos_slave[2] = z;

        // -- Receive REAL-TIME from Server --
        S2C rp{};
        if (recvfrom(sock, (char*)&rp, sizeof(rp), 0, (SOCKADDR*)&from, &fl) == sizeof(rp)) {
            tele::pos_master[0] = rp.mx;
            tele::pos_master[1] = rp.my;
            tele::pos_master[2] = rp.mz;
            g_recv.fetch_add(1, std::memory_order_relaxed);
            uint32_t rxs = rp.seq;
            uint32_t expected = g_lastRxSeq.load() + 1;
            if (g_lastRxSeq.load() > 0 && rxs > expected) g_pktLoss.fetch_add(rxs - expected, std::memory_order_relaxed);
            g_lastRxSeq.store(rxs);
            float rm = sqrtf(rp.mx * rp.mx + rp.my * rp.my + rp.mz * rp.mz);
            g_masterRing.push({ nowMs,rm,rxs });
            g_rx.store(rp.mx); g_ry.store(rp.my); g_rz.store(rp.mz); g_rmag.store(rm);
        }

        // -- Slave force logic --
        cVector3d force(0, 0, 0);
        if (tele::useFF) {
            for (int i = 0; i < 3; i++) {
                tele::Fd[i] = tele::Kp * (tele::pos_master[i] - tele::pos_slave[i]);
                double fm = fabs(tele::Fd[i]);
                if (fm > cfg::MAX_FORCE) tele::Fd[i] = (tele::Fd[i] / fm) * cfg::MAX_FORCE;
                force((int)i) = tele::Fd[i];
            }
        }
        if (has) dev->setForce(force);

        // -- Construct Outgoing Pkt --
        pktOut.seq = ++txSeq;
        pktOut.sx = x; pktOut.sy = y; pktOut.sz = z;
        pktOut.sfx = (float)tele::Fd[0];
        pktOut.sfy = (float)tele::Fd[1];
        pktOut.sfz = (float)tele::Fd[2];
        pktOut.ts = nowMs;

        // -- Add Sim Jitter & Queue to Send --
        {
            double random_delay = dist(rng);
            std::lock_guard<std::mutex> lk(g_sendMtx);

            DelayedSend ds;
            ds.sendAt = nowMs + random_delay;
            ds.pkt = pktOut;
            g_sendQ.push_back(ds);
        }

        // -- Drain Jitter Send Queue --
        {
            std::lock_guard<std::mutex> lk(g_sendMtx);
            auto it = g_sendQ.begin();
            while (it != g_sendQ.end()) {
                if (nowMs >= it->sendAt) {
                    sendto(sock, (char*)&it->pkt, sizeof(it->pkt), 0, (SOCKADDR*)&srvAddr, sizeof(srvAddr));
                    g_sent.fetch_add(1, std::memory_order_relaxed);
                    it = g_sendQ.erase(it);
                }
                else {
                    ++it;
                }
            }
            g_sendQDepth.store((int)g_sendQ.size());
        }

        float lm = sqrtf(x * x + y * y + z * z);
        g_slaveRing.push({ nowMs,lm,txSeq });
        g_lx.store(x); g_ly.store(y); g_lz.store(z); g_lmag.store(lm);
        g_fx.store((float)force.x()); g_fy.store((float)force.y());
        g_fz.store((float)force.z()); g_fmag.store((float)force.length());

        auto tgt = t0 + std::chrono::microseconds((long long)(1000000.0 / cfg::HAPTIC_HZ));
        while (std::chrono::high_resolution_clock::now() < tgt) _mm_pause();
    }
    if (has) { dev->setForce(cVector3d(0, 0, 0)); dev->close(); }
    closesocket(sock); WSACleanup(); timeEndPeriod(1);
}

// ============================================================
//  AGGREGATOR 
// ============================================================
static void buildCandles(Ring<Sample, cfg::RING_SZ>& ring, std::mutex& mtx, std::deque<Candle>& candles, Candle& live, bool& liveOpen, double& wO, float& cO, float& cC, float& cH, float& cL, bool& started, uint32_t& seqSt, uint32_t& seqEn, uint32_t& pktCnt) {
    Sample s{};
    while (ring.pop(s)) {
        float m = s.mag;
        if (!started) { wO = s.ts; cO = cC = cH = cL = m; started = true; seqSt = seqEn = s.seq; pktCnt = 1; }
        else {
            cC = m; if (m > cH)cH = m; if (m < cL)cL = m; seqEn = s.seq; ++pktCnt;
            if (s.ts - wO >= g_candleMs.load()) {
                Candle c{ wO,s.ts,cO,cC,cH,cL,(cC > cO),seqSt,seqEn,pktCnt };
                { std::lock_guard<std::mutex>lk(mtx); candles.push_back(c); if ((int)candles.size() > cfg::MAX_CANDLES)candles.pop_front(); }
                started = false; pktCnt = 0;
            }
        }
        { std::lock_guard<std::mutex>lk(mtx); live = { wO,s.ts,cO,cC,cH,cL,(cC > cO),seqSt,seqEn,pktCnt }; liveOpen = started; }
    }
}
void aggregatorThread() {
    double lwO = 0, rwO = 0; float lcO = 0, lcC = 0, lcH = 0, lcL = 1e9f, rcO = 0, rcC = 0, rcH = 0, rcL = 1e9f;
    bool lSt = false, rSt = false;
    uint32_t lSS = 0, lSE = 0, lPC = 0, rSS = 0, rSE = 0, rPC = 0;
    while (g_running) {
        buildCandles(g_slaveRing, g_slaveMtx, g_slaveCandles, g_slaveLive, g_slaveLO, lwO, lcO, lcC, lcH, lcL, lSt, lSS, lSE, lPC);
        buildCandles(g_masterRing, g_masterMtx, g_masterCandles, g_masterLive, g_masterLO, rwO, rcO, rcC, rcH, rcL, rSt, rSS, rSE, rPC);
        std::this_thread::sleep_for(std::chrono::microseconds(200));
    }
}

