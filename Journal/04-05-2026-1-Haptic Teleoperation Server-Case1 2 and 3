// ═════════════════════════════════════════════════════════════════════════════
//  GLFW CALLBACKS
// ═════════════════════════════════════════════════════════════════════════════
static void onKey(GLFWwindow* w, int key, int, int action, int) {
    if (action != GLFW_PRESS)return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_1: startExperiment(ExpMode::NO_DELAY);    break;
    case GLFW_KEY_2: startExperiment(ExpMode::CONST_250);   break;
    case GLFW_KEY_3: startExperiment(ExpMode::RAND_250_500); break;
    case GLFW_KEY_E: eba::enable = !eba::enable; printf("[EBA] %s\n", eba::enable ? "ON" : "OFF"); break;
    case GLFW_KEY_P: eba::projection = !eba::projection; printf("[PROJ] %s\n", eba::projection ? "ON" : "OFF"); break;
    case GLFW_KEY_D: {
        bool v = !g_delayEnabled.load(); g_delayEnabled.store(v);
        printf("[DELAY] %s  const=%.0fms  jitter=%.0fms\n",
            v ? "ON" : "OFF", g_delayConst.load(), g_delayJitter.load());
        break;
    }
    case GLFW_KEY_COMMA: {
        double v = std::max(0.0, g_delayConst.load() - cfg::DELAY_STEP);
        g_delayConst.store(v); printf("[DELAY] const=%.0fms\n", v); break;
    }
    case GLFW_KEY_PERIOD: {
        double v = std::min(cfg::DELAY_MAX_CONST, g_delayConst.load() + cfg::DELAY_STEP);
        g_delayConst.store(v); printf("[DELAY] const=%.0fms\n", v); break;
    }
    case GLFW_KEY_N: {
        double v = std::max(0.0, g_delayJitter.load() - cfg::DELAY_STEP);
        g_delayJitter.store(v); printf("[JITTER] max=%.0fms\n", v); break;
    }
    case GLFW_KEY_M: {
        double v = std::min(cfg::DELAY_MAX_JITTER, g_delayJitter.load() + cfg::DELAY_STEP);
        g_delayJitter.store(v); printf("[JITTER] max=%.0fms\n", v); break;
    }
    case GLFW_KEY_EQUAL:case GLFW_KEY_KP_ADD: {
        double v = std::min(g_candleMs.load() * 1.122, cfg::CANDLE_MS_MAX);
        g_candleMs.store(v); break;
    }
    case GLFW_KEY_MINUS:case GLFW_KEY_KP_SUBTRACT: {
        double v = std::max(g_candleMs.load() / 1.122, cfg::CANDLE_MS_MIN);
        g_candleMs.store(v); break;
    }
    case GLFW_KEY_LEFT_BRACKET:  g_candleMs.store(cfg::CANDLE_MS_MIN); break;
    case GLFW_KEY_RIGHT_BRACKET: g_candleMs.store(cfg::CANDLE_MS_MAX); break;
    default:break;
    }
}
static void onResize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_W = w; g_H = h; }

