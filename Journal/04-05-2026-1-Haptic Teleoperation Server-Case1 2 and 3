enum class ExpMode { NONE = 0, NO_DELAY = 1, CONST_250 = 2, RAND_250_500 = 3 };

// One record per sent packet that we are waiting to match a C2S echo for.
// NOTE: in this system the master SENDS S2C packets and the client echoes
// them back as C2S.  We record the outgoing master position at TX time and
// the slave position when the matching C2S arrives.
struct ExpRecord {
    uint32_t index;        // 1-based experiment packet index
    uint32_t globalSeq;    // global tx seq used to identify the round-trip
    double   txTimeMs;     // when we sent
    float    tx_x, tx_y, tx_z;   // master position at TX
    // filled on arrival:
    double   rxTimeMs;
    float    rx_x, rx_y, rx_z;
    bool     complete;
};

struct ExperimentState {
    std::atomic<ExpMode>   mode{ ExpMode::NONE };
    std::atomic<bool>      running{ false };
    std::atomic<uint32_t>  targetCount{ 0 };      // how many pkts to capture
    std::atomic<uint32_t>  sentCount{ 0 };       // pkts tagged so far
    std::atomic<uint32_t>  doneCount{ 0 };       // completed records

    // per-experiment delay override (ms); NaN = use global settings
    std::atomic<double>    delayConstMs{ 0.0 };
    std::atomic<double>    delayJitterMin{ 0.0 };
    std::atomic<double>    delayJitterMax{ 0.0 };
    std::atomic<bool>      useExpDelay{ false };   // override global delay?

    // records: written from haptic thread, read from render/save thread
    std::mutex             mtx;
    std::vector<ExpRecord> records;     // pre-allocated in startExperiment()

    // lookup: globalSeq → record index (for fast RX matching)
    std::unordered_map<uint32_t, uint32_t> seqToIdx;

    // status string for HUD
    char statusMsg[128] = "No experiment";
} g_exp;

// ─── forward declarations ─────────────────────────────────────────────────────
static void startExperiment(ExpMode m);
static void saveExperiment();

static void startExperiment(ExpMode m) {
    if (g_exp.running.load()) {
        printf("[EXP] Already running – wait for it to finish.\n");
        return;
    }
    std::lock_guard<std::mutex> lk(g_exp.mtx);
    g_exp.records.clear();
    g_exp.seqToIdx.clear();
    g_exp.sentCount.store(0);
    g_exp.doneCount.store(0);

    uint32_t n = 0;
    switch (m) {
    case ExpMode::NO_DELAY:
        n = 1000;
        g_exp.delayConstMs.store(0.0);
        g_exp.delayJitterMin.store(0.0);
        g_exp.delayJitterMax.store(0.0);
        g_exp.useExpDelay.store(true);
        snprintf(g_exp.statusMsg, sizeof(g_exp.statusMsg),
            "EXP1: 1000 pkts @ 1kHz  No delay  –  Running…");
        break;
    case ExpMode::CONST_250:
        n = 100;
        g_exp.delayConstMs.store(250.0);
        g_exp.delayJitterMin.store(0.0);
        g_exp.delayJitterMax.store(0.0);
        g_exp.useExpDelay.store(true);
        snprintf(g_exp.statusMsg, sizeof(g_exp.statusMsg),
            "EXP2: 100 pkts  Const 250 ms delay  –  Running…");
        break;
    case ExpMode::RAND_250_500:
        n = 100;
        g_exp.delayConstMs.store(0.0);
        g_exp.delayJitterMin.store(250.0);
        g_exp.delayJitterMax.store(500.0);
        g_exp.useExpDelay.store(true);
        snprintf(g_exp.statusMsg, sizeof(g_exp.statusMsg),
            "EXP3: 100 pkts  Random delay [250,500]ms  –  Running…");
        break;
    default: return;
    }
    g_exp.targetCount.store(n);
    g_exp.records.reserve(n);
    g_exp.mode.store(m);
    g_exp.running.store(true);
    printf("[EXP] Started: %s\n", g_exp.statusMsg);
}

static void saveExperiment() {
    ExpMode m = g_exp.mode.load();
    const char* fname = "experiment_nodelay.csv";
    if (m == ExpMode::CONST_250)    fname = "experiment_const250.csv";
    else if (m == ExpMode::RAND_250_500) fname = "experiment_rand250_500.csv";

    std::ofstream f(fname);
    if (!f) { printf("[EXP] ERROR: cannot open %s\n", fname); return; }

    f << "index,tx_timestamp_ms,rx_timestamp_ms,delay_ms,"
        "tx_x,tx_y,tx_z,rx_x,rx_y,rx_z\n";

    std::lock_guard<std::mutex> lk(g_exp.mtx);
    int saved = 0;
    for (auto& r : g_exp.records) {
        if (!r.complete) continue;
        double delay = r.rxTimeMs - r.txTimeMs;
        f << r.index << ","
            << r.txTimeMs << ","
            << r.rxTimeMs << ","
            << delay << ","
            << r.tx_x << ","
            << r.tx_y << ","
            << r.tx_z << ","
            << r.rx_x << ","
            << r.rx_y << ","
            << r.rx_z << "\n";
        ++saved;
    }
    f.close();
    printf("[EXP] Saved %d records → %s\n", saved, fname);
    snprintf(g_exp.statusMsg, sizeof(g_exp.statusMsg),
        "EXP%d DONE – %d records saved → %s",
        (int)m, saved, fname);
}

