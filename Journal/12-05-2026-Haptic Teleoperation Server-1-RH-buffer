bool   g_masterLO = false, g_slaveLO = false;
std::atomic<bool>   g_running{ true };
std::atomic<double> g_candleMs{ cfg::CANDLE_MS_DEF };

struct HRTimer {
    LARGE_INTEGER freq, start;
    HRTimer() { QueryPerformanceFrequency(&freq); reset(); }
    void reset() { QueryPerformanceCounter(&start); }
    double ms()const {
        LARGE_INTEGER n; QueryPerformanceCounter(&n);
        return double(n.QuadPart - start.QuadPart) * 1000.0 / double(freq.QuadPart);
    }
};

// ============================================================
//  HAPTIC THREAD
// ============================================================
void hapticThread() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    timeBeginPeriod(1);

    cHapticDeviceHandler handler; cGenericHapticDevicePtr dev;
    handler.getDevice(dev, 0);
    bool has = (dev != nullptr);
    if (has) { dev->open(); dev->calibrate(); }
    else printf("[MASTER] Demo mode\n");

    WSADATA wsa; WSAStartup(MAKEWORD(2, 2), &wsa);
    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    SOCKADDR_IN saddr{}; saddr.sin_family = AF_INET;
    saddr.sin_port = htons(cfg::UDP_PORT); saddr.sin_addr.s_addr = INADDR_ANY;
    bind(sock, (SOCKADDR*)&saddr, sizeof(saddr));
    u_long nb = 1; ioctlsocket(sock, FIONBIO, &nb);

    SOCKADDR_IN caddr{}; int caddrlen = sizeof(caddr);
    HRTimer clk; double demoPhase = 0;
    S2C pktOut{}; uint32_t txSeq = 0;
    double rttAcc = 0; int rttN = 0;

    initCSV(g_mode.load());

    // RH Buffer Tracking
    double base_rx_time = 0;
    uint32_t base_client_seq = 0;
    bool rh_first_packet = true;

    while (g_running) {
        auto t0 = std::chrono::high_resolution_clock::now();
        double nowMs = clk.ms();

        if (g_modeChanged.exchange(false)) {
            initCSV(g_mode.load());
            rh_first_packet = true;
            std::lock_guard<std::mutex> lk(g_rhMtx);
            g_rhQueue.clear();
        }

        // -- 1. Read master device --
        float x, y, z;
        if (has) {
            cVector3d pos; dev->getPosition(pos);
            x = (float)pos.x(); y = (float)pos.y(); z = (float)pos.z();
        }
        else {
            demoPhase += (2.0 * M_PI) / cfg::HAPTIC_HZ;
            x = 0.030f * (float)sin(demoPhase * 1.05f);
            y = 0.022f * (float)cos(demoPhase * 0.87f);
            z = 0.014f * (float)sin(demoPhase * 1.40f);
        }
        eba::pos_m[0] = x; eba::pos_m[1] = y; eba::pos_m[2] = z;

        // -- 2. Drain RH Buffer (if Case 2 is active) --
        if (g_mode.load() == ServerMode::CASE2_RH_BUFFER) {
            std::lock_guard<std::mutex> lk(g_rhMtx);

            std::sort(g_rhQueue.begin(), g_rhQueue.end(), [](const BufferedPkt& a, const BufferedPkt& b) {
                return a.deliverAt < b.deliverAt;
                });

            while (!g_rhQueue.empty() && nowMs >= g_rhQueue.front().deliverAt) {
                BufferedPkt bp = g_rhQueue.front();
                g_rhQueue.pop_front();

                eba::pos_s[0] = bp.pkt.sx; eba::pos_s[1] = bp.pkt.sy; eba::pos_s[2] = bp.pkt.sz;
                eba::Fd[0] = -bp.pkt.sfx;  eba::Fd[1] = -bp.pkt.sfy;  eba::Fd[2] = -bp.pkt.sfz;

                float sm = sqrtf(bp.pkt.sx * bp.pkt.sx + bp.pkt.sy * bp.pkt.sy + bp.pkt.sz * bp.pkt.sz);
                g_slaveRing.push({ nowMs, sm, bp.pkt.seq });
                g_rx.store(bp.pkt.sx); g_ry.store(bp.pkt.sy); g_rz.store(bp.pkt.sz); g_rmag.store(sm);

                if (g_csvFile) {
                    std::lock_guard<std::mutex> clk(g_csvMtx);
                    fprintf(g_csvFile, "2,%u,%.3f,%.3f,%.3f,%.5f,%.5f,%.5f\n",
                        bp.pkt.seq, bp.pkt.ts, (bp.deliverAt - cfg::RH_BUFFER_ESTIMATE_MS), nowMs, x, bp.pkt.sx, eba::Fd[0]);
                }
            }
            g_delayQDepth.store((int)g_rhQueue.size());
        }

        // -- 3. Receive C2S --
        C2S rp{};
        int r = (int)recvfrom(sock, (char*)&rp, sizeof(rp), 0, (SOCKADDR*)&caddr, &caddrlen);
        if (r == (int)sizeof(rp)) {
            inet_ntop(AF_INET, &caddr.sin_addr, g_clientIP, sizeof(g_clientIP));
            g_recv.fetch_add(1, std::memory_order_relaxed);

            if (g_mode.load() == ServerMode::CASE1_REALTIME) {
                // Apply Immediately
                eba::pos_s[0] = rp.sx; eba::pos_s[1] = rp.sy; eba::pos_s[2] = rp.sz;
                eba::Fd[0] = -rp.sfx;  eba::Fd[1] = -rp.sfy;  eba::Fd[2] = -rp.sfz;

                float sm = sqrtf(rp.sx * rp.sx + rp.sy * rp.sy + rp.sz * rp.sz);
                g_slaveRing.push({ nowMs, sm, rp.seq });
                g_rx.store(rp.sx); g_ry.store(rp.sy); g_rz.store(rp.sz); g_rmag.store(sm);

                if (g_csvFile) {
                    std::lock_guard<std::mutex> clk(g_csvMtx);
                    fprintf(g_csvFile, "1,%u,%.3f,%.3f,%.3f,%.5f,%.5f,%.5f\n",
                        rp.seq, rp.ts, nowMs, nowMs, x, rp.sx, eba::Fd[0]);
                }
            }
            else {
                // Case 2: Buffer and uniformize
                if (rh_first_packet) {
                    base_rx_time = nowMs;
                    base_client_seq = rp.seq;
                    rh_first_packet = false;
                }
                double playout = base_rx_time + cfg::RH_BUFFER_ESTIMATE_MS + ((rp.seq - base_client_seq) * 1.0);
                std::lock_guard<std::mutex> lk(g_rhMtx);

                BufferedPkt bp;
                bp.deliverAt = playout;
                bp.pkt = rp;
                g_rhQueue.push_back(bp);
            }

            // Stats
            double rtt = nowMs - rp.ts; rttAcc += rtt; rttN++;
            g_rtt.store(rtt);
            if (rttN >= 100) { g_avgRtt.store(rttAcc / rttN); rttAcc = 0; rttN = 0; }
            uint32_t expected = g_lastRxSeq.load() + 1;
            if (g_lastRxSeq.load() > 0 && rp.seq > expected) g_pktLoss.fetch_add(rp.seq - expected);
            g_lastRxSeq.store(rp.seq);
        }

        // -- 4. EBA --
        cVector3d force(0, 0, 0);
        if (g_useFF && has) {
            double FM2 = 0;
            for (int i = 0; i < 3; i++) {
                eba::XdP[i] = eba::Xd[i]; eba::Xd[i] = eba::pos_m[i];
                eba::DXd[i] = eba::Xd[i] - eba::XdP[i];
            }
            if (eba::enable) {
                for (int i = 0; i < 3; i++) {
                    if (eba::DXd[i] != 0.0) {
                        eba::uBETA[i] = eba::BETA[i] = (eba::Fd[i] - eba::dFe[i]) / eba::DXd[i];
                        double td = eba::dFe[i] / eba::DXd[i];
                        double sq = sqrt(td * td + eba::c2 * eba::c2);
                        eba::Bmax[i] = (std::min)(eba::c2 - td + sq, eba::c1);
                        eba::Bmin[i] = eba::c2 - td - sq;
                        eba::BETA[i] = (std::max)(eba::Bmin[i], (std::min)(eba::Bmax[i], eba::BETA[i]));
                    }
                    eba::dFe[i] += eba::BETA[i] * eba::DXd[i];
                    FM2 += eba::Fd[i] * eba::Fd[i];
                }
                eba::FOR_Mag = sqrt(FM2); eba::InnerProduct = 0;
                for (int i = 0; i < 3; i++) {
                    eba::UnitV[i] = (eba::FOR_Mag > 1e-9) ? eba::Fd[i] / eba::FOR_Mag : 0.0;
                    eba::InnerProduct += eba::dFe[i] * eba::UnitV[i];
                }
                for (int i = 0; i < 3; i++) {
                    eba::ProjFOR[i] = eba::InnerProduct * eba::UnitV[i];
                    force((int)i) = eba::projection ? -eba::ProjFOR[i] : -eba::dFe[i];
                }
            }
            else {
                for (int i = 0; i < 3; i++) force((int)i) = eba::Fd[i];
            }
        }
        if (has) dev->setForce(force);

        // -- 5. Send S2C --
        if (caddr.sin_addr.s_addr != 0) {
            pktOut.seq = ++txSeq;
            pktOut.mx = x; pktOut.my = y; pktOut.mz = z; pktOut.ts = nowMs;
            sendto(sock, (char*)&pktOut, sizeof(pktOut), 0, (SOCKADDR*)&caddr, sizeof(caddr));
            g_sent.fetch_add(1, std::memory_order_relaxed);
        }

        float lm = sqrtf(x * x + y * y + z * z);
        g_masterRing.push({ nowMs,lm,txSeq });
        g_lx.store(x); g_ly.store(y); g_lz.store(z); g_lmag.store(lm);
        g_fx.store((float)force.x()); g_fy.store((float)force.y());
        g_fz.store((float)force.z()); g_fmag.store((float)force.length());

        auto tgt = t0 + std::chrono::microseconds((long long)(1000000.0 / cfg::HAPTIC_HZ));
        while (std::chrono::high_resolution_clock::now() < tgt) _mm_pause();
    }
    if (has) { dev->setForce(cVector3d(0, 0, 0)); dev->close(); }
    if (g_csvFile) fclose(g_csvFile);
    closesocket(sock); WSACleanup(); timeEndPeriod(1);
}

// ============================================================
//  AGGREGATOR 
// ============================================================
static void buildCandles(Ring<Sample, cfg::RING_SZ>& ring, std::mutex& mtx, std::deque<Candle>& candles, Candle& live, bool& liveOpen, double& wO, float& cO, float& cC, float& cH, float& cL, bool& started, uint32_t& seqSt, uint32_t& seqEn, uint32_t& pktCnt) {
    Sample s{};
    while (ring.pop(s)) {
        float m = s.mag;
        if (!started) { wO = s.ts; cO = cC = cH = cL = m; started = true; seqSt = seqEn = s.seq; pktCnt = 1; }
        else {
            cC = m; if (m > cH)cH = m; if (m < cL)cL = m; seqEn = s.seq; ++pktCnt;
            if (s.ts - wO >= g_candleMs.load()) {
                Candle c{ wO,s.ts,cO,cC,cH,cL,(cC > cO),seqSt,seqEn,pktCnt };
                { std::lock_guard<std::mutex>lk(mtx); candles.push_back(c); if ((int)candles.size() > cfg::MAX_CANDLES)candles.pop_front(); }
                started = false; pktCnt = 0;
            }
        }
        { std::lock_guard<std::mutex>lk(mtx); live = { wO,s.ts,cO,cC,cH,cL,(cC > cO),seqSt,seqEn,pktCnt }; liveOpen = started; }
    }
}
void aggregatorThread() {
    double lwO = 0, rwO = 0; float lcO = 0, lcC = 0, lcH = 0, lcL = 1e9f, rcO = 0, rcC = 0, rcH = 0, rcL = 1e9f;
    bool lSt = false, rSt = false;
    uint32_t lSS = 0, lSE = 0, lPC = 0, rSS = 0, rSE = 0, rPC = 0;
    while (g_running) {
        buildCandles(g_masterRing, g_masterMtx, g_masterCandles, g_masterLive, g_masterLO, lwO, lcO, lcC, lcH, lcL, lSt, lSS, lSE, lPC);
        buildCandles(g_slaveRing, g_slaveMtx, g_slaveCandles, g_slaveLive, g_slaveLO, rwO, rcO, rcC, rcH, rcL, rSt, rSS, rSE, rPC);
        std::this_thread::sleep_for(std::chrono::microseconds(200));
    }
}

