// =============================================================================
//  GLFW CALLBACKS
// =============================================================================
static void onKey(GLFWwindow* w, int key, int, int action, int) {
    if (action != GLFW_PRESS)return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_1: g_useFF = !g_useFF; break;
    case GLFW_KEY_E: eba::enable = !eba::enable; printf("[EBA] %s\n", eba::enable ? "ON" : "OFF"); break;
    case GLFW_KEY_P: eba::projection = !eba::projection; break;
    case GLFW_KEY_S: { bool v = !g_smithOn.load(); g_smithOn.store(v); printf("[SMITH] %s\n", v ? "ON" : "OFF"); break; }
    case GLFW_KEY_B: { bool v = !g_ajbOn.load(); g_ajbOn.store(v); printf("[AJB] %s\n", v ? "ON" : "OFF"); break; }
    case GLFW_KEY_D: {
        bool v = !g_artDelayEnabled.load(); g_artDelayEnabled.store(v); g_artDelayOn.store(v);
        printf("[ART.DELAY] %s\n", v ? "ON" : "OFF"); break;
    }
    case GLFW_KEY_COMMA: { double v = std::max(0.0, g_artDelayConst.load() - cfg::DELAY_STEP); g_artDelayConst.store(v); break; }
    case GLFW_KEY_PERIOD: { double v = std::min(cfg::DELAY_MAX_CONST, g_artDelayConst.load() + cfg::DELAY_STEP); g_artDelayConst.store(v); break; }
    case GLFW_KEY_N: { double v = std::max(0.0, g_artDelayJitter.load() - cfg::DELAY_STEP); g_artDelayJitter.store(v); break; }
    case GLFW_KEY_M: { double v = std::min(cfg::DELAY_MAX_JITTER, g_artDelayJitter.load() + cfg::DELAY_STEP); g_artDelayJitter.store(v); break; }
    case GLFW_KEY_EQUAL:case GLFW_KEY_KP_ADD: { double v = std::min(g_candleMs.load() * 1.122, cfg::CANDLE_MS_MAX); g_candleMs.store(v); break; }
    case GLFW_KEY_MINUS:case GLFW_KEY_KP_SUBTRACT: { double v = std::max(g_candleMs.load() / 1.122, cfg::CANDLE_MS_MIN); g_candleMs.store(v); break; }
    case GLFW_KEY_LEFT_BRACKET:  g_candleMs.store(cfg::CANDLE_MS_MIN); break;
    case GLFW_KEY_RIGHT_BRACKET: g_candleMs.store(cfg::CANDLE_MS_MAX); break;
    default:break;
    }
}
static void onResize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_W = w; g_H = h; }

// =============================================================================
//  MAIN
// =============================================================================
int main() {
    printf("+===============================================================+\n");
    printf("|  Haptic Teleoperation  SLAVE  v5  (Smith + Adaptive Buffer)   |\n");
    printf("+===============================================================+\n");
    printf("|  S  toggle Smith Predictor (AR-2 + RLS, horizon = RTT/2)     |\n");
    printf("|  B  toggle Adaptive Jitter Buffer (RFC 3550 + adaptive)      |\n");
    printf("|  D  toggle artificial delay (for validation testing)         |\n");
    printf("|  , / .  const delay +/-5ms   N / M  jitter +/-5ms               |\n");
    printf("|  E=EBA  P=Proj  1=FF  +/-=candle  [  ]=preset  ESC=quit     |\n");
    printf("+===============================================================+\n\n");

    std::thread tH(hapticThread), tA(aggregatorThread);
    if (!glfwInit()) { g_running = false; tH.join(); tA.join(); return 1; }
    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);
    glfwWindowHint(GLFW_SAMPLES, 4);
    GLFWwindow* win = glfwCreateWindow(cfg::WIN_W, cfg::WIN_H,
        "SLAVE v5 - Smith Predictor + Adaptive Jitter Buffer", nullptr, nullptr);
    if (!win) { glfwTerminate(); g_running = false; tH.join(); tA.join(); return 1; }
    glfwMakeContextCurrent(win); glfwSwapInterval(1);
    glfwSetKeyCallback(win, onKey); glfwSetFramebufferSizeCallback(win, onResize);
    glfwGetFramebufferSize(win, &g_W, &g_H);
    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glEnable(GL_LINE_SMOOTH); glHint(GL_LINE_SMOOTH_HINT, GL_NICEST);
    glEnable(GL_MULTISAMPLE);

    const float LCL = 0.08f, LCR = 0.49f, RCL = 0.51f, RCR = 0.92f;

    while (!glfwWindowShouldClose(win)) {
        glfwGetFramebufferSize(win, &g_W, &g_H);
        glViewport(0, 0, g_W, g_H);
        glClearColor(0.05f, 0.07f, 0.10f, 1.f); glClear(GL_COLOR_BUFFER_BIT);
        glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        std::deque<Candle> mSnap, sSnap; Candle mLive{}, sLive{}; bool mLO = false, sLO = false;
        { std::lock_guard<std::mutex> lk(g_masterMtx); mSnap = g_masterCandles; mLive = g_masterLive; mLO = g_masterLO; }
        { std::lock_guard<std::mutex> lk(g_slaveMtx); sSnap = g_slaveCandles; sLive = g_slaveLive; sLO = g_slaveLO; }
        if (mLO)mSnap.push_back(mLive); if (sLO)sSnap.push_back(sLive);

        glLineWidth(1.5f); glColor3f(0.22f, 0.28f, 0.38f);
        glBegin(GL_LINES); glVertex2f(0.5f, cfg::PNH); glVertex2f(0.5f, 1.0f); glEnd();

        drawChart(mSnap, mLO, g_lmag.load(), LCL, LCR, cfg::CMB, cfg::CMT,
            "SLAVE position |m|  [local]", 0.28f, 0.82f, 0.38f);
        drawChart(sSnap, sLO, g_rmag.load(), RCL, RCR, cfg::CMB, cfg::CMT,
            "MASTER position |m|  (after jitter buffer + predictor)", 0.35f, 0.58f, 0.95f);

        drawPredictorPanel();
        drawArtDelayPanel();
        drawStatusPanel();

        glfwSwapBuffers(win); glfwPollEvents();
    }
    g_running = false; tH.join(); tA.join();
    glfwDestroyWindow(win); glfwTerminate();
    printf("Shutdown.  Sent:%llu  Recv:%llu  Loss:%llu\n",
        (unsigned long long)g_sent.load(),
        (unsigned long long)g_recv.load(),
        (unsigned long long)g_pktLoss.load());
    return 0;
}
