static void drawArtDelayPanel() {
    bool on = g_artDelayEnabled.load();
    double dc = g_artDelayConst.load(), dj = g_artDelayJitter.load();
    int    qdepth = g_artDelayQDepth.load();
    double lastD = g_lastArtDelayMs.load();
    uint64_t loss = g_pktLoss.load();

    // narrow strip just below predictor panel
    float py1 = cfg::CMB - 0.002f - 0.092f, py0 = py1 - 0.052f;
    rect(0, py0, 1, py1, 0.08f, 0.07f, 0.12f, 0.96f);
    glLineWidth(0.7f); glColor3f(0.22f, 0.20f, 0.30f);
    glBegin(GL_LINES); glVertex2f(0, py1); glVertex2f(1, py1); glEnd();

    float textY = (py0 + (py1 - py0) * 0.60f) * g_H;
    char buf[160];

    float dr = on ? 0.95f : 0.35f, dg = on ? 0.30f : 0.55f, db = on ? 0.20f : 0.40f;
    drawText(0.01f * g_W, textY, on ? "[ART.DELAY ON ]" : "[ART.DELAY OFF]", dr, dg, db, 1, 2);

    drawText(0.14f * g_W, textY, "CONST:", 0.60f, 0.60f, 0.72f, 1, 2);
    snprintf(buf, sizeof(buf), "%5.0fms", dc);
    drawText(0.22f * g_W, textY, buf, 0.30f, 0.82f, 0.95f, 1, 2);

    float bL = 0.30f, bR = 0.48f, bY0p = py0 + 0.006f, bY1p = py1 - 0.006f;
    rect(bL, bY0p, bR, bY1p, 0.14f, 0.16f, 0.22f, 0.9f);
    rect(bL, bY0p, bL + (bR - bL) * (float)std::min(dc / 500.0, 1.0), bY1p, 0.20f, 0.70f, 0.95f, 0.85f);

    drawText(0.49f * g_W, textY, "JITTER:", 0.60f, 0.60f, 0.72f, 1, 2);
    snprintf(buf, sizeof(buf), "0-%4.0fms", dj);
    drawText(0.57f * g_W, textY, buf, 0.95f, 0.72f, 0.20f, 1, 2);
    float jL = 0.66f, jR = 0.78f;
    rect(jL, bY0p, jR, bY1p, 0.14f, 0.16f, 0.22f, 0.9f);
    rect(jL, bY0p, jL + (jR - jL) * (float)std::min(dj / 200.0, 1.0), bY1p, 0.95f, 0.68f, 0.18f, 0.85f);

    snprintf(buf, sizeof(buf), "Q:%3d  Loss:%6llu  Last:%.1fms", qdepth, (unsigned long long)loss, lastD);
    drawText(0.79f * g_W, textY, buf, qdepth > 10 ? 0.95f : 0.50f, qdepth > 10 ? 0.30f : 0.65f, 0.50f, 1, 2);
}

