    // -- LEFT: Smith Predictor ---------------------------------------------
    float sR = spOn ? 0.20f : 0.45f, sG = spOn ? 0.95f : 0.35f, sB = spOn ? 0.45f : 0.30f;
    drawText(0.01f * g_W, rowT, spOn ? "SMITH PREDICTOR  [ON ]" : "SMITH PREDICTOR  [OFF]", sR, sG, sB, 1, 2);

    if (spOn) {
        float px = g_predx.load(), py = g_predy.load(), pz = g_predz.load();
