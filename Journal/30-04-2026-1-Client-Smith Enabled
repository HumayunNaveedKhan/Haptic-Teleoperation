    // vertical centre divider
    glBegin(GL_LINES); glVertex2f(0.5f, py0); glVertex2f(0.5f, py1); glEnd();

    float pH = py1 - py0;
    float rowT = (py0 + pH * 0.82f) * g_H, rowM = (py0 + pH * 0.50f) * g_H, rowB = (py0 + pH * 0.16f) * g_H;
