struct HRTimer {
    LARGE_INTEGER freq, start;
    HRTimer() { QueryPerformanceFrequency(&freq); reset(); }
    void reset() { QueryPerformanceCounter(&start); }
    double ms()const {
        LARGE_INTEGER n; QueryPerformanceCounter(&n);
        return double(n.QuadPart - start.QuadPart) * 1000.0 / double(freq.QuadPart);
    }
};

// =============================================================================
//  HAPTIC THREAD
// =============================================================================
void hapticThread() {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    timeBeginPeriod(1);

    cHapticDeviceHandler handler; cGenericHapticDevicePtr dev;
    handler.getDevice(dev, 0);
    bool has = (dev != nullptr);
    if (has) { dev->open(); dev->calibrate(); }
    else printf("[MASTER] Demo mode.\n");

    WSADATA wsa; WSAStartup(MAKEWORD(2, 2), &wsa);
    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    SOCKADDR_IN laddr{}; laddr.sin_family = AF_INET;
    laddr.sin_port = htons(cfg::UDP_PORT); laddr.sin_addr.s_addr = INADDR_ANY;
    bind(sock, (SOCKADDR*)&laddr, sizeof(laddr));
    u_long nb = 1; ioctlsocket(sock, FIONBIO, &nb);

    SOCKADDR_IN srvAddr{}; srvAddr.sin_family = AF_INET;
    srvAddr.sin_port = htons(cfg::UDP_PORT);
    inet_pton(AF_INET, cfg::SERVER_IP, &srvAddr.sin_addr);
    SOCKADDR_IN caddr{}; int caddrLen = sizeof(caddr);
    HRTimer clk; double demoPhase = 0;
    uint32_t txSeq = 0;
    double rttAcc = 0; int rttN = 0;

    SmithPredictor3DOF sp;
    AdaptiveJitterBuffer ajb;

    static std::mt19937 artRng(std::random_device{}());

    while (g_running) {
        auto t0 = std::chrono::high_resolution_clock::now();
        double nowMs = clk.ms();
        float x, y, z;

        // -- 1. Read local master device -----------------------------------
        if (has) {
            cVector3d pos; dev->getPosition(pos);
            x = (float)pos.x(); y = (float)pos.y(); z = (float)pos.z();
        }
        else {
            demoPhase += (2.0 * M_PI) / cfg::HAPTIC_HZ;
            x = 0.028f * (float)sin(demoPhase * 1.10f + 0.5f);
            y = 0.020f * (float)cos(demoPhase * 0.90f);
            z = 0.015f * (float)sin(demoPhase * 1.30f + 2.0f);
        }
        eba::pos_m[0] = x; eba::pos_m[1] = y; eba::pos_m[2] = z;

        // -- 2. Receive raw packet from network ----------------------------
        S2C rpNet{};
        bool gotRaw = false;
        int r = (int)recvfrom(sock, (char*)&rpNet, sizeof(rpNet), 0, (SOCKADDR*)&caddr, &caddrLen);
        if (r == (int)sizeof(rpNet)) gotRaw = true;

        // -- 3. Artificial delay queue (inject if enabled) -----------------
        if (gotRaw) {
            if (g_artDelayEnabled.load(std::memory_order_relaxed)) {
                double d = g_artDelayConst.load(), j = g_artDelayJitter.load();
                double jit = 0;
                if (j > 0) { std::uniform_real_distribution<double> dist(0, j); jit = dist(artRng); }
                double delAt = nowMs + d + jit;
                g_lastArtDelayMs.store(d + jit);
                std::lock_guard<std::mutex> lk(g_artDelayMtx);
                g_artDelayQ.push_back({ delAt, rpNet });
                gotRaw = false;
            }
        }
        // Drain artificial delay queue
        {
            std::lock_guard<std::mutex> lk(g_artDelayMtx);
            for (auto it = g_artDelayQ.begin(); it != g_artDelayQ.end();) {
                if (nowMs >= it->deliverAt) {
                    rpNet = it->pkt; gotRaw = true;
                    it = g_artDelayQ.erase(it);
                }
                else ++it;
            }
            g_artDelayQDepth.store((int)g_artDelayQ.size());
        }

        // -- 4. Feed packet into adaptive jitter buffer OR direct ----------
        bool newDataReady = false;
        S2C rp{};
        if (ajb.enabled && gotRaw) {
            ajb.insert(rpNet, nowMs, nowMs);
            gotRaw = false;
        }
        else if (gotRaw) {
            rp = rpNet; newDataReady = true;
        }
        // Pop from AJB if it's time
        if (ajb.enabled) {
            ajb.purgeLate(nowMs);
            S2C ajbOut{};
            if (ajb.pop(ajbOut, nowMs)) {
                rp = ajbOut; newDataReady = true;
                g_ajbDropped.store(ajb.nDropped);
            }
        }
        g_ajbJitter.store(ajb.jitterEst);
        g_ajbPlayoutMs.store(ajb.playoutDelay);
        g_ajbDepth.store(ajb.depth());

        // -- 5. Process newly available packet -----------------------------
        if (newDataReady) {
            // RTT estimate (ts is sender wallclock when packet was sent)
            double rtt = nowMs - rp.ts;
            rttAcc += rtt; rttN++;
            g_rtt.store(rtt);
            if (rttN >= 100) { g_avgRtt.store(rttAcc / rttN); rttAcc = 0; rttN = 0; }
            g_recv.fetch_add(1, std::memory_order_relaxed);

            // Loss detection
            uint32_t rxs = rp.seq;
            uint32_t expected = g_lastRxSeq.load() + 1;
            if (g_lastRxSeq.load() > 0 && rxs > expected)
                g_pktLoss.fetch_add(rxs - expected, std::memory_order_relaxed);
            g_lastRxSeq.store(rxs);

            // Store raw master position (received as S2C)
            double mpos[3] = { rp.mx, rp.my, rp.mz };

            // Feed Smith Predictor with new master measurement
            sp.ingest(mpos, rtt);

            float sm = sqrtf(rp.mx * rp.mx + rp.my * rp.my + rp.mz * rp.mz);
            g_slaveRing.push({ nowMs,sm,rxs });  // note: slaveRing tracks received (master) for chart
            g_rx.store(rp.mx); g_ry.store(rp.my); g_rz.store(rp.mz); g_rmag.store(sm);
            inet_ntop(AF_INET, &caddr.sin_addr, g_serverIP, sizeof(g_serverIP));
        }

        // -- 6. Smith Predictor: compute best current remote position ------
        sp.enabled = g_smithOn.load(std::memory_order_relaxed);
        ajb.enabled = g_ajbOn.load(std::memory_order_relaxed);
        sp.computePrediction();

        // Use predicted master position for coupling (or raw if predictor off)
        const double* remPos = sp.predPos;

        g_predx.store((float)remPos[0]);
        g_predy.store((float)remPos[1]);
        g_predz.store((float)remPos[2]);
        g_predHorizonMs.store(sp.horizonMs);
        g_predErrRms.store(sp.predErrRms);

        // -- 7. Slave coupling: F = Kp*(master_pred - slave_pos) ----------
        // Smith predictor feeds predicted master pos; EBA passivity bound applied
        cVector3d force(0, 0, 0);
        if (g_useFF && has) {
            // Simple spring coupling with EBA passivity bound
            const double Kp = 200.0;
            for (int i = 0; i < 3; i++) {
                double Fd_i = Kp * (remPos[i] - eba::pos_m[i]);
                // Apply EBA bound
                eba::XdP[i] = eba::Xd[i]; eba::Xd[i] = eba::pos_m[i];
                eba::DXd[i] = eba::Xd[i] - eba::XdP[i];
                if (eba::enable && eba::DXd[i] != 0.0) {
                    eba::Fd[i] = Fd_i;
                    eba::uBETA[i] = eba::BETA[i] = (eba::Fd[i] - eba::dFe[i]) / eba::DXd[i];
                    double td = eba::dFe[i] / eba::DXd[i], sq = sqrt(td * td + eba::c2 * eba::c2);
                    eba::Bmax[i] = std::min(eba::c2 - td + sq, eba::c1);
                    eba::Bmin[i] = eba::c2 - td - sq;
                    eba::BETA[i] = std::max(eba::Bmin[i], std::min(eba::Bmax[i], eba::BETA[i]));
                    eba::dFe[i] += eba::BETA[i] * eba::DXd[i];
                    force((int)i) = eba::projection ? -eba::dFe[i] : Fd_i;
                }
                else {
                    force((int)i) = Fd_i;
                }
                // Safety clamp
                double fm = fabs((double)force((int)i));
                if (fm > cfg::MAX_FORCE) force((int)i) *= (cfg::MAX_FORCE / fm);
            }
        }
        if (has) dev->setForce(force);

        // -- 8. Send C2S to server -----------------------------------------
        {
            C2S txPkt{};
            txPkt.seq = ++txSeq; txPkt.sx = x; txPkt.sy = y; txPkt.sz = z;
            txPkt.sfx = (float)force.x(); txPkt.sfy = (float)force.y(); txPkt.sfz = (float)force.z();
            txPkt.ts = nowMs;
            sendto(sock, (char*)&txPkt, sizeof(txPkt), 0, (SOCKADDR*)&srvAddr, sizeof(srvAddr));
            g_sent.fetch_add(1, std::memory_order_relaxed);
        }

        float lm = sqrtf(x * x + y * y + z * z);
        g_masterRing.push({ nowMs,lm,txSeq });  // local slave position
        g_lx.store(x); g_ly.store(y); g_lz.store(z); g_lmag.store(lm);
        g_fx.store((float)force.x()); g_fy.store((float)force.y());
        g_fz.store((float)force.z()); g_fmag.store((float)force.length());

        auto tgt = t0 + std::chrono::microseconds((long long)(1000000.0 / cfg::HAPTIC_HZ));
        while (std::chrono::high_resolution_clock::now() < tgt) _mm_pause();
    }
    if (has) { dev->setForce(cVector3d(0, 0, 0)); dev->close(); }
    closesocket(sock); WSACleanup(); timeEndPeriod(1);
}

