        rect(bL, bY0, bR, bY1, 0.10f, 0.18f, 0.12f, 0.9f);
        float hf = (float)std::min(horiz / 100.0, 1.0);
        rect(bL, bY0, bL + (bR - bL) * hf, bY1, 0.20f, 0.90f, 0.45f, 0.85f);
        drawText(bL * g_W, (bY0 - 0.002f) * g_H, "0 RTT/2 [ms] 100", 0.28f, 0.42f, 0.32f, 1, 1);
    }
    else {
        drawText(0.01f * g_W, rowM, "[Delay compensation disabled - EBA uses stale received position]",
            0.40f, 0.45f, 0.50f, 1, 1);
        drawText(0.01f * g_W, rowB, "Press S to enable Smith Predictor", 0.30f, 0.50f, 0.35f, 1, 2);
    }

    // -- RIGHT: Adaptive Jitter Buffer ------------------------------------
    float aR = ajbOn ? 0.20f : 0.45f, aG = ajbOn ? 0.80f : 0.35f, aB = ajbOn ? 0.95f : 0.30f;
    drawText(0.51f * g_W, rowT, ajbOn ? "JITTER BUFFER    [ON ]" : "JITTER BUFFER    [OFF]", aR, aG, aB, 1, 2);

    if (ajbOn) {
        snprintf(buf, sizeof(buf), "Jitter:%.2fms  Playout:%.1fms  Queued:%d  Dropped:%llu",
            jit, playout, ajbDepth, (unsigned long long)dropped);
        drawText(0.51f * g_W, rowM, buf, 0.30f, 0.75f, 0.95f, 1, 2);

        // Playout delay bar (0..AJB_MAX_MS)
        float bL = 0.51f, bR = 0.99f, bY0 = rowM / g_H - 0.025f, bY1 = bY0 + 0.012f;
        rect(bL, bY0, bR, bY1, 0.10f, 0.14f, 0.20f, 0.9f);
        float jf = (float)std::min(jit / 50.0, 1.0);         // jitter bar (0..50ms)
        float pf = (float)std::min(playout / cfg::AJB_MAX_MS, 1.0);  // playout bar
        rect(bL, bY0, bL + (bR - bL) * pf, bY1, 0.20f, 0.65f, 0.95f, 0.80f);  // playout (blue)
        rect(bL, bY0, bL + (bR - bL) * jf * (bR - bL), bY0 + 0.006f, 0.95f, 0.75f, 0.20f, 0.85f);  // jitter (orange, thin)

        snprintf(buf, sizeof(buf), "Playout 0-%.0fms  [orange=jitter estimate  blue=playout target]",
            cfg::AJB_MAX_MS);
        drawText(bL * g_W, (bY0 - 0.002f) * g_H, buf, 0.28f, 0.38f, 0.48f, 1, 1);

        // Mode annotation
        const char* mode = (!spOn && !ajbOn) ? "Mode: RAW" : (spOn && !ajbOn) ? "Mode: PREDICT only" :
            (!spOn && ajbOn) ? "Mode: BUFFER only" : "Mode: FULL (S+B) optimal";
        float mR = (spOn && ajbOn) ? 0.20f : 0.70f, mG = (spOn && ajbOn) ? 0.95f : 0.70f, mB = (spOn && ajbOn) ? 0.45f : 0.30f;
        drawText(0.51f * g_W, rowB, mode, mR, mG, mB, 1, 2);
    }
    else {
        drawText(0.51f * g_W, rowM, "[Jitter buffering disabled - packets delivered immediately]",
            0.40f, 0.45f, 0.50f, 1, 1);
        drawText(0.51f * g_W, rowB, "Press B to enable Adaptive Jitter Buffer", 0.28f, 0.40f, 0.55f, 1, 2);
    }

    // Key strip at the very bottom of panel
    drawText(0.01f * g_W, (py0 + 0.003f) * g_H,
        "S:Smith Predictor  B:Jitter Buffer  D:art.delay  ,.NM:art.delay ctrl",
        0.28f, 0.35f, 0.38f, 1, 1);
}

