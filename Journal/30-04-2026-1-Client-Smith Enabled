// =============================================================================
//  SMITH PREDICTOR  -  AR(2) per axis, forgetting-factor RLS
// =============================================================================
struct SmithAxis {
    // AR(2): x(k) = a[0]*x(k-1) + a[1]*x(k-2)
    double a[cfg::SP_ORDER] = { 1.5, -0.5 };  // init: constant-velocity model
    // RLS covariance (2x2 as flat array [P00,P01,P10,P11])
    double P[4] = { 100.0, 0.0, 0.0, 100.0 };

    // Circular history for regression
    double hist[64] = {};
    int    hd = 0;          // head pointer
    int    nSamples = 0;    // count for warm-up gate

    // Last two values (for fast prediction bootstrap)
    double xk1 = 0, xk2 = 0;

    // RLS measurement of prediction error (EMA)
    double errRms = 0;

    // Store measurement and update AR coefficients
    void update(double x, double lambda = cfg::SP_LAMBDA) {
        // phi = [x(k-1), x(k-2)]
        double phi[2] = { xk1, xk2 };
        double phi_dot_a = phi[0] * a[0] + phi[1] * a[1];
        double err = x - phi_dot_a;
        errRms = 0.95 * errRms + 0.05 * err * err;

        // RLS update: P = (P - P.phi.phi'.P / (lambda + phi'.P.phi)) / lambda
        // Gain: g = P.phi / (lambda + phi'.P.phi)
        double Pphi[2] = {
            P[0] * phi[0] + P[1] * phi[1],
            P[2] * phi[0] + P[3] * phi[1]
        };
        double denom = lambda + phi[0] * Pphi[0] + phi[1] * Pphi[1];
        if (fabs(denom) < 1e-12) denom = 1e-12;
        double g[2] = { Pphi[0] / denom, Pphi[1] / denom };

        // a = a + g * err
        a[0] += g[0] * err;
        a[1] += g[1] * err;

        // P = (I - g*phi') * P / lambda
        double gPhi[4] = {
            g[0] * phi[0], g[0] * phi[1],
            g[1] * phi[0], g[1] * phi[1]
        };
        double Pnew[4];
        for (int i = 0; i < 4; i++) Pnew[i] = (P[i] - gPhi[i] * P[i % 2 == 0 ? 0 : 1] * phi[i / 2]) / lambda;
        // Simpler update: P = (I - g.phi')*P / lambda
        Pnew[0] = (P[0] - g[0] * (P[0] * phi[0] + P[1] * phi[1])) / lambda;
        Pnew[1] = (P[1] - g[0] * (P[2] * phi[0] + P[3] * phi[1])) / lambda;
        Pnew[2] = (P[2] - g[1] * (P[0] * phi[0] + P[1] * phi[1])) / lambda;
        Pnew[3] = (P[3] - g[1] * (P[2] * phi[0] + P[3] * phi[1])) / lambda;
        // Symmetrise to prevent drift
        P[0] = Pnew[0]; P[1] = P[2] = (Pnew[1] + Pnew[2]) * 0.5; P[3] = Pnew[3];

        // Clamp coefficients to stable region (|a1|+|a2| < 1 for stability)
        // Soft clamp: project back if marginally unstable
        double mag = fabs(a[0]) + fabs(a[1]);
        if (mag > 1.98) { a[0] *= 1.95 / mag; a[1] *= 1.95 / mag; }

        // Advance history
        xk2 = xk1; xk1 = x;
        ++nSamples;
    }

    // Predict n_steps ahead starting from current state
    double predict(int n_steps) const {
        if (nSamples < cfg::SP_HIST || n_steps <= 0) return xk1;
        double p1 = xk1, p2 = xk2;
        for (int i = 0; i < n_steps; i++) {
            double p0 = a[0] * p1 + a[1] * p2;
            p2 = p1; p1 = p0;
        }
        return p1;
    }
};

struct SmithPredictor3DOF {
    SmithAxis ax[3];
    bool      enabled = false;
    double    horizonMs = 0.0;  // prediction horizon in ms (= RTT/2)
    double    dtMs = 1.0;  // expected sample interval ms
    double    predPos[3] = {};   // current prediction output
    double    rawPos[3] = {};   // last received position
    double    predErrRms = 0.0;  // composite prediction error

    // Called every time a new remote position is received
    void ingest(const double pos[3], double rttMs) {
        for (int i = 0; i < 3; i++) {
            ax[i].update(pos[i]);
            rawPos[i] = pos[i];
        }
        // One-way delay estimate = RTT/2
        horizonMs = std::max(1.0, rttMs * 0.5);
    }

    // Called each haptic tick: produce best estimate of CURRENT remote position
    // (compensates for one-way delay)
    void computePrediction() {
        if (!enabled) {
            for (int i = 0; i < 3; i++) predPos[i] = rawPos[i];
            return;
        }
        int nSteps = std::max(1, (int)round(horizonMs / dtMs));
        nSteps = std::min(nSteps, 100);  // cap at 100 ms prediction
        double errSum = 0;
        for (int i = 0; i < 3; i++) {
            predPos[i] = ax[i].predict(nSteps);
            errSum += ax[i].errRms;
        }
        predErrRms = sqrt(errSum / 3.0);
    }
};

// =============================================================================
//  ADAPTIVE JITTER BUFFER  -  RFC 3550 + adaptive playout delay
// =============================================================================
struct AJBEntry {
    double   arrivalMs;
    double   sendTs;
    uint32_t seq;
    S2C      pkt;
    bool operator>(const AJBEntry& o) const { return seq > o.seq; }  // min-heap on seq
};

struct AdaptiveJitterBuffer {
    // Min-heap ordered by sequence number
    std::priority_queue<AJBEntry, std::vector<AJBEntry>, std::greater<AJBEntry>> q;

    bool     enabled = false;
    double   jitterEst = 0.0;   // RFC 3550 jitter estimate (ms)
    double   playoutDelay = cfg::AJB_MIN_MS;  // adaptive playout delay (ms)
    double   lastArrival = 0.0;
    double   lastSendTs = 0.0;
    uint32_t nextExpected = 0;     // next expected seq
    uint64_t nDelivered = 0;
    uint64_t nDropped = 0;
    uint64_t nReordered = 0;
    double   reorderTimer = 0.0;   // time waiting for gap to fill

    void insert(const S2C& pkt, double arrivalMs, double nowMs) {
        if (!enabled) return;

        // RFC 3550 inter-arrival jitter
        if (lastSendTs > 0.0 && lastArrival > 0.0) {
            double transit_curr = arrivalMs - pkt.ts;
            double transit_prev = lastArrival - lastSendTs;
            double d = fabs(transit_curr - transit_prev);
            jitterEst = jitterEst * (1.0 - 1.0 / 16.0) + d * (1.0 / 16.0);
        }
        lastArrival = arrivalMs;
        lastSendTs = pkt.ts;

        // Adaptive playout delay: track jitter quickly, decay slowly
        double target = jitterEst * cfg::AJB_K_BASE + cfg::AJB_MIN_MS;
        target = std::min(target, cfg::AJB_MAX_MS);
        if (target > playoutDelay)
            playoutDelay += cfg::AJB_RISE;
        else
            playoutDelay = std::max(cfg::AJB_MIN_MS, playoutDelay - cfg::AJB_DECAY);

        q.push({ arrivalMs, (double)pkt.ts, pkt.seq, pkt });
    }

    // Try to deliver the next in-order packet. Returns true if one is ready.
    // nowMs = current haptic clock time
    bool pop(S2C& out, double nowMs) {
        if (q.empty()) return false;

        const AJBEntry& top = q.top();

        if (nextExpected == 0) nextExpected = top.seq;

        // Check if enough time has passed (playout delay elapsed since arrival)
        if (nowMs < top.arrivalMs + playoutDelay) return false;

        // In-order delivery
        if (top.seq == nextExpected || top.seq > nextExpected) {
            if (top.seq > nextExpected) ++nReordered;
            out = top.pkt;
            nextExpected = top.seq + 1;
            ++nDelivered;
            q.pop();
            return true;
        }

        // Old / duplicate packet - discard
        q.pop();
        ++nDropped;
        return false;
    }

    // Late packet drop: anything older than reorder_timeout that hasn't been
    // delivered yet is dropped on the floor
    void purgeLate(double nowMs) {
        while (!q.empty()) {
            const AJBEntry& top = q.top();
            if (nowMs > top.arrivalMs + cfg::AJB_REORDER_TIMEOUT_MS + playoutDelay) {
                q.pop(); ++nDropped;
            }
            else break;
        }
    }

    int depth() const { return (int)q.size(); }
};

