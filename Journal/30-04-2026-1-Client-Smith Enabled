    double rtt = g_rtt.load(), horiz = g_predHorizonMs.load();
    double predErr = g_predErrRms.load();
    double jit = g_ajbJitter.load(), playout = g_ajbPlayoutMs.load();
    int    ajbDepth = g_ajbDepth.load();
    uint64_t dropped = g_ajbDropped.load();

    // Strip occupies between chart bottom and delay panel top
    float py1 = cfg::CMB - 0.002f, py0 = py1 - 0.090f;
    rect(0, py0, 1, py1, 0.05f, 0.09f, 0.08f, 0.97f);
    glLineWidth(0.8f); glColor3f(0.15f, 0.32f, 0.22f);
