static const int FS = 2, GW = 5 * FS, GH = 7 * FS, GGAP = 1 * FS;

static void drawTextPx(float px, float py, const char* str,
    float r = 1, float g2 = 1, float b = 1, float a = 1) {
    if (!str || !str[0]) return;
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity();
    glOrtho(0, g_fbW, 0, g_fbH, -1, 1);
    glMatrixMode(GL_MODELVIEW); glPushMatrix(); glLoadIdentity();
    glColor4f(r, g2, b, a);
    glBegin(GL_QUADS);
    float cx = px;
    for (const char* p = str; *p; ++p) {
        int c = (unsigned char)*p;
        if (c < 32 || c>126) { cx += GW + GGAP; continue; }
        const uint8_t* col = GLYPHS[c - 32];
        for (int ci = 0; ci < 5; ++ci) {
            uint8_t bits = col[ci];
            for (int ri = 0; ri < 7; ++ri) {
                if (bits & (1 << ri)) {
                    float x0 = cx + ci * FS, y0 = py + (6 - ri) * FS, x1 = x0 + FS, y1 = y0 + FS;
                    glVertex2f(x0, y0); glVertex2f(x1, y0);
                    glVertex2f(x1, y1); glVertex2f(x0, y1);
                }
            }
        }
        cx += GW + GGAP;
    }
    glEnd();
    glMatrixMode(GL_PROJECTION); glPopMatrix();
    glMatrixMode(GL_MODELVIEW); glPopMatrix();
    glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
    glMatrixMode(GL_MODELVIEW); glLoadIdentity();
}

static void fillRect(float x0, float y0, float x1, float y1,
    float r, float g2, float b, float a = 1) {
    glColor4f(r, g2, b, a);
    glBegin(GL_QUADS);
    glVertex2f(x0, y0); glVertex2f(x1, y0); glVertex2f(x1, y1); glVertex2f(x0, y1);
    glEnd();
}

static inline float yOf(float m, float yb, float yt) {
    return yb + ((m - cfg::YMIN) / (cfg::YMAX - cfg::YMIN)) * (yt - yb);
}

static void drawCandle(float xc, float hw, float oY, float clY,
    float hY, float lY, bool bull, float alpha) {
    if (bull) glColor4f(0.114f, 0.722f, 0.416f, alpha);
    else     glColor4f(0.902f, 0.220f, 0.220f, alpha);
    float top = std::max(oY, clY), bot = std::min(oY, clY);
    float bh = top - bot; if (bh < 0.0010f) bh = 0.0010f;
    glBegin(GL_QUADS);
    glVertex2f(xc - hw, bot); glVertex2f(xc + hw, bot);
    glVertex2f(xc + hw, bot + bh); glVertex2f(xc - hw, bot + bh);
    glEnd();
    glLineWidth(1.4f);
    glBegin(GL_LINES);
    glVertex2f(xc, bot + bh); glVertex2f(xc, hY);
    glVertex2f(xc, bot);   glVertex2f(xc, lY);
    glEnd();
}

static void drawChart(const std::deque<Candle>& snap, bool liveOpen,
    float liveMag,
    float pL, float pR, float MB_n, float MT_n,
    const char* title, float tr, float tg, float tb) {
    float CW = pR - pL, CH = MT_n - MB_n;
    float slot = CW / (float)cfg::VISIBLE, hw = slot * 0.34f;
    int nTotal = (int)snap.size();
    fillRect(pL, MB_n, pR, MT_n, 0.09f, 0.11f, 0.15f);
    glLineWidth(0.5f); glColor4f(0.25f, 0.29f, 0.38f, 0.6f);
    glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) { float gy = MB_n + CH * ((float)i / cfg::Y_DIVS); glVertex2f(pL, gy); glVertex2f(pR, gy); }
    for (int i = 0; i <= cfg::VISIBLE; i += 5) { float gx = pL + slot * i; glVertex2f(gx, MB_n); glVertex2f(gx, MT_n); }
    glEnd();
    float midY = yOf(cfg::YMID, MB_n, MT_n);
    glLineWidth(1.2f); glColor4f(0.45f, 0.55f, 0.75f, 0.85f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(1, 0xF0F0);
    glBegin(GL_LINES); glVertex2f(pL, midY); glVertex2f(pR, midY); glEnd();
    glDisable(GL_LINE_STIPPLE);
    glLineWidth(1.0f); glColor4f(0.50f, 0.55f, 0.65f, 0.8f);
    glBegin(GL_LINES);
    for (int i = 0; i <= cfg::Y_DIVS; ++i) { float gy = MB_n + CH * ((float)i / cfg::Y_DIVS); glVertex2f(pL, gy); glVertex2f(pL - 0.012f, gy); }
    glEnd();
    for (int i = 0; i <= cfg::Y_DIVS; ++i) {
        float frac = (float)i / cfg::Y_DIVS;
        float val = cfg::YMIN + frac * (cfg::YMAX - cfg::YMIN);
        char lb[12]; snprintf(lb, sizeof(lb), "%.1f", val * 1000.0f);
        drawTextPx((pL - 0.065f) * g_fbW, (MB_n + CH * frac) * g_fbH - 7, lb, 0.55f, 0.60f, 0.72f);
    }
    drawTextPx((pL - 0.065f) * g_fbW, MT_n * g_fbH + 8, "mm", 0.45f, 0.50f, 0.62f);
    for (int si = 0; si < cfg::VISIBLE; ++si) {
        int ci = nTotal - cfg::VISIBLE + si;
        if (ci < 0) continue;
        const Candle& c = snap[ci];
        float xc = pL + (si + 0.5f) * slot;
        drawCandle(xc, hw, yOf(c.open, MB_n, MT_n), yOf(c.close, MB_n, MT_n),
            yOf(c.high, MB_n, MT_n), yOf(c.low, MB_n, MT_n),
            c.bull, (ci == nTotal - 1 && liveOpen) ? 0.55f : 1.0f);
    }
    float cy = yOf(liveMag, MB_n, MT_n);
    cy = std::max(MB_n + 0.001f, std::min(MT_n - 0.001f, cy));
    glLineWidth(1.0f); glColor4f(1.0f, 0.85f, 0.20f, 0.80f);
    glEnable(GL_LINE_STIPPLE); glLineStipple(2, 0xAAAA);
    glBegin(GL_LINES); glVertex2f(pL, cy); glVertex2f(pR, cy); glEnd();
    glDisable(GL_LINE_STIPPLE);
    glLineWidth(1.2f); glColor3f(0.40f, 0.44f, 0.54f);
    glBegin(GL_LINE_LOOP);
    glVertex2f(pL, MB_n); glVertex2f(pR, MB_n); glVertex2f(pR, MT_n); glVertex2f(pL, MT_n);
    glEnd();
    glLineWidth(1.0f); glColor3f(0.40f, 0.44f, 0.54f);
    glBegin(GL_LINES);
    for (int si = 0; si < cfg::VISIBLE; si += 5) { float gx = pL + (si + 0.5f) * slot; glVertex2f(gx, MB_n); glVertex2f(gx, MB_n - 0.012f); }
    glEnd();
    for (int si = 0; si < cfg::VISIBLE; si += 5) {
        int ci = nTotal - cfg::VISIBLE + si;
        float gx = pL + (si + 0.5f) * slot;
        char lb[16];
        if (ci >= 0 && ci < nTotal) snprintf(lb, sizeof(lb), "%.1fs", snap[ci].t0 / 1000.0);
        else snprintf(lb, sizeof(lb), "---");
        drawTextPx(gx * g_fbW - 14, (MB_n - 0.058f) * g_fbH, lb, 0.50f, 0.55f, 0.65f);
    }
    drawTextPx((pL + CW * 0.35f) * g_fbW, (MT_n + 0.010f) * g_fbH, title, tr, tg, tb);
}

// ═════════════════════════════════════════════════════════════════════════════
//  GLFW CALLBACKS
// ═════════════════════════════════════════════════════════════════════════════
static App* g_app = nullptr;

static void onKey(GLFWwindow* w, int key, int, int action, int) {
    if (action != GLFW_PRESS || !g_app) return;
    switch (key) {
    case GLFW_KEY_ESCAPE: glfwSetWindowShouldClose(w, GLFW_TRUE); break;
    case GLFW_KEY_T: { bool v = !g_app->txEnabled; g_app->txEnabled.store(v); printf("[NET] TX: %s\n", v ? "ON" : "OFF"); break; }
    case GLFW_KEY_R: { bool v = !g_app->rxEnabled; g_app->rxEnabled.store(v); printf("[NET] RX: %s\n", v ? "ON" : "OFF"); break; }
    case GLFW_KEY_F: { bool v = !g_app->fbEnabled; g_app->fbEnabled.store(v); printf("[FB]  Force feedback: %s\n", v ? "ON" : "OFF"); break; }
    case GLFW_KEY_EQUAL:case GLFW_KEY_KP_ADD: {
        double v = std::min(g_app->candleMs.load() * 1.122, cfg::CANDLE_MS_MAX);
        g_app->candleMs.store(v); printf("[UI] %.1fms\n", v); break;
    }
    case GLFW_KEY_MINUS:case GLFW_KEY_KP_SUBTRACT: {
        double v = std::max(g_app->candleMs.load() / 1.122, cfg::CANDLE_MS_MIN);
        g_app->candleMs.store(v); printf("[UI] %.1fms\n", v); break;
    }
    case GLFW_KEY_LEFT_BRACKET:  g_app->candleMs.store(cfg::CANDLE_MS_MIN); break;
    case GLFW_KEY_RIGHT_BRACKET: g_app->candleMs.store(cfg::CANDLE_MS_MAX); break;
    default:break;
    }
}
static void onFbSize(GLFWwindow*, int w, int h) { glViewport(0, 0, w, h); g_fbW = w; g_fbH = h; }

// ═════════════════════════════════════════════════════════════════════════════
//  MAIN
// ═════════════════════════════════════════════════════════════════════════════
int main() {
    WSADATA wsa{}; WSAStartup(MAKEWORD(2, 2), &wsa);

    App app; g_app = &app;
    detectLocalIP(app.localIP, sizeof(app.localIP));

    printf("╔══════════════════════════════════════════════╗\n");
    printf("║       HapticCandlestick  CLIENT              ║\n");
    printf("╠══════════════════════════════════════════════╣\n");
    printf("║  Client IP : %-30s  ║\n", app.localIP);
    printf("║  Server IP : %-30s  ║\n", cfg::SERVER_IP);
    printf("║  UDP Port  : %-30d  ║\n", cfg::NET_PORT);
    printf("╠══════════════════════════════════════════════╣\n");
    printf("║  T   toggle TX (send back to server)         ║\n");
    printf("║  R   toggle RX (receive from server)         ║\n");
    printf("║  F   toggle force feedback to local Falcon   ║\n");
    printf("║  +/- window  |  [  ] preset  |  ESC quit     ║\n");
    printf("╚══════════════════════════════════════════════╝\n\n");

    WSACleanup();

    std::thread tHaptic([&] { hapticThread(app); });
    std::thread tAgg([&] { aggregatorThread(app); });
    std::thread tNet([&] { networkThread(app); });

    if (!glfwInit()) {
        app.running = false;
        tHaptic.join(); tAgg.join(); tNet.join(); return 1;
    }

    glfwWindowHint(GLFW_CONTEXT_VERSION_MAJOR, 2);
    glfwWindowHint(GLFW_CONTEXT_VERSION_MINOR, 1);
    glfwWindowHint(GLFW_SAMPLES, 4);

    char wtitle[128];
    snprintf(wtitle, sizeof(wtitle),
        "CLIENT  %s  ←  SERVER %s  |  Port %d",
        app.localIP, cfg::SERVER_IP, cfg::NET_PORT);

    GLFWwindow* win = glfwCreateWindow(cfg::WIN_W, cfg::WIN_H, wtitle, nullptr, nullptr);
    if (!win) {
        glfwTerminate(); app.running = false;
        tHaptic.join(); tAgg.join(); tNet.join(); return 1;
    }

    glfwMakeContextCurrent(win);
    glfwSwapInterval(1);
    glfwSetKeyCallback(win, onKey);
    glfwSetFramebufferSizeCallback(win, onFbSize);
    glfwGetFramebufferSize(win, &g_fbW, &g_fbH);

    glEnable(GL_BLEND); glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA);
    glEnable(GL_LINE_SMOOTH); glHint(GL_LINE_SMOOTH_HINT, GL_NICEST);
    glEnable(GL_MULTISAMPLE);

    // Client layout is swapped vs server:
    // LEFT  = REMOTE (server RX)   RIGHT = LOCAL (client TX)
    const float RCL = 0.01f, RCR = 0.49f;  // left panel = remote
    const float LCL = 0.51f, LCR = 0.99f;  // right panel = local
    const float CMB = 0.10f, CMT = 0.82f;

    while (!glfwWindowShouldClose(win)) {
        glfwGetFramebufferSize(win, &g_fbW, &g_fbH);
        glViewport(0, 0, g_fbW, g_fbH);
        glClearColor(0.05f, 0.07f, 0.10f, 1.f);
        glClear(GL_COLOR_BUFFER_BIT);
        glMatrixMode(GL_PROJECTION); glLoadIdentity(); glOrtho(0, 1, 0, 1, -1, 1);
        glMatrixMode(GL_MODELVIEW); glLoadIdentity();

        std::deque<Candle> localSnap, remoteSnap;
        Candle localLive{}, remoteLive{}; bool localLO = false, remoteLO = false;
        {
            std::lock_guard<std::mutex> lk(app.localMtx);
            localSnap = app.localCandles; localLive = app.localLive; localLO = app.localLiveOpen;
        }
        {
            std::lock_guard<std::mutex> lk(app.remoteMtx);
            remoteSnap = app.remoteCandles; remoteLive = app.remoteLive; remoteLO = app.remoteLiveOpen;
        }
        if (localLO)  localSnap.push_back(localLive);
        if (remoteLO) remoteSnap.push_back(remoteLive);

        float lMag = app.lmag.load(), rMag = app.rmag.load();

        // Divider
        glLineWidth(1.5f); glColor3f(0.25f, 0.30f, 0.40f);
        glBegin(GL_LINES); glVertex2f(0.50f, 0); glVertex2f(0.50f, 1); glEnd();

        // Left = remote/server (received)
        drawChart(remoteSnap, remoteLO, rMag,
            RCL, RCR, CMB, CMT,
            "REMOTE (RX <- SERVER)",
            0.40f, 0.65f, 0.98f);  // blue

        // Right = local (sending back)
        drawChart(localSnap, localLO, lMag,
            LCL, LCR, CMB, CMT,
            "LOCAL (TX -> SERVER)",
            0.35f, 0.88f, 0.45f);  // green

        // INFO PANEL
        fillRect(0, 0.83f, 1, 1, 0.06f, 0.08f, 0.12f, 0.95f);
        glLineWidth(0.8f); glColor3f(0.20f, 0.24f, 0.32f);
        glBegin(GL_LINES); glVertex2f(0, 0.83f); glVertex2f(1, 0.83f); glEnd();
        glBegin(GL_LINES); glVertex2f(0.5f, 0.83f); glVertex2f(0.5f, 1.0f); glEnd();

        float row1y = 0.968f * g_fbH, row2y = 0.918f * g_fbH, row3y = 0.862f * g_fbH;
        char buf[96];

        // Remote (server) side – left panel
        drawTextPx(0.02f * g_fbW, row1y, "REMOTE HAPTIC (SERVER RX)", 0.35f, 0.58f, 0.95f);
        float rx = app.rx_.load(), ry = app.ry_.load(), rz = app.rz_.load(), rm = app.rmag.load();
        double staleMs = app.clock.ms() - app.lastRxMs.load();
        float stale = (staleMs > 500.0) ? 0.4f : 1.0f;
        snprintf(buf, sizeof(buf), "X:%+.4f", rx); drawTextPx(0.02f * g_fbW, row2y, buf, 0.38f * stale, 0.88f * stale, 0.42f * stale);
        snprintf(buf, sizeof(buf), "Y:%+.4f", ry); drawTextPx(0.11f * g_fbW, row2y, buf, 0.38f * stale, 0.62f * stale, 0.95f * stale);
        snprintf(buf, sizeof(buf), "Z:%+.4f", rz); drawTextPx(0.20f * g_fbW, row2y, buf, 0.95f * stale, 0.60f * stale, 0.20f * stale);
        snprintf(buf, sizeof(buf), "Mag:%.4fm (%.2fmm)", rm, rm * 1000);
        drawTextPx(0.29f * g_fbW, row2y, buf, 1.0f * stale, 0.92f * stale, 0.30f * stale);
        snprintf(buf, sizeof(buf), "RX:%s  FB:%s  Recv:%llu  Lag:%.0fms",
            app.rxEnabled ? "ON" : "OFF", app.fbEnabled ? "ON" : "OFF",
            (unsigned long long)app.pktsRecv.load(), staleMs);
        drawTextPx(0.02f * g_fbW, row3y, buf,
            app.rxEnabled ? 0.30f : 0.55f, app.rxEnabled ? 0.65f : 0.45f, app.rxEnabled ? 0.95f : 0.40f);

        // Local side – right panel
        drawTextPx(0.52f * g_fbW, row1y, "LOCAL HAPTIC (TX BACK)", 0.30f, 0.78f, 0.38f);
        float lx = app.lx.load(), ly_ = app.ly.load(), lz = app.lz.load(), lm = app.lmag.load();
        snprintf(buf, sizeof(buf), "X:%+.4f", lx); drawTextPx(0.52f * g_fbW, row2y, buf, 0.38f, 0.88f, 0.42f);
        snprintf(buf, sizeof(buf), "Y:%+.4f", ly_); drawTextPx(0.61f * g_fbW, row2y, buf, 0.38f, 0.62f, 0.95f);
        snprintf(buf, sizeof(buf), "Z:%+.4f", lz);  drawTextPx(0.70f * g_fbW, row2y, buf, 0.95f, 0.60f, 0.20f);
        snprintf(buf, sizeof(buf), "Mag:%.4fm (%.2fmm)", lm, lm * 1000);
        drawTextPx(0.79f * g_fbW, row2y, buf, 1.0f, 0.92f, 0.30f);
        snprintf(buf, sizeof(buf), "TX:%s  Sent:%llu",
            app.txEnabled ? "ON" : "OFF", (unsigned long long)app.pktsSent.load());
        drawTextPx(0.52f * g_fbW, row3y, buf,
            app.txEnabled ? 0.25f : 0.55f, app.txEnabled ? 0.88f : 0.45f, app.txEnabled ? 0.40f : 0.40f);

        // IP row
        snprintf(buf, sizeof(buf), "CLIENT: %s   SERVER: %s   PORT: %d",
            app.localIP, cfg::SERVER_IP, cfg::NET_PORT);
        drawTextPx(0.02f * g_fbW, 0.985f * g_fbH, buf, 0.40f, 0.44f, 0.55f);

        if (app.demoMode) {
            fillRect(0, 0, 0.004f, 1, 0.95f, 0.65f, 0.10f, 0.8f);
            drawTextPx(0.006f * g_fbW, 0.5f * g_fbH, "DEMO", 0.95f, 0.65f, 0.10f);
        }

        glfwSwapBuffers(win);
        glfwPollEvents();
    }

    app.running = false;
    tHaptic.join(); tAgg.join(); tNet.join();
    glfwDestroyWindow(win); glfwTerminate();
    printf("Client shutdown. Sent:%llu  Recv:%llu\n",
        (unsigned long long)app.pktsSent.load(),
        (unsigned long long)app.pktsRecv.load());
    return 0;
}
