// ─── IP detection ─────────────────────────────────────────────────────────────
static void detectLocalIP(char* buf, int len) {
    SOCKET s = socket(AF_INET, SOCK_DGRAM, 0);
    if (s == INVALID_SOCKET) { strncpy(buf, "unknown", len); return; }
    sockaddr_in r{}; r.sin_family = AF_INET; r.sin_port = htons(80);
    inet_pton(AF_INET, "8.8.8.8", &r.sin_addr);
    if (connect(s, (sockaddr*)&r, sizeof(r)) == 0) {
        sockaddr_in l{}; int ls = sizeof(l);
        getsockname(s, (sockaddr*)&l, &ls);
        inet_ntop(AF_INET, &l.sin_addr, buf, len);
    }
    else strncpy(buf, "unknown", len);
    closesocket(s);
}

// ═════════════════════════════════════════════════════════════════════════════
//  HAPTIC THREAD
// ═════════════════════════════════════════════════════════════════════════════
void hapticThread(App& app) {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_TIME_CRITICAL);
    timeBeginPeriod(1);

    cHapticDeviceHandler handler;
    cGenericHapticDevicePtr dev;
    handler.getDevice(dev, 0);
    bool has = (dev != nullptr);
    if (has) { dev->open(); dev->calibrate(); }
    else { app.demoMode = true; printf("[HAPTIC] Demo mode.\n"); }

    const double periodUs = 1000000.0 / cfg::HAPTIC_HZ;
    cVector3d zeroF(0, 0, 0);
    double demoPhase = 0.0;

    while (app.running) {
        auto t0 = std::chrono::high_resolution_clock::now();
        float x, y, z, mag; uint8_t btn = 0;

        if (has) {
            cVector3d pos; dev->getPosition(pos);
            x = (float)pos.x(); y = (float)pos.y(); z = (float)pos.z();
            mag = (float)pos.length();
            bool b[4]{}; for (int i = 0; i < 4; ++i) dev->getUserSwitch(i, b[i]);
            btn = (b[0] ? 1 : 0) | (b[1] ? 2 : 0) | (b[2] ? 4 : 0) | (b[3] ? 8 : 0);

            // Apply feedback force from server
            cVector3d applyF = zeroF;
            if (app.fbEnabled) {
                HapticPacket fp{}; HapticPacket tmp{};
                while (app.fbRing.pop(tmp)) fp = tmp;
                if (fp.mag > 0.0f) {
                    cVector3d remPos(fp.x, fp.y, fp.z);
                    cVector3d locPos(x, y, z);
                    applyF = (remPos - locPos) * cfg::FORCE_FB_K;
                    double fl = applyF.length();
                    if (fl > cfg::FORCE_MAX && fl > 0.0) applyF *= (cfg::FORCE_MAX / fl);
                }
            }
            dev->setForce(applyF);
        }
        else {
            // Demo: slightly different pattern from server so charts look distinct
            demoPhase += (2.0 * M_PI) / cfg::HAPTIC_HZ;
            x = 0.028f * (float)sin(demoPhase * 1.1f + 0.5f);
            y = 0.020f * (float)cos(demoPhase * 0.9f);
            z = 0.015f * (float)sin(demoPhase * 1.3f + 2.0f) + 0.008f * (float)sin(demoPhase * 3.7f);
            mag = sqrtf(x * x + y * y + z * z);
        }

        Sample s{ app.clock.ms(),x,y,z,mag,btn };
        app.localRing.push(s);

        if (app.txEnabled) {
            HapticPacket p{};
            p.ts = s.ts; p.x = x; p.y = y; p.z = z; p.mag = mag;
            p.fx = 0; p.fy = 0; p.fz = 0; p.btn = btn; p.flags = 0;
            app.txRing.push(p);
        }

        app.lx.store(x, std::memory_order_relaxed);
        app.ly.store(y, std::memory_order_relaxed);
        app.lz.store(z, std::memory_order_relaxed);
        app.lmag.store(mag, std::memory_order_relaxed);
        app.lbtn.store(btn, std::memory_order_relaxed);
        app.lts.store(s.ts, std::memory_order_relaxed);

        auto target = t0 + std::chrono::microseconds((long long)periodUs);
        while (std::chrono::high_resolution_clock::now() < target) _mm_pause();
    }
    if (has) dev->close();
    timeEndPeriod(1);
}

// ═════════════════════════════════════════════════════════════════════════════
//  AGGREGATOR
// ═════════════════════════════════════════════════════════════════════════════
static void agg(Ring<Sample, cfg::RING_SZ>& ring,
    std::mutex& mtx, std::deque<Candle>& candles,
    Candle& live, bool& liveOpen,
    double& wO, float& cO, float& cC, float& cH, float& cL, bool& st,
    double& jM, double& jJ, double& jL, double dur)
{
    Sample s{};
    while (ring.pop(s)) {
        float mag = s.mag;
        if (jL > 0.0) { double iv = s.ts - jL, dv = fabs(iv - jM); jM += 0.01 * (iv - jM); jJ += 0.01 * (dv - jJ); }
        jL = s.ts;
        double ad = dur * (1.0 + std::min(jJ / 2.0, 2.0));
        if (!st) { wO = s.ts; cO = cC = cH = cL = mag; st = true; }
        else {
            cC = mag; if (mag > cH)cH = mag; if (mag < cL)cL = mag;
            if (s.ts - wO >= ad) {
                Candle c{ wO,s.ts,cO,cC,cH,cL,(cC > cO) };
                {
                    std::lock_guard<std::mutex> lk(mtx);
                    candles.push_back(c);
                    if ((int)candles.size() > cfg::MAX_CANDLES)candles.pop_front();
                }
                st = false;
            }
        }
        {
            std::lock_guard<std::mutex> lk(mtx);
            live = { wO,s.ts,cO,cC,cH,cL,(cC > cO) }; liveOpen = st;
        }
    }
}

static Ring<Sample, cfg::RING_SZ> g_remSamples;

void aggregatorThread(App& app) {
    SetThreadPriority(GetCurrentThread(), THREAD_PRIORITY_ABOVE_NORMAL);
    double lwO = 0; float lcO = 0, lcC = 0, lcH = 0, lcL = 1e9f; bool lSt = false;
    double ljM = 1, ljJ = 0, ljL = 0;
    double rwO = 0; float rcO = 0, rcC = 0, rcH = 0, rcL = 1e9f; bool rSt = false;
    double rjM = 1, rjJ = 0, rjL = 0;

    while (app.running) {
        double dur = app.candleMs.load();
        agg(app.localRing, app.localMtx, app.localCandles,
            app.localLive, app.localLiveOpen,
            lwO, lcO, lcC, lcH, lcL, lSt, ljM, ljJ, ljL, dur);

        HapticPacket rp{};
        while (app.rxRing.pop(rp)) {
            app.fbRing.push(rp);
            app.rx_.store(rp.x, std::memory_order_relaxed);
            app.ry_.store(rp.y, std::memory_order_relaxed);
            app.rz_.store(rp.z, std::memory_order_relaxed);
            app.rmag.store(rp.mag, std::memory_order_relaxed);
            app.rts.store(rp.ts, std::memory_order_relaxed);
            app.lastRxMs.store(app.clock.ms(), std::memory_order_relaxed);
            Sample rs{ rp.ts,rp.x,rp.y,rp.z,rp.mag,rp.btn };
            g_remSamples.push(rs);
        }
        agg(g_remSamples, app.remoteMtx, app.remoteCandles,
            app.remoteLive, app.remoteLiveOpen,
            rwO, rcO, rcC, rcH, rcL, rSt, rjM, rjJ, rjL, dur);

        std::this_thread::sleep_for(std::chrono::microseconds(200));
    }
}

// ═════════════════════════════════════════════════════════════════════════════
//  NETWORK THREAD
// ═════════════════════════════════════════════════════════════════════════════
void networkThread(App& app) {
    WSADATA wsa{}; WSAStartup(MAKEWORD(2, 2), &wsa);

    SOCKET sock = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
    sockaddr_in local{};
    local.sin_family = AF_INET;
    local.sin_port = htons(cfg::NET_PORT);
    local.sin_addr.s_addr = INADDR_ANY;
    bind(sock, (sockaddr*)&local, sizeof(local));

    u_long nb = 1; ioctlsocket(sock, FIONBIO, &nb);

    sockaddr_in dst{};
    dst.sin_family = AF_INET;
    dst.sin_port = htons(cfg::NET_PORT);
    inet_pton(AF_INET, cfg::SERVER_IP, &dst.sin_addr);

    HapticPacket pkt{};
    while (app.running) {
        while (app.txEnabled && app.txRing.pop(pkt)) {
            sendto(sock, (char*)&pkt, sizeof(pkt), 0, (sockaddr*)&dst, sizeof(dst));
            app.pktsSent.fetch_add(1, std::memory_order_relaxed);
        }
        if (app.rxEnabled) {
            HapticPacket rp{};
            sockaddr_in from{}; int fl = sizeof(from);
            int r = (int)recvfrom(sock, (char*)&rp, sizeof(rp), 0, (sockaddr*)&from, &fl);
            if (r == (int)sizeof(rp)) {
                app.rxRing.push(rp);
                app.pktsRecv.fetch_add(1, std::memory_order_relaxed);
            }
        }
        std::this_thread::sleep_for(std::chrono::microseconds(200));
    }
    closesocket(sock); WSACleanup();
}

