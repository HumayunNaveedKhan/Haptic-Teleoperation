void updateHaptics(void) {
    simulationRunning = true;
    simulationFinished = false;
    int TAP = 0;

    while (simulationRunning) {
        cVector3d position, linearVelocity;
        hapticDevice->getPosition(position);
        hapticDevice->getLinearVelocity(linearVelocity);
        bool button0, button1, button2, button3;
        hapticDevice->getUserSwitch(0, button0);
        hapticDevice->getUserSwitch(1, button1);
        hapticDevice->getUserSwitch(2, button2);
        hapticDevice->getUserSwitch(3, button3);

        velocity->m_pointA = position;
        velocity->m_pointB = cAdd(position, linearVelocity);
        cursor->setLocalPos(position);

        if (button0) {
            cursor->m_material->setGreenMediumAquamarine();
            TAP = 0;
            c1 = 150;
        }
        else if (button1) {
            cursor->m_material->setYellowGold();
            TAP = max(TAP - 1, 0);
        }
        else if (button2) {
            cursor->m_material->setOrangeCoral();
            c1 += 0.1;
        }
        else if (button3) {
            cursor->m_material->setPurpleLavender();
            TAP++;
        }
        else {
            cursor->m_material->setBlueRoyal();
        }

        hapticDevicePosition = position;
        hapticDeviceVelocity = linearVelocity;

        for (int i = 0; i < DOF; i++) {
            pos_curr[i] = hapticDevicePosition(i);
        }

        adjustBufferSize();
        UDPReadData();
        Fd[0] = -ReadData[0];
        Fd[1] = -ReadData[1];
        Fd[2] = -ReadData[2];
        pos_recv[0] = ReadData[3];
        pos_recv[1] = ReadData[4];
        pos_recv[2] = ReadData[5];

        SendData[0] = pos_curr[0];
        SendData[1] = pos_curr[1];
        SendData[2] = pos_curr[2];
        UDPSendData(SendData);

        cVector3d force(0, 0, 0);
        if (useForceField) {
            cVector3d forceField = -c2 * position;
            force.add(forceField);

            for (int i = 0; i < 3; i++) {
                pos_prev[i] = pos_curr[i];
                XdP[i] = Xd[i];
                Xd[i] = pos_curr[i];
                DXd[i] = Xd[i] - XdP[i];

                if (EnableEBA && DXd[i] != 0) {
                    double uBETA = (Fd[i] - dFe[i]) / DXd[i];
                    double Bmax = c2 - dFe[i] / DXd[i] + sqrt(dFe[i] * dFe[i] / DXd[i] / DXd[i] + c2 * c2);
                    double Bmin = c2 - dFe[i] / DXd[i] - sqrt(dFe[i] * dFe[i] / DXd[i] / DXd[i] + c2 * c2);
                    Bmax = min(c1, Bmax);
                    double BETA = max(min(uBETA, Bmax), Bmin);
                    dFe[i] += BETA * DXd[i];

                    if (nProjection) {
                        double FOR_Mag = sqrt(Fd[0] * Fd[0] + Fd[1] * Fd[1] + Fd[2] * Fd[2]);
                        UnitV[i] = (FOR_Mag > 0.0) ? Fd[i] / FOR_Mag : 0.0;
                        InnerProduct = dFe[0] * UnitV[0] + dFe[1] * UnitV[1] + dFe[2] * UnitV[2];
                        ProjFOR[i] = InnerProduct * UnitV[i];
                        force(i) = -ProjFOR[i];
                    }
                }
                else {
                    dFe[i] = Fd[i];
                    force(i) = dFe[i];
                }
            }
        }

        hapticDevice->setForce(force);
        freqCounterHaptics.signal(1);
    }

    simulationFinished = true;
}

void adjustBufferSize() {
    delay = timeUDPS - timeUDPR;
    delayBuffer.push_back(abs(delay));
    if (delayBuffer.size() > 100) delayBuffer.erase(delayBuffer.begin());

    double sum = 0;
    for (double d : delayBuffer) sum += d;
    avg_delay = sum / delayBuffer.size();

    adaptiveBufferSize = MIN_BUFFER_SIZE + (int)(avg_delay / 10.0);
    adaptiveBufferSize = min(max(adaptiveBufferSize, MIN_BUFFER_SIZE), MAX_BUFFER_SIZE);
}

