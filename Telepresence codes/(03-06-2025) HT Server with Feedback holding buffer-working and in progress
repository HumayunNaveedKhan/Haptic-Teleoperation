struct Timer {
    chrono::time_point<chrono::steady_clock> start, end;
    chrono::duration<float> duration;
    Timer() { start = chrono::high_resolution_clock::now(); }
    ~Timer() {
        end = chrono::high_resolution_clock::now();
        duration = end - start;
        timeUDPR = duration.count() * 1000.0f;
    }
};

struct Timer2 {
    chrono::time_point<chrono::steady_clock> start, end;
    chrono::duration<float> duration;
    Timer2() { start = chrono::high_resolution_clock::now(); }
    ~Timer2() {
        end = chrono::high_resolution_clock::now();
        duration = end - start;
        timeUDPS = duration.count() * 1000.0f;
    }
};

