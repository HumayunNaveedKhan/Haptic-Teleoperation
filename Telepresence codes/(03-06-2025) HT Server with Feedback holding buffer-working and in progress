void InitUDP() {
    if (WSAStartup(MAKEWORD(2, 2), &wsa) != 0) {
        MessageBox(NULL, "Socket Open Error!!", "UDP", MB_OK);
    }
    sock = socket(AF_INET, SOCK_DGRAM, 0);
    if (sock == INVALID_SOCKET) err_quit("socket()");
    u_long mode = 1; // Non-blocking
    ioctlsocket(sock, FIONBIO, &mode);
    ZeroMemory(&serveraddr, sizeof(serveraddr));
    serveraddr.sin_family = AF_INET;
    serveraddr.sin_port = htons(UDP_PORT);
    serveraddr.sin_addr.s_addr = inet_addr(SERVER_IP);
    retval = ::bind(sock, (SOCKADDR*)&serveraddr, sizeof(serveraddr));
    if (retval == SOCKET_ERROR) {
        err_quit("bind()");
    }
    // Initialize client address to same IP and port
    ZeroMemory(&clientaddr, sizeof(clientaddr));
    clientaddr.sin_family = AF_INET;
    clientaddr.sin_port = htons(UDP_PORT);
    clientaddr.sin_addr.s_addr = inet_addr(SERVER_IP);
}

void UDPSendData(float sData[SENDDATA_NUM]) {
    Timer time;
    sprintf(sbuf, "%f %f %f", sData[0], sData[1], sData[2]);
    retval = sendto(sock, sbuf, strlen(sbuf), 0, (SOCKADDR*)&clientaddr, sizeof(clientaddr));
    if (retval == SOCKET_ERROR) {
        err_display("sendto()");
        return;
    }
    packet_out_magnitude = sqrt(sData[0] * sData[0] + sData[1] * sData[1] + sData[2] * sData[2]);
    last_packet_out_time = chrono::high_resolution_clock::now();
    cout << "Sent packet #" << send_count + 1 << ", magnitude: " << packet_out_magnitude << endl;
}

void UDPReadData() {
    Timer2 time;
    addrlen = sizeof(clientaddr);
    retval = recvfrom(sock, rbuf, BUFSIZE, 0, (SOCKADDR*)&clientaddr, &addrlen);
    if (retval == SOCKET_ERROR) {
        int error = WSAGetLastError();
        if (error == WSAEWOULDBLOCK) {
            return;
        }
        err_display("recvfrom()");
        return;
    }
    sscanf(rbuf, "%f %f %f", &ReadData[0], &ReadData[1], &ReadData[2]);
    if (force_buffer.size() >= MAX_BUFFER_SIZE) {
        force_buffer.pop_front();
    }
    ForcePacket packet;
    packet.force[0] = ReadData[0];
    packet.force[1] = ReadData[1];
    packet.force[2] = ReadData[2];
    packet.timestamp = chrono::high_resolution_clock::now();
    force_buffer.push_back(packet);
    packet_in_magnitude = sqrt(ReadData[0] * ReadData[0] + ReadData[1] * ReadData[1] + ReadData[2] * ReadData[2]);
    last_packet_in_time = chrono::high_resolution_clock::now();
    receive_count++;
    cout << "Received feedback packet #" << receive_count << ", magnitude: " << packet_in_magnitude << endl;
    delay = timeUDPS - timeUDPR;
    countd++;
    cSleepMs(TAP);
}

void CloseUDP() {
    closesocket(sock);
    WSACleanup();
}

void err_quit(const char* msg) {
    LPVOID lpMsgBuf;
    FormatMessage(FORMAT_MESSAGE_ALLOCATE_BUFFER | FORMAT_MESSAGE_FROM_SYSTEM, NULL, WSAGetLastError(),
        MAKELANGID(LANG_NEUTRAL, SUBLANG_DEFAULT), (LPTSTR)&lpMsgBuf, 0, NULL);
    MessageBox(NULL, (LPCTSTR)lpMsgBuf, msg, MB_ICONERROR);
    LocalFree(lpMsgBuf);
    exit(-1);
}

void err_display(const char* msg) {
    LPVOID lpMsgBuf;
    FormatMessage(FORMAT_MESSAGE_ALLOCATE_BUFFER | FORMAT_MESSAGE_FROM_SYSTEM, NULL, WSAGetLastError(),
        MAKELANGID(LANG_NEUTRAL, SUBLANG_DEFAULT), (LPTSTR)&lpMsgBuf, 0, NULL);
    printf("[%s] %s", msg, (LPCTSTR)lpMsgBuf);
    LocalFree(lpMsgBuf);
}
