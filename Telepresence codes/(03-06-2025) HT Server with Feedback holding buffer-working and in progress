void updateGraphics(void) {
    labelHapticDevicePosition->setText(hapticDevicePosition.str(3));
    labelRates->setText(cStr(freqCounterGraphics.getFrequency(), 0) + " Hz / " + cStr(freqCounterHaptics.getFrequency(), 0) + " Hz");
    labelRates->setLocalPos((int)(0.5 * (width - labelRates->getWidth())), 15);

    // Update packet signals
    auto now = chrono::high_resolution_clock::now();
    double time_since_last_delayed = chrono::duration<float>(now - last_delayed_force_time).count();
    double time_since_last_out = chrono::duration<float>(now - last_packet_out_time).count();
    double in_signal = (cycleState == APPLYING && time_since_last_delayed < pulse_duration) ? delayed_force_magnitude : 0.0;
    double out_signal = (cycleState == SENDING && time_since_last_out < pulse_duration) ? packet_out_magnitude : 0.0;

    scope0->setSignalValues(hapticDevicePosition.x(), ReadData[3]);
    scope1->setSignalValues(hapticDevicePosition.y(), ReadData[4]);
    scope2->setSignalValues(hapticDevicePosition.z(), ReadData[5]);
    scope3->setSignalValues(ProjFOR[0], -ReadData[0]);
    scope4->setSignalValues(ProjFOR[1], -ReadData[1]);
    scope5->setSignalValues(ProjFOR[2], -ReadData[2]);
    scope6->setSignalValues(in_signal);
    scope7->setSignalValues(out_signal);
    leveldelay->setValue(TAP);

    labelIP->setText("Client IP: " + string(inet_ntoa(clientaddr.sin_addr)) + ":" + cStr(ntohs(clientaddr.sin_port)));
    labelXd->setText("Master Pos: " + cStr(pos_curr[0], 3U) + "  " + cStr(pos_curr[1], 3U) + "  " + cStr(pos_curr[2], 3U));
    labelX_Recv->setText("Slave Pos:     " + cStr(pos_recv[0], 3U) + "  " + cStr(pos_recv[1], 3U) + "  " + cStr(pos_recv[2], 3U));
    labelFd->setText("Master force: " + cStr(Fd[0], 3U) + "  " + cStr(Fd[1], 3U) + "  " + cStr(Fd[2], 3U));
    labelSlave_force->setText("Slave force:    " + cStr(-ReadData[0], 3U) + "  " + cStr(-ReadData[1], 3U) + "  " + cStr(-ReadData[2], 3U));
    labeldFe->setText("EBA force: " + cStr(dFe[0], 3U) + "  " + cStr(dFe[1], 3U) + "  " + cStr(dFe[2], 3U));
    labelProjFOR->setText("Projected force: " + cStr(ProjFOR[0], 3U) + "  " + cStr(ProjFOR[1], 3U) + "  " + cStr(ProjFOR[2], 3U));
    labelDelay->setText("Delay: " + cStr(abs(delay), 3U) + "ms");
    labelc1->setText("c1: " + cStr(abs(c1), 3U));
    labelc2->setText("c2: " + cStr(abs(c2), 3U));

    // Update cycle state label
    switch (cycleState) {
    case SENDING:
        labelCycleState->setText("Cycle: Sending");
        break;
    case BUFFERING:
        labelCycleState->setText("Cycle: Buffering");
        break;
    case APPLYING:
        labelCycleState->setText("Cycle: Applying");
        break;
    }

    world->updateShadowMaps(false, mirroredDisplay);
    camera->renderView(width, height);
    glFinish();
    GLenum err = glGetError();
    if (err != GL_NO_ERROR) cout << "Error:  %s\n" << gluErrorString(err);
}

void updateHaptics(void) {
    simulationRunning = true;
    simulationFinished = false;

    while (simulationRunning) {
        cVector3d position;
        hapticDevice->getPosition(position);
        cVector3d linearVelocity;
        hapticDevice->getLinearVelocity(linearVelocity);

        bool button0, button1, button2, button3;
        button0 = button1 = button2 = button3 = false;
        hapticDevice->getUserSwitch(0, button0);
        hapticDevice->getUserSwitch(1, button1);
        hapticDevice->getUserSwitch(2, button2);
        hapticDevice->getUserSwitch(3, button3);

        velocity->m_pointA = position;
        velocity->m_pointB = cAdd(position, linearVelocity);
        cursor->setLocalPos(position);

        if (button0) {
            cursor->m_material->setGreenMediumAquamarine();
            TAP = 0;
            c1 = 100;
        }
        else if (button1) {
            cursor->m_material->setYellowGold();
            TAP = max(TAP - 1, 0);
        }
        else if (button2) {
            cursor->m_material->setOrangeCoral();
            c1 += 0.1;
        }
        else if (button3) {
            cursor->m_material->setPurpleLavender();
            TAP += 1;
        }
        else {
            cursor->m_material->setBlueRoyal();
        }

        hapticDevicePosition = position;
        hapticDeviceVelocity = linearVelocity;

        for (int i = 0; i < DOF; i++) {
            pos_curr[i] = hapticDevicePosition(i);
        }

        auto now = chrono::high_resolution_clock::now();

        // State machine for packet cycle
        switch (cycleState) {
        case SENDING:
            if (send_count < PACKET_BATCH_SIZE) {
                SendData[0] = pos_curr[0];
                SendData[1] = pos_curr[1];
                SendData[2] = pos_curr[2];
                UDPSendData(SendData);
                send_count++;
                cout << "Sent packet #" << send_count << ", magnitude: " << packet_out_magnitude << endl;
            }
            else {
                cycleState = BUFFERING;
            }
            UDPReadData();
            break;

        case BUFFERING:
            UDPReadData();
            if (receive_count >= PACKET_BATCH_SIZE) {
                cycleState = APPLYING;
            }
            break;

        case APPLYING:
            if (!force_buffer.empty()) {
                ForcePacket packet = force_buffer.front();
                Fd[0] = -packet.force[0];
                Fd[1] = -packet.force[1];
                Fd[2] = -packet.force[2];
                delayed_force_magnitude = sqrt(packet.force[0] * packet.force[0] +
                    packet.force[1] * packet.force[1] +
                    packet.force[2] * packet.force[2]);
                last_delayed_force_time = now;
                force_buffer.pop_front();
                cout << "Applied feedback packet, magnitude: " << delayed_force_magnitude << endl;
            }
            else {
                cycleState = SENDING;
                send_count = 0;
                receive_count = 0;
                force_buffer.clear();
                cout << "Completed feedback application, starting new cycle" << endl;
            }
            break;
        }

        cVector3d force(0, 0, 0);
        double gripperForce = 0.0;

        if (useForceField) {
            double Kp = c2;
            cVector3d forceField = -Kp * position;
            force.add(forceField);

            for (int i = 0; i < 3; i++) {
                pos_prev[i] = pos_curr[i];
                XdP[i] = Xd[i];
                Xd[i] = pos_curr[i];
                DXd[i] = Xd[i] - XdP[i];
            }

            if (EnableEBA) {
                for (int i = 0; i < 3; i++) {
                    if (DXd[i] != 0) {
                        uBETA[i] = BETA[i] = (Fd[i] - dFe[i]) / DXd[i];
                        Bmax[i] = c2 - dFe[i] / DXd[i] + sqrt(dFe[i] * dFe[i] / DXd[i] / DXd[i] + c2 * c2);
                        Bmin[i] = c2 - dFe[i] / DXd[i] - sqrt(dFe[i] * dFe[i] / DXd[i] / DXd[i] + c2 * c2);
                        if (Bmax[i] > c1) Bmax[i] = c1;
                        if (BETA[i] < Bmin[i]) BETA[i] = Bmin[i];
                        if (BETA[i] > Bmax[i]) BETA[i] = Bmax[i];
                    }
                    else {
                        uBETA[i] = BETA[i];
                    }
                    dFe[i] = dFe[i] + BETA[i] * DXd[i];

                    if (nProjection) {
                        FOR_Mag = sqrt(Fd[0] * Fd[0] + Fd[1] * Fd[1] + Fd[2] * Fd[2]);
                        if (fabs(FOR_Mag) > 0.0) {
                            UnitV[i] = Fd[i] / FOR_Mag;
                        }
                        else {
                            UnitV[i] = 0.0;
                        }
                        InnerProduct = dFe[0] * UnitV[0] + dFe[1] * UnitV[1] + dFe[2] * UnitV[2];
                        ProjFOR[i] = InnerProduct * UnitV[i];
                        force(i) = -ProjFOR[i];
                    }
                }
            }
            else {
                for (int i = 0; i < 3; i++) {
                    dFe[i] = Fd[i];
                    force(i) = -dFe[i];
                }
            }
        }

        hapticDevice->setForce(force);
        freqCounterHaptics.signal(1);
    }

    simulationFinished = true;
}

